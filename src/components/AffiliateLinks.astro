<style>
  .affiliate-section {
    border-top: 1px solid rgb(var(--gray-light));
    margin: 2.5em 0 1em;
    padding-top: 1.5em;
  }
  .affiliate-heading {
    font-size: 0.85em;
    font-weight: 700;
    color: rgb(var(--gray));
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.8em 0;
  }
  .affiliate-heading:not(:first-child) {
    margin-top: 1.5em;
  }
  .affiliate-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.6em;
  }
  .affiliate-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2em;
    padding: 0.8em 0.6em;
    border: 2px solid var(--card-color);
    border-radius: 10px;
    text-decoration: none;
    text-align: center;
    transition: background 0.15s, transform 0.15s;
    background: white;
  }
  .affiliate-card:hover {
    background: var(--card-color);
    transform: translateY(-2px);
  }
  .affiliate-card:hover .aff-name,
  .affiliate-card:hover .aff-desc {
    color: white;
  }
  .aff-emoji {
    font-size: 1.4em;
  }
  .aff-name {
    font-size: 0.85em;
    font-weight: 700;
    color: var(--card-color);
    line-height: 1.2;
  }
  .aff-desc {
    font-size: 0.72em;
    color: rgb(var(--gray));
    line-height: 1.3;
  }
  .affiliate-disclosure {
    font-size: 0.75em;
    color: rgb(var(--gray));
    margin: 1.2em 0 0;
    line-height: 1.5;
  }
  @media (max-width: 480px) {
    .affiliate-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
