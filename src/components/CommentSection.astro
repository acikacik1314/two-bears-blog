---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<section class="cs-wrap" id="comment-section">
  <div class="cs-header">
    <h3 class="cs-title">💬 觀測站留言板</h3>
    <span class="cs-count" id="cs-count">—</span>
  </div>

  <!-- Comment list -->
  <div class="cs-list" id="cs-list">
    <div class="cs-placeholder">載入留言中...</div>
  </div>

  <!-- Submit form -->
  <div class="cs-form-wrap">
    <div class="cs-form-title">發表評論</div>
    <form class="cs-form" id="cs-form" autocomplete="off">
      <div class="cs-row">
        <input class="cs-input" name="name" type="text" placeholder="你的名稱 *" maxlength="30" required />
        <input class="cs-input" name="email" type="email" placeholder="Email（選填，用於皇冠統計）" />
      </div>
      <textarea class="cs-textarea" name="content" placeholder="寫下你的想法或對這則預言的看法..." maxlength="500" required></textarea>
      <div class="cs-form-footer">
        <div class="cs-crown-legend">
          <span title="白銀觀測員 · 累積 3 則留言">🥈 白銀</span>
          <span title="黃金觀測員 · 累積 10 則留言">👑 黃金</span>
          <span title="鑽石觀測員 · 累積 20 則留言">💎 鑽石</span>
        </div>
        <button type="submit" class="cs-btn" id="cs-submit-btn">送出留言</button>
      </div>
      <div class="cs-msg" id="cs-msg"></div>
    </form>
  </div>
</section>

<script define:vars={{ slug }}>
const SLUG = slug.replace(/^\/|\/$/g, '');

function esc(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function crownBadge(crown) {
  if (crown === 'diamond') return '<span class="cs-badge cs-diamond" title="💎 鑽石觀測員">💎</span>';
  if (crown === 'gold')    return '<span class="cs-badge cs-gold"    title="👑 黃金觀測員">👑</span>';
  if (crown === 'silver')  return '<span class="cs-badge cs-silver"  title="🥈 白銀觀測員">🥈</span>';
  return '';
}

function relTime(iso) {
  const s = (Date.now() - new Date(iso).getTime()) / 1000;
  if (s < 60)        return '剛剛';
  if (s < 3600)      return `${Math.floor(s / 60)} 分鐘前`;
  if (s < 86400)     return `${Math.floor(s / 3600)} 小時前`;
  if (s < 2592000)   return `${Math.floor(s / 86400)} 天前`;
  return new Date(iso).toLocaleDateString('zh-TW');
}

async function loadComments() {
  const list  = document.getElementById('cs-list');
  const count = document.getElementById('cs-count');
  try {
    const res  = await fetch(`/api/comments?slug=${encodeURIComponent(SLUG)}`);
    const data = await res.json();

    count.textContent = `${data.length} 則`;

    if (data.length === 0) {
      list.innerHTML = '<div class="cs-placeholder">還沒有留言，成為第一個觀測員！</div>';
      return;
    }

    list.innerHTML = [...data].reverse().map(c => `
      <div class="cs-comment">
        <div class="cs-comment-top">
          <span class="cs-name">${esc(c.name)}${crownBadge(c.crown)}</span>
          <span class="cs-time">${relTime(c.timestamp)}</span>
        </div>
        <div class="cs-comment-body">${esc(c.content)}</div>
      </div>
    `).join('');
  } catch {
    list.innerHTML = '<div class="cs-placeholder cs-err">載入失敗，請重新整理頁面</div>';
  }
}

document.getElementById('cs-form').addEventListener('submit', async e => {
  e.preventDefault();
  const form = e.target;
  const btn  = document.getElementById('cs-submit-btn');
  const msg  = document.getElementById('cs-msg');

  const name    = form.name.value.trim();
  const email   = form.email.value.trim();
  const content = form.content.value.trim();

  btn.disabled    = true;
  btn.textContent = '送出中...';
  msg.className   = 'cs-msg';
  msg.textContent = '';

  try {
    const res  = await fetch('/api/comments', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ slug: SLUG, name, email, content }),
    });
    const data = await res.json();

    if (data.ok) {
      form.reset();
      let text = '✅ 留言成功！';
      const c = data.comment;
      if      (c.crown === 'diamond') text += ' 🎉 恭喜獲得 💎 鑽石皇冠！';
      else if (c.crown === 'gold')    text += ' 🎉 恭喜獲得 👑 黃金皇冠！';
      else if (c.crown === 'silver')  text += ' 🎉 恭喜獲得 🥈 白銀皇冠！';
      msg.className = 'cs-msg cs-ok';
      msg.innerHTML = text + ' <a href="https://ko-fi.com/twobear2" target="_blank" rel="noopener" class="cs-kofi-link">喜歡這裡？請我們喝杯咖啡 ☕</a>';
      loadComments();
    } else {
      msg.className   = 'cs-msg cs-err-msg';
      msg.textContent = data.error || '發送失敗，請再試一次';
    }
  } catch {
    msg.className   = 'cs-msg cs-err-msg';
    msg.textContent = '發送失敗，請再試一次';
  }

  btn.disabled    = false;
  btn.textContent = '送出留言';
});

loadComments();
</script>

<style>
  .cs-wrap {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .cs-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .cs-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: #e2e8f0;
    margin: 0;
  }

  .cs-count {
    font-size: 0.75rem;
    color: #64748b;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 0.15em 0.75em;
  }

  /* Comment list */
  .cs-placeholder {
    text-align: center;
    color: #475569;
    font-size: 0.85rem;
    padding: 2rem 0;
  }
  .cs-err { color: #f87171; }

  .cs-comment {
    padding: 1rem 1.1rem;
    border-radius: 10px;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 0.7rem;
    transition: border-color 0.2s;
  }
  .cs-comment:hover { border-color: rgba(255,255,255,0.12); }

  .cs-comment-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.45rem;
    gap: 0.5rem;
  }

  .cs-name {
    font-size: 0.88rem;
    font-weight: 700;
    color: #cbd5e1;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .cs-badge { font-size: 0.85rem; line-height: 1; }

  .cs-time {
    font-size: 0.7rem;
    color: #475569;
    flex-shrink: 0;
  }

  .cs-comment-body {
    font-size: 0.86rem;
    color: #94a3b8;
    line-height: 1.65;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Form */
  .cs-form-wrap {
    margin-top: 1.75rem;
    padding: 1.4rem 1.5rem;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
  }

  .cs-form-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .cs-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .cs-input,
  .cs-textarea {
    width: 100%;
    box-sizing: border-box;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    color: #e2e8f0;
    font-size: 0.86rem;
    padding: 0.55rem 0.875rem;
    font-family: inherit;
    transition: border-color 0.2s;
  }
  .cs-input:focus,
  .cs-textarea:focus {
    outline: none;
    border-color: rgba(0,245,255,0.45);
  }
  .cs-input::placeholder,
  .cs-textarea::placeholder { color: #475569; }

  .cs-textarea {
    min-height: 96px;
    resize: vertical;
    margin-bottom: 0.6rem;
  }

  .cs-form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cs-crown-legend {
    display: flex;
    gap: 0.75rem;
    font-size: 0.72rem;
    color: #475569;
  }
  .cs-crown-legend span { cursor: default; }

  .cs-btn {
    padding: 0.55rem 1.75rem;
    border-radius: 8px;
    background: linear-gradient(135deg, #00f5ff, #a78bfa);
    color: #020a14;
    font-weight: 800;
    font-size: 0.88rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .cs-btn:hover   { opacity: 0.9; }
  .cs-btn:active  { transform: scale(0.97); }
  .cs-btn:disabled { opacity: 0.45; cursor: not-allowed; }

  .cs-msg { margin-top: 0.65rem; font-size: 0.82rem; min-height: 1.2em; }
  .cs-ok      { color: #4ade80; }
  .cs-err-msg { color: #f87171; }
  .cs-kofi-link { color: #86efac; opacity: 0.7; text-underline-offset: 2px; transition: opacity 0.15s; }
  .cs-kofi-link:hover { opacity: 1; }

  @media (max-width: 520px) {
    .cs-row         { grid-template-columns: 1fr; }
    .cs-form-footer { flex-direction: column; align-items: flex-start; }
    .cs-form-wrap   { padding: 1rem; }
  }
</style>
