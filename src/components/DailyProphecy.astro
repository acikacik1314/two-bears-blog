---
const PROPHETS = [
  { id:'biggs',   name:'Biggs',      accuracy:59, color:'#b45309', icon:'💹',
    prophecies:['全球金融系統即將面臨史上最大重組','美元將失去全球儲備貨幣地位','黃金將突破每盎司 10,000 美元'] },
  { id:'kfk',     name:'KFK',        accuracy:83, color:'#1e40af', icon:'🔭',
    prophecies:['2026年將出現重大金融系統事件','AI 將在 2025 年達到人類智慧臨界點','比特幣將在 2026 年達到 20 萬美元'] },
  { id:'parker',  name:'Parker',     accuracy:82, color:'#0f766e', icon:'🌐',
    prophecies:['2026年台灣將進入歷史性轉折點','科技泡沫將在 2025–2026 年間破裂','中東局勢 2025 年底將達新高峰'] },
  { id:'anand',   name:'Anand',      accuracy:55, color:'#4c1d95', icon:'🌌',
    prophecies:['2028年前人類將成功登陸火星','全球人口將在 2035 年前達高峰後下降','量子通訊 2027 年實現商業化'] },
  { id:'babavanga', name:'Baba Vanga', accuracy:85, color:'#6b21a8', icon:'👁',
    prophecies:['歐洲將出現大規模停電持續超過一週','2025年將出現重大癌症治療突破','北極冰層將在 2028 年前完全消失'] },
  { id:'guofen',  name:'國分玲',     accuracy:68, color:'#065f46', icon:'🎋',
    prophecies:['2039年中國將發生重大政治變革','2026年日本東海岸將發生強烈地震','台灣 2027 年將進入新的歷史紀元'] },
];

const dayIdx = Math.floor(Date.now() / 86400000);
const todayProphet = PROPHETS[dayIdx % PROPHETS.length];
const todayQuote = todayProphet.prophecies[dayIdx % todayProphet.prophecies.length];
---

<div class="dp-wrap">
  <div class="dp-track" id="dp-track">
    {PROPHETS.map((p, i) => {
      const isToday = i === (dayIdx % PROPHETS.length);
      const quote = p.prophecies[dayIdx % p.prophecies.length];
      return (
        <div class={`dp-card${isToday ? ' active' : ''}`} data-i={i} style={`--pc:${p.color}`}>
          <div class="dp-avatar" style={`background:linear-gradient(135deg,${p.color} 0%,#0f172a 100%)`}>
            <span class="dp-icon">{p.icon}</span>
          </div>
          <div class="dp-meta">
            <span class="dp-name">{p.name}</span>
            <span class="dp-acc">命中率 {p.accuracy}%</span>
          </div>
          <div class="dp-bar"><div class="dp-fill" style={`width:${p.accuracy}%`}></div></div>
          <blockquote class="dp-quote">「{quote}」</blockquote>
          <div class="dp-votes">
            <button class="dp-btn agree" data-pid={p.id} data-v="agree">👍 我認同</button>
            <button class="dp-btn disagree" data-pid={p.id} data-v="disagree">👎 不認同</button>
          </div>
          <div class="dp-count" id={`vc-${p.id}`}>—</div>
        </div>
      );
    })}
  </div>
  <div class="dp-controls">
    <button class="dp-arrow" id="dp-prev">‹</button>
    <div class="dp-dots">
      {PROPHETS.map((_, i) => <span class={`dp-dot${i === (dayIdx % PROPHETS.length) ? ' on' : ''}`} data-i={i}></span>)}
    </div>
    <button class="dp-arrow" id="dp-next">›</button>
  </div>
</div>

<script>
  const track = document.getElementById('dp-track')!;
  const cards = Array.from(track.querySelectorAll<HTMLElement>('.dp-card'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.dp-dot'));
  let cur = cards.findIndex(c => c.classList.contains('active'));
  if (cur < 0) cur = 0;

  function go(n: number) {
    cards[cur].classList.remove('active');
    dots[cur].classList.remove('on');
    cur = (n + cards.length) % cards.length;
    cards[cur].classList.add('active');
    dots[cur].classList.add('on');
  }

  document.getElementById('dp-prev')!.addEventListener('click', () => go(cur - 1));
  document.getElementById('dp-next')!.addEventListener('click', () => go(cur + 1));
  dots.forEach(d => d.addEventListener('click', () => go(Number(d.dataset.i))));

  // Votes (localStorage per prophet per day)
  const today = new Date().toISOString().slice(0, 10);
  document.querySelectorAll<HTMLButtonElement>('.dp-btn').forEach(btn => {
    const pid = btn.dataset.pid!;
    const key = `pv_${pid}_${today}`;
    const saved = localStorage.getItem(key);
    if (saved === btn.dataset.v) btn.classList.add('voted');
    btn.addEventListener('click', () => {
      const alreadyVoted = localStorage.getItem(key);
      if (alreadyVoted) return;
      localStorage.setItem(key, btn.dataset.v!);
      btn.classList.add('voted');
      const countEl = document.getElementById(`vc-${pid}`);
      if (countEl && countEl.textContent !== '—') {
        const n = parseInt(countEl.textContent?.match(/\d+/)?.[0] ?? '0');
        countEl.textContent = `已有 ${(n + 1).toLocaleString()} 人投票`;
      }
    });
  });

  // Seed vote counts
  const BASE: Record<string, number> = { biggs:4218, kfk:8321, parker:6542, anand:2143, babavanga:12804, guofen:5671 };
  for (const [pid, base] of Object.entries(BASE)) {
    const el = document.getElementById(`vc-${pid}`);
    if (el) {
      const extra = parseInt(localStorage.getItem(`pvtotal_${pid}`) ?? '0');
      el.textContent = `已有 ${(base + extra).toLocaleString()} 人投票`;
    }
  }
</script>

<style>
.dp-wrap {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(168,85,247,0.2);
  border-radius: 16px;
  overflow: hidden;
  padding: 1.2em;
}
.dp-track { position: relative; min-height: 220px; }
.dp-card { display: none; flex-direction: column; gap: .6em; }
.dp-card.active { display: flex; }
.dp-avatar {
  width: 64px; height: 64px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 2px solid var(--pc, #a855f7);
  flex-shrink: 0;
}
.dp-icon { font-size: 1.8em; }
.dp-meta { display: flex; align-items: baseline; gap: .8em; }
.dp-name { font-size: 1.1em; font-weight: 900; color: #f1f5f9; }
.dp-acc { font-size: .72em; color: #94a3b8; }
.dp-bar { height: 4px; background: rgba(255,255,255,.08); border-radius: 2px; }
.dp-fill { height: 100%; background: var(--pc, #a855f7); border-radius: 2px; }
.dp-quote {
  font-size: .95em; font-weight: 700; color: #e2e8f0;
  line-height: 1.5; margin: 0;
  padding: .6em .8em;
  background: rgba(168,85,247,.08);
  border-left: 3px solid var(--pc, #a855f7);
  border-radius: 0 8px 8px 0;
}
.dp-votes { display: flex; gap: .6em; }
.dp-btn {
  flex: 1; padding: .45em; border-radius: 8px; border: 1px solid rgba(255,255,255,.1);
  font-size: .75em; font-weight: 700; cursor: pointer;
  background: rgba(255,255,255,.04); color: #94a3b8;
  transition: all .15s;
}
.dp-btn.agree.voted, .dp-btn.agree:hover { background: rgba(34,197,94,.15); color: #4ade80; border-color: rgba(34,197,94,.3); }
.dp-btn.disagree.voted, .dp-btn.disagree:hover { background: rgba(239,68,68,.15); color: #f87171; border-color: rgba(239,68,68,.3); }
.dp-count { font-size: .7em; color: #64748b; text-align: center; }

.dp-controls { display: flex; align-items: center; justify-content: center; gap: .8em; margin-top: .8em; }
.dp-arrow {
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  color: #94a3b8; font-size: 1.2em; width: 30px; height: 30px;
  border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all .15s;
}
.dp-arrow:hover { background: rgba(168,85,247,.2); color: #c084fc; }
.dp-dots { display: flex; gap: .4em; }
.dp-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,.15); cursor: pointer; transition: all .15s; }
.dp-dot.on { background: #a855f7; width: 14px; border-radius: 3px; }
</style>
