---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import UserMenu from './UserMenu.astro';
---

<!-- Ticker bar -->
<div class="ticker-bar">
  <div class="ticker-inner">
    <div class="ticker-track" id="ticker-track">
      <span class="ticker-label">вҡЎ еҚіжҷӮи§Җжё¬</span>
      <span class="ticker-item" id="t-gold">рҹҸ… й»ғйҮ‘ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-vix">вҡЎ VIX <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-oil">рҹӣў жІ№еғ№ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-xrp">XRP <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-nasdaq">рҹ“Ҳ NASDAQ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-sp500">рҹ“Ҡ S&P500 <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-fng">рҹҳұ жҒҗж…ҢиІӘе©Ә <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-jpytwd">рҹҮҜрҹҮө JPY/TWD <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-usdtwd">рҹ’ұ USD/TWD <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-btc">рҹӘҷ BTC <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-twii">еҸ°иӮЎ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-tsm">рҹ”ө еҸ°з©Қйӣ»ADR <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-weather">рҹҢҸ еҸ°еҢ—еӨ©ж°Ј <span class="t-wait">вҖ”</span></span>
    </div>
    <!-- duplicate for seamless loop -->
    <div class="ticker-track ticker-track-dup" aria-hidden="true">
      <span class="ticker-label">вҡЎ еҚіжҷӮи§Җжё¬</span>
      <span class="ticker-item" id="t-gold2">рҹҸ… й»ғйҮ‘ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-vix2">вҡЎ VIX <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-oil2">рҹӣў жІ№еғ№ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-xrp2">XRP <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-nasdaq2">рҹ“Ҳ NASDAQ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-sp5002">рҹ“Ҡ S&P500 <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-fng2">рҹҳұ жҒҗж…ҢиІӘе©Ә <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-jpytwd2">рҹҮҜрҹҮө JPY/TWD <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-usdtwd2">рҹ’ұ USD/TWD <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-btc2">рҹӘҷ BTC <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-twii2">еҸ°иӮЎ <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-tsm2">рҹ”ө еҸ°з©Қйӣ»ADR <span class="t-wait">вҖ”</span></span>
      <span class="ticker-item" id="t-weather2">рҹҢҸ еҸ°еҢ—еӨ©ж°Ј <span class="t-wait">вҖ”</span></span>
    </div>
  </div>
</div>

<!-- Main header -->
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <span class="logo-bears">рҹҗ»рҹҗ»</span>
      <span class="logo-title">{SITE_TITLE}</span>
    </a>
    <nav class="site-nav">
      <HeaderLink href="/">йҰ–й Ғ</HeaderLink>
      <HeaderLink href="/blog">ж–Үз« </HeaderLink>
      <HeaderLink href="/podcast">ж’ӯе®ў</HeaderLink>
      <HeaderLink href="/travel">вңҲпёҸ жё…е–®</HeaderLink>
      <HeaderLink href="/language">рҹ—ЈпёҸ иӘһиЁҖ</HeaderLink>
      <HeaderLink href="/avoid">рҹҡЁ йҒҝйӣ·</HeaderLink>
      <HeaderLink href="/picks">рҹҗ» йҒёзү©</HeaderLink>
      <HeaderLink href="/pick">рҹ’° жҜ”еғ№</HeaderLink>
      <HeaderLink href="/food">рҹҚң еҘҪж–ҷ</HeaderLink>
      <HeaderLink href="/travel-news">вңҲпёҸ ж—…йҒҠе ұ</HeaderLink>
      <HeaderLink href="/oracle">рҹ”® и§Җжё¬</HeaderLink>
      <HeaderLink href="/fortune">е‘ҪзҗҶ</HeaderLink>
      <HeaderLink href="/omikuji">е‘ҪйҒӢзұӨ</HeaderLink>
      <HeaderLink href="/market">рҹӣҚпёҸ дәҢжүӢ</HeaderLink>
      <HeaderLink href="/friends">дәӨеҸӢ</HeaderLink>
      <HeaderLink href="/member">жңғе“Ў</HeaderLink>
      <HeaderLink href="/about">й—ңж–ј</HeaderLink>
    </nav>
    <UserMenu />
  </div>
</header>

<script>
  function setTicker(id: string, html: string) {
    const el1 = document.getElementById(`t-${id}`);
    const el2 = document.getElementById(`t-${id}2`);
    if (el1) el1.innerHTML = html;
    if (el2) el2.innerHTML = html;
  }

  function chg(pct: number | null | undefined): string {
    if (pct == null) return '';
    const sign = pct >= 0 ? 'в–І' : 'в–ј';
    const cls = pct >= 0 ? 'text-green-400' : 'text-red-400';
    return ` <span class="${cls}">${sign}${Math.abs(pct).toFixed(2)}%</span>`;
  }

  function fmt(p: number | null, dec?: number): string {
    if (p == null) return 'вҖ”';
    return p.toLocaleString('en-US', { maximumFractionDigits: dec ?? (p >= 100 ? 0 : 4) });
  }

  async function loadMarket() {
    try {
      const r = await fetch('/api/market');
      const d = await r.json();
      const qs: Record<string, any> = {};
      for (const q of (d.quotes ?? [])) qs[q.symbol] = q;

      const btc = d.crypto?.bitcoin;
      const xrp = d.crypto?.ripple;
      if (btc) setTicker('btc', `рҹӘҷ BTC <span class="text-green-400">$${fmt(btc.usd)}${chg(btc.usd_24h_change)}</span>`);
      if (xrp) setTicker('xrp', `XRP <span class="text-purple-300">$${fmt(xrp.usd, 4)}${chg(xrp.usd_24h_change)}</span>`);
      if (qs['^GSPC']) setTicker('sp500', `рҹ“Ҡ S&P500 <span>${fmt(qs['^GSPC'].price)}${chg(qs['^GSPC'].change)}</span>`);
      if (qs['^TWII']) setTicker('twii', `еҸ°иӮЎ <span>${fmt(qs['^TWII'].price)}${chg(qs['^TWII'].change)}</span>`);
      if (qs['GC=F']) setTicker('gold', `рҹҸ… й»ғйҮ‘ <span class="text-yellow-300">$${fmt(qs['GC=F'].price)}${chg(qs['GC=F'].change)}</span>`);
      if (qs['^VIX']) {
        const v = qs['^VIX'].price;
        const vcls = v >= 30 ? 'text-red-400' : v >= 20 ? 'text-yellow-300' : 'text-green-400';
        setTicker('vix', `вҡЎ VIX <span class="${vcls}">${fmt(v, 1)}</span>`);
      }
      if (qs['^IXIC']) setTicker('nasdaq', `рҹ“Ҳ NASDAQ <span>${fmt(qs['^IXIC'].price)}${chg(qs['^IXIC'].change)}</span>`);
      if (qs['CL=F']) setTicker('oil', `рҹӣў жІ№еғ№ <span class="text-orange-300">$${fmt(qs['CL=F'].price, 2)}</span>`);
      if (qs['TSM']) setTicker('tsm', `рҹ”ө еҸ°з©Қйӣ»ADR <span>${fmt(qs['TSM'].price, 2)}${chg(qs['TSM'].change)}</span>`);
    } catch {}
  }

  async function loadCurrency() {
    try {
      const r = await fetch('https://open.er-api.com/v6/latest/USD', { signal: AbortSignal.timeout(8000) });
      const j = await r.json();
      if (j?.result !== 'success') return;
      const twd = j.rates?.TWD;
      const jpy = j.rates?.JPY;
      const jpytwd = twd && jpy ? twd / jpy : null;
      if (twd) setTicker('usdtwd', `рҹ’ұ USD/TWD <span class="text-blue-300">${twd.toFixed(2)}</span>`);
      if (jpytwd) setTicker('jpytwd', `рҹҮҜрҹҮө JPY/TWD <span class="text-blue-300">${jpytwd.toFixed(4)}</span>`);
    } catch {}
  }

  async function loadWeather() {
    try {
      const r = await fetch('https://api.open-meteo.com/v1/forecast?latitude=25.0330&longitude=121.5654&current=temperature_2m,weather_code&timezone=Asia/Taipei', { signal: AbortSignal.timeout(6000) });
      const j = await r.json();
      const c = j?.current;
      if (!c) return;
      const WMO: Record<number, string> = { 0:'вҳҖпёҸ', 1:'рҹҢӨ', 2:'вӣ…', 3:'вҳҒпёҸ', 45:'рҹҢ«', 51:'рҹҢҰ', 61:'рҹҢ§', 65:'рҹҢ§', 80:'рҹҢҰ', 95:'вӣҲ' };
      const icon = WMO[c.weather_code] ?? 'рҹҢЎ';
      setTicker('weather', `рҹҢҸ еҸ°еҢ— ${icon} <span class="text-sky-300">${Math.round(c.temperature_2m)}В°C</span>`);
    } catch {}
  }

  async function loadFearGreed() {
    try {
      const r = await fetch('https://api.alternative.me/fng/?limit=1', { signal: AbortSignal.timeout(8000) });
      const j = await r.json();
      const d = j?.data?.[0];
      if (!d) return;
      const val = parseInt(d.value);
      const cls = val >= 75 ? 'text-red-400' : val >= 55 ? 'text-orange-300' : val >= 45 ? 'text-yellow-300' : val >= 25 ? 'text-blue-300' : 'text-purple-400';
      const label = val >= 75 ? 'жҘөеәҰиІӘе©Ә' : val >= 55 ? 'иІӘе©Ә' : val >= 45 ? 'дёӯз«Ӣ' : val >= 25 ? 'жҒҗжҮј' : 'жҘөеәҰжҒҗжҮј';
      setTicker('fng', `рҹҳұ жҒҗж…ҢиІӘе©Ә <span class="${cls}">${val} (${label})</span>`);
    } catch {}
  }

  loadMarket();
  loadCurrency();
  loadWeather();
  loadFearGreed();
  setInterval(loadMarket, 60000);
  setInterval(loadCurrency, 300000);
  setInterval(loadWeather, 600000);
  setInterval(loadFearGreed, 3600000);
</script>

<style>
  .ticker-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 23, 42, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(168, 85, 247, 0.2);
    overflow: hidden;
    height: 32px;
    display: flex;
    align-items: center;
  }

  .ticker-inner {
    display: flex;
    overflow: hidden;
    width: 100%;
  }

  .ticker-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker-scroll 50s linear infinite;
    flex-shrink: 0;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .ticker-label {
    font-size: 0.68em;
    font-weight: 800;
    color: #a855f7;
    padding: 0 1.2em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ticker-item {
    font-size: 0.72em;
    color: #94a3b8;
    padding: 0 1em;
    border-left: 1px solid rgba(255,255,255,0.07);
  }

  .t-wait { color: #64748b; }

  .site-header {
    background: rgba(15, 23, 42, 0.95);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 32px;
    z-index: 99;
  }

  .header-inner {
    max-width: 1200px;
    margin: auto;
    padding: 0 1.5em;
    display: flex;
    align-items: center;
    gap: 0.4em;
    height: 56px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-bears { font-size: 1.3em; }

  .logo-title {
    font-size: 1em;
    font-weight: 900;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    gap: 0.05em;
    align-items: center;
    flex-wrap: nowrap;
    flex: 1;
    overflow: visible;
  }

  .site-nav :global(a) {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.82em;
    font-weight: 500;
    padding: 0.4em 0.55em;
    border-radius: 8px;
    transition: color 0.15s, background 0.15s;
    border-bottom: none !important;
    white-space: nowrap;
  }

  .site-nav :global(a:hover),
  .site-nav :global(a.active) {
    color: #e2e8f0;
    background: rgba(168, 85, 247, 0.12);
  }

  .site-nav :global(a.active) { color: #a855f7; }

  /* йҒҝйӣ· highlight */
  .site-nav :global(a[href="/avoid"]) { color: #e11d48; font-weight: 700; }
  .site-nav :global(a[href="/avoid"]:hover) { background: rgba(225,29,72,.1); color: #fb7185; }

  /* и§Җжё¬з«ҷ highlight */
  .site-nav :global(a[href="/oracle"]) { color: #14b8a6; font-weight: 700; }
  .site-nav :global(a[href="/oracle"]:hover) { background: rgba(20,184,166,.1); color: #2dd4bf; }

  @media (max-width: 900px) {
    .site-nav :global(a) { padding: 0.35em 0.4em; font-size: 0.78em; }
  }

  /* в”Җв”Җ жүӢж©ҹпјҡе…©иЎҢе°ҺиҰҪ в”Җв”Җ */
  @media (max-width: 700px) {
    .site-header { top: 32px; }

    .header-inner {
      height: auto;
      flex-wrap: wrap;
      padding: 0.35em 0.6em 0;
      gap: 0;
      justify-content: space-between;
      align-items: center;
    }

    /* Row 1пјҡlogo йқ е·ҰпјҢUserMenu йқ еҸі */
    .site-logo {
      order: 1;
      padding: 0.25em 0;
    }
    .site-logo .logo-title { display: none; }

    /* UserMenu и·іеҲ°з¬¬дёҖиЎҢеҸіеҒҙ */
    :global(.um-root) {
      order: 2;
      flex-shrink: 0;
    }

    /* Row 2пјҡnav дҪ”ж•ҙиЎҢпјҢе…ҒиЁұжҸӣиЎҢ */
    .site-nav {
      order: 3;
      flex-basis: 100%;
      flex-wrap: wrap;
      gap: 0.1em;
      padding: 0.2em 0 0.35em;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 0.2em;
    }

    .site-nav :global(a) {
      font-size: 0.72em;
      padding: 0.3em 0.45em;
    }
  }
</style>
