---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import UserMenu from './UserMenu.astro';
---

<!-- Ticker bar -->
<div class="ticker-bar">
  <div class="ticker-inner">
    <div class="ticker-track" id="ticker-track">
      <span class="ticker-label">⚡ 即時觀測</span>
      <span class="ticker-item" id="t-gold">🏅 黃金 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-vix">⚡ VIX <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-oil">🛢 油價 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-xrp">XRP <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-nasdaq">📈 NASDAQ <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-sp500">📊 S&P500 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-fng">😱 恐慌貪婪 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-jpytwd">🇯🇵 JPY/TWD <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-usdtwd">💱 USD/TWD <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-btc">🪙 BTC <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-twii">台股 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-tsm">🔵 台積電ADR <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-weather">🌏 台北天氣 <span class="t-wait">—</span></span>
    </div>
    <!-- duplicate for seamless loop -->
    <div class="ticker-track ticker-track-dup" aria-hidden="true">
      <span class="ticker-label">⚡ 即時觀測</span>
      <span class="ticker-item" id="t-gold2">🏅 黃金 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-vix2">⚡ VIX <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-oil2">🛢 油價 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-xrp2">XRP <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-nasdaq2">📈 NASDAQ <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-sp5002">📊 S&P500 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-fng2">😱 恐慌貪婪 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-jpytwd2">🇯🇵 JPY/TWD <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-usdtwd2">💱 USD/TWD <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-btc2">🪙 BTC <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-twii2">台股 <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-tsm2">🔵 台積電ADR <span class="t-wait">—</span></span>
      <span class="ticker-item" id="t-weather2">🌏 台北天氣 <span class="t-wait">—</span></span>
    </div>
  </div>
</div>

<!-- Main header -->
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo">
      <span class="logo-bears">🐻🐻</span>
      <span class="logo-title">{SITE_TITLE}</span>
    </a>
    <nav class="site-nav">
      <HeaderLink href="/">首頁</HeaderLink>
      <HeaderLink href="/blog">文章</HeaderLink>
      <HeaderLink href="/podcast">播客</HeaderLink>
      <HeaderLink href="/travel">✈️ 清單</HeaderLink>
      <HeaderLink href="/language">🗣️ 語言</HeaderLink>
      <HeaderLink href="/avoid">🚨 避雷</HeaderLink>
      <HeaderLink href="/picks">🐻 選物</HeaderLink>
      <HeaderLink href="/pick">💰 比價</HeaderLink>
      <HeaderLink href="/food">🍜 好料</HeaderLink>
      <HeaderLink href="/oracle">🔮 觀測</HeaderLink>
      <HeaderLink href="/fortune">命理</HeaderLink>
      <HeaderLink href="/omikuji">命運籤</HeaderLink>
      <HeaderLink href="/cruise">🚢 郵輪</HeaderLink>
      <HeaderLink href="/friends">情報</HeaderLink>
      <HeaderLink href="/member">會員</HeaderLink>
      <HeaderLink href="/about">關於</HeaderLink>
      <a href="https://ko-fi.com/twobear2" target="_blank" rel="noopener" class="nav-kofi">☕ 支持</a>
    </nav>
    <UserMenu />
  </div>
</header>

<script>
  function setTicker(id: string, html: string) {
    const el1 = document.getElementById(`t-${id}`);
    const el2 = document.getElementById(`t-${id}2`);
    if (el1) el1.innerHTML = html;
    if (el2) el2.innerHTML = html;
  }

  function chg(pct: number | null | undefined): string {
    if (pct == null) return '';
    const sign = pct >= 0 ? '▲' : '▼';
    const cls = pct >= 0 ? 'text-green-400' : 'text-red-400';
    return ` <span class="${cls}">${sign}${Math.abs(pct).toFixed(2)}%</span>`;
  }

  function fmt(p: number | null, dec?: number): string {
    if (p == null) return '—';
    return p.toLocaleString('en-US', { maximumFractionDigits: dec ?? (p >= 100 ? 0 : 4) });
  }

  async function loadMarket() {
    try {
      const r = await fetch('/api/market');
      const d = await r.json();
      const qs: Record<string, any> = {};
      for (const q of (d.quotes ?? [])) qs[q.symbol] = q;

      const btc = d.crypto?.bitcoin;
      const xrp = d.crypto?.ripple;
      if (btc) setTicker('btc', `🪙 BTC <span class="text-green-400">$${fmt(btc.usd)}${chg(btc.usd_24h_change)}</span>`);
      if (xrp) setTicker('xrp', `XRP <span class="text-purple-300">$${fmt(xrp.usd, 4)}${chg(xrp.usd_24h_change)}</span>`);
      if (qs['^GSPC']) setTicker('sp500', `📊 S&P500 <span>${fmt(qs['^GSPC'].price)}${chg(qs['^GSPC'].change)}</span>`);
      if (qs['^TWII']) setTicker('twii', `台股 <span>${fmt(qs['^TWII'].price)}${chg(qs['^TWII'].change)}</span>`);
      if (qs['GC=F']) setTicker('gold', `🏅 黃金 <span class="text-yellow-300">$${fmt(qs['GC=F'].price)}${chg(qs['GC=F'].change)}</span>`);
      if (qs['^VIX']) {
        const v = qs['^VIX'].price;
        const vcls = v >= 30 ? 'text-red-400' : v >= 20 ? 'text-yellow-300' : 'text-green-400';
        setTicker('vix', `⚡ VIX <span class="${vcls}">${fmt(v, 1)}</span>`);
      }
      if (qs['^IXIC']) setTicker('nasdaq', `📈 NASDAQ <span>${fmt(qs['^IXIC'].price)}${chg(qs['^IXIC'].change)}</span>`);
      if (qs['CL=F']) setTicker('oil', `🛢 油價 <span class="text-orange-300">$${fmt(qs['CL=F'].price, 2)}</span>`);
      if (qs['TSM']) setTicker('tsm', `🔵 台積電ADR <span>${fmt(qs['TSM'].price, 2)}${chg(qs['TSM'].change)}</span>`);
    } catch {}
  }

  async function loadCurrency() {
    try {
      const r = await fetch('https://open.er-api.com/v6/latest/USD', { signal: AbortSignal.timeout(8000) });
      const j = await r.json();
      if (j?.result !== 'success') return;
      const twd = j.rates?.TWD;
      const jpy = j.rates?.JPY;
      const jpytwd = twd && jpy ? twd / jpy : null;
      if (twd) setTicker('usdtwd', `💱 USD/TWD <span class="text-blue-300">${twd.toFixed(2)}</span>`);
      if (jpytwd) setTicker('jpytwd', `🇯🇵 JPY/TWD <span class="text-blue-300">${jpytwd.toFixed(4)}</span>`);
    } catch {}
  }

  async function loadWeather() {
    try {
      const r = await fetch('https://api.open-meteo.com/v1/forecast?latitude=25.0330&longitude=121.5654&current=temperature_2m,weather_code&timezone=Asia/Taipei', { signal: AbortSignal.timeout(6000) });
      const j = await r.json();
      const c = j?.current;
      if (!c) return;
      const WMO: Record<number, string> = { 0:'☀️', 1:'🌤', 2:'⛅', 3:'☁️', 45:'🌫', 51:'🌦', 61:'🌧', 65:'🌧', 80:'🌦', 95:'⛈' };
      const icon = WMO[c.weather_code] ?? '🌡';
      setTicker('weather', `🌏 台北 ${icon} <span class="text-sky-300">${Math.round(c.temperature_2m)}°C</span>`);
    } catch {}
  }

  async function loadFearGreed() {
    try {
      const r = await fetch('https://api.alternative.me/fng/?limit=1', { signal: AbortSignal.timeout(8000) });
      const j = await r.json();
      const d = j?.data?.[0];
      if (!d) return;
      const val = parseInt(d.value);
      const cls = val >= 75 ? 'text-red-400' : val >= 55 ? 'text-orange-300' : val >= 45 ? 'text-yellow-300' : val >= 25 ? 'text-blue-300' : 'text-purple-400';
      const label = val >= 75 ? '極度貪婪' : val >= 55 ? '貪婪' : val >= 45 ? '中立' : val >= 25 ? '恐懼' : '極度恐懼';
      setTicker('fng', `😱 恐慌貪婪 <span class="${cls}">${val} (${label})</span>`);
    } catch {}
  }

  loadMarket();
  loadCurrency();
  loadWeather();
  loadFearGreed();
  setInterval(loadMarket, 60000);
  setInterval(loadCurrency, 300000);
  setInterval(loadWeather, 600000);
  setInterval(loadFearGreed, 3600000);
</script>

<style>
  .ticker-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 23, 42, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(168, 85, 247, 0.2);
    overflow: hidden;
    height: 32px;
    display: flex;
    align-items: center;
  }

  .ticker-inner {
    display: flex;
    overflow: hidden;
    width: 100%;
  }

  .ticker-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker-scroll 50s linear infinite;
    flex-shrink: 0;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  .ticker-label {
    font-size: 0.68em;
    font-weight: 800;
    color: #a855f7;
    padding: 0 1.2em;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .ticker-item {
    font-size: 0.72em;
    color: #94a3b8;
    padding: 0 1em;
    border-left: 1px solid rgba(255,255,255,0.07);
  }

  .t-wait { color: #64748b; }

  .site-header {
    background: rgba(15, 23, 42, 0.95);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 32px;
    z-index: 99;
  }

  .header-inner {
    max-width: 1200px;
    margin: auto;
    padding: 0 1.5em;
    display: flex;
    align-items: center;
    gap: 0.4em;
    height: 56px;
  }

  .site-logo {
    display: flex;
    align-items: center;
    gap: 0.5em;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-bears { font-size: 1.3em; }

  .logo-title {
    font-size: 1em;
    font-weight: 900;
    background: linear-gradient(135deg, #a855f7, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    gap: 0.05em;
    align-items: center;
    flex-wrap: nowrap;
    flex: 1;
    overflow: visible;
  }

  .site-nav :global(a) {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.82em;
    font-weight: 500;
    padding: 0.4em 0.55em;
    border-radius: 8px;
    transition: color 0.15s, background 0.15s;
    border-bottom: none !important;
    white-space: nowrap;
  }

  .site-nav :global(a:hover),
  .site-nav :global(a.active) {
    color: #e2e8f0;
    background: rgba(168, 85, 247, 0.12);
  }

  .site-nav :global(a.active) { color: #a855f7; }

  /* 避雷 highlight */
  .site-nav :global(a[href="/avoid"]) { color: #e11d48; font-weight: 700; }
  .site-nav :global(a[href="/avoid"]:hover) { background: rgba(225,29,72,.1); color: #fb7185; }

  /* 觀測站 highlight */
  .site-nav :global(a[href="/oracle"]) { color: #14b8a6; font-weight: 700; }
  .site-nav :global(a[href="/oracle"]:hover) { background: rgba(20,184,166,.1); color: #2dd4bf; }

  /* Ko-fi 支持按鈕 */
  .nav-kofi {
    display: inline-flex; align-items: center;
    padding: 0.3em 0.8em;
    background: #FF5E5B;
    color: #fff !important;
    font-size: 0.78em; font-weight: 700;
    border-radius: 20px;
    text-decoration: none !important;
    white-space: nowrap;
    transition: background .15s, transform .12s;
    margin-left: 0.3em;
  }
  .nav-kofi:hover { background: #ff3d3a !important; transform: translateY(-1px); }

  @media (max-width: 900px) {
    .site-nav :global(a) { padding: 0.35em 0.4em; font-size: 0.78em; }
  }

  /* ── 手機：兩行導覽 ── */
  @media (max-width: 700px) {
    .site-header { top: 32px; }

    .header-inner {
      height: auto;
      flex-wrap: wrap;
      padding: 0.35em 0.6em 0;
      gap: 0;
      justify-content: space-between;
      align-items: center;
    }

    /* Row 1：logo 靠左，UserMenu 靠右 */
    .site-logo {
      order: 1;
      padding: 0.25em 0;
    }
    .site-logo .logo-title { display: none; }

    /* UserMenu 跳到第一行右側 */
    :global(.um-root) {
      order: 2;
      flex-shrink: 0;
    }

    /* Row 2：nav 佔整行，允許換行 */
    .site-nav {
      order: 3;
      flex-basis: 100%;
      flex-wrap: wrap;
      gap: 0.1em;
      padding: 0.2em 0 0.35em;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 0.2em;
    }

    .site-nav :global(a) {
      font-size: 0.72em;
      padding: 0.3em 0.45em;
    }
  }
</style>
