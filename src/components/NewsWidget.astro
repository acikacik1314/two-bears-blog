---
---
<div class="news-widget">
  <div class="nw-tabs">
    <button class="nw-tab active" data-topic="trump">🇺🇸 川普</button>
    <button class="nw-tab" data-topic="btc">₿ BTC</button>
    <button class="nw-tab" data-topic="prophecy">🔮 預言</button>
  </div>
  <div class="nw-body" id="nw-body">
    <div class="nw-loading">載入中…</div>
  </div>
</div>

<script>
  interface NewsItem { title: string; link: string; pubDate: string; source: string; }
  interface NewsData { trump: NewsItem[]; btc: NewsItem[]; prophecy: NewsItem[]; }

  let data: NewsData | null = null;
  let currentTopic: keyof NewsData = 'trump';

  function timeAgo(dateStr: string): string {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '';
    const mins = Math.floor((Date.now() - d.getTime()) / 60000);
    if (mins < 60) return `${mins}分鐘前`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}小時前`;
    return `${Math.floor(hrs / 24)}天前`;
  }

  function render(topic: keyof NewsData) {
    const body = document.getElementById('nw-body');
    if (!body) return;
    if (!data) { body.innerHTML = '<div class="nw-loading">載入中…</div>'; return; }
    const items = data[topic];
    if (!items?.length) { body.innerHTML = '<div class="nw-empty">暫無新聞</div>'; return; }
    body.innerHTML = items.map(item => `
      <a class="nw-item" href="${item.link}" target="_blank" rel="noopener noreferrer">
        <span class="nw-title">${item.title}</span>
        <span class="nw-meta">${item.source}${item.pubDate ? ' · ' + timeAgo(item.pubDate) : ''}</span>
      </a>
    `).join('');
  }

  async function load() {
    try {
      const r = await fetch('/api/news');
      if (r.ok) data = await r.json();
    } catch {}
    render(currentTopic);
  }

  document.querySelectorAll<HTMLButtonElement>('.nw-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      currentTopic = (btn.dataset.topic as keyof NewsData) ?? 'trump';
      document.querySelectorAll('.nw-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      render(currentTopic);
    });
  });

  load();
</script>

<style>
  .news-widget {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    overflow: hidden;
  }

  .nw-tabs {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nw-tab {
    background: transparent;
    border: none;
    color: #64748b;
    font-size: 0.72em;
    font-weight: 600;
    padding: 0.55em 0.3em;
    cursor: pointer;
    transition: all 0.15s;
    border-right: 1px solid rgba(255,255,255,0.06);
  }
  .nw-tab:last-child { border-right: none; }
  .nw-tab.active { background: rgba(168,85,247,0.12); color: #c084fc; }
  .nw-tab:hover:not(.active) { color: #94a3b8; background: rgba(255,255,255,0.04); }

  .nw-body { padding: 0.5em 0; min-height: 120px; }

  .nw-loading, .nw-empty {
    color: #64748b;
    font-size: 0.78em;
    text-align: center;
    padding: 2em 1em;
  }

  .nw-item {
    display: block;
    padding: 0.55em 0.9em;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s;
  }
  .nw-item:last-child { border-bottom: none; }
  .nw-item:hover { background: rgba(168,85,247,0.07); }

  .nw-title {
    display: block;
    font-size: 0.78em;
    color: #e2e8f0;
    line-height: 1.4;
    margin-bottom: 0.2em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .nw-item:hover .nw-title { color: #c084fc; }

  .nw-meta {
    font-size: 0.68em;
    color: #475569;
  }
</style>
