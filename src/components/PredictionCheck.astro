---
interface Props {
  hits?: string[];
  misses?: string[];
  pending?: string[];
}

const { hits = [], misses = [], pending = [] } = Astro.props;

const total = hits.length + misses.length;
const hitRate = total > 0 ? Math.round((hits.length / total) * 100) : null;

const rateColor =
  hitRate === null ? '#888' :
  hitRate >= 70 ? '#27ae60' :
  hitRate >= 40 ? '#e67e22' :
  '#e74c3c';
---

<div class="prediction-check">
  <div class="pc-header">
    <span class="pc-title">🔍 命中率檢驗</span>
    {hitRate !== null && (
      <span class="pc-rate" style={`color:${rateColor}`}>
        {hitRate}% 命中（{hits.length}/{total} 條已驗證）
      </span>
    )}
    {hitRate === null && pending.length > 0 && (
      <span class="pc-rate" style="color:#888">尚無已驗證預言</span>
    )}
  </div>

  {hits.length > 0 && (
    <ul class="pc-list pc-hits">
      {hits.map(item => <li>✅ {item}</li>)}
    </ul>
  )}

  {misses.length > 0 && (
    <ul class="pc-list pc-misses">
      {misses.map(item => <li>❌ {item}</li>)}
    </ul>
  )}

  {pending.length > 0 && (
    <ul class="pc-list pc-pending">
      {pending.map(item => <li>⏳ {item}</li>)}
    </ul>
  )}
</div>

<style>
  .prediction-check {
    border: 1px solid #ddd;
    border-left: 4px solid #8e44ad;
    border-radius: 8px;
    padding: 1.2em 1.4em;
    margin: 2em 0;
    background: #fafafa;
  }
  .pc-header {
    display: flex;
    align-items: center;
    gap: 1em;
    flex-wrap: wrap;
    margin-bottom: 0.8em;
  }
  .pc-title {
    font-weight: 700;
    font-size: 1.05em;
    color: #333;
  }
  .pc-rate {
    font-weight: 700;
    font-size: 0.95em;
  }
  .pc-list {
    list-style: none;
    padding: 0;
    margin: 0.4em 0;
  }
  .pc-list li {
    padding: 0.3em 0;
    font-size: 0.92em;
    line-height: 1.5;
    border-bottom: 1px solid #eee;
  }
  .pc-list li:last-child {
    border-bottom: none;
  }
  .pc-hits li { color: #1e6b3a; }
  .pc-misses li { color: #8b1a1a; }
  .pc-pending li { color: #666; }
</style>
