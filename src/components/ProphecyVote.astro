---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<div class="pv-wrap" id="pv-wrap" data-slug={slug}>
  <div class="pv-header">
    <span class="pv-title">🔮 社群驗證</span>
    <span class="pv-sub">這個預言是否成真？</span>
  </div>

  <!-- Voting buttons (shown before voting) -->
  <div class="pv-btns" id="pv-btns">
    <button class="pv-btn pv-true"  onclick="castVote('t')">✅ 已成真</button>
    <button class="pv-btn pv-false" onclick="castVote('f')">❌ 未成真</button>
    <button class="pv-btn pv-pend"  onclick="castVote('p')">⏳ 待觀察</button>
  </div>

  <!-- Result bar (shown after voting or if already voted) -->
  <div class="pv-result" id="pv-result" style="display:none">
    <div class="pv-bars" id="pv-bars"></div>
    <div class="pv-total" id="pv-total"></div>
  </div>

  <div class="pv-msg" id="pv-msg"></div>
</div>

<script>
  const wrap   = document.getElementById('pv-wrap')
  const slug   = wrap?.dataset.slug ?? location.pathname
  const STORE_KEY = `pv_${slug}`

  function pct(n: number, total: number) {
    return total ? Math.round(n / total * 100) : 0
  }

  function renderResult(counts: { t: number; f: number; p: number }, myVote?: string) {
    const total = counts.t + counts.f + counts.p
    const bars = document.getElementById('pv-bars')
    const tot  = document.getElementById('pv-total')
    const btns = document.getElementById('pv-btns')
    const res  = document.getElementById('pv-result')
    const msg  = document.getElementById('pv-msg')

    if (btns) btns.style.display = 'none'
    if (res)  res.style.display  = 'block'

    const rows = [
      { key: 't', label: '✅ 已成真', cls: 'bar-true',  val: counts.t },
      { key: 'f', label: '❌ 未成真', cls: 'bar-false', val: counts.f },
      { key: 'p', label: '⏳ 待觀察', cls: 'bar-pend',  val: counts.p },
    ]

    if (bars) {
      bars.innerHTML = rows.map(r => {
        const p = pct(r.val, total)
        const active = myVote === r.key ? ' pv-my' : ''
        return `<div class="pv-row${active}">
          <span class="pv-label">${r.label}</span>
          <div class="pv-bar-wrap">
            <div class="pv-bar ${r.cls}" style="width:${p}%"></div>
          </div>
          <span class="pv-pct">${p}%</span>
        </div>`
      }).join('')
    }
    if (tot) tot.textContent = `共 ${total} 人投票`
    if (msg && myVote) msg.textContent = '感謝你的投票！'
  }

  async function loadCounts() {
    try {
      const r = await fetch(`/api/post-vote?slug=${encodeURIComponent(slug)}`)
      const d = await r.json()
      return d as { t: number; f: number; p: number }
    } catch {
      return null
    }
  }

  window.castVote = async function(vote: string) {
    const already = localStorage.getItem(STORE_KEY)
    if (already) {
      const counts = await loadCounts()
      if (counts) renderResult(counts, already)
      return
    }

    const btns = document.getElementById('pv-btns')
    if (btns) btns.style.opacity = '0.5'

    try {
      const r = await fetch('/api/post-vote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, vote }),
      })
      const d = await r.json()
      if (d.ok && d.counts) {
        localStorage.setItem(STORE_KEY, vote)
        renderResult(d.counts, vote)
      }
    } catch {
      if (btns) btns.style.opacity = '1'
    }
  }

  // On load: check if already voted
  ;(async () => {
    const already = localStorage.getItem(STORE_KEY)
    if (already) {
      const counts = await loadCounts()
      if (counts) renderResult(counts, already)
    }
  })()
</script>

<style>
  .pv-wrap {
    margin: 2em 0;
    padding: 1.4em 1.6em;
    background: linear-gradient(135deg, rgba(88,28,135,.07), rgba(15,23,42,.04));
    border: 1px solid rgba(126,34,206,.25);
    border-left: 4px solid #7e22ce;
    border-radius: 12px;
  }

  .pv-header {
    display: flex;
    align-items: center;
    gap: .8em;
    margin-bottom: 1em;
  }

  .pv-title {
    font-size: 1em;
    font-weight: 800;
    color: #1e1b4b;
  }

  .pv-sub {
    font-size: .82em;
    color: #64748b;
  }

  .pv-btns {
    display: flex;
    gap: .6em;
    flex-wrap: wrap;
  }

  .pv-btn {
    flex: 1;
    min-width: 100px;
    padding: .6em 1em;
    border: 2px solid transparent;
    border-radius: 10px;
    font-size: .88em;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: all .15s;
  }

  .pv-true  { background: #f0fdf4; border-color: #86efac; color: #166534; }
  .pv-false { background: #fef2f2; border-color: #fca5a5; color: #991b1b; }
  .pv-pend  { background: #fefce8; border-color: #fde047; color: #854d0e; }

  .pv-true:hover  { background: #dcfce7; }
  .pv-false:hover { background: #fee2e2; }
  .pv-pend:hover  { background: #fef9c3; }

  .pv-row {
    display: grid;
    grid-template-columns: 90px 1fr 42px;
    align-items: center;
    gap: .6em;
    margin-bottom: .55em;
  }

  .pv-row.pv-my .pv-label { font-weight: 800; }

  .pv-label { font-size: .82em; color: #374151; white-space: nowrap; }

  .pv-bar-wrap {
    background: #e5e7eb;
    border-radius: 4px;
    height: 10px;
    overflow: hidden;
  }

  .pv-bar {
    height: 100%;
    border-radius: 4px;
    transition: width .5s ease;
    min-width: 3px;
  }

  .bar-true  { background: #22c55e; }
  .bar-false { background: #ef4444; }
  .bar-pend  { background: #eab308; }

  .pv-pct {
    font-size: .78em;
    font-weight: 700;
    color: #6b7280;
    text-align: right;
  }

  .pv-total {
    font-size: .75em;
    color: #9ca3af;
    margin-top: .4em;
    text-align: right;
  }

  .pv-msg {
    font-size: .78em;
    color: #7e22ce;
    font-weight: 600;
    margin-top: .4em;
  }

  @media (max-width: 500px) {
    .pv-wrap { padding: 1em; }
    .pv-row { grid-template-columns: 70px 1fr 36px; gap: .4em; }
  }
</style>
