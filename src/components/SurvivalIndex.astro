---
---
<div class="si-wrap" id="survival-index">
  <div class="si-title">🚨 今日生存指數 <span class="si-ai">AI 計算</span></div>
  <div id="si-body" class="si-body">
    <div class="si-loading">AI 分析中…</div>
  </div>
</div>

<script>
  interface RiskItem { score: number; level: string; note: string; }
  interface SurvivalData { geopolitical: RiskItem; economic: RiskItem; disaster: RiskItem; }

  const LABELS: Record<string, string> = {
    geopolitical: '🌍 地緣政治',
    economic:     '💰 經濟風險',
    disaster:     '🌋 天災風險',
  };
  const LEVEL_COLOR: Record<string, string> = {
    '偏低': '#22c55e', '中等': '#f59e0b', '偏高': '#ef4444', '極高': '#dc2626',
  };

  async function load() {
    const body = document.getElementById('si-body')!;
    try {
      const r = await fetch('/api/survival');
      if (!r.ok) throw new Error();
      const d: SurvivalData = await r.json();
      body.innerHTML = (Object.entries(d) as [string, RiskItem][]).map(([k, v]) => `
        <div class="si-row">
          <div class="si-meta">
            <span class="si-label">${LABELS[k] ?? k}</span>
            <span class="si-level" style="color:${LEVEL_COLOR[v.level] ?? '#94a3b8'}">${v.level}</span>
          </div>
          <div class="si-bar-wrap">
            <div class="si-bar" style="width:${v.score}%;background:${LEVEL_COLOR[v.level] ?? '#a855f7'}"></div>
          </div>
          <div class="si-note">${v.note} <span class="si-score">${v.score}/100</span></div>
        </div>
      `).join('');
    } catch {
      body.innerHTML = '<div class="si-loading">暫時無法取得數據</div>';
    }
  }
  load();
</script>

<style>
.si-wrap {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  padding: 1em;
}
.si-title { font-size: .78em; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .7em; display: flex; align-items: center; gap: .5em; }
.si-ai { font-size: .8em; background: rgba(168,85,247,.15); color: #c084fc; padding: .1em .45em; border-radius: 4px; font-weight: 700; }
.si-loading { color: #64748b; font-size: .78em; text-align: center; padding: 1.5em; }
.si-row { margin-bottom: .65em; }
.si-row:last-child { margin-bottom: 0; }
.si-meta { display: flex; justify-content: space-between; font-size: .75em; margin-bottom: .25em; }
.si-label { color: #e2e8f0; font-weight: 600; }
.si-level { font-weight: 700; font-size: .9em; }
.si-bar-wrap { height: 5px; background: rgba(255,255,255,.08); border-radius: 3px; margin-bottom: .2em; }
.si-bar { height: 100%; border-radius: 3px; transition: width .8s ease; }
.si-note { font-size: .68em; color: #64748b; display: flex; justify-content: space-between; }
.si-score { color: #475569; }
</style>
