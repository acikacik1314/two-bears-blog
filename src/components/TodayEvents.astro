---
---
<div class="te-wrap">
  <div class="te-header">
    <span class="te-title">🌍 今日異常事件</span>
    <span class="te-badge">即時</span>
  </div>
  <div id="te-body" class="te-body">
    <div class="te-loading">載入中…</div>
  </div>
</div>

<script>
  interface Event { text: string; time: string; level: 'high'|'medium'|'low'; link?: string; }

  async function loadEvents() {
    const body = document.getElementById('te-body')!;
    const events: Event[] = [];

    const [eqRes, newsRes, mktRes] = await Promise.allSettled([
      fetch('/api/earthquakes').then(r => r.json()),
      fetch('/api/news').then(r => r.json()),
      fetch('/api/market').then(r => r.json()),
    ]);

    // Earthquakes M5+
    if (eqRes.status === 'fulfilled') {
      const features = eqRes.value?.features ?? [];
      for (const f of features.slice(0, 5)) {
        const mag = f.properties?.mag ?? 0;
        if (mag >= 5) {
          const place = f.properties?.place ?? '';
          const hrs = Math.floor((Date.now() - f.properties.time) / 3600000);
          events.push({ text: `${place} M${mag} 地震`, time: hrs < 1 ? '剛剛' : `${hrs}小時前`, level: mag >= 6.5 ? 'high' : 'medium' });
        }
      }
    }

    // Market moves
    if (mktRes.status === 'fulfilled') {
      const m = mktRes.value;
      const btc = m?.crypto?.bitcoin;
      if (btc && Math.abs(btc.usd_24h_change ?? 0) >= 4) {
        const d = btc.usd_24h_change > 0 ? '▲' : '▼';
        events.push({ text: `BTC ${d}${Math.abs(btc.usd_24h_change).toFixed(1)}%  $${Math.round(btc.usd).toLocaleString()}`, time: '24h', level: Math.abs(btc.usd_24h_change) >= 8 ? 'high' : 'medium' });
      }
      const xrp = m?.crypto?.ripple;
      if (xrp && Math.abs(xrp.usd_24h_change ?? 0) >= 6) {
        const d = xrp.usd_24h_change > 0 ? '▲' : '▼';
        events.push({ text: `XRP ${d}${Math.abs(xrp.usd_24h_change).toFixed(1)}%`, time: '24h', level: 'medium' });
      }
    }

    // News
    if (newsRes.status === 'fulfilled') {
      const all = [...(newsRes.value?.trump ?? []).slice(0,2), ...(newsRes.value?.btc ?? []).slice(0,2)];
      for (const n of all) {
        events.push({ text: n.title, link: n.link, time: '', level: 'low' });
      }
    }

    if (!events.length) {
      body.innerHTML = '<div class="te-empty">暫無異常事件</div>';
      return;
    }

    const COLOR = { high: '#ef4444', medium: '#f59e0b', low: '#64748b' };
    body.innerHTML = events.slice(0,8).map(e => `
      <${e.link ? `a href="${e.link}" target="_blank" rel="noopener"` : 'div'} class="te-item">
        <span class="te-dot" style="background:${COLOR[e.level]}"></span>
        <span class="te-text">${e.text}</span>
        ${e.time ? `<span class="te-time">${e.time}</span>` : ''}
      </${e.link ? 'a' : 'div'}>
    `).join('');
  }

  loadEvents();
</script>

<style>
.te-wrap {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  overflow: hidden;
}
.te-header { display: flex; align-items: center; gap: .5em; padding: .8em 1em .6em; border-bottom: 1px solid rgba(255,255,255,.05); }
.te-title { font-size: .8em; font-weight: 700; color: #e2e8f0; }
.te-badge { font-size: .62em; background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.25); padding: .1em .4em; border-radius: 4px; font-weight: 700; }
.te-body { padding: .4em 0; min-height: 80px; }
.te-loading, .te-empty { color: #64748b; font-size: .75em; text-align: center; padding: 1.5em; }
.te-item {
  display: flex; align-items: flex-start; gap: .5em;
  padding: .4em 1em; text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,.03);
  transition: background .15s;
}
.te-item:last-child { border-bottom: none; }
a.te-item:hover { background: rgba(255,255,255,.03); }
.te-dot { width: 6px; height: 6px; border-radius: 50%; margin-top: .35em; flex-shrink: 0; }
.te-text { font-size: .75em; color: #e2e8f0; flex: 1; line-height: 1.4; }
a.te-item:hover .te-text { color: #c084fc; }
.te-time { font-size: .65em; color: #475569; white-space: nowrap; margin-top: .1em; }
</style>
