---
// No server-side computation — all calculated client-side so the date updates daily without redeploy
---

<div class="today-panel">
  <div class="tp-header">
    <span>🇹🇼</span>
    <span class="tp-label">台灣時間</span>
  </div>
  <div class="tp-bigdate" id="tp-bigdate">—</div>
  <div class="tp-week" id="tp-week">—</div>
  <hr class="tp-hr"/>
  <div class="tp-row"><span class="k">農曆</span><span id="tp-lunar">—</span></div>
  <div class="tp-row"><span class="k">距2027</span><span class="hi" id="tp-days2027">—</span></div>
  <div class="tp-row"><span class="k">今日吉日</span><span id="tp-auspicious">—</span></div>
  <div class="tp-row"><span class="k">月相</span><span id="tp-moon">—</span></div>
  <div class="tp-row"><span class="k">星座</span><span id="tp-zodiac">—</span></div>
  <div class="tp-row"><span class="k">九運年份</span><span id="tp-year">—</span></div>
</div>

<script>
function initTodayPanel() {
  // Taiwan time (UTC+8)
  const now = new Date();
  const tai = new Date(now.getTime() + (8 * 60 + now.getTimezoneOffset()) * 60000);
  const Y = tai.getFullYear();
  const M = tai.getMonth() + 1;
  const D = tai.getDate();
  const pad = (n: number) => String(n).padStart(2, '0');

  // ── Date & weekday ──────────────────────────────────────────
  const weekDay = ['日','一','二','三','四','五','六'][tai.getDay()];
  const bigdate = document.getElementById('tp-bigdate');
  const week    = document.getElementById('tp-week');
  if (bigdate) bigdate.textContent = `${Y}/${pad(M)}/${pad(D)}`;
  if (week)    week.textContent    = `星期${weekDay}`;

  // ── Days to 2027-01-01 ──────────────────────────────────────
  const target2027 = Date.UTC(2027, 0, 1);
  const todayUTC   = Date.UTC(Y, M - 1, D);
  const days2027   = Math.ceil((target2027 - todayUTC) / 86400000);
  const d2027El    = document.getElementById('tp-days2027');
  if (d2027El) d2027El.textContent = days2027 > 0 ? `還有 ${days2027} 天` : days2027 === 0 ? '就是今天！' : '已到達';

  // ── Lunar calendar (lookup table 2025–2027) ─────────────────
  // Each entry: [YYYY-MM-DD start of lunar month, month name, lunar year]
  const LUNAR_STARTS: [string, string][] = [
    ['2025-01-29', '正月'],
    ['2025-02-28', '二月'],
    ['2025-03-29', '三月'],
    ['2025-04-27', '四月'],
    ['2025-05-27', '五月'],
    ['2025-06-25', '六月'],
    ['2025-07-25', '七月'],
    ['2025-08-23', '八月'],
    ['2025-09-22', '九月'],
    ['2025-10-21', '十月'],
    ['2025-11-20', '十一月'],
    ['2025-12-20', '十二月'],
    ['2026-01-19', '閏十二月'],
    ['2026-02-17', '正月'],
    ['2026-03-19', '二月'],
    ['2026-04-17', '三月'],
    ['2026-05-16', '四月'],
    ['2026-06-15', '五月'],
    ['2026-07-14', '六月'],
    ['2026-08-13', '七月'],
    ['2026-09-11', '八月'],
    ['2026-10-11', '九月'],
    ['2026-11-09', '十月'],
    ['2026-12-09', '十一月'],
    ['2027-01-07', '十二月'],
    ['2027-02-06', '正月'],
    ['2027-03-08', '二月'],
    ['2027-04-06', '三月'],
    ['2027-05-05', '四月'],
    ['2027-06-04', '五月'],
    ['2027-07-03', '六月'],
    ['2027-08-01', '七月'],
    ['2027-08-31', '八月'],
    ['2027-09-29', '九月'],
    ['2027-10-29', '十月'],
    ['2027-11-27', '十一月'],
    ['2027-12-27', '十二月'],
  ];
  const LUNAR_D = ['初一','初二','初三','初四','初五','初六','初七','初八','初九','初十',
                   '十一','十二','十三','十四','十五','十六','十七','十八','十九','二十',
                   '廿一','廿二','廿三','廿四','廿五','廿六','廿七','廿八','廿九','三十'];

  const todayStr = `${Y}-${pad(M)}-${pad(D)}`;
  let lunarText = '—';
  for (let i = LUNAR_STARTS.length - 1; i >= 0; i--) {
    if (todayStr >= LUNAR_STARTS[i][0]) {
      const startMs = new Date(LUNAR_STARTS[i][0]).getTime();
      const dayNum  = Math.floor((todayUTC - new Date(LUNAR_STARTS[i][0]).getTime()) / 86400000);
      lunarText = LUNAR_STARTS[i][1] + LUNAR_D[Math.min(dayNum, 29)];
      break;
    }
  }
  const lunarEl = document.getElementById('tp-lunar');
  if (lunarEl) lunarEl.textContent = lunarText;

  // ── Moon phase ──────────────────────────────────────────────
  // Reference new moon: 2000-01-06 18:14 UTC (J2000 epoch new moon)
  const REF_NEW_MOON = Date.UTC(2000, 0, 6, 18, 14);
  const CYCLE = 29.53058867;
  const moonAge = ((todayUTC - REF_NEW_MOON) / 86400000 % CYCLE + CYCLE) % CYCLE;
  const moonEmoji = moonAge < 1.5  ? '🌑' :
                    moonAge < 7    ? '🌒' :
                    moonAge < 9    ? '🌓' :
                    moonAge < 13.5 ? '🌔' :
                    moonAge < 16   ? '🌕' :
                    moonAge < 20   ? '🌖' :
                    moonAge < 22   ? '🌗' :
                    moonAge < 26   ? '🌘' : '🌑';
  const moonName  = moonAge < 1.5  ? '新月' :
                    moonAge < 7    ? '娥眉月' :
                    moonAge < 9    ? '上弦月' :
                    moonAge < 13.5 ? '盈凸月' :
                    moonAge < 16   ? '滿月' :
                    moonAge < 20   ? '虧凸月' :
                    moonAge < 22   ? '下弦月' : '殘月';
  const moonEl = document.getElementById('tp-moon');
  if (moonEl) moonEl.textContent = `${moonEmoji} ${moonName}`;

  // ── Western zodiac ──────────────────────────────────────────
  let zodiac = '♓雙魚';
  if      ((M===3&&D>=21)||(M===4&&D<=19))  zodiac = '♈牡羊';
  else if ((M===4&&D>=20)||(M===5&&D<=20))  zodiac = '♉金牛';
  else if ((M===5&&D>=21)||(M===6&&D<=20))  zodiac = '♊雙子';
  else if ((M===6&&D>=21)||(M===7&&D<=22))  zodiac = '♋巨蟹';
  else if ((M===7&&D>=23)||(M===8&&D<=22))  zodiac = '♌獅子';
  else if ((M===8&&D>=23)||(M===9&&D<=22))  zodiac = '♍處女';
  else if ((M===9&&D>=23)||(M===10&&D<=22)) zodiac = '♎天秤';
  else if ((M===10&&D>=23)||(M===11&&D<=21))zodiac = '♏天蠍';
  else if ((M===11&&D>=22)||(M===12&&D<=21))zodiac = '♐射手';
  else if ((M===12&&D>=22)||(M===1&&D<=19)) zodiac = '♑摩羯';
  else if ((M===1&&D>=20)||(M===2&&D<=18))  zodiac = '♒水瓶';
  const zodiacEl = document.getElementById('tp-zodiac');
  if (zodiacEl) zodiacEl.textContent = `${zodiac}座`;

  // ── Chinese sexagenary year ─────────────────────────────────
  const STEMS   = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
  const BRANCHES= ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
  const ANIMALS = ['鼠','牛','虎','兔','龍','蛇','馬','羊','猴','雞','狗','豬'];
  // Use lunar year: if before Chinese New Year use previous year
  // Chinese New Year dates (first day of 正月)
  const CNY: Record<number, string> = {
    2025: '2025-01-29', 2026: '2026-02-17', 2027: '2027-02-06', 2028: '2028-01-26',
  };
  let lunarY = Y;
  const cnyThis = CNY[Y];
  if (cnyThis && todayStr < cnyThis) lunarY = Y - 1;
  const stem   = STEMS[(lunarY - 4) % 10];
  const branch = BRANCHES[(lunarY - 4) % 12];
  const animal = ANIMALS[(lunarY - 4) % 12];
  const yearEl = document.getElementById('tp-year');
  if (yearEl) yearEl.textContent = `${stem}${branch}年（${animal}年）`;

  // ── Daily auspicious ────────────────────────────────────────
  const AUSPICIOUS = ['開市・出行','祭祀・入宅','結婚・嫁娶','求財・立券','動土・破土',
                      '裁衣・開業','出行・移徙','納財・開光','開市・祈福','入宅・搬家',
                      '祭祀・開光','嫁娶・開業'];
  const auspEl = document.getElementById('tp-auspicious');
  if (auspEl) auspEl.textContent = AUSPICIOUS[(D + M * 3) % AUSPICIOUS.length];
}

// Run on initial load and after Astro view transitions
document.addEventListener('astro:page-load', initTodayPanel);
initTodayPanel();
</script>

<style>
.today-panel {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(168,85,247,0.2);
  border-radius: 14px;
  padding: 1.1em 1em;
  min-width: 0;
}
.tp-header { display:flex; align-items:center; gap:.4em; margin-bottom:.4em; font-size:.7em; }
.tp-label { color:#a855f7; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
.tp-bigdate { font-size:1.35em; font-weight:900; color:#f1f5f9; letter-spacing:.02em; }
.tp-week { font-size:.82em; color:#94a3b8; margin-bottom:.7em; }
.tp-hr { border:none; border-top:1px solid rgba(255,255,255,0.07); margin:.5em 0; }
.tp-row { display:flex; justify-content:space-between; font-size:.75em; color:#e2e8f0; padding:.22em 0; border-bottom:1px solid rgba(255,255,255,0.04); }
.tp-row:last-child { border-bottom:none; }
.k { color:#64748b; }
.hi { color:#c084fc; font-weight:700; }
</style>
