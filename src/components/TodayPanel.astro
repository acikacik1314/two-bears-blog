---
// All computed server-side in Taipei time (UTC+8)
const now = new Date();
const tai = new Date(now.getTime() + (8 * 60 + now.getTimezoneOffset()) * 60000);
const Y = tai.getFullYear(), M = tai.getMonth() + 1, D = tai.getDate();
const weekDay = ['日','一','二','三','四','五','六'][tai.getDay()];

// Days to 2027-01-01
const days2027 = Math.ceil((new Date('2027-01-01').getTime() - now.getTime()) / 86400000);

// Lunar calendar lookup table for 2026-2027
const LUNAR_STARTS: [string, string, string][] = [
  ['2025-01-29', '正月', '2025'],
  ['2025-02-28', '二月', '2025'],
  ['2025-03-29', '三月', '2025'],
  ['2025-04-27', '四月', '2025'],
  ['2025-05-27', '五月', '2025'],
  ['2025-06-25', '六月', '2025'],
  ['2025-07-25', '七月', '2025'],
  ['2025-08-23', '八月', '2025'],
  ['2025-09-22', '九月', '2025'],
  ['2025-10-21', '十月', '2025'],
  ['2025-11-20', '十一月', '2025'],
  ['2025-12-20', '十二月', '2025'],
  ['2026-02-17', '正月', '2026'],
  ['2026-03-19', '二月', '2026'],
  ['2026-04-17', '三月', '2026'],
  ['2026-05-16', '四月', '2026'],
  ['2026-06-15', '五月', '2026'],
  ['2026-07-14', '六月', '2026'],
  ['2026-08-13', '七月', '2026'],
  ['2026-09-11', '八月', '2026'],
  ['2026-10-11', '九月', '2026'],
  ['2026-11-09', '十月', '2026'],
  ['2026-12-09', '十一月', '2026'],
  ['2027-01-07', '十二月', '2026'],
  ['2027-02-06', '正月', '2027'],
];
const LUNAR_D = ['初一','初二','初三','初四','初五','初六','初七','初八','初九','初十','十一','十二','十三','十四','十五','十六','十七','十八','十九','二十','廿一','廿二','廿三','廿四','廿五','廿六','廿七','廿八','廿九','三十'];

let lunarMonth = '—', lunarDay = '—';
const todayStr = `${Y}-${String(M).padStart(2,'0')}-${String(D).padStart(2,'0')}`;
for (let i = LUNAR_STARTS.length - 1; i >= 0; i--) {
  if (todayStr >= LUNAR_STARTS[i][0]) {
    lunarMonth = LUNAR_STARTS[i][1];
    const startMs = new Date(LUNAR_STARTS[i][0]).getTime();
    const dayNum = Math.floor((now.getTime() - startMs) / 86400000);
    lunarDay = LUNAR_D[Math.min(dayNum, 29)];
    break;
  }
}

// Moon phase (known new moon: 2026-06-15 approx)
const knownNewMoon = new Date('2026-06-15').getTime();
const moonCycle = ((now.getTime() - knownNewMoon) / 86400000 % 29.53 + 29.53) % 29.53;
const moonEmoji = moonCycle < 1.5 ? '🌑' : moonCycle < 7 ? '🌒' : moonCycle < 9 ? '🌓' : moonCycle < 13.5 ? '🌔' : moonCycle < 16 ? '🌕' : moonCycle < 20 ? '🌖' : moonCycle < 22 ? '🌗' : moonCycle < 26 ? '🌘' : '🌑';
const moonName = moonCycle < 1.5 ? '新月' : moonCycle < 7 ? '娥眉月' : moonCycle < 9 ? '上弦月' : moonCycle < 13.5 ? '盈凸月' : moonCycle < 16 ? '滿月' : moonCycle < 20 ? '虧凸月' : moonCycle < 22 ? '下弦月' : '殘月';

// Western zodiac
let zodiac = '';
if ((M===3&&D>=21)||(M===4&&D<=19)) zodiac='♈牡羊';
else if ((M===4&&D>=20)||(M===5&&D<=20)) zodiac='♉金牛';
else if ((M===5&&D>=21)||(M===6&&D<=20)) zodiac='♊雙子';
else if ((M===6&&D>=21)||(M===7&&D<=22)) zodiac='♋巨蟹';
else if ((M===7&&D>=23)||(M===8&&D<=22)) zodiac='♌獅子';
else if ((M===8&&D>=23)||(M===9&&D<=22)) zodiac='♍處女';
else if ((M===9&&D>=23)||(M===10&&D<=22)) zodiac='♎天秤';
else if ((M===10&&D>=23)||(M===11&&D<=21)) zodiac='♏天蠍';
else if ((M===11&&D>=22)||(M===12&&D<=21)) zodiac='♐射手';
else if ((M===12&&D>=22)||(M===1&&D<=19)) zodiac='♑摩羯';
else if ((M===1&&D>=20)||(M===2&&D<=18)) zodiac='♒水瓶';
else zodiac='♓雙魚';

// Chinese year (干支)
const STEMS = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
const BRANCHES = ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
const ANIMALS = ['鼠','牛','虎','兔','龍','蛇','馬','羊','猴','雞','狗','豬'];
const stem = STEMS[(Y - 4) % 10];
const branch = BRANCHES[(Y - 4) % 12];
const animal = ANIMALS[(Y - 4) % 12];

// Daily auspicious (simplified rotation)
const AUSPICIOUS = ['開市・出行','祭祀・入宅','結婚・嫁娶','求財・立券','動土・破土','裁衣・開業','出行・移徙','納財・開光','開市・祈福','入宅・搬家','祭祀・開光','嫁娶・開業'];
const auspicious = AUSPICIOUS[(D + M * 3) % AUSPICIOUS.length];
---

<div class="today-panel">
  <div class="tp-header">
    <span>🇹🇼</span>
    <span class="tp-label">台灣時間</span>
  </div>
  <div class="tp-bigdate">{Y}/{String(M).padStart(2,'0')}/{String(D).padStart(2,'0')}</div>
  <div class="tp-week">星期{weekDay}</div>
  <hr class="tp-hr"/>
  <div class="tp-row"><span class="k">農曆</span><span>{lunarMonth}{lunarDay}</span></div>
  <div class="tp-row"><span class="k">距2027</span><span class="hi">還有 {days2027} 天</span></div>
  <div class="tp-row"><span class="k">今日吉日</span><span>{auspicious}</span></div>
  <div class="tp-row"><span class="k">月相</span><span>{moonEmoji} {moonName}</span></div>
  <div class="tp-row"><span class="k">星座</span><span>{zodiac}座</span></div>
  <div class="tp-row"><span class="k">九運年份</span><span>{stem}{branch}年（{animal}年）</span></div>
</div>

<style>
.today-panel {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(168,85,247,0.2);
  border-radius: 14px;
  padding: 1.1em 1em;
  min-width: 0;
}
.tp-header { display:flex; align-items:center; gap:.4em; margin-bottom:.4em; font-size:.7em; }
.tp-label { color:#a855f7; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
.tp-bigdate { font-size:1.35em; font-weight:900; color:#f1f5f9; letter-spacing:.02em; }
.tp-week { font-size:.82em; color:#94a3b8; margin-bottom:.7em; }
.tp-hr { border:none; border-top:1px solid rgba(255,255,255,0.07); margin:.5em 0; }
.tp-row { display:flex; justify-content:space-between; font-size:.75em; color:#e2e8f0; padding:.22em 0; border-bottom:1px solid rgba(255,255,255,0.04); }
.tp-row:last-child { border-bottom:none; }
.k { color:#64748b; }
.hi { color:#c084fc; font-weight:700; }
</style>
