---
// No server-side computation — everything is client-side so the card is always current
---

<div class="today-panel">
  <div class="tp-header">
    <span>🇹🇼</span>
    <span class="tp-label">台灣時間</span>
  </div>
  <div class="tp-bigdate" id="tp-bigdate">—</div>
  <div class="tp-week" id="tp-week">—</div>
  <hr class="tp-hr"/>
  <div class="tp-row"><span class="k">農曆</span><span id="tp-lunar">—</span></div>
  <div class="tp-row"><span class="k">距2027</span><span class="hi" id="tp-days2027">—</span></div>
  <div class="tp-row"><span class="k">今日吉日</span><span id="tp-auspicious">—</span></div>
  <div class="tp-row"><span class="k">月相</span><span id="tp-moon">—</span></div>
  <div class="tp-row"><span class="k">星座</span><span id="tp-zodiac">—</span></div>
  <div class="tp-row"><span class="k">九運年份</span><span id="tp-year">—</span></div>
</div>

<script is:inline>
(function () {
  // ── Taiwan date from Intl (survives any client timezone) ───────
  function twDate() {
    const s = new Date().toLocaleString('sv', { timeZone: 'Asia/Taipei' });
    const [dp] = s.split(' ');
    const [Y, M, D] = dp.split('-').map(Number);
    const dow = new Date(Y, M - 1, D).getDay();
    return { Y, M, D, dow };
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  function initTodayPanel() {
    const { Y, M, D, dow } = twDate();
    const todayStr = `${Y}-${pad(M)}-${pad(D)}`;
    const todayMs  = Date.UTC(Y, M - 1, D);

    // ── Date & weekday ──────────────────────────────────────────
    const bigdate = document.getElementById('tp-bigdate');
    const week    = document.getElementById('tp-week');
    if (bigdate) bigdate.textContent = `${Y}/${pad(M)}/${pad(D)}`;
    if (week)    week.textContent    = `星期${'日一二三四五六'[dow]}`;

    // ── Days to 2027-01-01 ──────────────────────────────────────
    const days2027 = Math.ceil((Date.UTC(2027, 0, 1) - todayMs) / 86400000);
    const d2027El  = document.getElementById('tp-days2027');
    if (d2027El) d2027El.textContent =
      days2027 > 0 ? `還有 ${days2027} 天` : days2027 === 0 ? '就是今天！' : '已到達';

    // ── Lunar via browser Intl (永遠不過期，無需 lookup table) ───
    const lunarEl = document.getElementById('tp-lunar');
    if (lunarEl) {
      try {
        const parts = new Intl.DateTimeFormat('zh-TW-u-ca-chinese', {
          month: 'long', day: 'numeric',
        }).formatToParts(new Date(Y, M - 1, D));
        const mo  = parts.find(p => p.type === 'month')?.value ?? '';
        const da  = parts.find(p => p.type === 'day')?.value  ?? '';
        lunarEl.textContent = mo && da ? mo + da : '—';
      } catch {
        lunarEl.textContent = '—';
      }
    }

    // ── Moon phase (Meeus synodic period) ──────────────────────
    const jd      = todayMs / 86400000 + 2440587.5;
    const phase   = ((jd - 2451550.1) / 29.53058867) % 1;
    const p       = phase < 0 ? phase + 1 : phase;
    const moonEmoji =
      p < 0.03 || p > 0.97 ? '🌑' :
      p < 0.22 ? '🌒' : p < 0.28 ? '🌓' : p < 0.47 ? '🌔' :
      p < 0.53 ? '🌕' : p < 0.72 ? '🌖' : p < 0.78 ? '🌗' : '🌘';
    const moonName =
      p < 0.03 || p > 0.97 ? '新月'  :
      p < 0.22 ? '眉月'  : p < 0.28 ? '上弦月' : p < 0.47 ? '盈凸月' :
      p < 0.53 ? '滿月'  : p < 0.72 ? '虧凸月' : p < 0.78 ? '下弦月' : '殘月';
    const moonEl = document.getElementById('tp-moon');
    if (moonEl) moonEl.textContent = `${moonEmoji} ${moonName}`;

    // ── Western zodiac ──────────────────────────────────────────
    let zodiac = '♓雙魚';
    if      ((M===3&&D>=21)||(M===4&&D<=19))   zodiac = '♈牡羊';
    else if ((M===4&&D>=20)||(M===5&&D<=20))   zodiac = '♉金牛';
    else if ((M===5&&D>=21)||(M===6&&D<=20))   zodiac = '♊雙子';
    else if ((M===6&&D>=21)||(M===7&&D<=22))   zodiac = '♋巨蟹';
    else if ((M===7&&D>=23)||(M===8&&D<=22))   zodiac = '♌獅子';
    else if ((M===8&&D>=23)||(M===9&&D<=22))   zodiac = '♍處女';
    else if ((M===9&&D>=23)||(M===10&&D<=22))  zodiac = '♎天秤';
    else if ((M===10&&D>=23)||(M===11&&D<=21)) zodiac = '♏天蠍';
    else if ((M===11&&D>=22)||(M===12&&D<=21)) zodiac = '♐射手';
    else if ((M===12&&D>=22)||(M===1&&D<=19))  zodiac = '♑摩羯';
    else if ((M===1&&D>=20)||(M===2&&D<=18))   zodiac = '♒水瓶';
    const zodiacEl = document.getElementById('tp-zodiac');
    if (zodiacEl) zodiacEl.textContent = `${zodiac}座`;

    // ── 九運年份（三元九運・下元九運 2024-2044）─────────────────
    // 以立春（約 2/4）為年度分界
    // 九運 = 下元第九運，九紫離火，2024-02-04 起至 2044-02-04
    const LICHUN_MONTH = 2, LICHUN_DAY = 4;
    const lichunPassed  = (M > LICHUN_MONTH) || (M === LICHUN_MONTH && D >= LICHUN_DAY);
    const fengShuiYear  = lichunPassed ? Y : Y - 1;

    let yearText;
    if (fengShuiYear >= 2024 && fengShuiYear < 2044) {
      const nth = fengShuiYear - 2024 + 1; // 1-20
      yearText = `下元九運・第${nth}年`;
    } else if (fengShuiYear >= 2004 && fengShuiYear < 2024) {
      const nth = fengShuiYear - 2004 + 1;
      yearText = `下元八運・第${nth}年`;
    } else if (fengShuiYear >= 2044 && fengShuiYear < 2064) {
      // 上元一運（下一循環）
      const nth = fengShuiYear - 2044 + 1;
      yearText = `上元一運・第${nth}年`;
    } else {
      // Fallback: sexagenary year
      const STEMS    = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
      const BRANCHES = ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
      const ANIMALS  = ['鼠','牛','虎','兔','龍','蛇','馬','羊','猴','雞','狗','豬'];
      yearText = STEMS[(fengShuiYear - 4) % 10] +
                 BRANCHES[(fengShuiYear - 4) % 12] + '年（' +
                 ANIMALS[(fengShuiYear - 4) % 12] + '年）';
    }
    const yearEl = document.getElementById('tp-year');
    if (yearEl) yearEl.textContent = yearText;

    // ── Daily auspicious (十二建除 daily rotation) ───────────────
    // Anchored to lunar day via Intl; fallback: solar-day hash
    const JIANZHU = ['建','除','滿','平','定','執','破','危','成','收','開','閉'];
    const AUSPICIOUS_MAP = {
      '建': '出行・求財', '除': '祭祀・沐浴', '滿': '結婚・嫁娶',
      '平': '開業・立券', '定': '入宅・移徙', '執': '納財・開光',
      '破': '宜靜・勿動', '危': '謹慎・防損', '成': '開市・動土',
      '收': '裁衣・求醫', '開': '開光・祈福', '閉': '安葬・修造',
    };
    let lunarDayNum = 0;
    try {
      const dayParts = new Intl.DateTimeFormat('zh-TW-u-ca-chinese', {
        day: 'numeric',
      }).formatToParts(new Date(Y, M - 1, D));
      const dayStr = dayParts.find(p => p.type === 'day')?.value ?? '';
      const CJK_DAY = ['初一','初二','初三','初四','初五','初六','初七','初八','初九','初十',
                       '十一','十二','十三','十四','十五','十六','十七','十八','十九','二十',
                       '廿一','廿二','廿三','廿四','廿五','廿六','廿七','廿八','廿九','三十'];
      lunarDayNum = CJK_DAY.indexOf(dayStr);
      if (lunarDayNum < 0) lunarDayNum = D - 1;
    } catch {
      lunarDayNum = D - 1;
    }
    const jzKey = JIANZHU[((lunarDayNum % 12) + 12) % 12];
    const auspEl = document.getElementById('tp-auspicious');
    if (auspEl) auspEl.textContent = `${jzKey}日・${AUSPICIOUS_MAP[jzKey]}`;
  }

  initTodayPanel();

  // ── Midnight refresh: schedule re-init at next Taipei midnight ─
  function scheduleMidnight() {
    const { Y, M, D } = twDate();
    // Next midnight UTC = next calendar day in Taipei at 00:00 Taipei = 16:00 UTC previous day
    const nextTaipeiMidnightUTC = Date.UTC(Y, M - 1, D + 1) - 8 * 3600000;
    const ms = nextTaipeiMidnightUTC - Date.now();
    setTimeout(function () {
      initTodayPanel();
      scheduleMidnight();
    }, ms > 0 ? ms : 1000);
  }
  scheduleMidnight();

  // Re-run after Astro view transitions
  document.addEventListener('astro:page-load', initTodayPanel);
})();
</script>

<style>
.today-panel {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(168,85,247,0.2);
  border-radius: 14px;
  padding: 1.1em 1em;
  min-width: 0;
}
.tp-header { display:flex; align-items:center; gap:.4em; margin-bottom:.4em; font-size:.7em; }
.tp-label { color:#a855f7; font-weight:800; letter-spacing:.06em; text-transform:uppercase; }
.tp-bigdate { font-size:1.35em; font-weight:900; color:#f1f5f9; letter-spacing:.02em; }
.tp-week { font-size:.82em; color:#94a3b8; margin-bottom:.7em; }
.tp-hr { border:none; border-top:1px solid rgba(255,255,255,0.07); margin:.5em 0; }
.tp-row { display:flex; justify-content:space-between; font-size:.75em; color:#e2e8f0; padding:.22em 0; border-bottom:1px solid rgba(255,255,255,0.04); }
.tp-row:last-child { border-bottom:none; }
.k { color:#64748b; }
.hi { color:#c084fc; font-weight:700; }
</style>
