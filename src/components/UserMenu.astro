---
// Client-side only — auth state loaded via /api/auth/me
---

<div class="um-root" id="um-root">
  <a href="/api/auth/google" class="um-login" id="um-login" style="display:none">
    <svg class="g-icon" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
      <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
      <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
      <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
    </svg>
    Google 登入
  </a>
  <div class="um-wrap" id="um-wrap" style="display:none">
    <button class="um-btn" id="um-btn" aria-label="帳號選單">
      <img id="um-avatar" class="um-avatar" alt="" referrerpolicy="no-referrer" style="display:none" />
      <span class="um-initial" id="um-initial" style="display:none"></span>
    </button>
    <div class="um-dropdown" id="um-dropdown">
      <div class="um-info">
        <div class="um-name" id="um-name"></div>
        <div class="um-email" id="um-email"></div>
      </div>
      <a href="/api/auth/logout" class="um-logout">登出</a>
    </div>
  </div>
</div>

<script>
  async function initUserMenu() {
    const login = document.getElementById('um-login') as HTMLElement
    const wrap  = document.getElementById('um-wrap')  as HTMLElement

    try {
      const res  = await fetch('/api/auth/me')
      const user = await res.json()

      if (!user?.email) {
        login.style.display = ''
        return
      }

      const avatar  = document.getElementById('um-avatar')  as HTMLImageElement
      const initial = document.getElementById('um-initial') as HTMLElement
      const nameEl  = document.getElementById('um-name')    as HTMLElement
      const emailEl = document.getElementById('um-email')   as HTMLElement

      wrap.style.display  = 'block'
      nameEl.textContent  = user.name
      emailEl.textContent = user.email

      if (user.picture) {
        avatar.src          = user.picture
        avatar.alt          = user.name
        avatar.style.display = 'block'
      } else {
        initial.textContent  = user.name[0] ?? '?'
        initial.style.display = 'flex'
      }
    } catch {
      login.style.display = ''
    }
  }

  initUserMenu()

  const btn = document.getElementById('um-btn')
  const drop = document.getElementById('um-dropdown')
  if (btn && drop) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation()
      drop.classList.toggle('open')
    })
    document.addEventListener('click', () => drop.classList.remove('open'))
  }
</script>

<style>
.um-root { position: relative; display: flex; align-items: center; }

.um-login {
  display: inline-flex; align-items: center; gap: .4em;
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
  color: #e2e8f0; font-size: .78em; font-weight: 600;
  padding: .4em .9em; border-radius: 8px; text-decoration: none;
  transition: background .15s, border-color .15s;
  white-space: nowrap;
}
.um-login:hover { background: rgba(255,255,255,.1); border-color: rgba(168,85,247,.4); color: #e2e8f0; }
.g-icon { width: 16px; height: 16px; flex-shrink: 0; }

.um-wrap { position: relative; }
.um-btn {
  background: none; border: none; cursor: pointer; padding: 0;
  display: flex; align-items: center;
}
.um-avatar {
  width: 32px; height: 32px; border-radius: 50%;
  border: 2px solid rgba(168,85,247,.4);
  object-fit: cover;
}
.um-initial {
  width: 32px; height: 32px; border-radius: 50%;
  background: linear-gradient(135deg,#7e22ce,#a855f7);
  color: white; font-size: .85em; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

.um-dropdown {
  display: none; position: absolute; right: 0; top: calc(100% + 8px);
  background: #1e1b2e; border: 1px solid rgba(168,85,247,.25);
  border-radius: 10px; padding: .5em; min-width: 180px; z-index: 200;
  box-shadow: 0 8px 24px rgba(0,0,0,.4);
}
.um-dropdown.open { display: block; }

.um-info { padding: .4em .6em .5em; border-bottom: 1px solid rgba(255,255,255,.07); margin-bottom: .3em; }
.um-name { font-size: .82em; font-weight: 700; color: #e2e8f0; }
.um-email { font-size: .7em; color: #64748b; margin-top: .1em; }

.um-logout {
  display: block; padding: .4em .6em; font-size: .78em; color: #f87171;
  text-decoration: none; border-radius: 6px; transition: background .15s;
}
.um-logout:hover { background: rgba(239,68,68,.1); }
</style>
