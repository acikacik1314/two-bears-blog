---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RumbleEmbed from '../components/RumbleEmbed.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { getCollection } from 'astro:content';
import { getPostCategory, CATEGORY_COLORS } from '../utils/category';
import NewsletterSubscribe from '../components/NewsletterSubscribe.astro';
import AffiliateLinks from '../components/AffiliateLinks.astro';
import PredictionCheck from '../components/PredictionCheck.astro';
import CommentSection from '../components/CommentSection.astro';
import { getProphetConfig } from '../utils/prophets';
import ArmstrongPiCycleCalculator from '../components/ArmstrongPiCycleCalculator.astro';
import RelatedTools from '../components/RelatedTools.astro';
import AdSlot from '../components/AdSlot.astro';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, tags, category, youtubePost, rumbleId, rumblePage, youtubeId, predictions, prophet } = Astro.props;
const prophetConfig = prophet ? getProphetConfig(prophet) : null;
const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);

// Related posts: shared tags only (same prophet/topic), exclude current page
const currentSlug = Astro.url.pathname;
const allPosts = (await getCollection('blog')).filter(p => !p.data.draft);
const related = allPosts
	.filter(p => {
		const slug = `/blog/${p.id.replace(/\.mdx?$/, '')}/`;
		if (slug === currentSlug) return false;
		return tags?.some(t => p.data.tags?.includes(t));
	})
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

function getThumb(post: CollectionEntry<'blog'>): string | null {
	if (post.data.youtubeId) return `https://img.youtube.com/vi/${post.data.youtubeId}/mqdefault.jpg`;
	if (post.data.heroImage) {
		const h = post.data.heroImage as any;
		return typeof h === 'string' ? h : h?.src ?? null;
	}
	return null;
}
// Derive category for display (re-derive since we only have data fields here)
const derivedCategory = category ?? (() => {
	if (rumbleId || youtubeId) return '影片';
	const prophecyKw = ['預言','比格斯','末日','台海','三戰','諾查丹瑪斯'];
	if (tags?.some((t: string) => prophecyKw.some(k => t.includes(k)))) return '預言';
	return null;
})();
const catColor = derivedCategory ? (CATEGORY_COLORS[derivedCategory] ?? '#7f8c8d') : null;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* Reading progress bar */
			#reading-progress {
				position: fixed;
				top: 0;
				left: 0;
				width: 0%;
				height: 3px;
				background: linear-gradient(90deg, var(--accent), #ff6b6b);
				z-index: 9999;
				transition: width 0.1s linear;
			}
			/* Reading time */
			.reading-meta {
				display: flex;
				align-items: center;
				gap: 1em;
				font-size: 0.82em;
				color: rgb(var(--gray));
				margin-bottom: 0.5em;
				flex-wrap: wrap;
			}
			.reading-meta span { display: flex; align-items: center; gap: 0.3em; }
			/* Share buttons */
			.share-section {
				margin: 2em 0 1em;
				padding: 1.2em;
				background: rgb(var(--gray-light), 0.4);
				border-radius: 12px;
				text-align: center;
			}
			.share-label {
				font-size: 0.85em;
				font-weight: 700;
				color: rgb(var(--gray));
				margin-bottom: 0.8em;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.share-buttons { display: flex; gap: 0.6em; justify-content: center; flex-wrap: wrap; }
			.share-btn {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.5em 1.1em;
				border-radius: 20px;
				font-size: 0.85em;
				font-weight: 700;
				text-decoration: none;
				color: white;
				border: none;
				cursor: pointer;
				transition: opacity 0.15s, transform 0.15s;
			}
			.share-btn:hover { opacity: 0.85; transform: translateY(-1px); color: white; }
			.share-line { background: #00b900; }
			.share-fb { background: #1877f2; }
			.share-x { background: #000; }
			.share-copy { background: rgb(var(--gray)); }
			.share-copy.copied { background: #27ae60; }
			/* Related posts */
			.related-posts {
				margin: 2.5em 0 1em;
				border-top: 1px solid rgb(var(--gray-light));
				padding-top: 1.5em;
			}
			.related-heading {
				font-size: 0.9em;
				font-weight: 700;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.05em;
				margin: 0 0 1em;
			}
			.related-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 0.8em;
			}
			.related-card {
				display: block;
				text-decoration: none;
				border-radius: 10px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				transition: transform 0.15s, box-shadow 0.15s;
				background: white;
			}
			.related-card:hover { transform: translateY(-3px); box-shadow: 0 4px 16px rgba(0,0,0,0.1); }
			.related-thumb {
				width: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
				display: block;
				background: rgb(var(--gray-light));
			}
			.related-thumb-placeholder {
				width: 100%;
				aspect-ratio: 16/9;
				background: linear-gradient(135deg, rgb(var(--gray-light)), rgb(var(--gray-light)));
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2em;
			}
			.related-info { padding: 0.6em 0.8em 0.8em; }
			.related-title {
				font-size: 0.82em;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				line-height: 1.4;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
		</style>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"datePublished": pubDate?.toISOString?.() ?? pubDate,
			"dateModified": updatedDate?.toISOString?.() ?? updatedDate ?? pubDate?.toISOString?.() ?? pubDate,
			"author": {
				"@type": "Person",
				"name": "兩隻大熊",
				"url": "https://twobears.vercel.app/about"
			},
			"publisher": {
				"@type": "Organization",
				"name": "兩隻大熊號",
				"url": "https://twobears.vercel.app",
				"logo": {
					"@type": "ImageObject",
					"url": "https://twobears.vercel.app/favicon.svg"
				}
			},
			"mainEntityOfPage": {
				"@type": "WebPage",
				"@id": Astro.url.href
			},
			...(heroImage ? { "image": new URL(heroImage.src ?? heroImage, Astro.site).href } : {})
		})} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				box-sizing: border-box;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: 100%;
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
				box-sizing: border-box;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			/* Prophet banner */
			.prophet-banner {
				display: flex;
				align-items: flex-start;
				gap: 1em;
				padding: 1.1em 1.3em;
				border: 1.5px solid;
				border-radius: 14px;
				margin: 0 0 1.6em;
			}
			.prophet-avatar {
				width: 68px;
				height: 68px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
				border: 2px solid currentColor;
			}
			.prophet-info { flex: 1; min-width: 0; }
			.prophet-name {
				font-size: 0.9em;
				font-weight: 800;
				margin-bottom: 0.3em;
			}
			.prophet-bio {
				font-size: 0.8em;
				color: rgb(var(--gray));
				line-height: 1.55;
				margin-bottom: 0.5em;
			}
			.prophet-chips { display: flex; flex-wrap: wrap; gap: 0.35em; }
			.prophet-chip {
				font-size: 0.7em;
				font-weight: 700;
				border: 1px solid;
				border-radius: 4px;
				padding: 0.1em 0.5em;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin-top: 0.8em;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.2em 0.7em;
				border-radius: 20px;
				font-size: 0.8em;
				text-decoration: none;
			}
			.youtube-link {
				display: block;
				text-align: center;
				margin: 2em 0 1em;
			}
			.youtube-btn {
				display: inline-block;
				background: #ff0000;
				color: white;
				padding: 0.7em 1.5em;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 700;
				font-size: 1em;
			}
			.youtube-btn:hover {
				background: #cc0000;
				color: white;
			}
			.rumble-watch-link {
				display: block;
				text-align: center;
				margin: 1em 0 2em;
			}
			.rumble-watch-btn {
				display: inline-block;
				background: #85c742;
				color: white;
				padding: 0.7em 1.5em;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 700;
				font-size: 1em;
			}
			.rumble-watch-btn:hover {
				background: #6aad27;
				color: white;
			}
		<style>
			@media (max-width: 640px) {
				.prose {
					padding-left: 0;
					padding-right: 0;
					width: 100%;
				}
			}
			.kofi-whisper {
				margin: 2.2em 0 0.5em;
				padding-top: 1.6em;
				border-top: 1px solid rgb(var(--gray-light));
				text-align: center;
				font-size: 0.83em;
				color: rgb(var(--gray));
				line-height: 1.8;
			}
			.kofi-whisper a {
				color: rgb(var(--gray));
				text-decoration: underline;
				text-underline-offset: 3px;
				text-decoration-color: rgba(128,128,128,0.35);
				transition: color 0.15s, text-decoration-color 0.15s;
			}
			.kofi-whisper a:hover {
				color: rgb(var(--gray-dark));
				text-decoration-color: rgba(128,128,128,0.7);
			}
		</style>
	<style>
		/* π 週期浮動按鈕 */
		.pi-float-btn {
			position: fixed;
			bottom: 24px;
			right: 24px;
			z-index: 999;
			background: #1a1a2e;
			color: #eab308;
			border: 2px solid rgba(234, 179, 8, 0.4);
			border-radius: 50px;
			padding: 10px 16px;
			font-size: 17px;
			font-weight: 900;
			cursor: pointer;
			display: flex;
			align-items: center;
			gap: 6px;
			box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
			transition: transform 0.15s, box-shadow 0.15s;
			font-family: inherit;
			line-height: 1;
		}
		.pi-float-btn .pi-btn-label {
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.05em;
			opacity: 0.75;
		}
		.pi-float-btn:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 28px rgba(0, 0, 0, 0.3);
			border-color: rgba(234, 179, 8, 0.7);
		}
		/* π 週期 Modal */
		.pi-modal {
			border: none;
			border-radius: 16px;
			padding: 0;
			max-width: min(740px, calc(100vw - 32px));
			width: 100%;
			box-shadow: 0 24px 64px rgba(0, 0, 0, 0.3);
			background: #fff;
		}
		.pi-modal::backdrop {
			background: rgba(0, 0, 0, 0.5);
			backdrop-filter: blur(3px);
		}
		.pi-modal-header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 1rem 1.5rem;
			border-bottom: 1px solid #eadfc8;
			gap: 1rem;
		}
		.pi-modal-title {
			font-size: 0.95rem;
			font-weight: 800;
			color: #3B2A1E;
			margin: 0;
		}
		.pi-modal-subtitle {
			font-size: 0.75rem;
			color: #5C4A35;
			margin: 2px 0 0;
			font-weight: 400;
		}
		.pi-modal-close {
			background: none;
			border: none;
			font-size: 1.1rem;
			color: #5C4A35;
			cursor: pointer;
			padding: 4px 8px;
			border-radius: 6px;
			line-height: 1;
			flex-shrink: 0;
			transition: background 0.1s;
		}
		.pi-modal-close:hover { background: #f4f0e8; }
		.pi-modal-body {
			padding: 1.5rem;
			overflow-y: auto;
			max-height: 80dvh;
		}
		@media (max-width: 640px) {
			.pi-float-btn { bottom: 16px; right: 16px; padding: 9px 13px; }
			.pi-modal-body { padding: 1rem; }
		}
	</style>
	</head>

	<body>
		<div id="reading-progress"></div>
		<Header />
		<main>
			<article>
				{!prophet && (
					<div class="hero-image">
						{heroImage && (
							typeof heroImage === 'string'
								? <img src={heroImage} alt="" width={1020} height={510} style="width:100%;height:auto;border-radius:12px;" />
								: <Image width={1020} height={510} src={heroImage} alt="" />
						)}
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										更新於 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{derivedCategory && catColor && (
							<div style="margin-bottom: 0.5em;">
								<a href={`/category/${derivedCategory}`}
								   style={`display:inline-block;background:${catColor};color:white;padding:0.2em 0.8em;border-radius:12px;font-size:0.8em;font-weight:700;text-decoration:none;`}>
									{derivedCategory}
								</a>
							</div>
						)}
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => <span class="tag">#{tag}</span>)}
							</div>
						)}
						<div class="reading-meta">
							<span id="reading-time">⏱ 計算中…</span>
						</div>
						<hr />
					</div>

					{prophetConfig && (
						<div class="prophet-banner" style={`border-color:${prophetConfig.color};background:${prophetConfig.bg}`}>
							<img class="prophet-avatar" src={prophetConfig.image} alt={prophetConfig.label} />
							<div class="prophet-info">
								<div class="prophet-name" style={`color:${prophetConfig.color}`}>
									{prophetConfig.icon} {prophetConfig.en}（{prophetConfig.label}）
								</div>
								<div class="prophet-bio">{prophetConfig.bio}</div>
								<div class="prophet-chips">
									{prophetConfig.tags.map(t => (
										<span class="prophet-chip" style={`border-color:${prophetConfig!.color}40;color:${prophetConfig!.color}`}>{t}</span>
									))}
								</div>
							</div>
						</div>
					)}

					{rumbleId && <RumbleEmbed videoId={rumbleId} title={title} />}
					{rumblePage && (
						<div class="rumble-watch-link">
							<a href={rumblePage} target="_blank" rel="noopener" class="rumble-watch-btn">
								▶ 在 Rumble 觀看影片
							</a>
						</div>
					)}
					{youtubeId && <YouTubeEmbed videoId={youtubeId} title={title} />}
					<slot />
					<AdSlot slot="" />
					{predictions && (
						<PredictionCheck
							hits={predictions.hits}
							misses={predictions.misses}
							pending={predictions.pending}
						/>
					)}
					{youtubePost && (
						<div class="youtube-link">
							<a href={youtubePost} target="_blank" rel="noopener" class="youtube-btn">
								▶ 在 YouTube 閱讀完整文章
							</a>
						</div>
					)}
					<AffiliateLinks />

					<p class="kofi-whisper">
						感謝你讀到這裡。如果這篇有幫到你，歡迎<a href="https://ko-fi.com/twobear2" target="_blank" rel="noopener">請兩隻熊喝杯咖啡 ☕</a>，讓我們繼續寫。
					</p>

					<!-- Share buttons -->
					<div class="share-section">
						<div class="share-label">覺得有幫助？分享給朋友！</div>
						<div class="share-buttons">
							<a href={`https://line.me/R/msg/text/?${encodedTitle}%0A${encodedUrl}`} target="_blank" rel="noopener" class="share-btn share-line">LINE</a>
							<a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener" class="share-btn share-fb">Facebook</a>
							<a href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener" class="share-btn share-x">X / Twitter</a>
							<button class="share-btn share-copy" id="copy-link-btn" data-url={pageUrl}>🔗 複製連結</button>
						</div>
					</div>

					<AdSlot slot="" />
					<RelatedTools category={category} tags={tags} prophet={prophet} />

					<CommentSection slug={Astro.url.pathname} />

					<NewsletterSubscribe />

					<!-- Related posts -->
					{related.length > 0 && (
						<div class="related-posts">
							<div class="related-heading">✦ 你可能也喜歡</div>
							<div class="related-grid">
								{related.map(post => {
									const thumb = getThumb(post);
									const postSlug = `/blog/${post.id.replace(/\.mdx?$/, '')}/`;
									return (
										<a href={postSlug} class="related-card">
											{thumb
												? <img src={thumb} alt={post.data.title} class="related-thumb" loading="lazy" />
												: <div class="related-thumb-placeholder">📄</div>
											}
											<div class="related-info">
												<div class="related-title">{post.data.title}</div>
											</div>
										</a>
									);
								})}
							</div>
						</div>
					)}

					<!-- Comments (Giscus) — enable after installing app at github.com/apps/giscus -->
					<div class="giscus-wrap" style="margin: 2em 0; display: none;">
						<script src="https://giscus.app/client.js"
							data-repo="acikacik1314/two-bears-blog"
							data-repo-id="R_kgDOSm-zaA"
							data-category="General"
							data-category-id="DIC_kwDOOzluJM4CrS8Q"
							data-mapping="pathname"
							data-strict="0"
							data-reactions-enabled="1"
							data-emit-metadata="0"
							data-input-position="top"
							data-theme="light"
							data-lang="zh-TW"
							crossorigin="anonymous"
							async>
						</script>
					</div>
				</div>
			</article>
		</main>
		<Footer />

		<!-- π 週期計算器浮動按鈕 -->
		<button id="pi-calc-trigger" class="pi-float-btn" type="button" aria-label="開啟馬丁阿姆斯壯 π 週期計算器">
			π<span class="pi-btn-label">週期</span>
		</button>

		<!-- π 週期計算器 Modal -->
		<dialog id="pi-calc-modal" class="pi-modal">
			<div class="pi-modal-header">
				<div>
					<p class="pi-modal-title">馬丁阿姆斯壯 π 週期計算器</p>
					<p class="pi-modal-subtitle">8.6 年週期（3141 天）· 錨點 1987/10/19</p>
				</div>
				<button id="pi-calc-close" type="button" class="pi-modal-close" aria-label="關閉">✕</button>
			</div>
			<div class="pi-modal-body">
				<ArmstrongPiCycleCalculator />
			</div>
		</dialog>

		<script>
			const trigger = document.getElementById('pi-calc-trigger');
			const modal = document.getElementById('pi-calc-modal') as HTMLDialogElement | null;
			const closeBtn = document.getElementById('pi-calc-close');
			if (trigger && modal) {
				trigger.addEventListener('click', () => modal.showModal());
				closeBtn?.addEventListener('click', () => modal.close());
				modal.addEventListener('click', (e) => {
					const rect = modal.getBoundingClientRect();
					const inDialog =
						e.clientX >= rect.left && e.clientX <= rect.right &&
						e.clientY >= rect.top  && e.clientY <= rect.bottom;
					if (!inDialog) modal.close();
				});
			}
		</script>
	</body>
	<script define:vars={{ slug: Astro.url.pathname }}>
		// View tracking
		fetch('/api/view', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ slug }),
			keepalive: true,
		}).catch(() => {});

		// Reading progress bar
		const bar = document.getElementById('reading-progress');
		const article = document.querySelector('article');
		if (bar && article) {
			window.addEventListener('scroll', () => {
				const rect = article.getBoundingClientRect();
				const total = article.offsetHeight - window.innerHeight;
				const scrolled = Math.max(0, -rect.top);
				bar.style.width = Math.min(100, (scrolled / total) * 100) + '%';
			}, { passive: true });
		}

		// Reading time estimate
		const prose = document.querySelector('.prose');
		const rtEl = document.getElementById('reading-time');
		if (prose && rtEl) {
			const text = prose.innerText || prose.textContent || '';
			const words = text.trim().split(/\s+/).length;
			const mins = Math.max(1, Math.round(words / 400));
			rtEl.innerHTML = `⏱ 約 ${mins} 分鐘閱讀 · <a href="https://ko-fi.com/twobear2" target="_blank" rel="noopener" style="color:inherit;opacity:0.45;text-decoration:none;transition:opacity 0.2s" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.45'" title="喜歡的話，歡迎請兩隻熊喝杯咖啡">☕</a>`;
		}

		// Copy link button
		const copyBtn = document.getElementById('copy-link-btn');
		if (copyBtn) {
			copyBtn.addEventListener('click', () => {
				const url = copyBtn.dataset.url;
				navigator.clipboard.writeText(url).then(() => {
					copyBtn.textContent = '✓ 已複製！';
					copyBtn.classList.add('copied');
					setTimeout(() => {
						copyBtn.textContent = '🔗 複製連結';
						copyBtn.classList.remove('copied');
					}, 2000);
				}).catch(() => {
					prompt('複製這個連結：', url);
				});
			});
		}
	</script>
</html>
