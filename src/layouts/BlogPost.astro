---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RumbleEmbed from '../components/RumbleEmbed.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { getPostCategory, CATEGORY_COLORS } from '../utils/category';
import NewsletterSubscribe from '../components/NewsletterSubscribe.astro';
import AffiliateLinks from '../components/AffiliateLinks.astro';
import PredictionCheck from '../components/PredictionCheck.astro';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, tags, category, youtubePost, rumbleId, rumblePage, youtubeId, predictions } = Astro.props;
// Derive category for display (re-derive since we only have data fields here)
const derivedCategory = category ?? (() => {
	if (rumbleId || youtubeId) return '影片';
	const prophecyKw = ['預言','比格斯','末日','台海','三戰','諾查丹瑪斯'];
	if (tags?.some((t: string) => prophecyKw.some(k => t.includes(k)))) return '預言';
	return null;
})();
const catColor = derivedCategory ? (CATEGORY_COLORS[derivedCategory] ?? '#7f8c8d') : null;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin-top: 0.8em;
			}
			.tag {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				padding: 0.2em 0.7em;
				border-radius: 20px;
				font-size: 0.8em;
				text-decoration: none;
			}
			.youtube-link {
				display: block;
				text-align: center;
				margin: 2em 0 1em;
			}
			.youtube-btn {
				display: inline-block;
				background: #ff0000;
				color: white;
				padding: 0.7em 1.5em;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 700;
				font-size: 1em;
			}
			.youtube-btn:hover {
				background: #cc0000;
				color: white;
			}
			.rumble-watch-link {
				display: block;
				text-align: center;
				margin: 1em 0 2em;
			}
			.rumble-watch-btn {
				display: inline-block;
				background: #85c742;
				color: white;
				padding: 0.7em 1.5em;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 700;
				font-size: 1em;
			}
			.rumble-watch-btn:hover {
				background: #6aad27;
				color: white;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										更新於 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{derivedCategory && catColor && (
							<div style="margin-bottom: 0.5em;">
								<a href={`/category/${derivedCategory}`}
								   style={`display:inline-block;background:${catColor};color:white;padding:0.2em 0.8em;border-radius:12px;font-size:0.8em;font-weight:700;text-decoration:none;`}>
									{derivedCategory}
								</a>
							</div>
						)}
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => <span class="tag">#{tag}</span>)}
							</div>
						)}
						<hr />
					</div>
					{rumbleId && <RumbleEmbed videoId={rumbleId} title={title} />}
					{rumblePage && (
						<div class="rumble-watch-link">
							<a href={rumblePage} target="_blank" rel="noopener" class="rumble-watch-btn">
								▶ 在 Rumble 觀看影片
							</a>
						</div>
					)}
					{youtubeId && <YouTubeEmbed videoId={youtubeId} title={title} />}
					<slot />
					{predictions && (
						<PredictionCheck
							hits={predictions.hits}
							misses={predictions.misses}
							pending={predictions.pending}
						/>
					)}
					{youtubePost && (
						<div class="youtube-link">
							<a href={youtubePost} target="_blank" rel="noopener" class="youtube-btn">
								▶ 在 YouTube 閱讀完整文章
							</a>
						</div>
					)}
					<AffiliateLinks />
					<NewsletterSubscribe />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
