---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/BlogPost.astro';

const entry = await getEntry('about', 'about');
const { Content } = entry ? await render(entry) : { Content: null };
const title = entry?.data.title ?? '關於兩隻熊的旅遊記事';
const description = entry?.data.description ?? '探索未來預言家的洞見';
const youtubeUrl = entry?.data.youtubeUrl;
---

<Layout title={title} description={description} pubDate={new Date('2026-05-22')}>
	{Content && <Content />}
	{youtubeUrl && (
		<div style="text-align:center; margin: 2em 0;">
			<a href={youtubeUrl} target="_blank" rel="noopener"
			   style="display:inline-block;background:#ff0000;color:white;padding:0.7em 1.5em;border-radius:6px;text-decoration:none;font-weight:700;">
				▶ 訂閱 YouTube 頻道
			</a>
		</div>
	)}
</Layout>
