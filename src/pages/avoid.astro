// ── 日期預設 ──────────────────────────────────────────────────
function offsetDate(days) {
  const d = new Date()
  d.setDate(d.getDate() + days)
  return d.toISOString().split('T')[0]
}
document.getElementById('checkIn').value = offsetDate(7)
document.getElementById('checkOut').value = offsetDate(10)

// ── 痛點 checkbox 樣式 ────────────────────────────────────────
document.querySelectorAll('.pain-item').forEach(item => {
  const cb = item.querySelector('input')
  cb.addEventListener('change', () => {
    item.classList.toggle('selected', cb.checked)
  })
})

// ── 取得 Agoda 篩選參數 ───────────────────────────────────────
const JAPAN_CITIES = new Set(['東京','大阪','京都','福岡','沖繩','北海道','箱根'])

function getAgodaFilter(pains, city) {
  const params = ['sort=popularity']
  // 桑拿/浴池設施只有日本或選了五星級（行李箱痛點）時才篩選
  const isJapan = JAPAN_CITIES.has(city)
  const isLuxury = pains.includes('luggage')
  if (isJapan || isLuxury) {
    params.push('roomAmenities=31')
  }
  if (pains.includes('noise') || pains.includes('bed') || pains.includes('female')) {
    params.push('hotelReviewScore=9')
  } else {
    params.push('hotelReviewScore=8')
  }
  if (isLuxury) {
    params.push('hotelStarRating=4')
  }
  if (pains.includes('elderly')) {
    params.push('hotelFacility=91')
  }
  return '&' + [...new Set(params)].join('&')
}

function getBookingNflt(pains) {
  const nflt = []
  if (pains.includes('noise') || pains.includes('female')) {
    nflt.push('review_score%3D90')
  } else {
    nflt.push('review_score%3D80')
  }
  if (pains.includes('luggage')) nflt.push('class%3D4')
  if (pains.includes('elderly')) nflt.push('hotelfacility%3D433')
  return nflt.join('%3B')
}

// ── 主分析函式 ────────────────────────────────────────────────
function analyze() {
  const city = document.getElementById('citySelect').value
  const checkIn = document.getElementById('checkIn').value || offsetDate(7)
  const checkOut = document.getElementById('checkOut').value || offsetDate(10)
  const adults = document.getElementById('adults').value
  const rooms = document.getElementById('rooms').value

  const selectedPains = [...document.querySelectorAll('.pain-cb:checked')].map(cb => cb.value)

  let zones = AVOID_DATA.filter(z => z.city === city)

  if (zones.length === 0) {
    document.getElementById('resultsList').innerHTML =
      '<div class="no-result">這個城市的避雷資料正在建置中，敬請期待 🐻</div>'
    document.getElementById('resultsSection').style.display = 'block'
    document.getElementById('resultsSection').scrollIntoView({behavior:'smooth'})
    return
  }

  zones = zones.map(z => {
    let score = 0
    if (selectedPains.length === 0) {
      score = Object.values(z.scores).reduce((a,b)=>a+b,0) / 8
    } else {
      selectedPains.forEach(p => { score += z.scores[p] || 0 })
      score = score / selectedPains.length
    }
    return {...z, score}
  }).sort((a,b) => b.score - a.score)

  const agodaId = AGODA_IDS[city] || 5085
  const cityEn = CITY_EN[city] || city
  const agodaFilter = getAgodaFilter(selectedPains, city)
  const bookingNflt = getBookingNflt(selectedPains)

  const html = zones.map((z, i) => {
    const dangerLevel = z.score >= 3.5 ? 'high' : z.score >= 2.5 ? 'mid' : 'low'
    const dangerText = dangerLevel === 'high' ? '⚠️ 高危區域' : dangerLevel === 'mid' ? '⚡ 中等風險' : '💡 輕微注意'
    const badgeClass = `badge-${dangerLevel}`

    const painDisplay = selectedPains.length > 0
      ? selectedPains.map(p => {
          const s = z.scores[p]
          const dots = ['','●','●●','●●●','●●●●','●●●●●'][s]
          return `<span class="score-chip score-${s}">${PAIN_LABELS[p]} ${dots}</span>`
        }).join('')
      : Object.entries(z.scores).map(([p, s]) => {
          if (s >= 4) return `<span class="score-chip score-${s}">${PAIN_LABELS[p]} ${'●'.repeat(s)}</span>`
          return ''
        }).join('')

    const agodaUrl = `https://www.agoda.com/zh-tw/search?city=${agodaId}&checkIn=${checkIn}&checkOut=${checkOut}&rooms=${rooms}&adults=${adults}&locale=zh-tw&currency=TWD${agodaFilter}&productType=-1`
    const agodaFinal = `${AGODA_TRACKING}?t=${encodeURIComponent(encodeURIComponent(agodaUrl))}`
    const bookingBase = `https://www.booking.com/searchresults.zh-tw.html?ss=${encodeURIComponent(cityEn)}&checkin=${checkIn}&checkout=${checkOut}&group_adults=${adults}&no_rooms=${rooms}&nflt=${bookingNflt}`
    const bookingUrl = `${BOOKING_TRACKING}?t=${encodeURIComponent(encodeURIComponent(bookingBase))}`

    return `
      <div class="result-card danger-${dangerLevel}">
        <div class="card-header">
          <div class="card-zone">${i+1}. ${z.zone}</div>
          <div class="card-tagline">${z.tagline}</div>
          <span class="danger-badge ${badgeClass}">${dangerText}</span>
        </div>
        ${painDisplay ? `<div class="pain-scores-row">${painDisplay}</div>` : ''}
        <div class="card-body">
          <div class="verdict-block">
            <strong>🐻 兩隻熊實判定</strong>
            <p>${z.verdict}</p>
          </div>
          <div class="defense-block">
            <strong>🛡️ 防禦建議</strong>
            <p>${z.defense}</p>
          </div>
        </div>
        <div class="card-footer">
          <a href="${agodaFinal}" target="_blank" rel="sponsored nofollow noopener" class="book-btn agoda-btn">
            🔍 Agoda 搜尋安全替代方案
          </a>
          <a href="${bookingUrl}" target="_blank" rel="sponsored nofollow noopener" class="book-btn booking-btn">
            🔍 Booking 搜尋安全替代方案
          </a>
        </div>
      </div>
    `
  }).join('')

  const painSummary = selectedPains.length > 0
    ? `依照你選的 ${selectedPains.map(p=>PAIN_LABELS[p]).join('、')} 排序`
    : '依綜合危險指數排序'

  document.getElementById('resultsTitle').textContent = `🎯 ${city} 的危險區域排行（共 ${zones.length} 個）`
  document.getElementById('resultsSub').textContent = `${painSummary} · 紅色邊框 = 高危，黃色 = 中等，綠色 = 輕微注意`
  document.getElementById('resultsList').innerHTML = html
  document.getElementById('resultsSection').style.display = 'block'
  document.getElementById('resultsSection').scrollIntoView({behavior:'smooth',block:'start'})
}
</script>
</body>
</html>
