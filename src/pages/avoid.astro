---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-TW">
<head>
  <BaseHead title="不踩雷比便宜更重要 | 兩隻熊出國避痛大腦" description="設定行程、勾選最怕的痛苦，兩隻熊幫你診斷哪些區域要遠離，並搜尋安全替代方案。" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500&family=Noto+Serif+TC:wght@400;600&display=swap" rel="stylesheet">
  <style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1816;--ink2:#4a4540;--ink3:#8a827a;
  --paper:#f7f4ef;--paper2:#ede9e2;--paper3:#e4dfd6;
  --gold:#b8960c;--gold2:#d4aa20;
  --red:#8b2020;--red2:#c0392b;
  --green:#2a5a3a;
  --warn:#faeeda;--warn-text:#854f0b;
  --radius:4px;--shadow:0 1px 8px rgba(26,24,22,.08);
}
body{background:var(--paper);color:var(--ink);font-family:'Noto Sans TC',sans-serif;font-weight:300;line-height:1.7}

/* HERO */
.hero{background:var(--ink);color:var(--paper);padding:3.5rem 2rem 3rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 30% 50%,rgba(139,32,32,.15) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 80% 30%,rgba(184,150,12,.10) 0%,transparent 70%);pointer-events:none}
.hero-eyebrow{font-size:11px;letter-spacing:.25em;color:rgba(184,150,12,.8);margin-bottom:1rem;text-transform:uppercase}
.hero h1{font-family:'Noto Serif TC',serif;font-weight:400;font-size:clamp(1.6rem,4vw,2.4rem);line-height:1.4;max-width:600px;margin:0 auto .75rem}
.hero h1 em{font-style:normal;color:var(--gold2)}
.hero-sub{font-size:13px;color:rgba(247,244,239,.6);max-width:440px;margin:0 auto}

/* MAIN */
.main{max-width:780px;margin:0 auto;padding:2rem 1.5rem}

/* FORM CARD */
.form-card{background:var(--paper);border:.5px solid var(--paper3);border-radius:var(--radius);padding:1.5rem;margin-bottom:1.5rem;box-shadow:var(--shadow)}
.form-card h2{font-family:'Noto Serif TC',serif;font-size:14px;font-weight:400;color:var(--ink3);letter-spacing:.15em;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:.5px solid var(--paper3)}

.form-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:1rem}
.form-group{display:flex;flex-direction:column;gap:5px;flex:1;min-width:130px}
.form-group label{font-size:11px;color:var(--ink3)}
.form-group select,.form-group input{font-size:13px;padding:8px 10px;border:.5px solid var(--paper3);border-radius:var(--radius);background:var(--paper);color:var(--ink);font-family:'Noto Sans TC',sans-serif;font-weight:300}
.form-group select:focus,.form-group input:focus{outline:none;border-color:var(--gold)}
.form-group input[type="date"]{width:100%}

/* PAIN GRID */
.pain-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;margin-bottom:1.25rem}
.pain-item{display:flex;align-items:center;gap:8px;padding:10px 12px;border:.5px solid var(--paper3);border-radius:var(--radius);cursor:pointer;transition:all .15s;background:var(--paper)}
.pain-item:hover{border-color:var(--gold);background:#fffbee}
.pain-item.selected{border-color:var(--red);background:rgba(139,32,32,.05)}
.pain-item input[type="checkbox"]{width:14px;height:14px;cursor:pointer;accent-color:var(--red2)}
.pain-label{font-size:12px;color:var(--ink2);line-height:1.3}
.pain-emoji{font-size:16px;flex-shrink:0}

.analyze-btn{width:100%;padding:13px;background:var(--ink);color:var(--paper);border:none;border-radius:var(--radius);font-size:14px;font-family:'Noto Sans TC',sans-serif;font-weight:500;cursor:pointer;transition:all .2s;letter-spacing:.05em}
.analyze-btn:hover{background:var(--red2)}
.analyze-btn:active{transform:scale(.99)}

/* RESULTS */
#resultsSection{display:none;margin-top:2rem}
.results-title{font-family:'Noto Serif TC',serif;font-size:15px;font-weight:400;color:var(--ink);margin-bottom:.5rem}
.results-sub{font-size:12px;color:var(--ink3);margin-bottom:1.5rem}

.result-card{background:var(--paper);border:.5px solid var(--paper3);border-radius:var(--radius);overflow:hidden;margin-bottom:1.25rem;box-shadow:var(--shadow)}
.result-card.danger-high{border-left:3px solid var(--red2)}
.result-card.danger-mid{border-left:3px solid var(--gold)}
.result-card.danger-low{border-left:3px solid var(--green)}

.card-header{padding:1rem 1.25rem .75rem;border-bottom:.5px solid var(--paper3);background:var(--paper2)}
.card-zone{font-family:'Noto Serif TC',serif;font-size:16px;font-weight:400;color:var(--ink);margin-bottom:3px}
.card-tagline{font-size:12px;color:var(--ink2);font-style:italic}
.danger-badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;padding:2px 8px;border-radius:100px;margin-top:6px;font-weight:500}
.badge-high{background:rgba(192,57,43,.12);color:#c0392b}
.badge-mid{background:rgba(184,150,12,.12);color:#7a6008}
.badge-low{background:rgba(42,90,58,.12);color:#2a5a3a}

.pain-scores-row{padding:.75rem 1.25rem;border-bottom:.5px solid var(--paper3);display:flex;flex-wrap:wrap;gap:6px;background:rgba(139,32,32,.02)}
.score-chip{display:flex;align-items:center;gap:4px;font-size:11px;padding:3px 8px;border-radius:100px;background:var(--paper);border:.5px solid var(--paper3)}
.score-chip.score-5{background:rgba(192,57,43,.1);border-color:rgba(192,57,43,.3);color:#c0392b}
.score-chip.score-4{background:rgba(230,126,34,.1);border-color:rgba(230,126,34,.3);color:#e67e22}
.score-chip.score-3{background:rgba(184,150,12,.1);border-color:rgba(184,150,12,.3);color:#7a6008}
.score-chip.score-2,.score-chip.score-1{background:rgba(42,90,58,.08);border-color:rgba(42,90,58,.2);color:#2a5a3a}

.card-body{padding:1rem 1.25rem}
.verdict-block{margin-bottom:.875rem}
.verdict-block strong{font-size:11px;color:var(--ink3);letter-spacing:.1em;display:block;margin-bottom:5px}
.verdict-block p{font-size:13px;color:var(--ink2);line-height:1.7}
.defense-block{background:rgba(42,90,58,.05);border-left:2px solid var(--green);padding:8px 12px;border-radius:0 var(--radius) var(--radius) 0;margin-bottom:.5rem}
.defense-block strong{font-size:11px;color:var(--green);letter-spacing:.1em;display:block;margin-bottom:4px}
.defense-block p{font-size:12px;color:var(--ink2);line-height:1.6}

.card-footer{padding:.875rem 1.25rem;border-top:.5px solid var(--paper3);background:var(--paper2);display:flex;gap:8px;flex-wrap:wrap}
.book-btn{flex:1;min-width:140px;padding:9px 12px;border-radius:var(--radius);font-size:12px;font-family:'Noto Sans TC',sans-serif;font-weight:400;cursor:pointer;text-decoration:none;text-align:center;display:flex;align-items:center;justify-content:center;gap:5px;transition:all .15s;border:.5px solid var(--paper3)}
.agoda-btn{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.agoda-btn:hover{background:var(--red2);border-color:var(--red2)}
.booking-btn{background:var(--paper);color:var(--ink2)}
.booking-btn:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}

.no-result{text-align:center;padding:3rem 1rem;color:var(--ink3);font-size:14px}

@media(max-width:640px){
  html{font-size:22px}
  .form-row{flex-direction:column}
  .pain-grid{grid-template-columns:1fr 1fr}
  .card-footer{flex-direction:column}
  .hero-eyebrow{font-size:16px}
  .hero-sub{font-size:20px}
  .form-card h2{font-size:20px}
  .form-group label{font-size:18px}
  .form-group select,.form-group input{font-size:20px}
  .pain-label{font-size:18px}
  .pain-emoji{font-size:20px}
  .analyze-btn{font-size:22px}
  .results-title{font-size:22px}
  .results-sub{font-size:18px}
  .card-zone{font-size:22px}
  .card-tagline{font-size:18px}
  .verdict-block strong{font-size:16px}
  .verdict-block p{font-size:20px}
  .defense-block strong{font-size:16px}
  .defense-block p{font-size:18px}
  .book-btn{font-size:18px}
  .no-result{font-size:20px}
}
  </style>
</head>
<body>
  <Header />

<div class="hero">
  <div class="hero-eyebrow">🐻🐻 兩隻熊出國避痛大腦</div>
  <h1>不踩雷，<em>比便宜更重要</em>。</h1>
  <p class="hero-sub">設定行程、勾選最怕的痛苦，兩隻熊幫你診斷哪些區域要遠離，並搜尋安全替代方案。</p>
</div>

<div class="main">

  <!-- 行程設定 -->
  <div class="form-card">
    <h2>行程設定</h2>
    <div class="form-row">
      <div class="form-group">
        <label>目的地</label>
        <select id="citySelect">
          <option value="東京">🇯🇵 東京</option>
          <option value="大阪">🇯🇵 大阪</option>
          <option value="京都">🇯🇵 京都</option>
          <option value="首爾">🇰🇷 首爾</option>
          <option value="曼谷">🇹🇭 曼谷</option>
          <option value="新加坡">🇸🇬 新加坡</option>
          <option value="福岡">🇯🇵 福岡</option>
          <option value="沖繩">🇯🇵 沖繩</option>
          <option value="釜山">🇰🇷 釜山</option>
          <option value="峇厘島">🇮🇩 峇厘島</option>
          <option value="清邁">🇹🇭 清邁</option>
          <option value="胡志明市">🇻🇳 胡志明市</option>
          <option value="台北">🇹🇼 台北</option>
          <option value="台南">🇹🇼 台南</option>
          <option value="花蓮">🇹🇼 花蓮</option>
          <option value="墾丁">🇹🇼 墾丁</option>
          <option value="高雄">🇹🇼 高雄</option>
          <option value="台中">🇹🇼 台中</option>
        </select>
      </div>
      <div class="form-group">
        <label>入住日期</label>
        <input type="date" id="checkIn">
      </div>
      <div class="form-group">
        <label>退房日期</label>
        <input type="date" id="checkOut">
      </div>
      <div class="form-group">
        <label>大人</label>
        <select id="adults">
          <option value="1">1人</option>
          <option value="2" selected>2人</option>
          <option value="3">3人</option>
          <option value="4">4人</option>
        </select>
      </div>
      <div class="form-group">
        <label>房間</label>
        <select id="rooms">
          <option value="1" selected>1間</option>
          <option value="2">2間</option>
          <option value="3">3間</option>
        </select>
      </div>
    </div>
  </div>

  <!-- 痛點選擇 -->
  <div class="form-card">
    <h2>這次出國，你最怕遇到什麼痛苦？（可多選）</h2>
    <div class="pain-grid" id="painGrid">
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="luggage">
        <span class="pain-emoji">🧳</span>
        <span class="pain-label">29吋行李箱打不開</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="walking">
        <span class="pain-emoji">🚶</span>
        <span class="pain-label">走路比官方說的遠有大坡</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="lateFood">
        <span class="pain-emoji">🍜</span>
        <span class="pain-label">晚上10點後沒宵夜</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="noise">
        <span class="pain-emoji">😴</span>
        <span class="pain-label">隔音差、隔壁打呼一起參與</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="elderly">
        <span class="pain-emoji">🧓</span>
        <span class="pain-label">帶長輩/推車有樓梯地獄</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="rain">
        <span class="pain-emoji">☔</span>
        <span class="pain-label">下雨天一出站直接迷航</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="female">
        <span class="pain-emoji">👩</span>
        <span class="pain-label">女性獨旅回飯店路段危險</span>
      </label>
      <label class="pain-item">
        <input type="checkbox" class="pain-cb" value="bed">
        <span class="pain-emoji">🛏️</span>
        <span class="pain-label">床鋪窄小超難睡</span>
      </label>
    </div>
    <button class="analyze-btn" onclick="analyze()">🔥 開始幫我肉眼避雷 →</button>
  </div>

  <!-- 結果 -->
  <div id="resultsSection">
    <div class="results-title" id="resultsTitle"></div>
    <div class="results-sub" id="resultsSub"></div>
    <div id="resultsList"></div>
  </div>

</div>

  <Footer />

<script is:inline>
// ── 聯盟設定 ──────────────────────────────────────────────────
const AGODA_TRACKING = 'https://affsrc.com/track/clicks/8682/c627c2bc9b0225dbff89ec23d62e994c21695b9633e0eef20f62a44125095ff88635aca3163d8e'
const BOOKING_TRACKING = 'https://abzcoupon.com/track/clicks/3455/c627c2bb980623dafa9cab248d2596412379128f78eee2f10276f6476a0449a8c23ae5a5112d'

const AGODA_IDS = {
  '東京':5085,'大阪':9590,'京都':1784,'首爾':14690,'曼谷':9395,
  '新加坡':4064,'台北':4951,'福岡':1714,'沖繩':1706,'釜山':14690,
  '峇厘島':1271,'清邁':3573,'胡志明市':3573,'台南':18347,'花蓮':23127,
  '墾丁':18343,'高雄':756,'台中':12080
}
const CITY_EN = {
  '東京':'Tokyo','大阪':'Osaka','京都':'Kyoto','首爾':'Seoul','曼谷':'Bangkok',
  '新加坡':'Singapore','台北':'Taipei','福岡':'Fukuoka','沖繩':'Okinawa',
  '釜山':'Busan','峇厘島':'Bali','清邁':'Chiang Mai','胡志明市':'Ho Chi Minh City',
  '台南':'Tainan','花蓮':'Hualien','墾丁':'Kenting','高雄':'Kaohsiung','台中':'Taichung'
}

// ── 痛點標籤 ──────────────────────────────────────────────────
const PAIN_LABELS = {
  luggage:'🧳 行李箱',walking:'🚶 坡道距離',lateFood:'🍜 宵夜',
  noise:'😴 隔音',elderly:'🧓 長輩樓梯',rain:'☔ 下雨迷路',
  female:'👩 女性安全',bed:'🛏️ 床鋪大小'
}

// ── 避雷資料庫 ────────────────────────────────────────────────
const AVOID_DATA = [
  // 東京
  {city:'東京',zone:'新宿歌舞伎町周邊',tagline:'交通最方便，但夜晚帶家人是場災難',
   scores:{luggage:4,walking:5,lateFood:1,noise:5,elderly:3,rain:5,female:4,bed:4},
   verdict:'新宿站是全日本最大的迷宮，官網寫「走路3分鐘」是不帶行李、不迷路、走特戰速度的結果。歌舞伎町晚上滿街是案內人和喝醉的外國人，帶長輩或小孩走這段會非常後悔。預算型商務旅館房間普遍12-14㎡，兩個人加兩個行李箱根本沒有轉身空間。',
   defense:'指定西口或南口徒步5分鐘內、樓層在4樓以上、房間標示16㎡以上的旅館。或直接往西新宿移動，價格差不多但安靜很多。'},
  {city:'東京',zone:'池袋北口周邊',tagline:'便宜陷阱，換個出口世界大不同',
   scores:{luggage:3,walking:2,lateFood:1,noise:4,elderly:2,rain:3,female:4,bed:3},
   verdict:'池袋東口是陽光城、西口是百貨公司，但「北口」是著名的無國界混亂區。很多比價網站列出的超便宜旅館就在這一帶，省了500元台幣卻換來每晚走夜路的不安。',
   defense:'池袋住宿請指定「東口徒步5分鐘內」或明確標示「近太陽城」。女性獨旅強烈建議避開北口所有旅館。'},
  {city:'東京',zone:'淺草藏前老街區',tagline:'江戶風情美，但晚上8點後只剩你和便利商店',
   scores:{luggage:3,walking:2,lateFood:5,noise:2,elderly:5,rain:2,female:1,bed:2},
   verdict:'淺草白天非常美，但這區是東京最早關店的觀光區之一。晚上8點後絕大多數餐廳收攤。淺草線部分老舊車站出口完全沒有電梯，29吋行李箱要爬三層樓梯。',
   defense:'選飯店時確認最近地鐵出口有無電梯，並確認飯店附近有便利商店。宵夜愛好者請改住上野或秋葉原一帶。'},
  {city:'東京',zone:'上野阿美橫丁周邊',tagline:'超鬧市場旁，白天熱鬧夜晚吵到睡不著',
   scores:{luggage:4,walking:1,lateFood:2,noise:5,elderly:2,rain:1,female:2,bed:4},
   verdict:'上野的交通無可挑剔，但阿美橫丁市場一帶的旅館隔音是東京最差之一，早上6點市場就開始搬貨卸貨，你的睡眠從此不完整。',
   defense:'上野住宿請選遠離阿美橫丁至少200公尺、標示有雙層隔音窗的旅館。或往北走5分鐘選日暮里，同樣方便但便宜又安靜。'},
  // 大阪
  {city:'大阪',zone:'新今宮動物園前',tagline:'全日本最便宜，但代價你要想清楚',
   scores:{luggage:4,walking:2,lateFood:2,noise:4,elderly:3,rain:2,female:5,bed:4},
   verdict:'NT$600-800的單人房看起來CP值極高，但這裡緊鄰大阪著名的「愛鄰地區」，是日本最密集的遊民聚居區之一。女性獨旅請完全迴避。',
   defense:'同樣的錢往北移到難波或日本橋，多花NT$300-500可以住到完全不同等級的環境。絕對不要因為「反正只是睡覺」就選這區。'},
  {city:'大阪',zone:'心齋橋道頓堀核心區',tagline:'下樓就是章魚燒，但你的耳朵和行李箱都會哭',
   scores:{luggage:5,walking:1,lateFood:1,noise:5,elderly:2,rain:1,female:2,bed:4},
   verdict:'這一帶的設計感精品旅館幾乎清一色是11-13㎡的「拍照很美、住起來像盒子」類型。大阪必買的藥妝和食品戰利品回來根本沒地方放，只能堆在床上。半夜警車臨檢、路人唱歌的聲音完全擋不住。',
   defense:'同區旅館請選標示「deluxe double」或房間20㎡以上的類型，或往堀江、美國村方向走。'},
  {city:'大阪',zone:'新大阪站周邊',tagline:'商務客的天堂，觀光旅客的荒漠',
   scores:{luggage:2,walking:1,lateFood:4,noise:2,elderly:1,rain:1,female:1,bed:2},
   verdict:'這裡一到晚上就是死寂的辦公商務區，完全沒有大阪那種熱情、浮誇的夜生活。如果你不去其他城市，只是純大阪玩，住這裡等於每天晚上提早進入退休生活。',
   defense:'觀光旅客選難波或梅田，新幹線搭JR幾站就到新大阪。'},
