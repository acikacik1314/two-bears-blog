---
import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import CategoryChips from '../../components/CategoryChips.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPostCategory, CATEGORY_COLORS } from '../../utils/category';
import AdSlot from '../../components/AdSlot.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const posts = (await getCollection('blog')).filter(p => !p.data.draft).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	return paginate(posts, { pageSize: 24 });
}

type Props = { page: Page<CollectionEntry<'blog'>> };
const { page } = Astro.props;

const CATEGORY_DEFAULT_IMAGES: Record<string, string> = {
	'預言': 'https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?w=800&h=450&fit=crop',
	'影片': 'https://images.unsplash.com/photo-1446776811953-b23d57bd21aa?w=800&h=450&fit=crop',
	'旅遊': 'https://images.unsplash.com/photo-1506318137071-a8e063b4bec0?w=800&h=450&fit=crop',
	'評測': 'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=800&h=450&fit=crop',
	'其他': 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=800&h=450&fit=crop',
};

function getThumbnail(post: CollectionEntry<'blog'>, cat: string): string {
	if (post.data.youtubeId) return `https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`;
	if (post.data.heroImage) {
		const h = post.data.heroImage as any;
		const url = typeof h === 'string' ? h : h?.src ?? null;
		if (url) return url;
	}
	return CATEGORY_DEFAULT_IMAGES[cat] ?? CATEGORY_DEFAULT_IMAGES['其他'];
}

const CATEGORY_GRADIENTS: Record<string, string> = {
	'預言': 'linear-gradient(135deg, #1a1a2e 0%, #c0392b 100%)',
	'影片': 'linear-gradient(135deg, #0f3460 0%, #16213e 100%)',
	'旅遊': 'linear-gradient(135deg, #134e5e 0%, #71b280 100%)',
	'評測': 'linear-gradient(135deg, #4a00e0 0%, #8e2de2 100%)',
	'其他': 'linear-gradient(135deg, #373b44 0%, #4286f4 100%)',
};
const CATEGORY_ICONS: Record<string, string> = {
	'預言': '🔮', '影片': '🎬', '旅遊': '✈️', '評測': '📦', '其他': '📝',
};

function getPageNums(current: number, last: number): (number | '…')[] {
	const show = new Set<number>();
	show.add(1);
	show.add(last);
	for (let i = Math.max(1, current - 2); i <= Math.min(last, current + 2); i++) show.add(i);
	const sorted = [...show].sort((a, b) => a - b);
	const result: (number | '…')[] = [];
	for (let i = 0; i < sorted.length; i++) {
		if (i > 0 && sorted[i] - sorted[i - 1] > 1) result.push('…');
		result.push(sorted[i]);
	}
	return result;
}

const pageNums = getPageNums(page.currentPage, page.lastPage);
const pageTitle = page.currentPage > 1
	? `文章列表 第${page.currentPage}頁 | ${SITE_TITLE}`
	: `文章列表 | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={pageTitle} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.page-title {
				text-align: center;
				margin-bottom: 1.5em;
				font-size: 1.8em;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul li a {
				display: block;
				border-radius: 12px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				transition: transform 0.2s, box-shadow 0.2s;
				height: 100%;
			}
			ul li a:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.card-thumb {
				position: relative;
				width: 100%;
				aspect-ratio: 16/9;
				overflow: hidden;
				background: #111;
			}
			.card-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				border-radius: 0;
				transition: transform 0.3s;
			}
			ul li a:hover .card-thumb img { transform: scale(1.04); }
			.card-thumb-placeholder {
				width: 100%;
				height: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 0.4em;
			}
			.placeholder-icon { font-size: 2.2em; opacity: 0.9; }
			.placeholder-cat { font-size: 0.8em; color: rgba(255,255,255,0.7); font-weight: 700; letter-spacing: 0.05em; }
			.cat-badge {
				position: absolute;
				top: 0.5em;
				left: 0.5em;
				display: inline-block;
				color: white;
				padding: 0.2em 0.6em;
				border-radius: 8px;
				font-size: 0.72em;
				font-weight: 700;
				backdrop-filter: blur(4px);
				background: rgba(0,0,0,0.45);
			}
			.card-body { padding: 0.85em; }
			.card-title {
				margin: 0 0 0.35em 0;
				color: #e2e8f0;
				line-height: 1.35;
				font-size: 0.92em;
				font-weight: 700;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			ul li a:hover .card-title { color: var(--accent); }
			.card-date { margin: 0; color: #94a3b8; font-size: 0.78em; }
			.pagination {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.35em;
				margin: 2.5em 0 1em;
				flex-wrap: wrap;
			}
			.page-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 2.2em;
				height: 2.2em;
				padding: 0 0.7em;
				border-radius: 8px;
				text-decoration: none;
				font-size: 0.85em;
				color: #94a3b8;
				background: #1e293b;
				border: 1px solid #334155;
				transition: background 0.15s, color 0.15s;
				white-space: nowrap;
			}
			.page-btn:hover { background: #334155; color: #e2e8f0; }
			.page-btn.active { background: var(--accent); border-color: var(--accent); color: white; font-weight: 700; pointer-events: none; }
			.page-btn.disabled { opacity: 0.3; pointer-events: none; }
			.page-ellipsis { color: #64748b; line-height: 2.2em; padding: 0 0.1em; }
			@media (max-width: 720px) {
				ul { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
			}
			@media (max-width: 480px) {
				ul { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">所有文章</h1>
			<CategoryChips />
			<ul>
				{page.data.map((post, i) => {
					const cat = getPostCategory(post);
					const color = CATEGORY_COLORS[cat] ?? '#7f8c8d';
					const thumb = getThumbnail(post, cat);
					const gradient = CATEGORY_GRADIENTS[cat] ?? CATEGORY_GRADIENTS['其他'];
					const icon = CATEGORY_ICONS[cat] ?? '📝';
					return (
						<>
							{i === 6 && (
								<li style="grid-column: 1 / -1; list-style: none; padding: 0;">
									<AdSlot unit="4916286882" format="horizontal" />
								</li>
							)}
							<li>
								<a href={`/blog/${post.id}`}>
									<div class="card-thumb">
										<img src={thumb} alt={post.data.title} loading="lazy" decoding="async"
											onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
										<div class="card-thumb-placeholder" style={`background: ${gradient}; display:none`}>
											<span class="placeholder-icon">{icon}</span>
											<span class="placeholder-cat">{cat}</span>
										</div>
										<span class="cat-badge" style={`background:${color}`}>{cat}</span>
									</div>
									<div class="card-body">
										<h4 class="card-title">{post.data.title}</h4>
										<p class="card-date"><FormattedDate date={post.data.pubDate} /></p>
									</div>
								</a>
							</li>
						</>
					);
				})}
			</ul>

			{page.lastPage > 1 && (
				<nav class="pagination" aria-label="分頁導覽">
					{page.url.prev
						? <a href={page.url.prev} class="page-btn" aria-label="上一頁">← 上一頁</a>
						: <span class="page-btn disabled">← 上一頁</span>
					}
					{pageNums.map(n =>
						n === '…'
							? <span class="page-ellipsis">…</span>
							: <a
									href={n === 1 ? '/blog' : `/blog/${n}`}
									class={`page-btn${n === page.currentPage ? ' active' : ''}`}
									aria-current={n === page.currentPage ? 'page' : undefined}
								>{n}</a>
					)}
					{page.url.next
						? <a href={page.url.next} class="page-btn" aria-label="下一頁">下一頁 →</a>
						: <span class="page-btn disabled">下一頁 →</span>
					}
				</nav>
			)}

			<p style="text-align:center;margin:2em 0 1.5em;font-size:0.78em;color:#94a3b8;">
				每篇文章都是認真整理的。如果你喜歡這裡，歡迎
				<a href="https://ko-fi.com/twobear2" target="_blank" rel="noopener"
				   style="color:#94a3b8;text-decoration:underline;text-underline-offset:2px;transition:color 0.15s;"
				   onmouseover="this.style.color='#cbd5e1'" onmouseout="this.style.color='#94a3b8'">請兩隻熊喝杯咖啡 ☕</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
