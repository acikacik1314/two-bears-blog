---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPostCategory, CATEGORY_COLORS } from '../../utils/category';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryCounts: Record<string, number> = { '全部': posts.length };
for (const post of posts) {
	const cat = getPostCategory(post);
	categoryCounts[cat] = (categoryCounts[cat] ?? 0) + 1;
}

function getThumbnail(post: CollectionEntry<'blog'>): string | null {
	if (post.data.youtubeId) {
		return `https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`;
	}
	if (post.data.heroImage) {
		const h = post.data.heroImage as any;
		return typeof h === 'string' ? h : h?.src ?? null;
	}
	return null;
}

const CATEGORY_GRADIENTS: Record<string, string> = {
	'預言': 'linear-gradient(135deg, #1a1a2e 0%, #c0392b 100%)',
	'影片': 'linear-gradient(135deg, #0f3460 0%, #16213e 100%)',
	'旅遊': 'linear-gradient(135deg, #134e5e 0%, #71b280 100%)',
	'評測': 'linear-gradient(135deg, #4a00e0 0%, #8e2de2 100%)',
	'其他': 'linear-gradient(135deg, #373b44 0%, #4286f4 100%)',
};

const CATEGORY_ICONS: Record<string, string> = {
	'預言': '🔮',
	'影片': '🎬',
	'旅遊': '✈️',
	'評測': '📦',
	'其他': '📝',
};
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`文章列表 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.page-title {
				text-align: center;
				margin-bottom: 1.5em;
				font-size: 1.8em;
			}
			.nav-tabs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				margin-bottom: 2em;
			}
			.nav-tab {
				padding: 0.4em 1.1em;
				border-radius: 20px;
				text-decoration: none;
				font-size: 0.9em;
				border: 2px solid #334155;
				color: #94a3b8;
				background: #1e293b;
			}
			.nav-tab:hover { border-color: var(--accent); color: var(--accent); }
			.nav-tab.active {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
				font-weight: 700;
			}
			.count-badge {
				background: rgba(0,0,0,0.15);
				border-radius: 10px;
				padding: 0 0.4em;
				font-size: 0.85em;
				margin-left: 0.3em;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul li a {
				display: block;
				border-radius: 12px;
				overflow: hidden;
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				transition: transform 0.2s, box-shadow 0.2s;
				height: 100%;
			}
			ul li a:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.card-thumb {
				position: relative;
				width: 100%;
				aspect-ratio: 16/9;
				overflow: hidden;
				background: #111;
			}
			.card-thumb img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				border-radius: 0;
				transition: transform 0.3s;
			}
			ul li a:hover .card-thumb img {
				transform: scale(1.04);
			}
			.card-thumb-placeholder {
				width: 100%;
				height: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 0.4em;
			}
			.placeholder-icon {
				font-size: 2.2em;
				opacity: 0.9;
			}
			.placeholder-cat {
				font-size: 0.8em;
				color: rgba(255,255,255,0.7);
				font-weight: 700;
				letter-spacing: 0.05em;
			}
			.cat-badge {
				position: absolute;
				top: 0.5em;
				left: 0.5em;
				display: inline-block;
				color: white;
				padding: 0.2em 0.6em;
				border-radius: 8px;
				font-size: 0.72em;
				font-weight: 700;
				backdrop-filter: blur(4px);
				background: rgba(0,0,0,0.45);
			}
			.card-body {
				padding: 0.85em;
			}
			.card-title {
				margin: 0 0 0.35em 0;
				color: #e2e8f0;
				line-height: 1.35;
				font-size: 0.92em;
				font-weight: 700;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			ul li a:hover .card-title { color: var(--accent); }
			.card-date {
				margin: 0;
				color: #94a3b8;
				font-size: 0.78em;
			}
			@media (max-width: 720px) {
				ul { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
			}
			@media (max-width: 480px) {
				ul { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">所有文章</h1>
			<nav class="nav-tabs">
				<a href="/blog" class="nav-tab active">
					全部 <span class="count-badge">{categoryCounts['全部']}</span>
				</a>
				{(['評測', '預言', '旅遊', '影片'] as const).map(cat => (
					<a href={`/category/${cat}`} class="nav-tab">
						{cat} <span class="count-badge">{categoryCounts[cat] ?? 0}</span>
					</a>
				))}
			</nav>
			<ul>
				{posts.map((post) => {
					const cat = getPostCategory(post);
					const color = CATEGORY_COLORS[cat] ?? '#7f8c8d';
					const thumb = getThumbnail(post);
					const gradient = CATEGORY_GRADIENTS[cat] ?? CATEGORY_GRADIENTS['其他'];
					const icon = CATEGORY_ICONS[cat] ?? '📝';
					return (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="card-thumb">
									{thumb ? (
										<>
											<img src={thumb} alt={post.data.title} loading="lazy" decoding="async"
												onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
											<div class="card-thumb-placeholder" style={`background: ${gradient}; display:none`}>
												<span class="placeholder-icon">{icon}</span>
												<span class="placeholder-cat">{cat}</span>
											</div>
										</>
									) : (
										<div class="card-thumb-placeholder" style={`background: ${gradient}`}>
											<span class="placeholder-icon">{icon}</span>
											<span class="placeholder-cat">{cat}</span>
										</div>
									)}
									<span class="cat-badge" style={`background:${color}`}>{cat}</span>
								</div>
								<div class="card-body">
									<h4 class="card-title">{post.data.title}</h4>
									<p class="card-date"><FormattedDate date={post.data.pubDate} /></p>
								</div>
							</a>
						</li>
					);
				})}
			</ul>
		<p style="text-align:center;margin:3em 0 1.5em;font-size:0.78em;color:#94a3b8;">
			每篇文章都是認真整理的。如果你喜歡這裡，歡迎
			<a href="https://ko-fi.com/twobear2" target="_blank" rel="noopener"
			   style="color:#94a3b8;text-decoration:underline;text-underline-offset:2px;transition:color 0.15s;"
			   onmouseover="this.style.color='#cbd5e1'" onmouseout="this.style.color='#94a3b8'">請兩隻熊喝杯咖啡 ☕</a>
		</p>
		</main>
		<Footer />
	</body>
</html>
