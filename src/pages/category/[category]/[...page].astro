---
import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { getPostCategory, CATEGORIES, CATEGORY_COLORS } from '../../../utils/category';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allPosts = await getCollection('blog');
  const categories = CATEGORIES.filter(c => c !== '全部');

  return categories.flatMap(category =>
    paginate(
      allPosts
        .filter(post => getPostCategory(post) === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
      { params: { category }, pageSize: 24 },
    )
  );
}

type Props = { page: Page<CollectionEntry<'blog'>> };
const { page } = Astro.props;
const { category } = Astro.params;

const color = CATEGORY_COLORS[category] ?? '#7f8c8d';

function getThumbnail(post: CollectionEntry<'blog'>): string | null {
  if (post.data.youtubeId) return `https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`;
  if (post.data.heroImage) {
    const h = post.data.heroImage as any;
    return typeof h === 'string' ? h : h?.src ?? null;
  }
  return null;
}

const CATEGORY_GRADIENTS: Record<string, string> = {
  '預言': 'linear-gradient(135deg, #1a1a2e 0%, #c0392b 100%)',
  '影片': 'linear-gradient(135deg, #0f3460 0%, #16213e 100%)',
  '旅遊': 'linear-gradient(135deg, #134e5e 0%, #71b280 100%)',
  '評測': 'linear-gradient(135deg, #4a00e0 0%, #8e2de2 100%)',
  '其他': 'linear-gradient(135deg, #373b44 0%, #4286f4 100%)',
};
const CATEGORY_ICONS: Record<string, string> = {
  '預言': '🔮', '影片': '🎬', '旅遊': '✈️', '評測': '📦', '其他': '📝',
};

function getPageNums(current: number, last: number): (number | '…')[] {
  const show = new Set<number>();
  show.add(1);
  show.add(last);
  for (let i = Math.max(1, current - 2); i <= Math.min(last, current + 2); i++) show.add(i);
  const sorted = [...show].sort((a, b) => a - b);
  const result: (number | '…')[] = [];
  for (let i = 0; i < sorted.length; i++) {
    if (i > 0 && sorted[i] - sorted[i - 1] > 1) result.push('…');
    result.push(sorted[i]);
  }
  return result;
}

const pageNums = getPageNums(page.currentPage, page.lastPage);
const pageTitle = page.currentPage > 1
  ? `${category} 第${page.currentPage}頁 | ${SITE_TITLE}`
  : `${category} | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={pageTitle} description={`${SITE_TITLE} 的 ${category} 分類文章`} />
    <style>
      main { width: 960px; max-width: calc(100% - 2em); margin: auto; padding: 2em 1em; }
      .category-header { text-align: center; margin-bottom: 1.5em; }
      .category-badge {
        display: inline-block;
        background: var(--cat-color);
        color: white;
        padding: 0.4em 1.2em;
        border-radius: 20px;
        font-size: 1.1em;
        font-weight: 700;
        margin-bottom: 0.4em;
      }
      .post-count { color: rgb(var(--gray)); font-size: 0.9em; margin: 0; }
      .nav-tabs {
        display: flex; flex-wrap: wrap; gap: 0.5em;
        justify-content: center; margin-bottom: 2em;
      }
      .nav-tab {
        padding: 0.4em 1em; border-radius: 20px; text-decoration: none;
        font-size: 0.9em; border: 2px solid rgb(var(--gray-light));
        color: rgb(var(--gray-dark)); background: white;
      }
      .nav-tab:hover { border-color: var(--accent); color: var(--accent); }
      .nav-tab.active { border-color: var(--accent); color: var(--accent); font-weight: 700; }
      ul {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
        list-style: none; margin: 0; padding: 0;
      }
      ul li a {
        display: block; border-radius: 12px; overflow: hidden;
        border: 1px solid rgb(var(--gray-light)); text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s; height: 100%;
      }
      ul li a:hover { transform: translateY(-3px); box-shadow: var(--box-shadow); }
      .card-thumb {
        position: relative; width: 100%; aspect-ratio: 16/9;
        overflow: hidden; background: #111;
      }
      .card-thumb img {
        width: 100%; height: 100%; object-fit: cover; display: block;
        border-radius: 0; transition: transform 0.3s;
      }
      ul li a:hover .card-thumb img { transform: scale(1.04); }
      .card-thumb-placeholder {
        width: 100%; height: 100%; display: flex;
        flex-direction: column; align-items: center; justify-content: center; gap: 0.4em;
      }
      .placeholder-icon { font-size: 2.2em; opacity: 0.9; }
      .placeholder-cat { font-size: 0.8em; color: rgba(255,255,255,0.7); font-weight: 700; }
      .card-body { padding: 0.85em; }
      .card-title {
        margin: 0 0 0.35em 0; color: #e2e8f0;
        line-height: 1.35; font-size: 0.92em; font-weight: 700;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
      }
      ul li a:hover .card-title { color: var(--accent); }
      .card-date { margin: 0; color: #94a3b8; font-size: 0.78em; }
      .empty { text-align: center; color: rgb(var(--gray)); padding: 3em 0; }
      .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35em;
        margin: 2.5em 0 1em;
        flex-wrap: wrap;
      }
      .page-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2.2em;
        height: 2.2em;
        padding: 0 0.7em;
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.85em;
        color: rgb(var(--gray-dark));
        background: white;
        border: 1px solid rgb(var(--gray-light));
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }
      .page-btn:hover { border-color: var(--accent); color: var(--accent); }
      .page-btn.active { background: var(--accent); border-color: var(--accent); color: white; font-weight: 700; pointer-events: none; }
      .page-btn.disabled { opacity: 0.3; pointer-events: none; }
      .page-ellipsis { color: rgb(var(--gray)); line-height: 2.2em; padding: 0 0.1em; }
      @media (max-width: 720px) { ul { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 480px) { ul { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="category-header">
        <div class="category-badge" style={`--cat-color: ${color}`}>{category}</div>
        <p class="post-count">共 {page.total} 篇文章</p>
      </div>
      <nav class="nav-tabs">
        <a href="/blog" class="nav-tab">全部</a>
        {(['評測', '預言', '旅遊', '影片'] as const).map(cat => (
          <a href={`/category/${cat}`} class={`nav-tab${cat === category ? ' active' : ''}`}>{cat}</a>
        ))}
      </nav>
      {page.data.length === 0 ? (
        <p class="empty">此分類目前沒有文章。</p>
      ) : (
        <ul>
          {page.data.map(post => {
            const thumb = getThumbnail(post);
            const gradient = CATEGORY_GRADIENTS[category] ?? CATEGORY_GRADIENTS['其他'];
            const icon = CATEGORY_ICONS[category] ?? '📝';
            return (
              <li>
                <a href={`/blog/${post.id}`}>
                  <div class="card-thumb">
                    {thumb ? (
                      <>
                        <img src={thumb} alt={post.data.title} loading="lazy" decoding="async"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                        <div class="card-thumb-placeholder" style={`background: ${gradient}; display:none`}>
                          <span class="placeholder-icon">{icon}</span>
                          <span class="placeholder-cat">{category}</span>
                        </div>
                      </>
                    ) : (
                      <div class="card-thumb-placeholder" style={`background: ${gradient}`}>
                        <span class="placeholder-icon">{icon}</span>
                        <span class="placeholder-cat">{category}</span>
                      </div>
                    )}
                  </div>
                  <div class="card-body">
                    <h4 class="card-title">{post.data.title}</h4>
                    <p class="card-date"><FormattedDate date={post.data.pubDate} /></p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="分頁導覽">
          {page.url.prev
            ? <a href={page.url.prev} class="page-btn" aria-label="上一頁">← 上一頁</a>
            : <span class="page-btn disabled">← 上一頁</span>
          }
          {pageNums.map(n =>
            n === '…'
              ? <span class="page-ellipsis">…</span>
              : <a
                  href={n === 1 ? `/category/${category}` : `/category/${category}/${n}`}
                  class={`page-btn${n === page.currentPage ? ' active' : ''}`}
                  aria-current={n === page.currentPage ? 'page' : undefined}
                >{n}</a>
          )}
          {page.url.next
            ? <a href={page.url.next} class="page-btn" aria-label="下一頁">下一頁 →</a>
            : <span class="page-btn disabled">下一頁 →</span>
          }
        </nav>
      )}
    </main>
    <Footer />
  </body>
</html>
