---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="zh-TW">
<head>
  <BaseHead title="命理分析中心 — 兩隻熊" description="西洋星座命盤、紫薇斗數、卜卦易經、八字四柱全方位命理分析" />
</head>
<body>
<Header />
<main class="fp-main">

  <!-- Hero -->
  <div class="fp-hero">
    <div class="fp-badge">✦ 綜合命理分析平台</div>
    <h1>🔮 命理分析中心</h1>
    <p class="fp-sub">整合西洋星座命盤・紫薇斗數・卜卦易經・八字四柱<br/>輸入生日即可獲得全方位命理解析</p>
  </div>

  <!-- Input Form -->
  <div class="fp-form-wrap">
    <div class="fp-form">
      <div class="fp-field">
        <label>姓名（選填）</label>
        <input type="text" id="fp-name" placeholder="你的名字" maxlength="20" />
      </div>
      <div class="fp-field">
        <label>出生年月日 *</label>
        <input type="date" id="fp-bdate" required />
      </div>
      <div class="fp-field">
        <label>出生時辰（選填）</label>
        <select id="fp-hour">
          <option value="-1">不知道</option>
          <option value="0">子時 23:00–01:00</option>
          <option value="1">丑時 01:00–03:00</option>
          <option value="2">寅時 03:00–05:00</option>
          <option value="3">卯時 05:00–07:00</option>
          <option value="4">辰時 07:00–09:00</option>
          <option value="5">巳時 09:00–11:00</option>
          <option value="6">午時 11:00–13:00</option>
          <option value="7">未時 13:00–15:00</option>
          <option value="8">申時 15:00–17:00</option>
          <option value="9">酉時 17:00–19:00</option>
          <option value="10">戌時 19:00–21:00</option>
          <option value="11">亥時 21:00–23:00</option>
        </select>
      </div>
      <button class="fp-btn" id="fp-calc">✨ 開始分析</button>
    </div>
    <p class="fp-note">✦ 本工具僅供娛樂參考，不代表真實命理占卜</p>
  </div>

  <!-- Results (hidden until calculated) -->
  <div id="fp-results" style="display:none">
    <div class="res-tabs">
      <button class="res-tab active" data-panel="zodiac">🌟 星座命盤</button>
      <button class="res-tab" data-panel="ziwei">⭐ 紫薇斗數</button>
      <button class="res-tab" data-panel="bazi">🀄 八字四柱</button>
    </div>

    <!-- 星座命盤 Panel -->
    <div class="res-panel active" id="panel-zodiac">
      <div class="res-greeting" id="res-greeting"></div>
      <div class="zodiac-result-grid" id="zodiac-result"></div>
      <div class="year-fortune-box" id="year-fortune"></div>
    </div>

    <!-- 紫薇斗數 Panel -->
    <div class="res-panel" id="panel-ziwei">
      <div id="ziwei-result"></div>
    </div>

    <!-- 八字四柱 Panel -->
    <div class="res-panel" id="panel-bazi">
      <div id="bazi-result"></div>
    </div>
  </div>

  <!-- ══════════════════════════════
       卜卦易經
  ══════════════════════════════ -->
  <section class="knowledge-section" id="iching-section">
    <div class="ks-header">
      <h2 class="ks-title">🔯 卜卦易經</h2>
      <p class="ks-sub">心誠則靈，靜心一問，觀卦象以知天機</p>
    </div>

    <div class="iching-tool">
      <div class="iching-question">
        <label>你的問題（選填）</label>
        <input type="text" id="iching-q" placeholder="例：這次創業會成功嗎？" maxlength="50" />
      </div>
      <button class="iching-btn" id="iching-cast">🎲 擲卦</button>
    </div>
    <div class="iching-result" id="iching-result" style="display:none"></div>

    <div class="trigrams-grid">
      <h3 class="sub-heading">八卦基礎</h3>
      <div class="trigrams">
        <div class="trigram-card">
          <div class="tri-symbol">☰</div>
          <div class="tri-name">乾 · 天</div>
          <div class="tri-attr">剛健、創始</div>
          <p class="tri-desc">乾為天，代表至陽、至剛之力。乾卦象徵天道運行，生生不息，剛健而不止。凡事皆有其時，懷抱理想，行動果決，可成大業。乾卦之人，志向高遠，領袖氣質天成，適合在逆境中展現韌性，但需避免剛愎自用，保持謙遜方能長久。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☷</div>
          <div class="tri-name">坤 · 地</div>
          <div class="tri-attr">柔順、承載</div>
          <p class="tri-desc">坤為地，代表至陰、至柔之德。坤卦象徵大地承載萬物，厚德載物，以柔克剛。坤卦指引我們以包容、謙遜的姿態面對人生，順應自然規律，不強求而自得。此卦提醒：柔順非軟弱，而是更高層次的智慧與力量。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☳</div>
          <div class="tri-name">震 · 雷</div>
          <div class="tri-attr">動、行動力</div>
          <p class="tri-desc">震為雷，象徵震動、驚醒與行動。雷聲一響，萬物驚醒，代表突破舊局的力量。震卦提醒我們：危機往往是轉機的開始，勇於行動、敢於面對恐懼，才能突破現狀。凡遇震卦，宜大膽前進，但需保持清醒的判斷，避免衝動冒失。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☴</div>
          <div class="tri-name">巽 · 風</div>
          <div class="tri-attr">入、柔和滲透</div>
          <p class="tri-desc">巽為風，象徵柔和而持續的滲透力。風無形無跡，卻能穿透一切。巽卦提示我們以溫和、靈活的方式處世，循序漸進，以退為進，待機而動。此卦也代表溝通與交流，善於傾聽與協調，往往能化解衝突，創造共贏局面。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☵</div>
          <div class="tri-name">坎 · 水</div>
          <div class="tri-attr">陷、危險與智慧</div>
          <p class="tri-desc">坎為水，象徵重重險阻與深不可測的智慧。水無常形，遇方則方，遇圓則圓，無論何種阻礙皆能找到出路。坎卦代表人生中的試煉與磨難，提醒我們在逆境中保持冷靜，以智慧化解危機。歷經坎坷者，往往擁有最深厚的人生閱歷。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☲</div>
          <div class="tri-name">離 · 火</div>
          <div class="tri-attr">麗、附著光明</div>
          <p class="tri-desc">離為火，象徵光明、熱情與附著之力。火必附著於物方能燃燒，代表事物依附關係的重要性。離卦之人，才華橫溢，光芒四射，具有感染他人的能量。此卦提醒我們珍惜當下的光明，發揮自身才能照亮周遭，但需注意不可過於燃燒自己，適時補充能量。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☶</div>
          <div class="tri-name">艮 · 山</div>
          <div class="tri-attr">止、靜止沉穩</div>
          <p class="tri-desc">艮為山，象徵靜止、止步與沉穩。山屹立不動，代表知所進退、適時停止的智慧。艮卦提醒我們：並非所有時刻都適合前進，懂得在適當時機停下腳步，沉澱思慮，才是真正的智慧。凡遇艮卦，宜靜觀其變，養精蓄銳，等待最佳時機再行動。</p>
        </div>
        <div class="trigram-card">
          <div class="tri-symbol">☱</div>
          <div class="tri-name">兌 · 澤</div>
          <div class="tri-attr">悅、喜悅交流</div>
          <p class="tri-desc">兌為澤，象徵喜悅、溝通與滋潤萬物之力。澤水滋養大地，代表分享與交流的美好。兌卦之人，口才出眾，善於表達，容易獲得他人喜愛。此卦提示我們：以真誠喜悅的心態與人互動，廣結善緣，人際關係將成為最大的財富與助力。</p>
        </div>
      </div>
    </div>

    <div class="hexagrams-highlight">
      <h3 class="sub-heading">六十四卦精選解析</h3>
      <div class="hex-grid">
        <div class="hex-card">
          <div class="hex-num">第1卦</div>
          <div class="hex-name">乾為天 ䷀</div>
          <p class="hex-meaning"><strong>象曰：</strong>天行健，君子以自強不息。此卦象徵剛健有為，萬事亨通。事業上宜積極進取，不可懈怠；感情上熱情主動，但需避免強求；財運旺盛，適合大膽投資。整體運勢極佳，把握機遇，前途無量。</p>
        </div>
        <div class="hex-card">
          <div class="hex-num">第2卦</div>
          <div class="hex-name">坤為地 ䷁</div>
          <p class="hex-meaning"><strong>象曰：</strong>地勢坤，君子以厚德載物。此卦象徵包容謙遜，順勢而為。事業上宜輔佐而非領導，配合他人能有所成就；感情上以包容取勝，對方需要穩定的支持；財運平穩，適合守成而非冒進。</p>
        </div>
        <div class="hex-card">
          <div class="hex-num">第11卦</div>
          <div class="hex-name">地天泰 ䷊</div>
          <p class="hex-meaning"><strong>象曰：</strong>天地交，泰。此卦象徵萬事亨通，陰陽調和。凡事順暢，計畫易成，人際關係和諧美滿。事業迎來高峰期，適合推進重要項目；感情甜蜜融洽，可考慮進一步發展；整體財運大吉，可積極把握機遇。</p>
        </div>
        <div class="hex-card">
          <div class="hex-num">第14卦</div>
          <div class="hex-name">火天大有 ䷍</div>
          <p class="hex-meaning"><strong>象曰：</strong>火在天上，大有。此卦象徵豐收與盛大。處於鼎盛時期，地位崇高，財富豐盛。然盛極必衰，提醒在享受成功的同時，應保持謙遜，廣施恩德，方能持續長久。此時宜積極行動，但需避免驕傲自滿。</p>
        </div>
        <div class="hex-card">
          <div class="hex-num">第29卦</div>
          <div class="hex-name">坎為水 ䷜</div>
          <p class="hex-meaning"><strong>象曰：</strong>水洊至，習坎。此卦象徵重重險阻，考驗重重。當前面臨困境，需謹慎應對，不可輕舉妄動。保持內心的誠信與堅持，終能度過難關。遇此卦者，宜靜不宜動，等待時機，守正待變，危機自然解除。</p>
        </div>
        <div class="hex-card">
          <div class="hex-num">第63卦</div>
          <div class="hex-name">水火既濟 ䷾</div>
          <p class="hex-meaning"><strong>象曰：</strong>水在火上，既濟。此卦象徵事業已成，諸事完備。代表某件事已達到完成的狀態，凡事各得其位，秩序井然。然此卦也提醒：成功之後更需謹慎維持，防微杜漸，避免功虧一簣。宜鞏固現有成果，不宜輕易冒險改變。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════
       西洋十二星座完整解析
  ══════════════════════════════ -->
  <section class="knowledge-section">
    <div class="ks-header">
      <h2 class="ks-title">🌟 西洋十二星座完整解析</h2>
      <p class="ks-sub">從火象到水象，深入了解每個星座的性格特質、愛情觀與事業傾向</p>
    </div>
    <div class="zodiac-full-grid">

      <div class="zf-card fire">
        <div class="zf-head">
          <span class="zf-symbol">♈</span>
          <div><div class="zf-name">白羊座</div><div class="zf-date">3/21 – 4/19　火象　守護星：火星</div></div>
        </div>
        <p>白羊座是黃道帶的第一個星座，象徵著新生命的開端與無限可能。白羊座的人天生具有衝勁與領袖魅力，面對挑戰從不退縮，行動力與執行力是他們最大的優勢。在感情方面，白羊座率直熱烈，喜歡主動出擊，愛得轟轟烈烈，卻也容易因為沒有耐心而讓感情降溫。在職業選擇上，白羊座適合從事創業、體育競技、軍警或任何需要突破與開創的領域。今年流年對白羊座而言，事業運強勁，有機會升職或拓展新業務；感情方面需多一些耐心與包容，才能讓關係更加穩固。健康方面需注意頭部與頸部問題，避免過度勞累。</p>
      </div>

      <div class="zf-card earth">
        <div class="zf-head">
          <span class="zf-symbol">♉</span>
          <div><div class="zf-name">金牛座</div><div class="zf-date">4/20 – 5/20　土象　守護星：金星</div></div>
        </div>
        <p>金牛座由金星守護，天生具有對美與舒適的強烈追求。金牛座的人務實穩重，做事有始有終，對財物的管理極為謹慎，是十二星座中最擅長積累財富的星座之一。在感情方面，金牛座深情專一，一旦付出便全心全意，但固執的個性有時會讓感情陷入僵局。在職業上，金牛座適合從事金融、藝術、房地產或任何需要長期規劃與執行的領域。今年金牛座在財運方面表現亮眼，適合進行長期投資或置產；感情方面穩定中帶有浪漫，單身者有機會遇到合拍的對象。需注意喉嚨與甲狀腺健康，以及過度飲食帶來的體重問題。</p>
      </div>

      <div class="zf-card air">
        <div class="zf-head">
          <span class="zf-symbol">♊</span>
          <div><div class="zf-name">雙子座</div><div class="zf-date">5/21 – 6/20　風象　守護星：水星</div></div>
        </div>
        <p>雙子座由水星守護，象徵溝通、智慧與變化。雙子座的人思維敏捷，口才出眾，善於同時處理多件事情，對新知識有著強烈的好奇心。在感情方面，雙子座需要智識上的刺激與心靈的共鳴，一旦對伴侶失去新鮮感便容易分心。在職業上，雙子座適合從事媒體、教育、銷售、公關或任何需要溝通交流的工作。今年雙子座的溝通運與人際運旺盛，適合拓展人脈、簽署合約或推動新計畫；感情方面多說甜言蜜語，減少爭辯，有助於關係升溫。需注意手臂、肺部與神經系統的保養，避免過度用腦造成精神疲憊。</p>
      </div>

      <div class="zf-card water">
        <div class="zf-head">
          <span class="zf-symbol">♋</span>
          <div><div class="zf-name">巨蟹座</div><div class="zf-date">6/21 – 7/22　水象　守護星：月亮</div></div>
        </div>
        <p>巨蟹座由月亮守護，象徵情感、家庭與記憶。巨蟹座的人感情細膩豐富，對家人與朋友有著深厚的情感，保護慾強烈，是十二星座中最重視家庭溫暖的星座。他們直覺敏銳，能快速感受到他人的情緒變化，但也容易因情緒起伏影響判斷力。在職業上，巨蟹座適合從事教育、心理諮詢、護理、餐飲或任何以照顧他人為核心的工作。今年巨蟹座的家庭運與感情運強旺，適合改善居家環境或深化親密關係；事業方面需要主動出擊，不可過於被動等待。需特別注意腸胃問題，飲食規律對健康至關重要。</p>
      </div>

      <div class="zf-card fire">
        <div class="zf-head">
          <span class="zf-symbol">♌</span>
          <div><div class="zf-name">獅子座</div><div class="zf-date">7/23 – 8/22　火象　守護星：太陽</div></div>
        </div>
        <p>獅子座由太陽守護，象徵自信、光芒與統御力。獅子座的人天生喜歡成為焦點，具有強烈的表現慾與創造力，慷慨大方，對朋友忠誠可靠。在感情方面，獅子座需要被崇拜與認可，懂得欣賞他們的伴侶才能讓這段感情長久。在職業上，獅子座適合從事演藝、管理、設計、政治或任何需要展現個人魅力的領域。今年獅子座的創意運與表現運達到高峰，適合展現才華或推出個人品牌；感情上若能放下自我中心，願意傾聽伴侶，關係將有質的飛躍。心臟與脊椎是獅子座需要特別保養的部位。</p>
      </div>

      <div class="zf-card earth">
        <div class="zf-head">
          <span class="zf-symbol">♍</span>
          <div><div class="zf-name">處女座</div><div class="zf-date">8/23 – 9/22　土象　守護星：水星</div></div>
        </div>
        <p>處女座同樣由水星守護，象徵分析、完美與服務精神。處女座的人心思縝密，注重細節，對自己與他人都有很高的要求標準，是十二星座中最具批判性思維的星座。在感情方面，處女座內斂含蓄，不擅長表達情感，但內心充滿溫柔，一旦確定關係便會全力付出。在職業上，處女座適合從事醫療、研究、會計、編輯或任何需要嚴謹分析的工作。今年處女座在工作效率上表現卓越，適合完成複雜的長期項目；感情方面需降低完美主義傾向，接受伴侶的不完美，關係才能更輕鬆。消化系統是處女座的健康弱點，飲食習慣影響整體狀況甚鉅。</p>
      </div>

      <div class="zf-card air">
        <div class="zf-head">
          <span class="zf-symbol">♎</span>
          <div><div class="zf-name">天秤座</div><div class="zf-date">9/23 – 10/22　風象　守護星：金星</div></div>
        </div>
