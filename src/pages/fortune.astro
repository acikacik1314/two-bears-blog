  const WX_COLOR: Record<string,string>={木:'#4ade80',火:'#f87171',土:'#fbbf24',金:'#e2e8f0',水:'#60a5fa'};
  const GAN_COLOR = ['#4ade80','#86efac','#f87171','#fca5a5','#fbbf24','#fde68a','#e2e8f0','#cbd5e1','#60a5fa','#93c5fd'];

  /* ── 計算按鈕 ── */
  document.getElementById('fp-calc')?.addEventListener('click', () => {
    const dv = (document.getElementById('fp-bdate') as HTMLInputElement).value;
