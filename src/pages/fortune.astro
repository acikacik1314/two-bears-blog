    if(bz===cz) return {level:'⚠️ 值太歲',color:'#f59e0b',tip:'今年是你的本命年，太歲當頭坐，喜事多也是非多。建議行事謹慎，避免大投資、大變動，可佩戴紅色護身物品化煞，廣行善事以積累福德。'};
    const COMBINE: Record<string,string>={鼠:'牛',虎:'豬',兔:'狗',龍:'雞',馬:'羊',猴:'蛇'};
    if(COMBINE[bz]===cz||COMBINE[cz]===bz) return {level:'🟢 六合年',color:'#22c55e',tip:'今年與太歲六合，整體運勢和諧順遂，貴人相助，諸事易成。適合推進重要計畫、深化人際關係，把握機遇積極進取。'};
    return {level:'🔵 平順年',color:'#60a5fa',tip:'今年太歲與你無特殊衝突，整體運勢平穩向上。適合穩紮穩打，推進長期計畫，在原有基礎上持續累積實力。'};
  }
  const ZODIAC_LUCKY: Record<string,{color:string,num:string,dir:string,stone:string}> = {
    鼠:{color:'藍色、金色',num:'2、3',dir:'北方',stone:'石榴石'},牛:{color:'白色、黃色',num:'1、4',dir:'東北',stone:'翡翠'},
