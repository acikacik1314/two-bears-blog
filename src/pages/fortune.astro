<script>
  /* ── 基礎算法 ── */
  const TIAN_GAN = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
  const DI_ZHI   = ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
  const ZODIAC   = ['鼠','牛','虎','兔','龍','蛇','馬','羊','猴','雞','狗','豬'];
  const WUXING_TG = ['木','木','火','火','土','土','金','金','水','水'];

  function getYearPillar(y: number) {
    return { gan: TIAN_GAN[((y-4)%10+10)%10], zhi: DI_ZHI[((y-4)%12+12)%12], ganIdx: ((y-4)%10+10)%10, zhiIdx: ((y-4)%12+12)%12 };
  }
  function getDayPillar(y: number, mo: number, d: number) {
    const diff = Math.floor((new Date(y,mo-1,d).getTime()-new Date(2000,0,1).getTime())/86400000);
    const n = ((40+diff)%60+60)%60;
    return { gan: TIAN_GAN[n%10], zhi: DI_ZHI[n%12], ganIdx: n%10, zhiIdx: n%12 };
  }
  function getMonthPillar(y: number, mo: number) {
    const zi = ((mo+1)%12); const ygi = ((y-4)%10+10)%10;
    const starts = [2,4,6,8,0]; const gi = (starts[ygi%5]+zi-2+60)%10;
    return { gan: TIAN_GAN[gi], zhi: DI_ZHI[zi], ganIdx: gi, zhiIdx: zi };
  }
  function getHourPillar(dgi: number, hb: number) {
    const starts = [0,2,4,6,8]; return { gan: TIAN_GAN[(starts[dgi%5]+hb)%10], zhi: DI_ZHI[hb], ganIdx: (starts[dgi%5]+hb)%10, zhiIdx: hb };
  }
  function getZodiac(y: number) { return ZODIAC[((y-4)%12+12)%12]; }
  function getWesternSign(mo: number, d: number) {
    const S=[['摩羯',1,1],['水瓶',1,20],['雙魚',2,19],['白羊',3,21],['金牛',4,20],['雙子',5,21],['巨蟹',6,21],['獅子',7,23],['處女',8,23],['天秤',9,23],['天蠍',10,23],['射手',11,22],['摩羯',12,22]] as [string,number,number][];
    let sign='摩羯'; for(const [n,m,day] of S){ if(mo>m||(mo===m&&d>=day)) sign=n; } return sign;
  }
  function getWesternSignSymbol(name: string) {
    const M: Record<string,string>={白羊:'♈',金牛:'♉',雙子:'♊',巨蟹:'♋',獅子:'♌',處女:'♍',天秤:'♎',天蠍:'♏',射手:'♐',摩羯:'♑',水瓶:'♒',雙魚:'♓'};
    return M[name]??'⭐';
  }
  function getElement(sign: string) {
    const fire=['白羊','獅子','射手']; const earth=['金牛','處女','摩羯']; const air=['雙子','天秤','水瓶'];
    if(fire.includes(sign)) return '🔥 火象'; if(earth.includes(sign)) return '🌍 土象'; if(air.includes(sign)) return '💨 風象'; return '💧 水象';
  }
  function countWuxing(pillars: {ganIdx:number}[]) {
    const c: Record<string,number>={木:0,火:0,土:0,金:0,水:0};
    for(const p of pillars){ const w=WUXING_TG[p.ganIdx]; c[w]=(c[w]??0)+1; } return c;
  }
  function getPalace(mo: number, hb: number) {
    const zi = ((14-mo-hb)%12+12)%12;
    const DESC: Record<string,{star:string,title:string,desc:string}> = {
      子:{star:'天機',title:'謀略之宮',desc:'命主思維靈活，善於策略規劃，適合幕後運籌帷幄。貴人緣佳，但需防止想太多而錯失行動時機。'},
      丑:{star:'天相',title:'輔佐之宮',desc:'命主穩重踏實，重視規則秩序，具有良好的執行力與服務精神。財運穩定，適合擔任管理或行政職務。'},
      寅:{star:'七殺',title:'將帥之宮',desc:'命主個性剛烈，獨立不群，具有強烈的開創精神。適合挑戰性高的工作，但需學會團隊合作。'},
      卯:{star:'太陽',title:'光明之宮',desc:'命主熱情外向，正義感強，貴人運極佳。事業上容易得到上司賞識，適合公眾性工作。'},
      辰:{star:'紫微',title:'帝王之宮',desc:'命帶紫微帝星，天生具有領袖氣質與統御能力。自尊心強，適合擔任領導職，但需學習謙遜。'},
      巳:{star:'天府',title:'財庫之宮',desc:'命主保守穩健，財庫豐厚，一生衣食無虞。重視家庭與安全感，適合長期規劃的工作。'},
      午:{star:'廉貞',title:'才藝之宮',desc:'命主感情豐富，才華出眾，藝術天分高。適合創意藝術或娛樂業，感情路上多彩多姿。'},
      未:{star:'太陰',title:'陰柔之宮',desc:'命主感性直覺強，夜型人，精神世界豐富。女性緣佳，適合靈性、藝術或輔導相關工作。'},
      申:{star:'貪狼',title:'桃花之宮',desc:'命主多才多藝，享受生活，桃花旺盛。社交能力極強，適合業務、公關或娛樂行業。'},
