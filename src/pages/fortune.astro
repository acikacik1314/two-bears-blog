---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="zh-TW">
<head>
  <BaseHead title="命理分析中心 — 兩隻熊" description="AI驅動的西洋星座、紫微斗數、卜卦易經綜合命理分析" />
</head>
<body>
<Header />
<main class="fp-main">

  <div class="fp-hero">
    <div class="fp-badge">✦ AI 命理分析中心</div>
    <h1>🔮 命理分析中心</h1>
    <p class="fp-sub">整合西洋星座・紫微斗數・卜卦易經<br/>輸入資料即獲 AI 量身直斷</p>
  </div>

  <!-- ══════════════ 綜合命理分析 ══════════════ -->
  <section class="ft-section">
    <div class="ft-sec-title">✨ 綜合命理分析</div>

    <div class="ft-form">
      <div class="ft-row">
        <div class="ft-field">
          <label>姓名（選填）</label>
          <input type="text" id="ft-name" placeholder="你的名字" maxlength="20" />
        </div>
        <div class="ft-field">
          <label>出生年月日 *</label>
          <input type="date" id="ft-bdate" required />
        </div>
        <div class="ft-field">
          <label>出生時辰（選填）</label>
          <select id="ft-hour">
            <option value="-1">不知道</option>
            <option value="0">子時 23:00–01:00</option>
            <option value="1">丑時 01:00–03:00</option>
            <option value="2">寅時 03:00–05:00</option>
            <option value="3">卯時 05:00–07:00</option>
            <option value="4">辰時 07:00–09:00</option>
            <option value="5">巳時 09:00–11:00</option>
            <option value="6">午時 11:00–13:00</option>
            <option value="7">未時 13:00–15:00</option>
            <option value="8">申時 15:00–17:00</option>
            <option value="9">酉時 17:00–19:00</option>
            <option value="10">戌時 19:00–21:00</option>
            <option value="11">亥時 21:00–23:00</option>
          </select>
        </div>
      </div>
      <button class="ft-btn" id="ft-submit">✨ 開始分析</button>
    </div>

    <div class="ft-result" id="ft-result" style="display:none">
      <div class="ft-result-header">
        <span class="ft-result-icon">🔮</span>
        <span class="ft-result-label" id="ft-result-label">專屬你的亂世流年直斷</span>
      </div>
      <div class="ft-result-body" id="ft-result-body"></div>
    </div>

    <p class="ft-note">✦ 本工具僅供娛樂參考，不代表真實命理占卜</p>
  </section>

  <!-- ══════════════ 卜卦易經 ══════════════ -->
  <section class="ft-section ft-section-iching">
    <div class="ft-sec-title">🔯 卜卦易經</div>
    <p class="ft-sec-sub">心誠則靈，靜心一問，AI 以易經智慧直接指點迷津</p>

    <div class="ft-form">
      <div class="ft-field ft-field-full">
        <label>你的問題（選填，不填則問整體運勢）</label>
        <input type="text" id="ic-question" placeholder="例：這次創業會成功嗎？" maxlength="60" />
      </div>
      <button class="ft-btn ft-btn-iching" id="ic-cast">🎲 擲卦</button>
    </div>

    <div class="ft-result" id="ic-result" style="display:none">
      <div class="ft-result-header">
        <span class="ic-dice" id="ic-dice">🎲</span>
        <span class="ft-result-label">易經直斷</span>
      </div>
      <div class="ft-result-body" id="ic-result-body"></div>
    </div>
  </section>

</main>
<Footer />
</body>
</html>

<script>
  /* ── 綜合命理分析 ── */
  document.getElementById('ft-submit')?.addEventListener('click', async () => {
    const bdate = (document.getElementById('ft-bdate') as HTMLInputElement).value
    if (!bdate) { alert('請輸入出生年月日'); return }

    const name  = (document.getElementById('ft-name') as HTMLInputElement).value
    const hour  = parseInt((document.getElementById('ft-hour') as HTMLSelectElement).value)
    const btn   = document.getElementById('ft-submit') as HTMLButtonElement
    const res   = document.getElementById('ft-result')!
    const body  = document.getElementById('ft-result-body')!
    const label = document.getElementById('ft-result-label')!

    btn.disabled = true
    btn.textContent = '⏳ AI 解析中…'
    res.style.display = 'none'

    try {
      const r = await fetch('/api/fortune-analysis', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, birthday: bdate, hour }),
      })
      const d = await r.json()

      const nameStr = name.trim() || '你'
      label.textContent = `🔮 ${nameStr} 的專屬命理直斷`
      body.innerHTML = formatText(d.answer ?? '無法獲得回應，請稍後再試。')
      res.style.display = 'block'
      res.scrollIntoView({ behavior: 'smooth', block: 'start' })
    } catch {
      body.innerHTML = '<p style="color:#991b1b">⚠️ 連線失敗，請稍後再試。</p>'
      res.style.display = 'block'
    } finally {
      btn.disabled = false
      btn.textContent = '✨ 開始分析'
    }
  })

  /* ── 卜卦易經 ── */
  document.getElementById('ic-cast')?.addEventListener('click', async () => {
    const question = (document.getElementById('ic-question') as HTMLInputElement).value
    const btn      = document.getElementById('ic-cast') as HTMLButtonElement
    const res      = document.getElementById('ic-result')!
    const body     = document.getElementById('ic-result-body')!
    const dice     = document.getElementById('ic-dice')!

    btn.disabled = true
    btn.textContent = '🎲 擲卦中…'
    res.style.display = 'none'

    // Dice rolling animation
    const DICE_FRAMES = ['⚀','⚁','⚂','⚃','⚄','⚅']
    let frame = 0
    const anim = setInterval(() => {
      dice.textContent = DICE_FRAMES[frame % DICE_FRAMES.length]
      frame++
    }, 100)

    try {
      const r = await fetch('/api/iching-cast', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question }),
      })
      const d = await r.json()

      clearInterval(anim)
      dice.textContent = '☯'
      body.innerHTML = formatText(d.answer ?? '無法獲得回應，請稍後再試。')
      res.style.display = 'block'
      res.scrollIntoView({ behavior: 'smooth', block: 'start' })
    } catch {
      clearInterval(anim)
      dice.textContent = '🎲'
      body.innerHTML = '<p style="color:#991b1b">⚠️ 連線失敗，請稍後再試。</p>'
      res.style.display = 'block'
    } finally {
      btn.disabled = false
      btn.textContent = '🎲 擲卦'
    }
  })

  function formatText(text: string): string {
    return text
      .split('\n')
      .map(line => line.trim())
      .filter(Boolean)
      .map(line => `<p>${line}</p>`)
      .join('')
  }
</script>

<style>
  .fp-main {
    max-width: 720px;
    margin: auto;
    padding: 2em 1.2em 5em;
  }

  .fp-hero {
    text-align: center;
    padding: 2.5em 0 2em;
  }

  .fp-badge {
    display: inline-block;
    font-size: 0.72em;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #7e22ce;
    background: rgba(126,34,206,.08);
    border: 1px solid rgba(126,34,206,.2);
    border-radius: 20px;
    padding: 0.3em 1em;
    margin-bottom: 0.8em;
  }

  .fp-hero h1 {
    font-size: 2em;
    margin: 0 0 0.3em;
    background: linear-gradient(135deg, #7e22ce, #db2777);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .fp-sub {
    color: #64748b;
    font-size: 0.9em;
    line-height: 1.7;
    margin: 0;
  }

  /* Sections */
  .ft-section {
    background: #fff;
    border: 1px solid rgba(126,34,206,.15);
    border-left: 4px solid #7e22ce;
    border-radius: 14px;
    padding: 1.8em 2em;
    margin-bottom: 2em;
  }

  .ft-section-iching {
    border-left-color: #0ea5e9;
  }

  .ft-sec-title {
    font-size: 1.1em;
    font-weight: 800;
    color: #1e1b4b;
    margin-bottom: 0.3em;
  }

  .ft-sec-sub {
    font-size: 0.82em;
    color: #64748b;
    margin: 0 0 1.2em;
  }

  /* Form */
  .ft-form { margin-top: 1.2em; }

  .ft-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.8em;
    margin-bottom: 1em;
  }

  .ft-field { display: flex; flex-direction: column; gap: 0.3em; }
  .ft-field-full { margin-bottom: 1em; }

  .ft-field label {
    font-size: 0.78em;
    font-weight: 600;
    color: #374151;
  }

  .ft-field input,
  .ft-field select {
    padding: 0.55em 0.75em;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    font-size: 0.88em;
    font-family: inherit;
    background: #f9fafb;
    color: #111827;
    transition: border-color .15s;
    width: 100%;
    box-sizing: border-box;
  }

  .ft-field input:focus,
  .ft-field select:focus {
    outline: none;
    border-color: #7e22ce;
    background: #fff;
  }

  .ft-btn {
    padding: 0.7em 2em;
    background: linear-gradient(135deg, #7e22ce, #a855f7);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 0.95em;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: opacity .15s;
  }

  .ft-btn-iching {
    background: linear-gradient(135deg, #0ea5e9, #38bdf8);
  }

  .ft-btn:hover { opacity: 0.88; }
  .ft-btn:disabled { opacity: 0.55; cursor: not-allowed; }

  .ft-note {
    font-size: 0.72em;
    color: #9ca3af;
    margin-top: 1em;
  }

  /* Result */
  .ft-result {
    margin-top: 1.5em;
    background: linear-gradient(135deg, rgba(88,28,135,.05), rgba(219,39,119,.03));
    border: 1px solid rgba(126,34,206,.18);
    border-radius: 12px;
    padding: 1.4em 1.6em;
    animation: fadeIn .4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ft-result-header {
    display: flex;
    align-items: center;
    gap: 0.5em;
    margin-bottom: 1em;
  }

  .ft-result-icon { font-size: 1.3em; }

  .ic-dice {
    font-size: 1.5em;
    display: inline-block;
    transition: transform .1s;
  }

  .ft-result-label {
    font-size: 0.9em;
    font-weight: 800;
    color: #1e1b4b;
  }

  .ft-result-body {
    font-size: 0.9em;
    line-height: 1.85;
    color: #1e293b;
  }

  .ft-result-body :global(p) {
    margin: 0 0 0.7em;
  }

  @media (max-width: 600px) {
    .ft-section { padding: 1.2em 1.1em; }
    .ft-row { grid-template-columns: 1fr; }
  }
</style>
