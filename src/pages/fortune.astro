    馬:{color:'紫色、黃色',num:'2、3',dir:'南方',stone:'黃水晶'},羊:{color:'綠色、紅色',num:'3、9',dir:'南方',stone:'紫水晶'},
    猴:{color:'白色、藍色',num:'4、9',dir:'西北',stone:'矽孔雀石'},雞:{color:'金色、棕色',num:'5、7',dir:'西方',stone:'碧玉'},
    狗:{color:'紅色、綠色',num:'3、4',dir:'東方',stone:'鑽石'},豬:{color:'黃色、灰色',num:'2、5',dir:'東南',stone:'月光石'},
