    };
    return { zhi: DI_ZHI[zi], ...DESC[DI_ZHI[zi]] };
  }
  function getYearLuck(by: number, cy: number) {
    const bz=getZodiac(by); const cz=getZodiac(cy);
    const CLASH: Record<string,string>={鼠:'馬',牛:'羊',虎:'猴',兔:'雞',龍:'狗',蛇:'豬',馬:'鼠',羊:'牛',猴:'虎',雞:'兔',狗:'龍',豬:'蛇'};
