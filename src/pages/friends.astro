---
export const prerender = false;
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead
      title="先行者聯盟 · 情報交換站 — 兩隻熊"
      description="先行者聯盟是一個末日預言情報交換與互助社群，集結關注預言、未來趨勢與靈性分析的先行者。"
    />
  </head>
  <body class="alliance-page">
    <Header />
    <main class="alliance-main">

      <!-- ── Star canvas ── -->
      <canvas id="star-canvas" aria-hidden="true"></canvas>

      <!-- ══════════ HERO ══════════ -->
      <section class="al-hero">
        <div class="al-hero-badge">⬡ CLASSIFIED · EYES ONLY</div>
        <h1 class="al-hero-title">
          <span class="al-title-main">先行者聯盟</span>
          <span class="al-title-sub">· 情報交換站</span>
        </h1>
        <p class="al-hero-desc">
          亂世中，獨自清醒是孤獨的。<br/>
          這裡聚集了最早看穿局勢的人——<br/>
          我們交換情報、互相備戰、不留下任何人。
        </p>
        <div class="al-hero-stats" id="hero-stats">
          <div class="al-stat"><span class="al-stat-num" id="stat-members">-</span><span class="al-stat-lbl">聯盟成員</span></div>
          <div class="al-stat-div"></div>
          <div class="al-stat"><span class="al-stat-num" id="stat-online">🟢 即時</span><span class="al-stat-lbl">情報更新中</span></div>
          <div class="al-stat-div"></div>
          <div class="al-stat"><span class="al-stat-num">17</span><span class="al-stat-lbl">預言檔案</span></div>
        </div>
        <div class="al-hero-cta">
          <a href="https://t.me/twobearstw" target="_blank" rel="noopener" class="al-btn al-btn-primary">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.562 8.248l-2.018 9.516c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L6.68 14.49l-2.948-.924c-.64-.203-.653-.64.136-.948l11.527-4.447c.535-.194 1.002.13.167.077z"/></svg>
            加入 Telegram 社群
          </a>
          <a href="#join" class="al-btn al-btn-ghost">⬇ 留下你的情報檔案</a>
        </div>
        <p class="al-hero-warn">⚠ 重要生存訊息僅對聯盟成員開放 · 不要錯過每週情報彙整</p>
      </section>

      <!-- ══════════ BELIEF VOTE ══════════ -->
      <section class="al-section">
        <div class="al-section-label">📡 本週信念投票</div>
        <h2 class="al-section-title">你認為三戰在幾年內爆發？</h2>
        <div class="al-vote-wrap" id="belief-vote">
          <div class="al-vote-options" id="vote-options">
            <button class="al-vote-btn" data-vote="1y">1 年內</button>
            <button class="al-vote-btn" data-vote="3y">1–3 年</button>
            <button class="al-vote-btn" data-vote="5y">3–5 年</button>
            <button class="al-vote-btn" data-vote="never">不會發生</button>
          </div>
          <div class="al-vote-result" id="vote-result" style="display:none"></div>
          <div class="al-vote-total" id="vote-total"></div>
        </div>
      </section>

      <!-- ══════════ HOT TOPICS ══════════ -->
      <section class="al-section">
        <div class="al-section-label">🔥 熱門情報討論串</div>
        <h2 class="al-section-title">目前最受關注的預言分析</h2>
        <div class="al-topics">

          <a href="/blog/mcmoneagle-2026-end/" class="al-topic-card al-glow-green">
            <div class="al-topic-header">
              <span class="al-topic-badge al-badge-green">CIA 遙視</span>
              <span class="al-topic-hot">🔴 LIVE</span>
            </div>
            <h3 class="al-topic-title">美軍001號遙視者：四年內大國政府崩潰，三戰起點已鎖定</h3>
            <p class="al-topic-desc">麥克蒙尼格親口說——他用靈魂出體潛入中國機密設施，還預言了 2025 年北韓的愚蠢行動……</p>
            <div class="al-topic-meta">
              <span>👁 2.4k 查看</span>
              <span>💬 87 討論</span>
              <span>🕐 2天前更新</span>
            </div>
          </a>

          <a href="/blog/brandon-biggs-2026/" class="al-topic-card al-glow-amber">
            <div class="al-topic-header">
              <span class="al-topic-badge al-badge-amber">末日預言</span>
              <span class="al-topic-hot">🟠 HOT</span>
            </div>
            <h3 class="al-topic-title">比格斯警告：美元已完蛋、蚯蚓漢堡時代來臨、電網即將被攻擊</h3>
            <p class="al-topic-desc">他說「需求金字塔」正在被從底層攻擊——食物、水、溫暖都會被控制。你準備好了嗎？</p>
            <div class="al-topic-meta">
              <span>👁 3.1k 查看</span>
              <span>💬 134 討論</span>
              <span>🕐 1天前更新</span>
            </div>
          </a>

          <a href="/blog/craig-hamilton-parker-2026/" class="al-topic-card al-glow-blue">
            <div class="al-topic-header">
              <span class="al-topic-badge al-badge-blue">英國通靈</span>
            </div>
            <h3 class="al-topic-title">帕克驚爆：英國加拿大終將成為美國一部分，無限能源技術已存在</h3>
            <p class="al-topic-desc">他說「自由民主是病入膏肓的動物」。西方體制大洗牌、UFO古代技術即將公開……</p>
            <div class="al-topic-meta">
              <span>👁 1.8k 查看</span>
              <span>💬 62 討論</span>
              <span>🕐 1天前更新</span>
            </div>
          </a>

          <a href="/blog/2026-05-22-brandon-biggs-gray-matter-taiwan/" class="al-topic-card al-glow-red">
            <div class="al-topic-header">
              <span class="al-topic-badge al-badge-red">台灣局勢</span>
              <span class="al-topic-hot">⚠ 緊急</span>
            </div>
            <h3 class="al-topic-title">灰色物質降臨美東！比格斯：這就是中國動台灣的完美時機</h3>
            <p class="al-topic-desc">美國東海岸被神秘物質覆蓋時，台海危機同步爆發。「閃電戰・48小時・台灣領導層直接被換掉」……</p>
            <div class="al-topic-meta">
              <span>👁 4.2k 查看</span>
              <span>💬 211 討論</span>
              <span>🕐 3天前更新</span>
            </div>
          </a>

        </div>
      </section>

      <!-- ══════════ REGIONAL MAP ══════════ -->
      <section class="al-section">
        <div class="al-section-label">🗺 地區互助網絡</div>
        <h2 class="al-section-title">認領你的地區，建立本地聯盟小組</h2>
        <p class="al-section-desc">在大事發生前，本地情報網比任何東西都重要。點擊你的地區，留下你的聯繫。</p>
        <div class="al-regions" id="region-grid"></div>
        <p class="al-region-note">✦ 地區資料僅供媒合，不會儲存個人資訊</p>
      </section>

      <!-- ══════════ CHECK-IN ══════════ -->
      <section class="al-section al-checkin-section">
        <div class="al-checkin-inner">
          <div class="al-checkin-left">
            <div class="al-section-label">⚡ 每日簽到</div>
            <h2 class="al-section-title" style="margin-bottom:.4em">先行者打卡</h2>
            <p class="al-section-desc" style="margin:0">保持警醒，每日簽到累積連續天數。</p>
          </div>
          <div class="al-checkin-right" id="checkin-area">
            <div class="al-checkin-streak" id="checkin-streak">
              <span class="al-streak-num" id="streak-num">-</span>
              <span class="al-streak-lbl">連續天數</span>
            </div>
            <button class="al-btn al-btn-checkin" id="checkin-btn">⚡ 今日簽到</button>
            <p class="al-checkin-status" id="checkin-status"></p>
          </div>
        </div>
      </section>

      <!-- ══════════ JOIN FORM ══════════ -->
      <section class="al-section" id="join">
        <div class="al-section-label">📁 建立你的情報檔案</div>
        <h2 class="al-section-title">加入先行者聯盟</h2>
        <p class="al-section-desc">留下你的情報檔案，讓同頻的人找到你。我們不需要你的真名，只需要你的洞察。</p>

        <div class="al-form-card">
          <form id="alliance-form">
            <div class="al-form-grid">
              <div class="al-field">
                <label>代號 <span class="al-req">*</span></label>
                <input type="text" name="nickname" maxlength="20" placeholder="你的代號（最多20字）" required />
              </div>
              <div class="al-field">
                <label>地區</label>
                <input type="text" name="location" maxlength="20" placeholder="例：台北、高雄、海外" />
              </div>
              <div class="al-field">
                <label>性別</label>
                <select name="gender">
                  <option value="">不透露</option>
                  <option>男</option>
                  <option>女</option>
                  <option>非二元</option>
                </select>
              </div>
              <div class="al-field">
                <label>年齡</label>
                <input type="text" name="age" maxlength="10" placeholder="例：28歲" />
              </div>
            </div>
            <div class="al-field">
              <label>關注領域</label>
              <input type="text" name="interests" maxlength="80" placeholder="例：末日備戰、靈性修行、台海局勢、XRP..." />
            </div>
            <div class="al-field">
              <label>尋找同伴類型</label>
              <input type="text" name="lookingFor" maxlength="60" placeholder="例：同城備戰夥伴、靈性討論對象..." />
            </div>
            <div class="al-field">
              <label>情報簡報 <span class="al-req">*</span></label>
              <textarea name="intro" maxlength="200" rows="3" placeholder="說說你對目前局勢的判斷，或你在關注什麼……（最多200字）" required></textarea>
            </div>
            <div class="al-field">
              <label>聯絡方式</label>
              <input type="text" name="contact" maxlength="60" placeholder="IG、Telegram、LINE（自願填寫）" />
            </div>
            <div class="al-form-footer">
              <p class="al-disclaimer">⬡ 請勿填寫真實姓名。本站為開放式社群，請自行判斷資訊安全。</p>
              <button type="submit" class="al-btn al-btn-primary" id="submit-btn">📡 發佈情報檔案</button>
            </div>
            <p class="al-form-status" id="form-status"></p>
          </form>
        </div>
      </section>

      <!-- ══════════ MEMBERS ══════════ -->
      <section class="al-section">
        <div class="al-section-label" style="display:flex;align-items:center;justify-content:space-between">
          <span>👥 聯盟成員檔案</span>
          <span id="member-count-badge" class="al-count-badge">載入中…</span>
        </div>
        <div id="profiles-container" class="al-profiles"></div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<script>
/* ═══ TYPES ═══ */
interface Comment { id: string; text: string; time: string; }
interface Profile {
  id: string; nickname: string; age: string; gender: string;
  location: string; interests: string; lookingFor: string;
  intro: string; contact: string; createdAt: string; comments: Comment[];
}

/* ═══ STAR CANVAS ═══ */
(function initStars() {
  const canvas = document.getElementById('star-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  let stars: { x: number; y: number; r: number; o: number; d: number }[] = [];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function createStars() {
    stars = Array.from({ length: 160 }, () => ({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      r: Math.random() * 1.4 + 0.3,
      o: Math.random(),
      d: (Math.random() * 0.004 + 0.001) * (Math.random() > 0.5 ? 1 : -1),
    }));
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach(s => {
      s.o += s.d;
      if (s.o > 1 || s.o < 0.1) s.d *= -1;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(180,160,255,${s.o})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }

  resize();
  createStars();
  draw();
  window.addEventListener('resize', () => { resize(); createStars(); });
})();

/* ═══ BELIEF VOTE ═══ */
(function initVote() {
  const VOTE_KEY = 'al_belief_vote_ww3';
  const LABELS: Record<string, string> = { '1y': '1 年內', '3y': '1–3 年', '5y': '3–5 年', 'never': '不會發生' };
  const COLORS: Record<string, string> = { '1y': '#ef4444', '3y': '#f59e0b', '5y': '#10b981', 'never': '#3b82f6' };

  const stored = localStorage.getItem(VOTE_KEY);
  if (stored) showVoteResult(JSON.parse(stored).vote);

  document.querySelectorAll('.al-vote-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const vote = (btn as HTMLElement).dataset.vote!;
      const existing = JSON.parse(localStorage.getItem(VOTE_KEY) || 'null');
      if (existing) return;

      // Simulated community totals
      const base: Record<string, number> = { '1y': 342, '3y': 589, '5y': 201, 'never': 87 };
      base[vote]++;
      localStorage.setItem(VOTE_KEY, JSON.stringify({ vote, totals: base }));
      showVoteResult(vote, base);
    });
  });

  function showVoteResult(myVote: string, totals?: Record<string, number>) {
    const opts = document.getElementById('vote-options');
    const res = document.getElementById('vote-result');
    const tot = document.getElementById('vote-total');
    if (!opts || !res) return;

    const t = totals ?? JSON.parse(localStorage.getItem(VOTE_KEY) || '{}').totals ?? { '1y': 342, '3y': 589, '5y': 201, 'never': 87 };
    const total = Object.values(t).reduce((a: number, b: number) => a + b, 0);

    opts.style.display = 'none';
    res.style.display = 'block';
    res.innerHTML = Object.entries(LABELS).map(([k, lbl]) => {
      const pct = Math.round((t[k] / total) * 100);
      const isMine = k === myVote;
      return `<div class="al-vbar-row${isMine ? ' al-vbar-mine' : ''}">
        <span class="al-vbar-lbl">${isMine ? '▶ ' : ''}${lbl}</span>
        <div class="al-vbar-wrap">
          <div class="al-vbar-fill" style="width:${pct}%;background:${COLORS[k]}22;border-right:2px solid ${COLORS[k]}"></div>
        </div>
        <span class="al-vbar-pct" style="color:${COLORS[k]}">${pct}%</span>
      </div>`;
    }).join('');
    if (tot) tot.textContent = `共 ${total.toLocaleString()} 位先行者投票`;
  }
})();

/* ═══ REGIONAL MAP ═══ */
(function initRegions() {
  const REGIONS = [
    '台北', '新北', '桃園', '新竹', '台中', '彰化', '南投', '雲林',
    '嘉義', '台南', '高雄', '屏東', '宜蘭', '花蓮', '台東', '澎湖',
    '金門', '馬祖', '海外', '其他',
  ];
  const KEY = 'al_region';
  const COUNTS: Record<string, number> = {
    '台北': 47, '新北': 38, '桃園': 29, '台中': 31, '高雄': 24,
    '新竹': 18, '台南': 21, '彰化': 12, '海外': 35,
  };

  const grid = document.getElementById('region-grid');
  if (!grid) return;
  const myRegion = localStorage.getItem(KEY);

  grid.innerHTML = REGIONS.map(r => {
    const count = COUNTS[r] ?? Math.floor(Math.random() * 8) + 1;
    const mine = r === myRegion;
    return `<button class="al-region-btn${mine ? ' al-region-mine' : ''}" data-region="${r}">
      <span class="al-region-name">${r}</span>
      <span class="al-region-count">${mine ? '✓ 你在這' : `${count} 人`}</span>
    </button>`;
  }).join('');

  grid.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest('[data-region]') as HTMLElement | null;
    if (!btn) return;
    const region = btn.dataset.region!;
    if (localStorage.getItem(KEY) === region) return;
    localStorage.setItem(KEY, region);
    grid.querySelectorAll('.al-region-btn').forEach(b => {
      b.classList.remove('al-region-mine');
      const c = (b as HTMLElement).dataset.region!;
      const cnt = b.querySelector('.al-region-count')!;
      cnt.textContent = `${COUNTS[c] ?? 3} 人`;
    });
    btn.classList.add('al-region-mine');
    btn.querySelector('.al-region-count')!.textContent = '✓ 你在這';
  });
})();

/* ═══ CHECK-IN ═══ */
(function initCheckin() {
  const KEY_LAST = 'al_checkin_last';
  const KEY_STREAK = 'al_checkin_streak';
  const btn = document.getElementById('checkin-btn') as HTMLButtonElement;
  const statusEl = document.getElementById('checkin-status');
  const numEl = document.getElementById('streak-num');

  const streak = parseInt(localStorage.getItem(KEY_STREAK) ?? '0');
  if (numEl) numEl.textContent = streak.toString();

  const last = localStorage.getItem(KEY_LAST);
  const today = new Date().toDateString();
  const yesterday = new Date(Date.now() - 86400000).toDateString();

  if (last === today) {
    if (btn) { btn.textContent = '✅ 今日已簽到'; btn.disabled = true; }
    if (statusEl) statusEl.textContent = `連續 ${streak} 天 — 保持警醒！`;
  }

  btn?.addEventListener('click', () => {
    const now = new Date().toDateString();
    const prev = localStorage.getItem(KEY_LAST);
    let s = parseInt(localStorage.getItem(KEY_STREAK) ?? '0');
    if (prev === new Date(Date.now() - 86400000).toDateString()) s++;
    else if (prev !== now) s = 1;

    localStorage.setItem(KEY_LAST, now);
    localStorage.setItem(KEY_STREAK, s.toString());
    if (numEl) numEl.textContent = s.toString();
    btn.textContent = '✅ 今日已簽到';
    btn.disabled = true;
    if (statusEl) statusEl.textContent = `連續 ${s} 天 — 先行者保持警醒！`;
  });
})();

/* ═══ FRIENDS API ═══ */
function esc(s: string): string {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

const COLORS = ['#7c3aed','#2563eb','#059669','#dc2626','#d97706','#0891b2','#c026d3'];
function avatarColor(id: string): string {
  let h = 0;
  for (const c of id) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return COLORS[Math.abs(h) % COLORS.length];
}

function renderProfile(p: Profile): string {
  const tags = [p.age, p.gender, p.location].filter(Boolean)
    .map(t => `<span class="al-ptag">${t}</span>`).join('');

  const cmts = p.comments.length
    ? p.comments.map(c => `<div class="al-cmt"><span class="al-cmt-time">${c.time}</span><span class="al-cmt-text">${esc(c.text)}</span></div>`).join('')
    : '<p class="al-cmt-empty">成為第一個回應的先行者</p>';

  return `<div class="al-profile" data-id="${p.id}">
    <div class="al-profile-hd" onclick="toggleP('${p.id}')">
      <div class="al-avatar" style="background:${avatarColor(p.id)}">${p.nickname.charAt(0).toUpperCase()}</div>
      <div class="al-profile-info">
        <span class="al-profile-name">${esc(p.nickname)}</span>
        <div class="al-profile-tags">${tags}</div>
        ${p.interests ? `<div class="al-profile-int">⬡ ${esc(p.interests)}</div>` : ''}
      </div>
      <div class="al-profile-right">
        <span class="al-cmt-cnt">💬 ${p.comments.length}</span>
        <span class="al-expand" id="icon-${p.id}">▼</span>
      </div>
    </div>
    <div class="al-profile-bd" id="body-${p.id}" style="display:none">
      <div class="al-profile-intro">${esc(p.intro)}</div>
      ${p.lookingFor ? `<div class="al-profile-looking"><span>尋找：</span>${esc(p.lookingFor)}</div>` : ''}
      ${p.contact ? `<div class="al-profile-contact">📡 ${esc(p.contact)}</div>` : ''}
      <div class="al-profile-date">🕐 ${p.createdAt}</div>
      <div class="al-cmts-wrap">
        <div class="al-cmts-label">回應電文</div>
        <div class="al-cmts-list" id="cmts-${p.id}">${cmts}</div>
        <div class="al-cmt-form">
          <input class="al-cmt-input" id="ci-${p.id}" maxlength="100" placeholder="回應此情報（最多100字）…" />
          <button class="al-cmt-btn" onclick="sendCmt('${p.id}')">發送</button>
        </div>
        <p class="al-cmt-status" id="cs-${p.id}"></p>
      </div>
    </div>
  </div>`;
}

(window as any).toggleP = function(id: string) {
  const body = document.getElementById(`body-${id}`);
  const icon = document.getElementById(`icon-${id}`);
  if (!body) return;
  const open = body.style.display === 'none';
  body.style.display = open ? 'block' : 'none';
  if (icon) icon.textContent = open ? '▲' : '▼';
};

(window as any).sendCmt = async function(pid: string) {
  const input = document.getElementById(`ci-${pid}`) as HTMLInputElement;
  const status = document.getElementById(`cs-${pid}`);
  if (!input) return;
  const text = input.value.trim();
  if (!text) return;
  try {
    const r = await fetch('/api/friends', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'comment', profileId: pid, text }),
    });
    const d = await r.json();
    if (d.ok) {
      input.value = '';
      const list = document.getElementById(`cmts-${pid}`);
      if (list) {
        list.querySelector('.al-cmt-empty')?.remove();
        const div = document.createElement('div');
        div.className = 'al-cmt';
        div.innerHTML = `<span class="al-cmt-time">${d.comment.time}</span><span class="al-cmt-text">${esc(d.comment.text)}</span>`;
        list.appendChild(div);
      }
      const card = document.querySelector(`.al-profile[data-id="${pid}"]`);
      const cnt = card?.querySelector('.al-cmt-cnt');
      if (cnt) cnt.textContent = `💬 ${parseInt(cnt.textContent?.replace(/\D/g,'') ?? '0') + 1}`;
      if (status) { status.textContent = '✓ 電文發送成功'; setTimeout(() => { if (status) status.textContent=''; }, 3000); }
    }
  } catch { /* ignore */ }
};

async function loadProfiles() {
  const container = document.getElementById('profiles-container');
  const badge = document.getElementById('member-count-badge');
  const statEl = document.getElementById('stat-members');
  if (!container) return;
  try {
    const r = await fetch('/api/friends');
    const profiles: Profile[] = await r.json();
    if (badge) badge.textContent = `${profiles.length} 位成員`;
    if (statEl) statEl.textContent = (profiles.length + 1284).toString(); // adds simulated community size
    if (!profiles.length) {
      container.innerHTML = '<div class="al-empty">聯盟尚無成員檔案，成為第一位先行者！</div>';
      return;
    }
    container.innerHTML = profiles.map(renderProfile).join('');
  } catch {
    container.innerHTML = '<div class="al-empty">載入失敗，請重新整理頁面</div>';
  }
}

/* ═══ FORM SUBMIT ═══ */
const form = document.getElementById('alliance-form') as HTMLFormElement;
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
const formStatus = document.getElementById('form-status');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  submitBtn.disabled = true;
  submitBtn.textContent = '傳輸中…';
  const body = Object.fromEntries(new FormData(form).entries());
  try {
    const r = await fetch('/api/friends', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const d = await r.json();
    if (d.ok) {
      form.reset();
      if (formStatus) formStatus.textContent = '✓ 情報檔案已建立，歡迎加入聯盟！';
      loadProfiles();
    } else {
      if (formStatus) formStatus.textContent = d.error === 'board full' ? '聯盟成員已滿' : '發佈失敗，請確認必填欄位';
    }
  } catch {
    if (formStatus) formStatus.textContent = '連線失敗，請稍後再試';
  }
  submitBtn.disabled = false;
  submitBtn.textContent = '📡 發佈情報檔案';
});

loadProfiles();
</script>

