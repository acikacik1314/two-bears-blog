---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-Hant">
<head>
  <BaseHead
    title="🐻 兩隻熊超省飯店比價器｜同條件三平台查價"
    description="一鍵產生 Agoda、Booking.com、Trip.com 三平台「完全相同條件」的搜尋連結，自己看價、回填比價，找出真正最便宜的住宿。"
  />
</head>
<body>
  <Header />

  <main class="wrap">

    <!-- ============ HERO ============ -->
    <header class="hero">
      <p class="hero-eyebrow">兩隻熊的旅遊記事 · 省錢工具</p>
      <h1>同條件 <span class="amber">三平台</span> 查價</h1>
      <p class="hero-sub">
        朋友，比價網站常常「比個寂寞」——日期不同、稅費不同、房型不同，根本沒得比。<br />
        這裡幫你把<strong>同一個目的地、同一組日期、同樣人數和星級</strong>，一次帶到三個平台，<br class="desktop-only" />
        打開就是公平對照，再用下面的比價器算出誰最便宜。
      </p>
    </header>

    <!-- ============ 熊熊精選 ============ -->
    <section class="card picks-card" id="picks">
      <h2>🐻 熊熊精選</h2>
      <p class="muted">不是演算法排序，是兩隻熊一間一間挑出來的。點「比最低價」直接看這間在各平台的房價對照。</p>

      <div class="chips" id="pickCities" aria-label="精選城市"></div>
      <div class="picks-grid" id="pickList"></div>
    </section>

    <!-- ============ STEP 1 搜尋條件 ============ -->
    <section class="card" id="step1">
      <h2><span class="step-tag">步驟 1</span>設定你的旅程</h2>

      <div class="chips" id="hotCities" aria-label="熱門城市快選">
        <!-- JS 產生城市 chips -->
      </div>

      <div class="form-grid">
        <label class="field field-wide">
          <span>目的地</span>
          <input type="text" id="dest" placeholder="例如：東京、曼谷、台南…" autocomplete="off" />
        </label>

        <label class="field">
          <span>入住日期</span>
          <input type="date" id="checkin" />
        </label>

        <label class="field">
          <span>退房日期</span>
          <input type="date" id="checkout" />
        </label>

        <label class="field">
          <span>大人</span>
          <select id="adults">
            <option>1</option><option selected>2</option><option>3</option><option>4</option>
          </select>
        </label>

        <label class="field">
          <span>房間</span>
          <select id="rooms">
            <option selected>1</option><option>2</option>
          </select>
        </label>

        <fieldset class="field field-wide stars">
          <legend>星級（可複選）</legend>
          <label><input type="checkbox" value="3" checked /> ⭐⭐⭐ 三星</label>
          <label><input type="checkbox" value="4" checked /> ⭐⭐⭐⭐ 四星</label>
          <label><input type="checkbox" value="5" /> ⭐⭐⭐⭐⭐ 五星</label>
        </fieldset>
      </div>

      <button class="btn-primary" id="buildBtn" type="button">🔍 產生三平台查價連結</button>
      <p class="hint" id="formHint" hidden>請先填目的地和日期喔！</p>
    </section>

    <!-- ============ STEP 2 三平台連結 ============ -->
    <section class="card" id="step2" hidden>
      <h2><span class="step-tag">步驟 2</span>懶人比價：一頁看完各平台價格</h2>
      <p class="muted">點下面這張大卡片，在 TripAdvisor 搜到你的飯店後，<strong>同一頁就會列出 Agoda、Booking、Trip 等各家的房價對照</strong>，直接點最便宜的過去訂。</p>

      <a class="ta-featured" id="linkTa" target="_blank" rel="noopener sponsored">
        <div class="ta-left">
          <span class="ta-logo">🦉</span>
          <div>
            <span class="ta-name">TripAdvisor 比價</span>
            <span class="ta-desc">十多家訂房平台的價格，一頁比完</span>
          </div>
        </div>
        <span class="ta-cta">開始比價 →</span>
      </a>

      <h3 class="sub-title">或直接到偏好的平台（條件已幫你帶好）</h3>
      <p class="muted">三個連結帶<strong>完全相同的搜尋條件</strong>，都已按「價格由低到高」排序。Agoda 鐵粉直衝 Agoda 領 APP 價也完全 OK。</p>

      <div class="platforms">
        <a class="platform agoda" id="linkAgoda" target="_blank" rel="noopener sponsored">
          <div class="p-head"><span class="p-logo">🏨</span><span class="p-name">Agoda</span></div>
          <ul class="p-tips">
            <li>看到喜歡的，再用 <strong>APP 開同一間</strong>，常有 APP 限定價再省 3–10%</li>
            <li>顯示 TWD 含稅價，最後結帳前確認「總額」</li>
          </ul>
          <span class="p-cta">在 Agoda 查價 →</span>
        </a>

        <a class="platform booking" id="linkBooking" target="_blank" rel="noopener sponsored">
          <div class="p-head"><span class="p-logo">🛏️</span><span class="p-name">Booking.com</span></div>
          <ul class="p-tips">
            <li><strong>先登入</strong>再看價，Genius 等級折扣 10–20%</li>
            <li>行程還沒確定？認明「免費取消」再下訂</li>
          </ul>
          <span class="p-cta">在 Booking 查價 →</span>
        </a>

        <a class="platform trip" id="linkTrip" target="_blank" rel="noopener sponsored">
          <div class="p-head"><span class="p-logo">✈️</span><span class="p-name">Trip.com</span></div>
          <ul class="p-tips">
            <li>連住多晚、機+酒組合常有隱藏優惠</li>
            <li>注意部分低價房「不可退」，下訂前看清楚</li>
          </ul>
          <span class="p-cta">在 Trip 查價 →</span>
        </a>
      </div>

      <button class="btn-secondary" id="openAllBtn" type="button">⚡ 嘗試一鍵全開（瀏覽器可能擋彈窗）</button>
      <p class="hint" id="popupHint" hidden>有分頁被瀏覽器擋下來了——直接點上面三張卡片就一定打得開！</p>
    </section>

    <!-- ============ STEP 3 回填比價器 ============ -->
    <section class="card" id="step3" hidden>
      <h2><span class="step-tag">步驟 3</span>把看到的「總價」填回來，熊熊幫你算</h2>
      <p class="muted">填同一間飯店、同一種房型在三個平台的<strong>含稅總價（TWD）</strong>。沒查的平台留空就好。</p>

      <div class="compare-grid">
        <label class="field">
          <span>🏨 Agoda 總價</span>
          <input type="number" inputmode="numeric" min="0" id="priceAgoda" placeholder="例如 8800" />
        </label>
        <label class="field">
          <span>🛏️ Booking 總價</span>
          <input type="number" inputmode="numeric" min="0" id="priceBooking" placeholder="例如 9200" />
        </label>
        <label class="field">
          <span>✈️ Trip 總價</span>
          <input type="number" inputmode="numeric" min="0" id="priceTrip" placeholder="例如 8650" />
        </label>
      </div>

      <button class="btn-primary" id="compareBtn" type="button">🧮 算出最便宜的平台</button>

      <div class="result" id="result" hidden>
        <div class="result-stamp">🐻 最低價</div>
        <p class="result-winner" id="resultWinner"></p>
        <p class="result-detail" id="resultDetail"></p>
      </div>
    </section>

    <!-- ============ 省錢檢查清單 ============ -->
    <section class="card checklist">
      <h2>🍯 下訂前的最後檢查</h2>
      <ol>
        <li><strong>比「總價」不要比「每晚價」</strong>——稅、服務費、清潔費各平台算法不同，總額才是真相。</li>
        <li><strong>APP 再開一次</strong>——Agoda 和 Trip 的 APP 限定價常常比網頁便宜。</li>
        <li><strong>查飯店官網</strong>——日本商務旅館（東橫INN、APA）官網會員價有時最低。</li>
        <li><strong>取消條款</strong>——便宜 200 元但不可退，行程一變就虧大了。</li>
        <li><strong>用信用卡海外回饋</strong>——選對卡再省 2–3%。</li>
      </ol>
      <p class="disclosure">本頁連結為聯盟連結，透過連結訂房兩隻熊會獲得少量回饋，<strong>你的價格完全不受影響</strong>。謝謝朋友支持頻道 🐻🐻</p>
    </section>

  </main>

  <Footer />

  <script is:inline>
/* ====================================================================
   ⚙️ 設定區 —— 只需要改這裡
   ==================================================================== */
const AFFILIATE = {
  // Involve Asia 追蹤連結。深連結格式：追蹤連結 + ?t=<雙重編碼的目標網址>
  // （格式依據你後台產出的 TripAdvisor 深連結樣本：?t=https%253A%252F...）
  // ⚠️ 上線前每條都點一次，確認落地頁正確且網址帶有追蹤參數。

  // TripAdvisor（offer 2070）— 本頁的「真比價」主引擎
  tripadvisorTracking: 'https://aftck.com/track/clicks/2070/c627c2bb980727dcff9cab248d2596412379128f78efe6f30776f6476a0449a8c23ae5a5112d',

  // Agoda（offer 3408）
  agodaTracking: 'https://affsrc.com/track/clicks/3408/c627c2ba900929dcfc9cab248d2596412379128f78eee2f40f76f6476a0449a8c23ae5a5112d',

  // Booking / Trip 如果也有追蹤連結就填進來；留空 = 直接開官網（沒佣金但功能正常）。
  bookingTracking: '',
  tripTracking: '',
};

/* ====================================================================
   🐻 熊熊精選資料 —— 直接在這裡新增/修改
   每間飯店：
     name   飯店名稱
     area   位置一句話
     tags   特色標籤（1-3 個）
     note   熊熊點評（一兩句，最重要！）
     taUrl  該飯店的 TripAdvisor 頁面網址（強烈建議填，轉換率最高；
            留空會退而求其次用「飯店名+城市」搜尋）
   ⚠️ 以下為佔位範例，請換成你們實際住過或研究過的飯店再上線。
   ==================================================================== */
const HOTEL_PICKS = {
  '🇯🇵 東京': [
    { name: '（範例）上野不忍可可飯店', area: '上野站走 5 分', tags: ['機能型', '近 JR'],
      note: '佔位點評：寫你們的真實心得，例如「房間小但床超好睡，去成田超方便」。', taUrl: '' },
    { name: '（範例）淺草雷門景觀旅宿', area: '淺草寺旁', tags: ['景觀', '老街'],
      note: '佔位點評：頂樓看得到晴空塔，晚上雷門人潮散去超清幽。', taUrl: '' },
    { name: '（範例）新宿大浴場商旅', area: '新宿東口', tags: ['大浴場', '宵夜方便'],
      note: '佔位點評：逛完歌舞伎町回來泡湯，熊先生認證。', taUrl: '' },
    { name: '（範例）東京站日航系飯店', area: '東京站直結', tags: ['家庭', '拖行李神器'],
      note: '佔位點評：下雨天完全不用出站，帶長輩首選。', taUrl: '' },
  ],
  '🗻 河口湖': [
    { name: '（範例）湖畔逆富士溫泉旅館', area: '河口湖北岸', tags: ['逆富士', '溫泉'],
      note: '佔位點評：清晨五點半的逆富士，從房間窗戶就拍得到。', taUrl: '' },
    { name: '(範例)車站前背包客棧', area: '河口湖站走 2 分', tags: ['平價', '巴士方便'],
      note: '佔位點評:預算有限但想看富士山的最佳解。', taUrl: '' },
    { name: '(範例)天上山纜車旁旅宿', area: '近纜車站', tags: ['視野', '安靜'],
      note: '佔位點評:避開湖畔一排觀光團,晚上星空很猛。', taUrl: '' },
  ],
};

/* ====================================================================
   TripAdvisor 城市「飯店專頁」對照表
   有填的城市 → 直達該城市飯店列表（有各平台比價）
   沒填的城市 → 退回關鍵字搜尋（可能混到活動，建議補齊）
   ✏️ 補齊方法超簡單：去 tripadvisor.com.tw 搜城市 → 點「飯店」分頁
      → 把網址貼進來（長得像 /Hotels-gXXXXXX-城市名-Hotels.html）
   ==================================================================== */
const TA_HOTELS = {
  '東京': 'https://www.tripadvisor.com.tw/Hotels-g298184-Tokyo_Tokyo_Prefecture_Kanto-Hotels.html',
  // '大阪': '',
  // '京都': '',
  // '曼谷': '',
  // ...其他城市照上面的方法補
};

const HOT_CITIES = [
  '🇯🇵 東京','🇯🇵 大阪','🇯🇵 京都','🇯🇵 沖繩','🇯🇵 北海道','🇯🇵 福岡','🗻 河口湖',
  '🇰🇷 首爾','🇹🇭 曼谷','🇹🇭 清邁','🇸🇬 新加坡','🇲🇾 吉隆坡','🇮🇩 峇厘島',
  '🇹🇼 台北','🇹🇼 台南','🇹🇼 高雄','🇹🇼 花蓮','🇻🇳 胡志明市',
];

/* ====================================================================
   工具函式
   ==================================================================== */
const $ = (id) => document.getElementById(id);

function wrapTracking(trackingLink, targetUrl) {
  if (!trackingLink) return targetUrl;
  const joiner = trackingLink.includes('?') ? '&' : '?';
  // Involve Asia 格式：?t= + 雙重 URL 編碼（依後台深連結樣本）
  return `${trackingLink}${joiner}t=${encodeURIComponent(encodeURIComponent(targetUrl))}`;
}

function getStars() {
  return [...document.querySelectorAll('.stars input:checked')].map(c => c.value);
}

function nightsBetween(d1, d2) {
  const ms = new Date(d2) - new Date(d1);
  return Math.max(1, Math.round(ms / 86400000));
}

/* ====================================================================
   三平台網址產生器（條件完全一致 + 價格低到高排序）
   ⚠️ 平台參數偶爾會改版，上線前每個都實際點開驗證一次。
   ==================================================================== */
function buildUrls() {
  const dest = $('dest').value.replace(/^[^一-鿿A-Za-z]+/, '').trim(); // 去掉開頭國旗 emoji
  const ci = $('checkin').value;   // YYYY-MM-DD
  const co = $('checkout').value;
  const adults = $('adults').value;
  const rooms = $('rooms').value;
  const stars = getStars();        // e.g. ['3','4']

  // --- Agoda：textToSearch 文字搜尋，免維護城市 ID ---
  const agoda = new URL('https://www.agoda.com/zh-tw/search');
  agoda.searchParams.set('textToSearch', dest);
  agoda.searchParams.set('checkIn', ci);
  agoda.searchParams.set('checkOut', co);
  agoda.searchParams.set('adults', adults);
  agoda.searchParams.set('rooms', rooms);
  agoda.searchParams.set('children', '0');
  agoda.searchParams.set('currency', 'TWD');
  agoda.searchParams.set('locale', 'zh-tw');
  agoda.searchParams.set('sort', 'priceLowToHigh');
  if (stars.length) agoda.searchParams.set('hotelStarRating', stars.join(','));

  // --- Booking.com ---
  const booking = new URL('https://www.booking.com/searchresults.zh-tw.html');
  booking.searchParams.set('ss', dest);
  booking.searchParams.set('checkin', ci);
  booking.searchParams.set('checkout', co);
  booking.searchParams.set('group_adults', adults);
  booking.searchParams.set('no_rooms', rooms);
  booking.searchParams.set('group_children', '0');
  booking.searchParams.set('order', 'price');
  if (stars.length) booking.searchParams.set('nflt', stars.map(s => `class=${s}`).join(';'));

  // --- Trip.com ---
  const trip = new URL('https://tw.trip.com/hotels/list');
  trip.searchParams.set('searchword', dest);
  trip.searchParams.set('checkin', ci.replaceAll('-', '/'));
  trip.searchParams.set('checkout', co.replaceAll('-', '/'));
  trip.searchParams.set('adult', adults);
  trip.searchParams.set('crn', rooms);
  trip.searchParams.set('curr', 'TWD');
  if (stars.length) trip.searchParams.set('star', stars.join(','));

  // --- TripAdvisor：優先直達城市飯店專頁（有比價），否則退回搜尋 ---
  let taTarget;
  if (TA_HOTELS[dest]) {
    taTarget = TA_HOTELS[dest];
  } else {
    const ta = new URL('https://www.tripadvisor.com.tw/Search');
    ta.searchParams.set('q', dest + ' 飯店');
    ta.searchParams.set('ssrc', 'h');
    taTarget = ta.toString();
  }

  return {
    tripadvisor: wrapTracking(AFFILIATE.tripadvisorTracking, taTarget),
    agoda: wrapTracking(AFFILIATE.agodaTracking, agoda.toString()),
    booking: wrapTracking(AFFILIATE.bookingTracking, booking.toString()),
    trip: wrapTracking(AFFILIATE.tripTracking, trip.toString()),
  };
}

/* ====================================================================
   互動
   ==================================================================== */
/* ====================================================================
   熊熊精選渲染
   ==================================================================== */
function pickLink(hotel, city) {
  const cityName = city.replace(/^[^一-鿿A-Za-z]+/, '').trim();
  const target = hotel.taUrl
    ? hotel.taUrl
    : `https://www.tripadvisor.com.tw/Search?q=${encodeURIComponent(hotel.name.replace(/（範例）|\(範例\)/g, '') + ' ' + cityName)}&ssrc=h`;
  return wrapTracking(AFFILIATE.tripadvisorTracking, target);
}

function renderPicks(city) {
  const list = HOTEL_PICKS[city] || [];
  $('pickList').innerHTML = list.map(h => `
    <article class="pick">
      <div class="pick-top">
        <h3>${h.name}</h3>
        <span class="pick-area">📍 ${h.area}</span>
      </div>
      <div class="pick-tags">${h.tags.map(t => `<span>${t}</span>`).join('')}</div>
      <p class="pick-note">${h.note}</p>
      <a class="pick-cta" href="${pickLink(h, city)}" target="_blank" rel="noopener sponsored">🔎 比最低價 →</a>
    </article>
  `).join('');
}

const pickCityNames = Object.keys(HOTEL_PICKS);
$('pickCities').innerHTML = pickCityNames
  .map((c, i) => `<button type="button" class="chip${i === 0 ? ' on' : ''}" data-city="${c}">${c}</button>`).join('');
$('pickCities').addEventListener('click', (e) => {
  const btn = e.target.closest('.chip');
  if (!btn) return;
  $('pickCities').querySelectorAll('.chip').forEach(c => c.classList.toggle('on', c === btn));
  renderPicks(btn.dataset.city);
});
renderPicks(pickCityNames[0]);

// 城市 chips
$('hotCities').innerHTML = HOT_CITIES
  .map(c => `<button type="button" class="chip">${c}</button>`).join('');
$('hotCities').addEventListener('click', (e) => {
  const btn = e.target.closest('.chip');
  if (!btn) return;
  $('dest').value = btn.textContent.trim();
  document.querySelectorAll('.chip').forEach(c => c.classList.toggle('on', c === btn));
});

// 預設日期：兩週後入住、住兩晚
(() => {
  const d = new Date(); d.setDate(d.getDate() + 14);
  const d2 = new Date(d); d2.setDate(d2.getDate() + 2);
  const fmt = (x) => x.toISOString().slice(0, 10);
  $('checkin').value = fmt(d);
  $('checkout').value = fmt(d2);
})();

// 產生連結
$('buildBtn').addEventListener('click', () => {
  const ok = $('dest').value.trim() && $('checkin').value && $('checkout').value;
  $('formHint').hidden = ok;
  if (!ok) return;

  const urls = buildUrls();
  $('linkTa').href = urls.tripadvisor;
  $('linkAgoda').href = urls.agoda;
  $('linkBooking').href = urls.booking;
  $('linkTrip').href = urls.trip;

  $('step2').hidden = false;
  $('step3').hidden = false;
  $('step2').scrollIntoView({ behavior: 'smooth', block: 'start' });
});

// 一鍵全開（誠實版：開不了就提示改點卡片）
$('openAllBtn').addEventListener('click', () => {
  const wins = ['linkAgoda', 'linkBooking', 'linkTrip']
    .map(id => window.open($(id).href, '_blank'));
  $('popupHint').hidden = !wins.some(w => !w);
});

// 回填比價
$('compareBtn').addEventListener('click', () => {
  const entries = [
    { name: 'Agoda',       icon: '🏨', val: parseFloat($('priceAgoda').value) },
    { name: 'Booking.com', icon: '🛏️', val: parseFloat($('priceBooking').value) },
    { name: 'Trip.com',    icon: '✈️', val: parseFloat($('priceTrip').value) },
  ].filter(e => !isNaN(e.val) && e.val > 0);

  if (entries.length < 2) {
    $('result').hidden = false;
    $('resultWinner').textContent = '至少要填兩個平台的價格才有得比喔！';
    $('resultDetail').textContent = '';
    return;
  }

  entries.sort((a, b) => a.val - b.val);
  const win = entries[0];
  const worst = entries[entries.length - 1];
  const diff = worst.val - win.val;
  const nights = nightsBetween($('checkin').value, $('checkout').value);
  const perNight = Math.round(win.val / nights);

  $('result').hidden = false;
  $('resultWinner').textContent = `${win.icon} ${win.name} 最便宜：NT$ ${win.val.toLocaleString()}`;
  $('resultDetail').textContent =
    diff > 0
      ? `比最貴的 ${worst.name} 省下 NT$ ${diff.toLocaleString()}（${nights} 晚，平均每晚約 NT$ ${perNight.toLocaleString()}）。記得再用 APP 開一次確認有沒有更低！`
      : `兩邊價格一樣，這時候比取消條款和點數回饋就好。`;
});
  </script>
</body>
</html>

