---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<style is:global>
:root {
  --honey: #E8920A;
  --honey-deep: #C2740A;
  --bear: #3B2A1E;
  --cream: #FFF8EC;
  --paper: #FFFFFF;
  --line: #EADFC8;
  --muted: #5C4A35;
}
* { box-sizing: border-box; }
html body {
  margin: 0;
  font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif;
  background: #FFF8EC;
  color: #3B2A1E;
  line-height: 1.7;
}
.wrap { max-width: 860px; margin: 0 auto; padding: 24px 16px 80px; color: #3B2A1E; }

/* ── Hero ── */
.hero { text-align: center; padding: 32px 8px 8px; }
.hero-eyebrow { letter-spacing: .35em; font-size: .8rem; color: #5C4A35; margin: 0 0 8px; }
.hero h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0 0 10px; font-weight: 900; color: #3B2A1E; }
.amber { color: #E8920A; }
.hero-sub { color: #5C4B3A; font-size: .95rem; max-width: 560px; margin: 0 auto 0; }

/* ── Card ── */
.card {
  background: #FFFFFF;
  border: 1px solid #EADFC8;
  border-radius: 20px;
  padding: 24px 20px;
  margin-top: 24px;
  box-shadow: 0 4px 16px rgba(59,42,30,.05);
  color: #3B2A1E;
}
.card h2 { font-size: 1.15rem; margin: 0 0 4px; display: flex; align-items: center; gap: 10px; color: #3B2A1E; }
.card-sub { color: #5C4A35; font-size: .88rem; margin: 0 0 20px; }

/* ── Form ── */
.field-label {
  font-size: .85rem;
  font-weight: 700;
  color: #3B2A1E;
  margin: 0 0 8px;
  display: block;
}
.dest-input {
  width: 100%;
  border: 2px solid #EADFC8;
  border-radius: 14px;
  padding: 13px 16px;
  font-size: 1rem;
  background: #FFF8EC;
  color: #3B2A1E;
  font-family: inherit;
  transition: border-color .15s;
  margin-bottom: 20px;
}
.dest-input:focus { outline: none; border-color: #E8920A; }
.dest-input::placeholder { color: #9C8870; }

.radio-group { margin-bottom: 20px; }
.radio-row { display: flex; flex-wrap: wrap; gap: 8px; }

.radio-opt {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 8px 16px;
  border: 1.5px solid #EADFC8;
  border-radius: 999px;
  cursor: pointer;
  transition: background .15s, border-color .15s, color .15s;
  font-size: .88rem;
  color: #3B2A1E;
  background: #FFF8EC;
  user-select: none;
  font-family: inherit;
}
.radio-opt input[type="radio"] {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 0;
}
.radio-opt:has(input:checked) {
  background: #E8920A;
  border-color: #E8920A;
  color: #fff;
  font-weight: 700;
}
.radio-opt:hover:not(:has(input:checked)) {
  border-color: #E8920A;
}

.hint-text { color: #D32F2F; font-size: .83rem; margin: -12px 0 16px; }

.btn-ask {
  width: 100%;
  border: none;
  border-radius: 14px;
  padding: 15px;
  font-size: 1.05rem;
  font-weight: 900;
  cursor: pointer;
  font-family: inherit;
  background: #E8920A;
  color: #fff;
  transition: background .15s, transform .1s;
  letter-spacing: .05em;
}
.btn-ask:hover:not(:disabled) { background: #C2740A; }
.btn-ask:active:not(:disabled) { transform: scale(.97); }
.btn-ask:disabled { opacity: .6; cursor: not-allowed; }

/* ── Loading ── */
.loading-area {
  text-align: center;
  padding: 48px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}
.loading-bear { font-size: 3rem; animation: bearBounce 1s ease-in-out infinite; }
@keyframes bearBounce {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-10px); }
}
.loading-text { color: #5C4A35; font-size: .95rem; }
.loading-dots::after {
  content: '';
  animation: dots 1.5s step-end infinite;
}
@keyframes dots {
  0%   { content: ''; }
  25%  { content: '.'; }
  50%  { content: '..'; }
  75%  { content: '...'; }
}

/* ── Hotel cards grid ── */
.hotel-grid {
  display: grid;
  gap: 14px;
  grid-template-columns: 1fr;
}
@media (min-width: 600px) { .hotel-grid { grid-template-columns: 1fr 1fr; } }

.hotel-card {
  background: #FFF8EC;
  border: 1.5px solid #EADFC8;
  border-radius: 16px;
  padding: 18px 16px;
  cursor: pointer;
  transition: border-color .15s, box-shadow .15s, transform .12s;
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: left;
  font-family: inherit;
  color: #3B2A1E;
}
.hotel-card:hover {
  border-color: #E8920A;
  box-shadow: 0 4px 20px rgba(232,146,10,.14);
  transform: translateY(-2px);
}
.hotel-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
}
.hotel-name { font-size: 1rem; font-weight: 900; margin: 0; color: #3B2A1E; flex: 1; }
.hotel-city {
  font-size: .75rem;
  color: #5C4A35;
  background: #FFEFD2;
  border-radius: 999px;
  padding: 2px 10px;
  white-space: nowrap;
  flex-shrink: 0;
}
.hotel-reason { font-size: .85rem; color: #5C4A35; margin: 0; line-height: 1.55; flex: 1; }
.hotel-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.hotel-tags span {
  background: #FFEFD2;
  color: #C2740A;
  border-radius: 999px;
  font-size: .72rem;
  padding: 2px 10px;
  font-weight: 700;
}
.hotel-card-cta {
  align-self: flex-end;
  font-size: .8rem;
  color: #E8920A;
  font-weight: 700;
  margin-top: 2px;
}

/* ── Results toolbar ── */
.results-toolbar {
  display: flex;
  gap: 10px;
  margin-top: 16px;
  flex-wrap: wrap;
}
.btn-more {
  flex: 1;
  border: 1.5px solid #EADFC8;
  border-radius: 14px;
  padding: 11px 16px;
  font-size: .9rem;
  font-weight: 700;
  cursor: pointer;
  background: #FFF8EC;
  color: #3B2A1E;
  font-family: inherit;
  transition: border-color .15s;
  white-space: nowrap;
}
.btn-more:hover { border-color: #E8920A; }
.btn-restart {
  border: none;
  border-radius: 14px;
  padding: 11px 20px;
  font-size: .9rem;
  font-weight: 700;
  cursor: pointer;
  background: #E8920A;
  color: #fff;
  font-family: inherit;
  transition: background .15s;
  white-space: nowrap;
}
.btn-restart:hover { background: #C2740A; }

/* ── Modal ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 16px;
}
.modal-card {
  background: #FFFFFF;
  border-radius: 20px;
  max-width: 460px;
  width: 100%;
  max-height: 88vh;
  overflow-y: auto;
  padding: 28px 22px 24px;
  position: relative;
  color: #3B2A1E;
}
.modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 32px;
  height: 32px;
  border: none;
  background: #F5F0E8;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1rem;
  color: #5C4A35;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s;
}
.modal-close:hover { background: #EADFC8; }
.modal-hotel-name { font-size: 1.3rem; font-weight: 900; margin: 0 28px 4px 0; color: #3B2A1E; }
.modal-hotel-en { font-size: .82rem; color: #5C4A35; margin: 0 0 4px; }
.modal-hotel-city {
  display: inline-block;
  font-size: .78rem;
  color: #C2740A;
  background: #FFEFD2;
  border-radius: 999px;
  padding: 2px 12px;
  margin-bottom: 14px;
  font-weight: 700;
}
.modal-divider { border: none; border-top: 1px solid #EADFC8; margin: 14px 0; }
.modal-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 14px; }
.modal-tags span {
  background: #FFEFD2;
  color: #C2740A;
  border-radius: 999px;
  font-size: .75rem;
  padding: 3px 12px;
  font-weight: 700;
}
.modal-section-label {
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #9C8870;
  margin: 0 0 6px;
}
.modal-list { margin: 0 0 14px; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 5px; }
.modal-list li {
  font-size: .88rem;
  line-height: 1.5;
  padding-left: 1.2em;
  position: relative;
  color: #3B2A1E;
}
.modal-list.pros li::before { content: '✅'; position: absolute; left: 0; font-size: .75em; top: .15em; }
.modal-list.cons li::before { content: '⚠️'; position: absolute; left: 0; font-size: .75em; top: .15em; }

.btn-cta {
  display: block;
  width: 100%;
  background: #E8920A;
  color: #fff;
  text-align: center;
  padding: 14px;
  border-radius: 14px;
  font-weight: 900;
  font-size: 1rem;
  text-decoration: none;
  letter-spacing: .04em;
  transition: background .15s;
  margin-top: 8px;
}
.btn-cta:hover { background: #C2740A; }
.modal-disclaimer {
  text-align: center;
  font-size: .73rem;
  color: #9C8870;
  margin: 8px 0 0;
}

/* ── Error box ── */
.error-box {
  background: #FFF0F0;
  border: 1px solid #FFC5C5;
  border-radius: 12px;
  padding: 14px 16px;
  color: #8B1A1A;
  font-size: .88rem;
  margin-bottom: 8px;
}

/* ── Checklist ── */
.checklist ol { padding-left: 22px; margin: 0; }
.checklist li { margin-bottom: 8px; font-size: .92rem; color: #3B2A1E; }
.disclosure {
  margin-top: 18px;
  padding: 12px 14px;
  background: #FFF8EC;
  border-radius: 12px;
  font-size: .8rem;
  color: #5C4A35;
}

@media (prefers-reduced-motion: reduce) { * { transition: none !important; animation: none !important; } }
</style>

<html lang="zh-Hant">
<head>
  <BaseHead
    title="🐻 問兩隻熊｜旅遊住宿顧問"
    description="不知道住哪？告訴兩隻熊你的目的地、旅伴和預算，熊熊幫你推薦最適合的飯店，再一鍵查 TripAdvisor 最低價。"
  />
</head>
<body>
  <Header />

  <main class="wrap">

    <!-- ── Hero ── -->
    <header class="hero">
      <p class="hero-eyebrow">兩隻熊旅遊顧問</p>
      <h1>不知道住哪？<span class="amber">問兩隻熊</span></h1>
      <p class="hero-sub">告訴我們目的地、旅伴、預算，熊熊幫你篩出最適合的飯店，再一鍵查 TripAdvisor 最低價。</p>
    </header>

    <!-- ── Advisor section ── -->
    <section class="card" id="advisor-section">
      <h2>🐻 問熊熊推薦飯店</h2>
      <p class="card-sub">AI 顧問 + Google 即時搜尋 · 推薦真實存在的飯店</p>

      <!-- Form -->
      <div id="form-area">
        <label class="field-label" for="dest-input">想去哪裡？</label>
        <input
          type="text"
          id="dest-input"
          class="dest-input"
          placeholder="例如：河口湖、大阪心齋橋、京都嵐山、清邁古城…"
          autocomplete="off"
        />

        <div class="radio-group">
          <span class="field-label">旅伴</span>
          <div class="radio-row" id="companion-row">
            <label class="radio-opt"><input type="radio" name="companion" value="情侶" />💕 情侶</label>
            <label class="radio-opt"><input type="radio" name="companion" value="親子" />👶 親子</label>
            <label class="radio-opt"><input type="radio" name="companion" value="一個人" />🎒 一個人</label>
            <label class="radio-opt"><input type="radio" name="companion" value="長輩" />👵 長輩</label>
          </div>
        </div>

        <div class="radio-group">
          <span class="field-label">每晚預算（台幣）</span>
          <div class="radio-row" id="budget-row">
            <label class="radio-opt"><input type="radio" name="budget" value="5000以下" />5,000 以下</label>
            <label class="radio-opt"><input type="radio" name="budget" value="5000–10000" />5,000–10,000</label>
            <label class="radio-opt"><input type="radio" name="budget" value="10000以上" />10,000 以上</label>
          </div>
        </div>

        <p class="hint-text" id="form-hint" style="display:none"></p>
        <button class="btn-ask" id="btn-ask" type="button">🐻 問熊熊</button>
      </div>

      <!-- Loading -->
      <div id="loading-area" class="loading-area" style="display:none">
        <div class="loading-bear">🐻</div>
        <div class="loading-text">熊熊正在搜尋資料<span class="loading-dots"></span></div>
        <div style="font-size:.82rem; color:#9C8870">利用 Google 搜尋驗證飯店真實性</div>
      </div>

      <!-- Error -->
      <div id="error-area" style="display:none">
        <div class="error-box" id="error-msg"></div>
        <button class="btn-ask" id="btn-retry" type="button">重新問熊熊</button>
      </div>

      <!-- Results -->
      <div id="results-area" style="display:none">
        <div class="hotel-grid" id="hotel-grid"></div>
        <div class="results-toolbar">
          <button class="btn-more" id="btn-more" type="button">😅 都不喜歡？再推薦四間</button>
          <button class="btn-restart" id="btn-restart" type="button">重新問熊熊</button>
        </div>
      </div>
    </section>

    <!-- ── Checklist ── -->
    <section class="card checklist">
      <h2>🍯 查到飯店後的下一步</h2>
      <ol>
        <li><strong>點「查看 TripAdvisor 價格」</strong>——搜尋框輸入飯店英文名，找到後用 TripAdvisor 聚合十多家平台的報價一次比完。</li>
        <li><strong>比「總價」不要比「每晚價」</strong>——稅、服務費各平台算法不同，總額才是真相。</li>
        <li><strong>APP 再確認一次</strong>——Agoda 和 Trip 的 APP 限定價常常比網頁便宜。</li>
        <li><strong>取消條款</strong>——便宜 200 元但不可退，行程一變就虧大了。</li>
        <li><strong>用信用卡海外回饋</strong>——選對卡再省 2–3%。</li>
      </ol>
      <p class="disclosure">本頁連結為聯盟連結，透過連結訂房兩隻熊會獲得少量回饋，<strong>你的價格完全不受影響</strong>。謝謝朋友支持頻道 🐻🐻</p>
    </section>

  </main>

  <!-- ── Modal ── -->
  <div id="hotel-modal" class="modal-overlay" style="display:none" role="dialog" aria-modal="true">
    <div class="modal-card" id="modal-card">
      <button class="modal-close" id="modal-close" aria-label="關閉">✕</button>
      <h2 class="modal-hotel-name" id="modal-name"></h2>
      <p class="modal-hotel-en" id="modal-en"></p>
      <span class="modal-hotel-city" id="modal-city"></span>
      <hr class="modal-divider" />
      <div class="modal-tags" id="modal-tags"></div>
      <p class="modal-section-label">✅ 優點</p>
      <ul class="modal-list pros" id="modal-pros"></ul>
      <p class="modal-section-label">⚠️ 要注意</p>
      <ul class="modal-list cons" id="modal-cons"></ul>
      <a id="modal-cta" class="btn-cta" target="_blank" rel="noopener sponsored" href="#">
        查看 TripAdvisor 價格 →
      </a>
      <p class="modal-disclaimer">價格與房況以訂房平台為準 · 兩隻熊不保證房源可訂</p>
    </div>
  </div>

  <Footer />
</body>
</html>

<script is:inline>
/* ===================================================================
   設定
   =================================================================== */
const TA_TRACKING = 'https://aftck.com/track/clicks/2070/c627c2bb980727dcff9cab248d2596412379128f78efe6f30776f6476a0449a8c23ae5a5112d';

function taLink(enName, city) {
  const target = 'https://www.tripadvisor.com.tw/Search?q=' +
    encodeURIComponent(enName + ' ' + city) + '&ssrc=h';
  return TA_TRACKING + '?t=' + encodeURIComponent(encodeURIComponent(target));
}

/* ===================================================================
   狀態
   =================================================================== */
let askedHotelNames = [];
let lastRequest = null;   // { destination, companion, budget }
let currentHotels = [];

/* ===================================================================
   顯示切換
   =================================================================== */
function showArea(id) {
  ['form-area', 'loading-area', 'error-area', 'results-area'].forEach(a => {
    const el = document.getElementById(a);
    if (el) el.style.display = a === id ? '' : 'none';
  });
}

/* ===================================================================
   表單驗證
   =================================================================== */
function getFormValues() {
  const dest = document.getElementById('dest-input').value.trim();
  const companion = document.querySelector('input[name="companion"]:checked')?.value || '';
  const budget = document.querySelector('input[name="budget"]:checked')?.value || '';
  return { dest, companion, budget };
}

function validateForm(dest, companion, budget) {
  if (!dest) { showHint('請填寫想去的目的地！'); return false; }
  if (!companion) { showHint('請選擇旅伴！'); return false; }
  if (!budget) { showHint('請選擇預算範圍！'); return false; }
  return true;
}

function showHint(msg) {
  const el = document.getElementById('form-hint');
  el.textContent = msg;
  el.style.display = 'block';
}
function clearHint() {
  const el = document.getElementById('form-hint');
  if (el) el.style.display = 'none';
}

/* ===================================================================
   API 呼叫
   =================================================================== */
async function callAdvisor(destination, companion, budget, excludeNames) {
  const res = await fetch('/api/advisor', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ destination, companion, budget, excludeNames }),
  });
  if (!res.ok) throw new Error('HTTP ' + res.status);
  return res.json();
}

/* ===================================================================
   首次問熊熊
   =================================================================== */
async function askBear() {
  const { dest, companion, budget } = getFormValues();
  clearHint();
  if (!validateForm(dest, companion, budget)) return;

  lastRequest = { destination: dest, companion, budget };
  askedHotelNames = [];

  showArea('loading-area');
  document.getElementById('btn-ask').disabled = true;

  try {
    const data = await callAdvisor(dest, companion, budget, []);
    if (!data.ok || !data.hotels?.length) {
      showError(data.error || '熊熊這次沒找到合適的飯店，請換個關鍵字或稍後再試 🐻');
      return;
    }
    currentHotels = data.hotels;
    askedHotelNames = data.hotels.map(h => h.name);
    renderHotels(data.hotels);
    showArea('results-area');
  } catch {
    showError('網路或 AI 暫時有問題，請稍後再試 🐻');
  } finally {
    document.getElementById('btn-ask').disabled = false;
  }
}

/* ===================================================================
   再推薦四間
   =================================================================== */
async function askMore() {
  if (!lastRequest) return;
  document.getElementById('btn-more').disabled = true;
  document.getElementById('btn-more').textContent = '搜尋中…';

  try {
    const data = await callAdvisor(
      lastRequest.destination,
      lastRequest.companion,
      lastRequest.budget,
      askedHotelNames,
    );
    if (!data.ok || !data.hotels?.length) {
      alert('熊熊已推薦完這個地區的飯店了，換個關鍵字試試看？');
      return;
    }
    currentHotels = data.hotels;
    askedHotelNames.push(...data.hotels.map(h => h.name));
    renderHotels(data.hotels);
  } catch {
    alert('網路暫時有問題，請稍後再試 🐻');
  } finally {
    document.getElementById('btn-more').disabled = false;
    document.getElementById('btn-more').textContent = '😅 都不喜歡？再推薦四間';
  }
}

/* ===================================================================
   渲染飯店卡片
   =================================================================== */
function renderHotels(hotels) {
  const grid = document.getElementById('hotel-grid');
  grid.innerHTML = hotels.map((h, i) => `
    <button class="hotel-card" type="button" data-idx="${i}">
      <div class="hotel-card-header">
        <h3 class="hotel-name">${escHtml(h.name)}</h3>
        <span class="hotel-city">${escHtml(h.city)}</span>
      </div>
      <p class="hotel-reason">${escHtml(h.reason)}</p>
      <div class="hotel-tags">${(h.tags||[]).map(t => `<span>${escHtml(t)}</span>`).join('')}</div>
      <span class="hotel-card-cta">查看詳情 →</span>
    </button>
  `).join('');

  grid.addEventListener('click', function handler(e) {
    const card = e.target.closest('.hotel-card');
    if (!card) return;
    const idx = parseInt(card.dataset.idx);
    openModal(currentHotels[idx]);
  }, { once: true });

  // Re-bind after each render (the { once } above means we need a separate approach)
  // Actually, let's use event delegation directly without "once":
  grid.onclick = (e) => {
    const card = e.target.closest('.hotel-card');
    if (!card) return;
    const idx = parseInt(card.dataset.idx);
    openModal(currentHotels[idx]);
  };
}

function escHtml(s) {
  return String(s ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

/* ===================================================================
   Modal
   =================================================================== */
function openModal(h) {
  document.getElementById('modal-name').textContent = h.name;
  document.getElementById('modal-en').textContent = h.en;
  document.getElementById('modal-city').textContent = '📍 ' + h.city;

  const tags = document.getElementById('modal-tags');
  tags.innerHTML = (h.tags||[]).map(t => `<span>${escHtml(t)}</span>`).join('');

  const pros = document.getElementById('modal-pros');
  pros.innerHTML = (h.pros||[]).map(p => `<li>${escHtml(p)}</li>`).join('');

  const cons = document.getElementById('modal-cons');
  cons.innerHTML = (h.cons||[]).map(c => `<li>${escHtml(c)}</li>`).join('');

  const cta = document.getElementById('modal-cta');
  cta.href = taLink(h.en, h.city);

  const modal = document.getElementById('hotel-modal');
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('hotel-modal').style.display = 'none';
  document.body.style.overflow = '';
}

document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('hotel-modal').addEventListener('click', (e) => {
  if (e.target === document.getElementById('hotel-modal')) closeModal();
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeModal();
});

/* ===================================================================
   Error + Retry
   =================================================================== */
function showError(msg) {
  document.getElementById('error-msg').textContent = msg;
  showArea('error-area');
}

document.getElementById('btn-retry').addEventListener('click', () => {
  showArea('form-area');
});

/* ===================================================================
   Restart
   =================================================================== */
function restart() {
  askedHotelNames = [];
  lastRequest = null;
  currentHotels = [];
  clearHint();
  showArea('form-area');
}

/* ===================================================================
   Event bindings
   =================================================================== */
document.getElementById('btn-ask').addEventListener('click', askBear);
document.getElementById('dest-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') askBear();
});
document.getElementById('btn-more').addEventListener('click', askMore);
document.getElementById('btn-restart').addEventListener('click', restart);
</script>
