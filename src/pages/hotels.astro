---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<style is:global>
:root {
  --honey: #E8920A;
  --honey-deep: #C2740A;
  --bear: #3B2A1E;
  --cream: #FFF8EC;
  --paper: #FFFFFF;
  --line: #EADFC8;
  --muted: #5C4A35;
}
* { box-sizing: border-box; }
html body {
  margin: 0;
  font-family: "Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif;
  background: #FFF8EC;
  color: #3B2A1E;
  line-height: 1.7;
}
.wrap { max-width: 880px; margin: 0 auto; padding: 24px 16px 80px; color: #3B2A1E; }

/* hero */
.hero { text-align: center; padding: 32px 8px 8px; }
.hero-eyebrow { letter-spacing: .35em; font-size: .8rem; color: #5C4A35; margin: 0 0 8px; }
.hero h1 { font-size: clamp(1.8rem, 5vw, 2.6rem); margin: 0 0 14px; font-weight: 900; color: #3B2A1E; }
.amber { color: #E8920A; }
.hero-sub { color: #5C4B3A; font-size: .95rem; max-width: 600px; margin: 0 auto; }
.desktop-only { display: none; }
@media (min-width: 720px) { .desktop-only { display: inline; } }

/* cards */
.card {
  background: #FFFFFF;
  border: 1px solid #EADFC8;
  border-radius: 20px;
  padding: 24px 20px;
  margin-top: 24px;
  box-shadow: 0 4px 16px rgba(59, 42, 30, .05);
}
.card h2 { font-size: 1.15rem; margin: 0 0 14px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; color: #3B2A1E; }
.muted { color: #5C4A35; font-size: .88rem; margin-top: -4px; }

/* search bar */
.search-row {
  display: flex; gap: 10px; align-items: stretch;
}
.search-input {
  flex: 1; min-width: 0;
  border: 2px solid #EADFC8; border-radius: 14px; padding: 13px 16px;
  font-size: 1rem; background: #FFF8EC; color: #3B2A1E; font-family: inherit;
  transition: border-color .15s;
}
.search-input:focus { outline: none; border-color: #E8920A; }
.search-input::placeholder { color: #9C8870; }
.btn-search {
  white-space: nowrap; border: none; border-radius: 14px; padding: 13px 22px;
  font-size: 1rem; font-weight: 900; cursor: pointer; font-family: inherit;
  background: #E8920A; color: #fff; transition: background .15s, transform .1s;
}
.btn-search:hover { background: #C2740A; }
.btn-search:active { transform: scale(.97); }

/* date row */
.date-row {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px;
}
@media (min-width: 560px) { .date-row { grid-template-columns: repeat(4, 1fr); } }
.date-field { display: flex; flex-direction: column; gap: 4px; font-size: .8rem; font-weight: 700; color: #3B2A1E; }
.date-field input, .date-field select {
  border: 1.5px solid #EADFC8; border-radius: 10px; padding: 9px 10px;
  font-size: .9rem; background: #FFF8EC; color: #3B2A1E; font-family: inherit;
}
.date-field input:focus, .date-field select:focus { outline: 2px solid #E8920A; border-color: #E8920A; }

/* hint */
.hint { color: #D32F2F; font-size: .85rem; margin: 8px 0 0; }

/* chips */
.chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
.chip {
  border: 1px solid #EADFC8; background: #FFF8EC; color: #3B2A1E;
  border-radius: 999px; padding: 6px 14px; font-size: .85rem; cursor: pointer;
  transition: all .15s;
}
.chip:hover { border-color: #E8920A; }
.chip.on { background: #E8920A; border-color: #E8920A; color: #fff; font-weight: 700; }

/* picks separator */
.picks-sep {
  display: flex; align-items: center; gap: 12px;
  margin: 24px 0 12px; color: #5C4A35; font-size: .88rem;
}
.picks-sep::before, .picks-sep::after {
  content: ''; flex: 1; border-top: 1px solid #EADFC8;
}

/* 熊熊精選 cards */
.picks-grid { display: grid; gap: 14px; margin-top: 14px; }
@media (min-width: 720px) { .picks-grid { grid-template-columns: 1fr 1fr; } }
.pick {
  background: #FFF8EC; border: 1.5px solid #EADFC8; border-radius: 16px;
  padding: 16px; display: flex; flex-direction: column; gap: 8px;
}
.pick:hover { border-color: #E8920A; }
.pick-top { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; flex-wrap: wrap; }
.pick h3 { margin: 0; font-size: 1.02rem; color: #3B2A1E; }
.pick-area { font-size: .78rem; color: #5C4A35; white-space: nowrap; }
.pick-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.pick-tags span {
  background: #FFEFD2; color: #C2740A; border-radius: 999px;
  font-size: .72rem; padding: 2px 10px; font-weight: 700;
}
.pick-note { margin: 0; font-size: .88rem; color: #5C4B3A; flex: 1; }
.pick-cta {
  align-self: flex-start; text-decoration: none; font-weight: 900; font-size: .92rem;
  background: #E8920A; color: #fff; padding: 8px 16px; border-radius: 10px;
  transition: background .15s;
}
.pick-cta:hover { background: #C2740A; }

/* checklist */
.checklist ol { padding-left: 22px; margin: 0; }
.checklist li { margin-bottom: 8px; font-size: .92rem; color: #3B2A1E; }
.disclosure {
  margin-top: 18px; padding: 12px 14px; background: #FFF8EC;
  border-radius: 12px; font-size: .8rem; color: #5C4A35;
}

@media (prefers-reduced-motion: reduce) {
  * { transition: none !important; }
}
</style>

<html lang="zh-Hant">
<head>
  <BaseHead
    title="🐻 兩隻熊找飯店｜一鍵查 TripAdvisor 最低價"
    description="輸入飯店名稱或目的地，TripAdvisor 聚合十多家訂房平台，一頁看完所有價格。也有兩隻熊親身挑選的精選飯店推薦。"
  />
</head>
<body>
  <Header />

  <main class="wrap">

    <!-- ============ HERO ============ -->
    <header class="hero">
      <p class="hero-eyebrow">兩隻熊的旅遊記事 · 省錢工具</p>
      <h1>找飯店，<span class="amber">一鍵查最低價</span></h1>
      <p class="hero-sub">
        搜尋飯店名稱或目的地，TripAdvisor 幫你把 Agoda、Booking、Trip 等十多家平台的價格<br class="desktop-only" />
        全部攤開來比，再也不用一個一個開。
      </p>
    </header>

    <!-- ============ 搜尋 + 熊熊精選（合併） ============ -->
    <section class="card">
      <h2>🔍 查飯店最低價</h2>

      <!-- 搜尋列 -->
      <div class="search-row">
        <input type="text" id="searchInput" class="search-input"
               placeholder="飯店名稱或城市，例如：東京、淺草 Richmond Hotel…" autocomplete="off" />
        <button class="btn-search" id="searchBtn" type="button">查最低價</button>
      </div>
      <p class="hint" id="formHint" hidden>請輸入飯店名稱或目的地！</p>

      <!-- 熱門城市快選 -->
      <div class="chips" id="hotCities" style="margin-top:12px" aria-label="熱門城市快選"></div>

      <!-- 日期 / 人數列 -->
      <div class="date-row">
        <label class="date-field">
          <span>入住</span>
          <input type="date" id="ci" />
        </label>
        <label class="date-field">
          <span>退房</span>
          <input type="date" id="co" />
        </label>
        <label class="date-field">
          <span>大人</span>
          <select id="adults">
            <option>1</option><option selected>2</option><option>3</option><option>4</option>
          </select>
        </label>
        <label class="date-field">
          <span>房間</span>
          <select id="rooms">
            <option selected>1</option><option>2</option>
          </select>
        </label>
      </div>

      <!-- 熊熊精選 -->
      <div class="picks-sep">🐻 熊熊精選</div>
      <p class="muted">不是演算法排序，是兩隻熊一間一間挑出來的。點「查最低價」自動帶入你設的日期。</p>
      <div class="chips" id="pickCities" aria-label="精選城市" style="margin-top:12px"></div>
      <div class="picks-grid" id="pickList"></div>

    </section>

    <!-- ============ 省錢檢查清單 ============ -->
    <section class="card checklist">
      <h2>🍯 下訂前的最後檢查</h2>
      <ol>
        <li><strong>比「總價」不要比「每晚價」</strong>——稅、服務費各平台算法不同，總額才是真相。</li>
        <li><strong>APP 再開一次</strong>——Agoda 和 Trip 的 APP 限定價常常比網頁便宜。</li>
        <li><strong>查飯店官網</strong>——日本商務旅館（東橫INN、APA）官網會員價有時最低。</li>
        <li><strong>取消條款</strong>——便宜 200 元但不可退，行程一變就虧大了。</li>
        <li><strong>用信用卡海外回饋</strong>——選對卡再省 2–3%。</li>
      </ol>
      <p class="disclosure">本頁連結為聯盟連結，透過連結訂房兩隻熊會獲得少量回饋，<strong>你的價格完全不受影響</strong>。謝謝朋友支持頻道 🐻🐻</p>
    </section>

  </main>

  <Footer />

  <script is:inline>
/* ====================================================================
   ⚙️ 聯盟連結設定
   ==================================================================== */
const AFFILIATE = {
  tripadvisorTracking: 'https://aftck.com/track/clicks/2070/c627c2bb980727dcff9cab248d2596412379128f78efe6f30776f6476a0449a8c23ae5a5112d',
};

/* ====================================================================
   🐻 熊熊精選資料 —— 直接在這裡新增/修改
   每間飯店：
     name   飯店名稱
     area   位置一句話
     tags   特色標籤（1-3 個）
     note   熊熊點評（一兩句，最重要！）
     taUrl  該飯店的 TripAdvisor 頁面網址（強烈建議填，轉換率最高；
            留空會退而求其次用「飯店名+城市」搜尋）
   ⚠️ 以下為佔位範例，請換成你們實際住過或研究過的飯店再上線。
   ==================================================================== */
const HOTEL_PICKS = {
  '🇯🇵 東京': [
    { name: '（範例）上野不忍可可飯店', area: '上野站走 5 分', tags: ['機能型', '近 JR'],
      note: '佔位點評：寫你們的真實心得，例如「房間小但床超好睡，去成田超方便」。', taUrl: '' },
    { name: '（範例）淺草雷門景觀旅宿', area: '淺草寺旁', tags: ['景觀', '老街'],
      note: '佔位點評：頂樓看得到晴空塔，晚上雷門人潮散去超清幽。', taUrl: '' },
    { name: '（範例）新宿大浴場商旅', area: '新宿東口', tags: ['大浴場', '宵夜方便'],
      note: '佔位點評：逛完歌舞伎町回來泡湯，熊先生認證。', taUrl: '' },
    { name: '（範例）東京站日航系飯店', area: '東京站直結', tags: ['家庭', '拖行李神器'],
      note: '佔位點評：下雨天完全不用出站，帶長輩首選。', taUrl: '' },
  ],
  '🗻 河口湖': [
    { name: '（範例）湖畔逆富士溫泉旅館', area: '河口湖北岸', tags: ['逆富士', '溫泉'],
      note: '佔位點評：清晨五點半的逆富士，從房間窗戶就拍得到。', taUrl: '' },
    { name: '(範例)車站前背包客棧', area: '河口湖站走 2 分', tags: ['平價', '巴士方便'],
      note: '佔位點評:預算有限但想看富士山的最佳解。', taUrl: '' },
  ],
};

/* ====================================================================
   TripAdvisor 城市飯店列表對照
   ==================================================================== */
const TA_HOTELS = {
  '東京': 'https://www.tripadvisor.com.tw/Hotels-g298184-Tokyo_Tokyo_Prefecture_Kanto-Hotels.html',
};

const HOT_CITIES = [
  '🇯🇵 東京','🇯🇵 大阪','🇯🇵 京都','🇯🇵 沖繩','🇯🇵 北海道','🇯🇵 福岡','🗻 河口湖',
  '🇰🇷 首爾','🇹🇭 曼谷','🇹🇭 清邁','🇸🇬 新加坡','🇲🇾 吉隆坡','🇮🇩 峇厘島',
  '🇹🇼 台北','🇹🇼 台南','🇹🇼 高雄','🇹🇼 花蓮','🇻🇳 胡志明市',
];

/* ====================================================================
   工具函式
   ==================================================================== */
const $ = (id) => document.getElementById(id);

function wrapTracking(trackingLink, targetUrl) {
  if (!trackingLink) return targetUrl;
  const joiner = trackingLink.includes('?') ? '&' : '?';
  return `${trackingLink}${joiner}t=${encodeURIComponent(encodeURIComponent(targetUrl))}`;
}

function getDates() {
  return { ci: $('ci').value, co: $('co').value };
}

/* ====================================================================
   TripAdvisor 網址產生器
   ==================================================================== */
function buildSearchUrl(query) {
  const q = query.replace(/^[^一-鿿A-Za-z]+/, '').trim();
  const { ci, co } = getDates();
  const adults = $('adults').value;

  // 已知城市 → 直達飯店列表（可帶日期）
  const cityKey = Object.keys(TA_HOTELS).find(k => q.includes(k));
  if (cityKey && TA_HOTELS[cityKey]) {
    const url = new URL(TA_HOTELS[cityKey]);
    if (ci) url.searchParams.set('checkin', ci.replaceAll('-', '_'));
    if (co) url.searchParams.set('checkout', co.replaceAll('-', '_'));
    url.searchParams.set('adults', adults);
    return wrapTracking(AFFILIATE.tripadvisorTracking, url.toString());
  }

  // 一般關鍵字搜尋
  const url = new URL('https://www.tripadvisor.com.tw/Search');
  url.searchParams.set('q', q);
  url.searchParams.set('ssrc', 'h');
  return wrapTracking(AFFILIATE.tripadvisorTracking, url.toString());
}

function buildPickUrl(hotel, city) {
  const { ci, co } = getDates();
  const adults = $('adults').value;

  if (hotel.taUrl) {
    const url = new URL(hotel.taUrl);
    if (ci) url.searchParams.set('checkin', ci);
    if (co) url.searchParams.set('checkout', co);
    url.searchParams.set('adults', adults);
    return wrapTracking(AFFILIATE.tripadvisorTracking, url.toString());
  }

  const cityName = city.replace(/^[^一-鿿A-Za-z]+/, '').trim();
  const name = hotel.name.replace(/（範例）|\(範例\)/g, '').trim();
  const target = `https://www.tripadvisor.com.tw/Search?q=${encodeURIComponent(name + ' ' + cityName)}&ssrc=h`;
  return wrapTracking(AFFILIATE.tripadvisorTracking, target);
}

/* ====================================================================
   熊熊精選渲染
   ==================================================================== */
function renderPicks(city) {
  const list = HOTEL_PICKS[city] || [];
  $('pickList').innerHTML = list.map(h => `
    <article class="pick">
      <div class="pick-top">
        <h3>${h.name}</h3>
        <span class="pick-area">📍 ${h.area}</span>
      </div>
      <div class="pick-tags">${h.tags.map(t => `<span>${t}</span>`).join('')}</div>
      <p class="pick-note">${h.note}</p>
      <a class="pick-cta" href="${buildPickUrl(h, city)}" target="_blank" rel="noopener sponsored"
         data-hotel='${JSON.stringify({name: h.name, area: h.area, taUrl: h.taUrl || ''})}' data-city="${city}">
        🔎 查最低價 →
      </a>
    </article>
  `).join('');
}

// pick 卡片的連結需在點擊時重新計算日期（用戶可能改過）
$('pickList').addEventListener('click', e => {
  const cta = e.target.closest('.pick-cta');
  if (!cta) return;
  const hotel = JSON.parse(cta.dataset.hotel);
  const city = cta.dataset.city;
  cta.href = buildPickUrl(hotel, city);
});

/* ====================================================================
   初始化
   ==================================================================== */
// 預設日期：兩週後入住、住兩晚
(() => {
  const d = new Date(); d.setDate(d.getDate() + 14);
  const d2 = new Date(d); d2.setDate(d2.getDate() + 2);
  const fmt = x => x.toISOString().slice(0, 10);
  $('ci').value = fmt(d);
  $('co').value = fmt(d2);
})();

// 精選城市 chips
const pickCityNames = Object.keys(HOTEL_PICKS);
$('pickCities').innerHTML = pickCityNames
  .map((c, i) => `<button type="button" class="chip${i === 0 ? ' on' : ''}" data-city="${c}">${c}</button>`).join('');
$('pickCities').addEventListener('click', e => {
  const btn = e.target.closest('.chip');
  if (!btn) return;
  $('pickCities').querySelectorAll('.chip').forEach(c => c.classList.toggle('on', c === btn));
  renderPicks(btn.dataset.city);
});
renderPicks(pickCityNames[0]);

// 熱門城市 chips → 填入搜尋欄
$('hotCities').innerHTML = HOT_CITIES
  .map(c => `<button type="button" class="chip">${c}</button>`).join('');
$('hotCities').addEventListener('click', e => {
  const btn = e.target.closest('.chip');
  if (!btn) return;
  $('searchInput').value = btn.textContent.trim();
  $('hotCities').querySelectorAll('.chip').forEach(c => c.classList.toggle('on', c === btn));
  $('searchInput').focus();
});

// 搜尋按鈕
$('searchBtn').addEventListener('click', () => {
  const q = $('searchInput').value.trim();
  $('formHint').hidden = !!q;
  if (!q) return;
  window.open(buildSearchUrl(q), '_blank', 'noopener');
});

// Enter 鍵搜尋
$('searchInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') $('searchBtn').click();
});
  </script>
</body>
</html>
