---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<style is:global>
:root {
  --honey: #E8920A;
  --honey-deep: #C2740A;
  --bear: #3B2A1E;
  --cream: #FFF8EC;
  --paper: #FFFFFF;
  --line: #EADFC8;
  --muted: #5C4A35;
}
* { box-sizing: border-box; }
html body {
  margin: 0;
  font-family: "Noto Sans TC","PingFang TC","Microsoft JhengHei",system-ui,sans-serif;
  background: #FFF8EC;
  color: #3B2A1E;
  line-height: 1.7;
}
.wrap { max-width: 860px; margin: 0 auto; padding: 24px 16px 80px; color: #3B2A1E; }

/* ── Hero ── */
.hero { text-align: center; padding: 28px 8px 4px; }
.hero-eyebrow { letter-spacing: .35em; font-size: .78rem; color: #5C4A35; margin: 0 0 6px; }
.hero h1 { font-size: clamp(1.7rem, 5vw, 2.5rem); margin: 0 0 8px; font-weight: 900; color: #3B2A1E; }
.amber { color: #E8920A; }
.hero-sub { color: #5C4B3A; font-size: .9rem; max-width: 520px; margin: 0 auto; }

/* ── Direct hotel search ── */
.direct-card {
  background: #fff;
  border: 1px solid #EADFC8;
  border-radius: 16px;
  padding: 13px 16px;
  margin-top: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  box-shadow: 0 2px 8px rgba(59,42,30,.04);
}
.direct-label {
  font-size: .82rem;
  color: #5C4A35;
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
}
.direct-input {
  flex: 1;
  min-width: 140px;
  border: 1.5px solid #EADFC8;
  border-radius: 12px;
  padding: 8px 13px;
  font-size: .88rem;
  background: #FFF8EC;
  color: #3B2A1E;
  font-family: inherit;
  transition: border-color .15s;
}
.direct-input:focus { outline: none; border-color: #E8920A; }
.direct-input::placeholder { color: #B0977A; }
.btn-direct {
  border: none;
  border-radius: 12px;
  padding: 8px 16px;
  background: #E8920A;
  color: #fff;
  font-weight: 900;
  font-size: .88rem;
  cursor: pointer;
  font-family: inherit;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background .15s;
}
.btn-direct:hover:not(:disabled) { background: #C2740A; }
.btn-direct:disabled { opacity: .55; cursor: not-allowed; }
.direct-msg {
  font-size: .79rem;
  width: 100%;
  padding: 0 2px;
  margin: 0;
}
.direct-msg.ok  { color: #4A7A28; }
.direct-msg.err { color: #C2400A; }

/* ── Chat card ── */
.chat-card {
  background: #FFFFFF;
  border: 1px solid #EADFC8;
  border-radius: 20px;
  margin-top: 20px;
  box-shadow: 0 4px 16px rgba(59,42,30,.05);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-header {
  padding: 14px 18px;
  border-bottom: 1px solid #EADFC8;
  display: flex;
  align-items: center;
  gap: 10px;
  background: #FFFCF5;
}
.chat-header-avatar { font-size: 1.5rem; }
.chat-header-title { font-size: .9rem; font-weight: 900; color: #3B2A1E; }
.chat-header-sub { font-size: .72rem; color: #9C8870; }

/* ── Chat log ── */
.chat-log {
  flex: 1;
  overflow-y: auto;
  padding: 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 240px;
  max-height: 400px;
  background: #FFFDF8;
}
@media (min-width: 600px) { .chat-log { max-height: 460px; } }

/* ── Bubbles ── */
.bubble-row {
  display: flex;
  align-items: flex-end;
  gap: 7px;
  animation: bubbleFadeIn .2s ease both;
}
@keyframes bubbleFadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.bear-row  { justify-content: flex-start; }
.user-row  { justify-content: flex-end; }

.bear-avatar {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #FFEFD2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  flex-shrink: 0;
  border: 1px solid #EADFC8;
}

.bubble {
  max-width: 76%;
  padding: 9px 13px;
  border-radius: 18px;
  font-size: .88rem;
  line-height: 1.55;
  word-break: break-word;
}
.bear-bubble {
  background: #FFFFFF;
  border: 1px solid #EADFC8;
  border-bottom-left-radius: 5px;
  color: #3B2A1E;
}
.user-bubble {
  background: #E8920A;
  color: #fff;
  border-bottom-right-radius: 5px;
}

/* ── Typing dots ── */
.typing-bubble {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 10px 14px;
}
.typing-dot {
  display: inline-block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #C2A882;
  animation: typingBounce 1.2s infinite;
}
.typing-dot:nth-child(2) { animation-delay: .18s; }
.typing-dot:nth-child(3) { animation-delay: .36s; }
@keyframes typingBounce {
  0%,80%,100% { transform: translateY(0); opacity: .5; }
  40%          { transform: translateY(-6px); opacity: 1; }
}

/* ── Chat input ── */
.chat-input-row {
  display: flex;
  gap: 8px;
  padding: 10px 12px;
  border-top: 1px solid #EADFC8;
  background: #FFFFFF;
}
.chat-input {
  flex: 1;
  border: 1.5px solid #EADFC8;
  border-radius: 20px;
  padding: 9px 15px;
  font-size: .9rem;
  background: #FFF8EC;
  color: #3B2A1E;
  font-family: inherit;
  transition: border-color .15s;
  resize: none;
}
.chat-input:focus { outline: none; border-color: #E8920A; }
.chat-input::placeholder { color: #B0977A; }
.btn-send {
  border: none;
  border-radius: 20px;
  padding: 9px 18px;
  background: #E8920A;
  color: #fff;
  font-weight: 900;
  font-size: .88rem;
  cursor: pointer;
  font-family: inherit;
  transition: background .15s, transform .1s;
  white-space: nowrap;
  flex-shrink: 0;
}
.btn-send:hover:not(:disabled) { background: #C2740A; }
.btn-send:active:not(:disabled) { transform: scale(.95); }
.btn-send:disabled { opacity: .5; cursor: not-allowed; }

/* ── Hotel grid & cards ── */
.hotels-section { margin-top: 16px; }
.hotel-grid { display: grid; gap: 13px; grid-template-columns: 1fr; }
@media (min-width: 580px) { .hotel-grid { grid-template-columns: 1fr 1fr; } }

.hotel-card {
  background: #FFF8EC;
  border: 1.5px solid #EADFC8;
  border-radius: 16px;
  padding: 17px 15px;
  cursor: pointer;
  transition: border-color .15s, box-shadow .15s, transform .12s;
  display: flex;
  flex-direction: column;
  gap: 7px;
  text-align: left;
  font-family: inherit;
  color: #3B2A1E;
}
.hotel-card:hover {
  border-color: #E8920A;
  box-shadow: 0 4px 18px rgba(232,146,10,.14);
  transform: translateY(-2px);
}
.hotel-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
.hotel-name { font-size: .97rem; font-weight: 900; margin: 0; color: #3B2A1E; flex: 1; }
.hotel-city {
  font-size: .72rem; color: #C2740A; background: #FFEFD2;
  border-radius: 999px; padding: 2px 9px; white-space: nowrap; flex-shrink: 0; font-weight: 700;
}
.hotel-reason { font-size: .83rem; color: #5C4A35; margin: 0; line-height: 1.5; flex: 1; }
.hotel-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.hotel-tags span {
  background: #FFEFD2; color: #C2740A; border-radius: 999px;
  font-size: .7rem; padding: 2px 9px; font-weight: 700;
}
.hotel-card-hint { font-size: .75rem; color: #E8920A; font-weight: 700; align-self: flex-end; }

/* ── Results toolbar ── */
.results-toolbar { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
.btn-more {
  flex: 1;
  border: 1.5px solid #EADFC8; border-radius: 14px; padding: 11px 14px;
  font-size: .88rem; font-weight: 700; cursor: pointer;
  background: #FFF8EC; color: #3B2A1E; font-family: inherit; transition: border-color .15s;
  white-space: nowrap;
}
.btn-more:hover { border-color: #E8920A; }
.btn-more:disabled { opacity: .5; cursor: not-allowed; }
.btn-restart {
  border: none; border-radius: 14px; padding: 11px 18px;
  font-size: .88rem; font-weight: 700; cursor: pointer;
  background: #E8920A; color: #fff; font-family: inherit; transition: background .15s;
  white-space: nowrap;
}
.btn-restart:hover { background: #C2740A; }

/* ── Modal ── */
.modal-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.5);
  display: flex; align-items: center; justify-content: center;
  z-index: 9999; padding: 16px;
}
.modal-card {
  background: #FFFFFF; border-radius: 20px;
  max-width: 460px; width: 100%; max-height: 88vh; overflow-y: auto;
  padding: 26px 20px 22px; position: relative; color: #3B2A1E;
}
.modal-close {
  position: absolute; top: 14px; right: 14px; width: 30px; height: 30px;
  border: none; background: #F5F0E8; border-radius: 50%; cursor: pointer;
  font-size: .95rem; color: #5C4A35; display: flex; align-items: center; justify-content: center;
  transition: background .15s;
}
.modal-close:hover { background: #EADFC8; }
.modal-hotel-name { font-size: 1.25rem; font-weight: 900; margin: 0 28px 3px 0; color: #3B2A1E; }
.modal-hotel-en   { font-size: .8rem; color: #5C4A35; margin: 0 0 6px; }
.modal-hotel-city {
  display: inline-block; font-size: .75rem; color: #C2740A;
  background: #FFEFD2; border-radius: 999px; padding: 2px 12px;
  margin-bottom: 14px; font-weight: 700;
}
.modal-divider { border: none; border-top: 1px solid #EADFC8; margin: 12px 0; }
.modal-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 12px; }
.modal-tags span {
  background: #FFEFD2; color: #C2740A; border-radius: 999px;
  font-size: .73rem; padding: 3px 12px; font-weight: 700;
}
.modal-section-label {
  font-size: .75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
  color: #9C8870; margin: 0 0 5px;
}
.modal-list {
  margin: 0 0 12px; padding: 0; list-style: none;
  display: flex; flex-direction: column; gap: 4px;
}
.modal-list li { font-size: .86rem; line-height: 1.5; padding-left: 1.3em; position: relative; color: #3B2A1E; }
.modal-list.pros li::before { content: '✅'; position: absolute; left: 0; font-size: .72em; top: .18em; }
.modal-list.cons li::before { content: '⚠️'; position: absolute; left: 0; font-size: .72em; top: .18em; }
.btn-cta {
  display: block; width: 100%; background: #E8920A; color: #fff; text-align: center;
  padding: 13px; border-radius: 14px; font-weight: 900; font-size: .97rem;
  text-decoration: none; letter-spacing: .04em; transition: background .15s; margin-top: 6px;
}
.btn-cta:hover { background: #C2740A; }
.modal-disclaimer { text-align: center; font-size: .7rem; color: #9C8870; margin: 7px 0 0; }

/* ── Checklist ── */
.card {
  background: #FFFFFF; border: 1px solid #EADFC8; border-radius: 20px;
  padding: 22px 18px; margin-top: 20px; box-shadow: 0 4px 16px rgba(59,42,30,.05); color: #3B2A1E;
}
.card h2 { font-size: 1.1rem; margin: 0 0 12px; color: #3B2A1E; display: flex; align-items: center; gap: 8px; }
.checklist ol { padding-left: 20px; margin: 0; }
.checklist li { margin-bottom: 7px; font-size: .9rem; color: #3B2A1E; }
.disclosure { margin-top: 14px; padding: 10px 12px; background: #FFF8EC; border-radius: 10px; font-size: .78rem; color: #5C4A35; }

@media (prefers-reduced-motion: reduce) { * { transition: none !important; animation: none !important; } }
</style>

<html lang="zh-Hant">
<head>
  <BaseHead
    title="🐻 問兩隻熊｜旅遊住宿顧問"
    description="不知道住哪？跟兩隻熊聊一聊，告訴熊你的需求，熊熊幫你推薦最適合的飯店，一鍵查 TripAdvisor 最低價。"
  />
</head>
<body>
  <Header />

  <main class="wrap">

    <!-- ── Hero ── -->
    <header class="hero">
      <p class="hero-eyebrow">兩隻熊旅遊顧問</p>
      <h1>不知道住哪？<span class="amber">問兩隻熊</span></h1>
      <p class="hero-sub">跟熊熊聊一聊你的需求，熊熊幫你找最適合的飯店，再一鍵查 TripAdvisor 最低價。</p>
    </header>

    <!-- ── Direct hotel search ── -->
    <div class="direct-card">
      <span class="direct-label">🔍 已知飯店名稱？直接比價：</span>
      <input id="direct-input" class="direct-input" type="text" placeholder="例：台北晶華、東京半島飯店" maxlength="100" autocomplete="off" />
      <button id="btn-direct" class="btn-direct" type="button">比價 →</button>
      <p class="direct-msg" id="direct-msg" style="display:none"></p>
    </div>

    <!-- ── Chat card ── -->
    <div class="chat-card">
      <div class="chat-header">
        <div class="chat-header-avatar">🐻</div>
        <div>
          <div class="chat-header-title">兩隻熊旅遊顧問</div>
          <div class="chat-header-sub">AI 聊天 · 推薦真實飯店 · 一鍵查 TripAdvisor 價格</div>
        </div>
      </div>

      <div class="chat-log" id="chat-log"></div>

      <div class="chat-input-row" id="input-row">
        <input
          type="text"
          id="chat-input"
          class="chat-input"
          placeholder="請輸入…"
          autocomplete="off"
          maxlength="200"
        />
        <button class="btn-send" id="btn-send" type="button">送出</button>
      </div>
    </div>

    <!-- ── Hotel cards (shown after recommendation) ── -->
    <div class="hotels-section" id="hotels-section" style="display:none">
      <div class="hotel-grid" id="hotel-grid"></div>
      <div class="results-toolbar">
        <button class="btn-more" id="btn-more" type="button">😅 都不喜歡？再推薦四間</button>
        <button class="btn-restart" id="btn-restart" type="button">重新問熊熊</button>
      </div>
    </div>

    <!-- ── Checklist ── -->
    <section class="card checklist">
      <h2>🍯 查到飯店後的下一步</h2>
      <ol>
        <li><strong>點「查看 TripAdvisor 價格」</strong>——TripAdvisor 聚合 Agoda、Booking 等十多家平台的報價，一頁比完。</li>
        <li><strong>比「總價」不要比「每晚價」</strong>——稅、服務費各平台算法不同，總額才是真相。</li>
        <li><strong>APP 再確認一次</strong>——Agoda 和 Trip 的 APP 限定價常常比網頁便宜。</li>
        <li><strong>取消條款</strong>——便宜 200 元但不可退，行程一變就虧大了。</li>
        <li><strong>用信用卡海外回饋</strong>——選對卡再省 2–3%。</li>
      </ol>
      <p class="disclosure">本頁連結為聯盟連結，透過連結訂房兩隻熊會獲得少量回饋，<strong>你的價格完全不受影響</strong>。謝謝朋友支持頻道 🐻🐻</p>
    </section>

  </main>

  <!-- ── Modal ── -->
  <div id="hotel-modal" class="modal-overlay" style="display:none" role="dialog" aria-modal="true">
    <div class="modal-card">
      <button class="modal-close" id="modal-close" aria-label="關閉">✕</button>
      <h2 class="modal-hotel-name" id="modal-name"></h2>
      <p class="modal-hotel-en"   id="modal-en"></p>
      <span class="modal-hotel-city" id="modal-city"></span>
      <hr class="modal-divider" />
      <div class="modal-tags" id="modal-tags"></div>
      <p class="modal-section-label">✅ 優點</p>
      <ul class="modal-list pros" id="modal-pros"></ul>
      <p class="modal-section-label">⚠️ 要注意</p>
      <ul class="modal-list cons" id="modal-cons"></ul>
      <a id="modal-cta" class="btn-cta" target="_blank" rel="sponsored nofollow noopener" href="#">
        查看 TripAdvisor 價格 →
      </a>
      <p class="modal-disclaimer">價格與房況以訂房平台為準 · 兩隻熊不保證房源可訂</p>
    </div>
  </div>

  <Footer />
</body>
</html>

<script is:inline>
/* ===================================================================
   設定
   =================================================================== */
const TA_TRACKING = 'https://tlcafftrax.com/track/clicks/2070/c627c2bb980727dcff9cab248d2596412379128f78efe6f30776f6476a0449a8c23ae5a5112d';

function taLink(enName, city) {
  var q = encodeURIComponent(enName + ' ' + city);
  var target = 'https://www.tripadvisor.com.tw/Search?q=' + q + '&ssrc=h';
  return TA_TRACKING + '?t=' + encodeURIComponent(encodeURIComponent(target));
}

function escHtml(s) {
  return String(s ?? '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

/* ===================================================================
   狀態
   =================================================================== */
var chatHistory  = [];   // Gemini API 格式：[{role, parts:[{text}]}]
var phase        = 'chatting'; // 'chatting' | 'searching' | 'done'
var turnCount    = 0;
var MAX_TURNS    = 10;
var isWaiting    = false;
var lastSummary  = null;
var currentHotels = [];
var askedNames   = [];

/* ===================================================================
   DOM helpers
   =================================================================== */
function scrollLog() {
  var log = document.getElementById('chat-log');
  if (log) setTimeout(function() { log.scrollTop = log.scrollHeight; }, 40);
}

function addBearBubble(text) {
  var log = document.getElementById('chat-log');
  var row = document.createElement('div');
  row.className = 'bubble-row bear-row';
  var av = document.createElement('div'); av.className = 'bear-avatar'; av.textContent = '🐻';
  var bub = document.createElement('div'); bub.className = 'bubble bear-bubble'; bub.textContent = text;
  row.appendChild(av); row.appendChild(bub);
  log.appendChild(row);
  scrollLog();
}

function addUserBubble(text) {
  var log = document.getElementById('chat-log');
  var row = document.createElement('div');
  row.className = 'bubble-row user-row';
  var bub = document.createElement('div'); bub.className = 'bubble user-bubble'; bub.textContent = text;
  row.appendChild(bub);
  log.appendChild(row);
  scrollLog();
}

function showTyping() {
  var log = document.getElementById('chat-log');
  var row = document.createElement('div');
  row.id = 'typing-row';
  row.className = 'bubble-row bear-row';
  row.innerHTML = '<div class="bear-avatar">🐻</div><div class="bubble bear-bubble typing-bubble"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>';
  log.appendChild(row);
  scrollLog();
}

function hideTyping() {
  var el = document.getElementById('typing-row');
  if (el) el.remove();
}

function setUI(disabled) {
  var inp = document.getElementById('chat-input');
  var btn = document.getElementById('btn-send');
  if (inp) inp.disabled = disabled;
  if (btn) btn.disabled = disabled;
}

/* ===================================================================
   送出訊息
   =================================================================== */
async function sendMessage() {
  if (isWaiting || phase !== 'chatting') return;
  var inp = document.getElementById('chat-input');
  var text = inp.value.trim();
  if (!text) return;

  inp.value = '';
  isWaiting = true;
  setUI(true);
  turnCount++;

  addUserBubble(text);
  chatHistory.push({ role: 'user', parts: [{ text: text }] });

  showTyping();

  try {
    // 接近上限時加觸發指令
    var messages = chatHistory;
    if (turnCount >= MAX_TURNS) {
      messages = chatHistory.concat([
        { role: 'user', parts: [{ text: '（資訊已夠了，請現在整理並推薦飯店）' }] }
      ]);
    }

    var res = await fetch('/api/advisor-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'chat', messages: messages }),
    });
    var data = await res.json();
    hideTyping();

    if (!data.ok) {
      addBearBubble(data.error || '抱歉朋友，我暫時有點問題，要再說一遍嗎？🐻');
      setUI(false);
      isWaiting = false;
      return;
    }

    // 加 model 回應到歷史
    if (data.modelText) {
      chatHistory.push({ role: 'model', parts: [{ text: data.modelText }] });
    }

    if (data.action === 'recommend' || turnCount >= MAX_TURNS) {
      var summary = data.summary || buildFallbackSummary();
      addBearBubble('好的朋友！讓我幫你翻一翻 🐻✨');
      phase = 'searching';
      await startRecommend(summary);
    } else if (data.action === 'ask') {
      addBearBubble(data.question);
      setUI(false);
    }

  } catch (e) {
    hideTyping();
    addBearBubble('網路有點問題，要再試一次嗎？🐻');
    setUI(false);
  }

  isWaiting = false;
}

// 超過輪數時從歷史拼湊摘要
function buildFallbackSummary() {
  var userTexts = chatHistory
    .filter(function(m) { return m.role === 'user'; })
    .map(function(m) { return m.parts[0].text; })
    .join('，');
  return {
    destination: '未指定',
    companions:  '未指定',
    comfort:     '未指定',
    budget:      '未指定',
    dates:       '未指定',
    preferences: userTexts.slice(0, 150),
  };
}

/* ===================================================================
   推薦飯店
   =================================================================== */
async function startRecommend(summary) {
  lastSummary = summary;
  showTyping();

  try {
    var res = await fetch('/api/advisor-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        type: 'recommend',
        summary: summary,
        excludeNames: askedNames.length ? askedNames : undefined,
      }),
    });
    var data = await res.json();
    hideTyping();

    if (!data.ok || !data.hotels || !data.hotels.length) {
      addBearBubble(data.error || '這次沒找到很合適的，要調整一下需求再試試嗎？🐻');
      phase = 'chatting';
      setUI(false);
      return;
    }

    currentHotels = data.hotels;
    askedNames = askedNames.concat(data.hotels.map(function(h) { return h.name; }));

    addBearBubble('幫你找到 ' + data.hotels.length + ' 間！點卡片看詳情，喜歡的再查 TripAdvisor 價格 ↓');

    document.getElementById('hotels-section').style.display = '';
    renderHotels(data.hotels);
    document.getElementById('input-row').style.display = 'none';
    phase = 'done';

    setTimeout(function() {
      document.getElementById('hotels-section').scrollIntoView({ behavior: 'smooth' });
    }, 350);

  } catch (e) {
    hideTyping();
    addBearBubble('搜尋時出了點問題，要再試一次嗎？🐻');
    phase = 'chatting';
    setUI(false);
  }
}

/* ===================================================================
   再推薦四間
   =================================================================== */
async function askMore() {
  if (!lastSummary) return;
  var btn = document.getElementById('btn-more');
  if (btn) { btn.disabled = true; btn.textContent = '搜尋中…'; }

  try {
    var res = await fetch('/api/advisor-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        type: 'recommend',
        summary: lastSummary,
        excludeNames: askedNames,
      }),
    });
    var data = await res.json();

    if (!data.ok || !data.hotels || !data.hotels.length) {
      alert('熊熊已推薦完這個地區的飯店了，換個關鍵字試試看？');
      return;
    }

    currentHotels = data.hotels;
    askedNames = askedNames.concat(data.hotels.map(function(h) { return h.name; }));
    renderHotels(data.hotels);
    document.getElementById('hotels-section').scrollIntoView({ behavior: 'smooth' });

  } catch (e) {
    alert('網路暫時有問題，請稍後再試 🐻');
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = '😅 都不喜歡？再推薦四間'; }
  }
}

/* ===================================================================
   渲染飯店卡片
   =================================================================== */
function renderHotels(hotels) {
  var grid = document.getElementById('hotel-grid');
  grid.innerHTML = hotels.map(function(h, i) {
    var tags = (h.tags || []).map(function(t) { return '<span>' + escHtml(t) + '</span>'; }).join('');
    return '<button class="hotel-card" type="button" data-idx="' + i + '">' +
      '<div class="hotel-card-header">' +
        '<h3 class="hotel-name">' + escHtml(h.name) + '</h3>' +
        '<span class="hotel-city">' + escHtml(h.city) + '</span>' +
      '</div>' +
      '<p class="hotel-reason">' + escHtml(h.reason) + '</p>' +
      '<div class="hotel-tags">' + tags + '</div>' +
      '<span class="hotel-card-hint">查看詳情 →</span>' +
      '</button>';
  }).join('');

  grid.onclick = function(e) {
    var card = e.target.closest('.hotel-card');
    if (!card) return;
    openModal(currentHotels[parseInt(card.dataset.idx)]);
  };
}

/* ===================================================================
   Modal
   =================================================================== */
function openModal(h) {
  document.getElementById('modal-name').textContent = h.name;
  document.getElementById('modal-en').textContent = h.en;
  document.getElementById('modal-city').textContent = '📍 ' + h.city;
  document.getElementById('modal-tags').innerHTML =
    (h.tags || []).map(function(t) { return '<span>' + escHtml(t) + '</span>'; }).join('');
  document.getElementById('modal-pros').innerHTML =
    (h.pros || []).map(function(p) { return '<li>' + escHtml(p) + '</li>'; }).join('');
  document.getElementById('modal-cons').innerHTML =
    (h.cons || []).map(function(c) { return '<li>' + escHtml(c) + '</li>'; }).join('');
  document.getElementById('modal-cta').href = taLink(h.en, h.city);
  document.getElementById('hotel-modal').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('hotel-modal').style.display = 'none';
  document.body.style.overflow = '';
}

document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('hotel-modal').addEventListener('click', function(e) {
  if (e.target === document.getElementById('hotel-modal')) closeModal();
});
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeModal();
});

/* ===================================================================
   重置
   =================================================================== */
function resetChat() {
  chatHistory = []; phase = 'chatting'; turnCount = 0;
  isWaiting = false; lastSummary = null; currentHotels = []; askedNames = [];
  document.getElementById('chat-log').innerHTML = '';
  document.getElementById('hotels-section').style.display = 'none';
  document.getElementById('input-row').style.display = '';
  setUI(false);
  addBearBubble('嗨朋友！我是兩隻熊旅遊顧問 🐻 你想去哪裡旅遊？');
  document.getElementById('chat-input').focus();
}

/* ===================================================================
   直接比價
   =================================================================== */
async function directSearch() {
  var inp = document.getElementById('direct-input');
  var btn = document.getElementById('btn-direct');
  var msg = document.getElementById('direct-msg');
  var name = inp.value.trim();
  if (!name) { inp.focus(); return; }

  btn.disabled = true;
  btn.textContent = '查詢中…';
  msg.className = 'direct-msg';
  msg.textContent = '熊熊正在找飯店英文名…';
  msg.style.display = '';

  try {
    var res = await fetch('/api/advisor-chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type: 'direct', hotelName: name }),
    });
    var data = await res.json();

    if (data.ok && data.hotel) {
      msg.className = 'direct-msg ok';
      msg.textContent = '✅ 找到「' + data.hotel.name + '」，正在開啟比價頁面…';
      window.open(taLink(data.hotel.en, data.hotel.city), '_blank');
      inp.value = '';
      setTimeout(function() { msg.style.display = 'none'; }, 3500);
    } else {
      msg.className = 'direct-msg err';
      msg.textContent = '❌ ' + (data.error || '找不到這間飯店，請試試英文名稱');
    }
  } catch (e) {
    msg.className = 'direct-msg err';
    msg.textContent = '❌ 網路有點問題，請再試一次';
  } finally {
    btn.disabled = false;
    btn.textContent = '比價 →';
  }
}

/* ===================================================================
   事件綁定
   =================================================================== */
document.getElementById('btn-send').addEventListener('click', sendMessage);
document.getElementById('chat-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});
document.getElementById('btn-more').addEventListener('click', askMore);
document.getElementById('btn-restart').addEventListener('click', resetChat);
document.getElementById('btn-direct').addEventListener('click', directSearch);
document.getElementById('direct-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') { e.preventDefault(); directSearch(); }
});

/* ===================================================================
   初始化
   =================================================================== */
addBearBubble('嗨朋友！我是兩隻熊旅遊顧問 🐻 你想去哪裡旅遊？');
document.getElementById('chat-input').focus();
</script>
