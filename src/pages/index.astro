---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, YOUTUBE_CHANNEL } from '../consts';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { getPostCategory, CATEGORY_COLORS } from '../utils/category';
import TodayPanel from '../components/TodayPanel.astro';
import DailyProphecy from '../components/DailyProphecy.astro';
import GlobalCountdown from '../components/GlobalCountdown.astro';
import SurvivalIndex from '../components/SurvivalIndex.astro';
import TodayEvents from '../components/TodayEvents.astro';
import DailyQuote from '../components/DailyQuote.astro';
import ProphecyLeaderboard from '../components/ProphecyLeaderboard.astro';
import MultiCityWeather from '../components/MultiCityWeather.astro';

let viewCounts: Record<string, number> = {};
try {
	const res = await fetch(new URL('/api/view', Astro.site));
	if (res.ok) viewCounts = await res.json();
} catch {}

const allPosts = await getCollection('blog');
const CATEGORY_ORDER: Record<string, number> = { '預言': 0, '評測': 1, '旅遊': 2, '影片': 3 };

function categoryPriority(post: CollectionEntry<'blog'>): number {
	const cat = getPostCategory(post);
	return cat && cat in CATEGORY_ORDER ? CATEGORY_ORDER[cat] : 3;
}
function score(post: CollectionEntry<'blog'>): number {
	const slug = `/blog/${post.id.replace(/\.mdx?$/, '')}/`;
	const views = viewCounts[slug] ?? 0;
	const ageDays = (Date.now() - new Date(post.data.pubDate).getTime()) / 86400000;
	return views + Math.max(0, 30 - ageDays) * 2;
}
const posts = allPosts.sort((a, b) => {
	const d = categoryPriority(a) - categoryPriority(b);
	return d !== 0 ? d : score(b) - score(a);
});

function getThumbnail(post: CollectionEntry<'blog'>): string | null {
	if (post.data.youtubeId) return `https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`;
	if (post.data.heroImage) {
		const h = post.data.heroImage as any;
		return typeof h === 'string' ? h : h?.src ?? null;
	}
	return null;
}
const CATEGORY_GRADIENTS: Record<string, string> = {
	'預言': 'linear-gradient(135deg,#1a1a2e,#c0392b)',
	'影片': 'linear-gradient(135deg,#0f3460,#16213e)',
	'旅遊': 'linear-gradient(135deg,#134e5e,#71b280)',
	'評測': 'linear-gradient(135deg,#4a00e0,#8e2de2)',
	'其他': 'linear-gradient(135deg,#373b44,#4286f4)',
};
const CATEGORY_ICONS: Record<string, string> = {
	'預言': '🔮', '影片': '🎬', '旅遊': '✈️', '評測': '📦', '其他': '📝',
};
---

<!doctype html>
<html lang="zh-TW">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />
<main class="home-main">

	<!-- ── Hero ── -->
	<section class="hero-section">
		<div class="hero-inner">
			<div class="hero-badge">🔥 今日世界異象觀測站</div>
			<h1 class="hero-title">每天追蹤全球預言<br/><span class="hero-accent">國際局勢・虛擬貨幣・生存資訊</span></h1>
			<a href={YOUTUBE_CHANNEL || 'https://www.youtube.com/@twobears'} target="_blank" rel="noopener noreferrer" class="hero-yt-btn">
				<svg class="yt-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
				訂閱 YouTube 頻道
				<span class="yt-sub-hint">免費獲得最新預言影片通知</span>
			</a>
			<div class="hero-btns">
				<a href="/category/影片" class="hero-btn btn-video">📺 最新影片</a>
				<a href="/category/預言" class="hero-btn btn-prophecy">🔮 今日預言</a>
				<a href="/blog" class="hero-btn btn-news">🚨 全球異常事件</a>
				<a href="/hotels" class="hero-btn btn-hotels">🏨 超省訂房</a>
				<a href="/travel-news" class="hero-btn btn-travel">✈️ 旅遊最新報</a>
			</div>
		</div>
	</section>

	<!-- ── Top grid: hero-body + events ── -->
	<div class="top-grid">
		<!-- Left: today panel + prophecy + AI -->
		<div class="left-top">
			<div class="prophet-row">
				<TodayPanel />
				<DailyProphecy />
			</div>
			<iframe
				src="/biggsgpt"
				width="100%"
				height="400"
				class="biggsgpt-top-iframe"
				style="border:none;border-radius:12px;display:block;margin-top:.8em;"
				title="比格斯 GPT"
				loading="lazy"
			></iframe>
		</div>
		<!-- Right: events feed -->
		<aside class="right-top">
			<TodayEvents />
			<MultiCityWeather />
		</aside>
	</div>

	<!-- ── Leaderboard full width ── -->
	<section class="lb-section">
		<ProphecyLeaderboard />
	</section>

	<!-- ── Hotel Finder Banner ── -->
	<a href="/hotels" class="hotel-banner">
		<div class="hotel-banner-left">
			<span class="hotel-banner-emoji">🐻</span>
			<div>
				<div class="hotel-banner-title">兩隻熊超省飯店搜尋器</div>
				<div class="hotel-banner-sub">全網比價 · 信用卡疊加省錢 · AI旅遊助手 · LINE降價通知</div>
			</div>
		</div>
		<div class="hotel-banner-deals">
			<span>沖繩 ↓31%</span>
			<span>東京 ↓23%</span>
			<span>首爾 ↓27%</span>
			<span>曼谷 ↓35%</span>
		</div>
		<div class="hotel-banner-cta">立即找最低價 →</div>
	</a>

	<!-- ── Main grid: articles + sidebar ── -->
	<div class="content-grid">

		<!-- Articles -->
		<section class="articles-section">
			<div class="section-heading">
				<span class="sh-icon">✨</span>
				<h2 class="sh-title">最新文章與趨勢觀測</h2>
				<span class="sh-sub">今天發生什麼事</span>
			</div>
			<ul class="posts-grid">
				{posts.slice(0, 9).map((post) => {
					const cat = getPostCategory(post);
					const color = CATEGORY_COLORS[cat] ?? '#7f8c8d';
					const thumb = getThumbnail(post);
					const gradient = CATEGORY_GRADIENTS[cat] ?? CATEGORY_GRADIENTS['其他'];
					const icon = CATEGORY_ICONS[cat] ?? '📝';
					return (
						<li class="post-card">
							<a href={`/blog/${post.id}/`}>
								<div class="post-thumb">
									{thumb ? (
										<img src={thumb} alt={post.data.title} loading="lazy" decoding="async" />
									) : (
										<div class="post-placeholder" style={`background:${gradient}`}>
											<span class="ph-icon">{icon}</span>
											<span class="ph-cat">{cat}</span>
										</div>
									)}
									<span class="cat-tag" style={`background:${color}`}>{cat}</span>
								</div>
								<div class="post-body">
									<h4 class="post-title">{post.data.title}</h4>
									<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
								</div>
							</a>
						</li>
					);
				})}
			</ul>
			<div class="more-posts-row">
				<a href="/blog" class="btn-more-posts">查看全部 {posts.length} 篇文章 →</a>
			</div>
		</section>

		<!-- Sidebar tools -->
		<aside class="tools-sidebar">

			<!-- Survival + countdown section -->
			<div class="section-heading">
				<span class="sh-icon">🔴</span>
				<h2 class="sh-title">全球倒數計時 & 今日生存指數</h2>
			</div>

			<div class="sidebar-content">
				<GlobalCountdown />
				<SurvivalIndex />
			</div>

		</aside>
	</div>

	<!-- ── Food Delivery Promos ── -->
	<section class="food-section">
		<div class="food-header">
			<span class="food-header-icon">🛵</span>
			<span class="food-header-title">外送優惠</span>
			<span class="food-header-sub">新顧客首單 · 老顧客本月代碼 <span class="auto-badge">🤖 每月自動更新</span></span>
		</div>
		<div class="food-grid">

			<!-- 左：foodpanda -->
			<div class="food-card">
				<div class="food-platform-header fp-header">
					<span class="fp-logo">🐼</span>
					<span class="fp-name">foodpanda</span>
				</div>
				<div class="food-card-label">🆕 新顧客</div>
				<a
					href="https://www.foodpanda.com.tw/referral?code=cb759283bc3b8d82342c97237b399e9b&geid=FP_TW&ts=1781084008"
					target="_blank" rel="noopener noreferrer"
					class="food-btn food-btn-panda"
				>
					<div class="food-btn-text">
						<div class="food-btn-name">首單最高現折</div>
						<div class="food-btn-deal"><strong>$150</strong> 優惠</div>
					</div>
					<span class="food-btn-arrow">立即領取 →</span>
				</a>
				<div class="food-card-label" style="margin-top:.85em">
					📅 老顧客代碼
				</div>
				<div id="food-codes-panda">
					<div class="code-loading"><span class="code-spin">⟳</span> 載入中...</div>
				</div>
			</div>

			<!-- 右：Uber Eats -->
			<div class="food-card">
				<div class="food-platform-header ue-header">
					<span class="fp-logo">🚗</span>
					<span class="fp-name">Uber Eats</span>
				</div>
				<div class="food-card-label">🆕 新顧客</div>
				<a
					href="https://ubereats.com/feed?promoCode=eats-b7ybz1"
					target="_blank" rel="noopener noreferrer"
					class="food-btn food-btn-uber"
				>
					<div class="food-btn-text">
						<div class="food-btn-name">首單折抵優惠</div>
						<div class="food-btn-deal"><strong>15%</strong> · 代碼 <code>eats-b7ybz1</code></div>
					</div>
					<span class="food-btn-arrow">立即領取 →</span>
				</a>
				<div class="food-card-label" style="margin-top:.85em">
					📅 老顧客代碼
				</div>
				<div id="food-codes-uber">
					<div class="code-loading"><span class="code-spin">⟳</span> 載入中...</div>
				</div>
			</div>

		</div>
		<p class="food-update-note" id="food-update-note">📌 每月1日自動從全網更新最新有效代碼</p>
	</section>

	<!-- ── Daily Quote ── -->
	<DailyQuote />

</main>
<Footer />
</body>
</html>

<script>
  function copyCode(btn: HTMLButtonElement) {
    const code = btn.dataset.code;
    if (!code) return;
    navigator.clipboard.writeText(code).then(() => {
      const label = btn.querySelector('.copy-label') as HTMLElement;
      if (label) { label.textContent = '已複製！'; setTimeout(() => { label.textContent = '複製'; }, 2000); }
    });
  }
  (window as any).copyCode = copyCode;

  function toggleRegion(id: string) {
    const el = document.getElementById(id);
    const btn = el?.previousElementSibling as HTMLButtonElement | null;
    if (!el || !btn) return;
    const open = el.style.display !== 'none';
    el.style.display = open ? 'none' : 'block';
    btn.textContent = btn.textContent!.replace(open ? '▲' : '▼', open ? '▼' : '▲');
  }
  (window as any).toggleRegion = toggleRegion;

  // ── Auto-load food delivery codes ──
  async function loadFoodCodes() {
    const pandaEl = document.getElementById('food-codes-panda');
    const uberEl  = document.getElementById('food-codes-uber');
    const note    = document.getElementById('food-update-note');

    type CodeEntry = { platform: string; code: string; desc: string; expires?: string; general: boolean; source?: string };

    const CODE_COLORS = [
      { bg: 'rgba(251,191,36,.15)',  border: 'rgba(251,191,36,.4)',  text: '#fbbf24' },
      { bg: 'rgba(52,211,153,.15)',  border: 'rgba(52,211,153,.4)',  text: '#34d399' },
      { bg: 'rgba(167,139,250,.15)', border: 'rgba(167,139,250,.4)', text: '#a78bfa' },
      { bg: 'rgba(251,146,60,.15)',  border: 'rgba(251,146,60,.4)',  text: '#fb923c' },
      { bg: 'rgba(96,165,250,.15)',  border: 'rgba(96,165,250,.4)',  text: '#60a5fa' },
      { bg: 'rgba(244,114,182,.15)', border: 'rgba(244,114,182,.4)', text: '#f472b6' },
      { bg: 'rgba(74,222,128,.15)',  border: 'rgba(74,222,128,.4)',  text: '#4ade80' },
      { bg: 'rgba(248,113,113,.15)', border: 'rgba(248,113,113,.4)', text: '#f87171' },
    ];
    let codeColorIdx = 0;

    function codeRowHtml(entry: CodeEntry, accentColor: string): string {
      const expireStr = entry.expires ? `・${entry.expires.slice(5).replace('-','/')} 到期` : '';
      const autoTag   = entry.source === 'auto' ? '<span style="font-size:.6em;opacity:.5;margin-left:.3em">網路搜尋</span>' : '';
      const c = CODE_COLORS[codeColorIdx % CODE_COLORS.length];
      codeColorIdx++;
      return `<div class="code-row" style="--accent:${accentColor}">
        <div class="code-info">
          <div class="code-desc">${entry.desc}${expireStr}${autoTag}</div>
        </div>
        <button class="code-copy-btn" data-code="${entry.code}" onclick="copyCode(this)"
          style="background:${c.bg};border-color:${c.border}">
          <span class="code-val" style="color:${c.text}">${entry.code}</span>
          <span class="copy-label">複製</span>
        </button>
      </div>`;
    }

    function renderPlatform(el: HTMLElement | null, codes: CodeEntry[], color: string, fbUrl: string, rid: string) {
      if (!el) return;
      const general  = codes.filter(c => c.general);
      const regional = codes.filter(c => !c.general);
      if (codes.length === 0) {
        el.innerHTML = `<div class="code-row" style="--accent:${color}">
          <div class="code-info"><div class="code-desc">本月暫無公開代碼</div></div>
          <a href="${fbUrl}" target="_blank" rel="noopener noreferrer" class="code-fb-btn">粉專 →</a>
        </div>`;
        return;
      }
      let html = general.map(e => codeRowHtml(e, color)).join('');
      if (regional.length > 0) {
        html += `<button class="code-expand-btn" onclick="toggleRegion('${rid}')">🗺 還有 ${regional.length} 個地區限定代碼 ▼</button>
          <div id="${rid}" class="code-regional" style="display:none">${regional.map(e => codeRowHtml(e, color)).join('')}</div>`;
      }
      el.innerHTML = html;
    }

    try {
      const res = await fetch('/api/food-codes');
      const data = await res.json();
      const allCodes: CodeEntry[] = (data as any).codes ?? [];

      codeColorIdx = 0;
      renderPlatform(pandaEl, allCodes.filter(c => c.platform === 'foodpanda'), '#d70f64', 'https://www.facebook.com/foodpanda.taiwan', 'region-panda');
      codeColorIdx = 4;
      renderPlatform(uberEl,  allCodes.filter(c => c.platform === 'ubereats'),  '#00b140', 'https://www.facebook.com/UberEatsTaiwan',    'region-uber');

      if (note && (data as any).fetched) {
        const d = new Date((data as any).fetched);
        note.textContent = `📌 上次更新：${d.getMonth()+1}月${d.getDate()}日 · 每月1日自動刷新`;
      }
    } catch {
      if (pandaEl) pandaEl.innerHTML = '<p class="code-error">載入失敗</p>';
      if (uberEl)  uberEl.innerHTML  = '<p class="code-error">載入失敗</p>';
    }
  }
  loadFoodCodes();

</script>

<style>
.home-main { max-width: 1200px; margin: 0 auto; padding: 0 1.2em 4em; width: 100%; }

/* ── Hero ── */
.hero-section {
	background: linear-gradient(135deg, #0f172a 0%, rgba(88,28,135,0.3) 50%, #0f172a 100%);
	border: 1px solid rgba(168,85,247,0.15);
	border-radius: 20px;
	padding: 2em 2em 1.8em;
	margin: 1.5em 0 1.2em;
	position: relative;
	overflow: hidden;
}
.hero-section::before {
	content: '';
	position: absolute;
	inset: 0;
	background: radial-gradient(circle at 70% 30%, rgba(168,85,247,0.12), transparent 60%);
	pointer-events: none;
}
.hero-inner { position: relative; }
.hero-badge {
	display: inline-flex; align-items: center; gap: .4em;
	background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25);
	color: #f87171; font-size: .72em; font-weight: 800;
	padding: .3em .9em; border-radius: 20px; margin-bottom: .8em;
	letter-spacing: .04em;
}
.hero-title {
	font-size: clamp(1.5em, 3.5vw, 2.4em);
	font-weight: 900; color: #f1f5f9; line-height: 1.2; margin-bottom: .8em;
}
.hero-accent {
	background: linear-gradient(135deg, #a855f7, #ec4899);
	-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
/* YouTube primary CTA */
.hero-yt-btn {
	display: inline-flex; align-items: center; gap: .65em;
	background: #ff0000; color: #fff;
	padding: .75em 1.6em; border-radius: 14px;
	font-size: 1.05em; font-weight: 800;
	text-decoration: none; margin-bottom: .85em;
	box-shadow: 0 4px 20px rgba(255,0,0,.45);
	transition: transform .15s, box-shadow .15s;
	position: relative;
}
.hero-yt-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(255,0,0,.6); color: #fff; }
.yt-icon { width: 1.3em; height: 1.3em; flex-shrink: 0; }
.yt-sub-hint {
	font-size: .6em; font-weight: 400; opacity: .85;
	position: absolute; bottom: -.05em; right: .8em;
	background: rgba(0,0,0,.35); padding: .1em .5em; border-radius: 0 0 10px 10px;
	display: none;
}
.hero-yt-btn:hover .yt-sub-hint { display: block; }

.hero-btns { display: flex; flex-wrap: wrap; gap: .6em; }
.hero-btn {
	display: inline-flex; align-items: center; gap: .3em;
	font-size: .82em; font-weight: 600; padding: .45em 1em;
	border-radius: 10px; text-decoration: none;
	border: 1px solid rgba(255,255,255,.18);
	background: rgba(255,255,255,.06); color: #cbd5e1;
	transition: background .15s, border-color .15s, color .15s;
}
.hero-btn:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.35); color: #f1f5f9; }
.btn-prophecy { border-color: rgba(168,85,247,.4); color: #c084fc; }
.btn-prophecy:hover { background: rgba(168,85,247,.12); border-color: rgba(168,85,247,.7); color: #d8b4fe; }
.btn-video    { border-color: rgba(59,130,246,.4); color: #93c5fd; }
.btn-video:hover { background: rgba(59,130,246,.12); border-color: rgba(59,130,246,.7); color: #bfdbfe; }
.btn-news     { border-color: rgba(239,68,68,.4); color: #fca5a5; }
.btn-news:hover { background: rgba(239,68,68,.1); border-color: rgba(239,68,68,.6); color: #fecaca; }
.btn-hotels   { border-color: rgba(245,158,11,.4); color: #fcd34d; }
.btn-hotels:hover { background: rgba(245,158,11,.1); border-color: rgba(245,158,11,.6); color: #fde68a; }
.btn-travel   { border-color: rgba(56,189,248,.4); color: #7dd3fc; }
.btn-travel:hover { background: rgba(56,189,248,.1); border-color: rgba(56,189,248,.6); color: #bae6fd; }

/* ── Hotel Banner ── */
.hotel-banner {
	display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1em;
	background: linear-gradient(135deg, rgba(146,64,14,.25) 0%, rgba(217,119,6,.15) 100%);
	border: 1px solid rgba(217,119,6,.35);
	border-radius: 16px; padding: 1em 1.4em; margin-bottom: 1.2em;
	text-decoration: none; transition: border-color .2s, box-shadow .2s;
}
.hotel-banner:hover { border-color: rgba(217,119,6,.6); box-shadow: 0 0 24px rgba(217,119,6,.15); }
.hotel-banner-left { display: flex; align-items: center; gap: .8em; }
.hotel-banner-emoji { font-size: 2em; }
.hotel-banner-title { font-size: .95em; font-weight: 800; color: #fbbf24; margin-bottom: .15em; }
.hotel-banner-sub { font-size: .72em; color: #94a3b8; }
.hotel-banner-deals { display: flex; gap: .5em; flex-wrap: wrap; }
.hotel-banner-deals span {
	background: rgba(239,68,68,.15); border: 1px solid rgba(239,68,68,.3);
	color: #f87171; font-size: .72em; font-weight: 700;
	padding: .2em .6em; border-radius: 20px;
}
.hotel-banner-cta {
	background: linear-gradient(135deg,#92400e,#d97706);
	color: white; font-weight: 800; font-size: .85em;
	padding: .55em 1.3em; border-radius: 10px; white-space: nowrap;
}
@media (max-width: 700px) {
	.hotel-banner { flex-direction: column; align-items: flex-start; }
	.hotel-banner-deals { display: none; }
}

/* ── Top grid ── */
.top-grid {
	display: grid;
	grid-template-columns: 1fr 340px;
	gap: 1.2em;
