---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { getPostCategory, CATEGORY_COLORS } from '../utils/category';
import DailyFortune from '../components/DailyFortune.astro';
import EarthquakeWidget from '../components/EarthquakeWidget.astro';
import MessageWall from '../components/MessageWall.astro';
import ProphecyLeaderboard from '../components/ProphecyLeaderboard.astro';
import MultiCityWeather from '../components/MultiCityWeather.astro';
import ProphecyPoll from '../components/ProphecyPoll.astro';

let viewCounts: Record<string, number> = {};
try {
	const res = await fetch(new URL('/api/view', Astro.site));
	if (res.ok) viewCounts = await res.json();
} catch {}

const allPosts = await getCollection('blog');

const CATEGORY_ORDER: Record<string, number> = { '預言': 0, '評測': 1, '旅遊': 2, '影片': 3 };

function categoryPriority(post: CollectionEntry<'blog'>): number {
	const cat = getPostCategory(post);
	return cat && cat in CATEGORY_ORDER ? CATEGORY_ORDER[cat] : 3;
}

function score(post: CollectionEntry<'blog'>): number {
	const slug = `/blog/${post.id.replace(/\.mdx?$/, '')}/`;
	const views = viewCounts[slug] ?? 0;
	const ageMs = Date.now() - new Date(post.data.pubDate).getTime();
	const ageDays = ageMs / 86400000;
	const recencyBonus = Math.max(0, 30 - ageDays) * 2;
	return views + recencyBonus;
}

const posts = allPosts.sort((a, b) => {
	const catDiff = categoryPriority(a) - categoryPriority(b);
	if (catDiff !== 0) return catDiff;
	return score(b) - score(a);
});

function getThumbnail(post: CollectionEntry<'blog'>): string | null {
	if (post.data.youtubeId) return `https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`;
	if (post.data.heroImage) {
		const h = post.data.heroImage as any;
		return typeof h === 'string' ? h : h?.src ?? null;
	}
	return null;
}

const CATEGORY_GRADIENTS: Record<string, string> = {
	'預言': 'linear-gradient(135deg,#1a1a2e,#c0392b)',
	'影片': 'linear-gradient(135deg,#0f3460,#16213e)',
	'旅遊': 'linear-gradient(135deg,#134e5e,#71b280)',
	'評測': 'linear-gradient(135deg,#4a00e0,#8e2de2)',
	'其他': 'linear-gradient(135deg,#373b44,#4286f4)',
};

const CATEGORY_ICONS: Record<string, string> = {
	'預言': '🔮', '影片': '🎬', '旅遊': '✈️', '評測': '📦', '其他': '📝',
};
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-main">

			<!-- ── Hero ── -->
			<section class="hero-section">
				<div class="hero-badge">⏳ 時空情報觀測站</div>
				<h1 class="hero-title">
					誰說旅遊只能留在當下？<br/>
					<span class="hero-accent">兩隻熊帶你橫跨時空</span>
				</h1>
				<p class="hero-sub">探索未來預言家的洞見、世界金融趨勢分析與真相拆解。<br class="hide-mobile"/>不只記錄風景，更記錄時代的演變。</p>
				<a href="/fortune/" class="hero-cta">🔮 命理分析 — 輸入生日算八字</a>
			</section>

			<!-- ── Leaderboard ── -->
			<section class="lb-section">
				<ProphecyLeaderboard />
			</section>

			<!-- ── Main grid: articles + tools ── -->
			<div class="content-grid">

				<!-- Articles (left 2/3) -->
				<section class="articles-section">
					<div class="section-heading">
						<span class="sh-icon">📰</span>
						<h2 class="sh-title">最新情報觀測</h2>
					</div>
					<ul class="posts-grid">
						{posts.map((post) => {
							const cat = getPostCategory(post);
							const color = CATEGORY_COLORS[cat] ?? '#7f8c8d';
							const thumb = getThumbnail(post);
							const gradient = CATEGORY_GRADIENTS[cat] ?? CATEGORY_GRADIENTS['其他'];
							const icon = CATEGORY_ICONS[cat] ?? '📝';
							return (
								<li class="post-card">
									<a href={`/blog/${post.id}/`}>
										<div class="post-thumb">
											{thumb ? (
												<img src={thumb} alt={post.data.title} loading="lazy" decoding="async" />
											) : (
												<div class="post-placeholder" style={`background:${gradient}`}>
													<span class="ph-icon">{icon}</span>
													<span class="ph-cat">{cat}</span>
												</div>
											)}
											<span class="cat-tag" style={`background:${color}`}>{cat}</span>
										</div>
										<div class="post-body">
											<h4 class="post-title">{post.data.title}</h4>
											<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				</section>

				<!-- Sidebar tools (right 1/3) -->
				<aside class="tools-sidebar">
					<div class="section-heading">
						<span class="sh-icon">🛠️</span>
						<h2 class="sh-title">觀測生存工具箱</h2>
					</div>

					<!-- Tab buttons -->
					<div class="tab-bar">
						<button class="tab-btn active" data-tab="daily">📅 今日指引</button>
						<button class="tab-btn" data-tab="survival">🛡 防災</button>
						<button class="tab-btn" data-tab="soul">🕯 心靈</button>
					</div>

					<div class="tab-content active" id="tab-daily">
						<DailyFortune />
					</div>
					<div class="tab-content" id="tab-survival">
						<EarthquakeWidget />
					</div>
					<div class="tab-content" id="tab-soul">
						<MessageWall />
					</div>

					<div class="sidebar-extra">
						<MultiCityWeather />
					</div>
					<div class="sidebar-extra">
						<ProphecyPoll />
					</div>
				</aside>
			</div>

		</main>
		<Footer />
	</body>
</html>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabContents = document.querySelectorAll<HTMLElement>('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      tabContents.forEach(c => {
        c.classList.toggle('active', c.id === `tab-${target}`);
      });
    });
  });
</script>

<style>
	.home-main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.2em 4em;
		width: 100%;
	}

	/* ── Hero ── */
	.hero-section {
		position: relative;
		background: linear-gradient(135deg, #0f172a 0%, rgba(88,28,135,0.25) 50%, #0f172a 100%);
		border: 1px solid rgba(168,85,247,0.15);
		border-radius: 20px;
		padding: 2.5em 2em;
		margin: 1.5em 0 1.2em;
		overflow: hidden;
	}

	.hero-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 70% 30%, rgba(168,85,247,0.12), transparent 60%);
		pointer-events: none;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		background: rgba(168,85,247,0.1);
		border: 1px solid rgba(168,85,247,0.25);
		color: #c084fc;
		font-size: 0.72em;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.3em 0.9em;
		border-radius: 20px;
		margin-bottom: 1em;
	}

	.hero-title {
		font-size: clamp(1.6em, 4vw, 2.6em);
		font-weight: 900;
		color: #f1f5f9;
		line-height: 1.25;
		margin-bottom: 0.6em;
	}

	.hero-accent {
		background: linear-gradient(135deg, #a855f7, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-sub {
		color: #94a3b8;
		font-size: 0.95em;
		line-height: 1.7;
		margin-bottom: 1.2em;
	}

	.hero-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		background: linear-gradient(135deg, #7e22ce, #be185d);
		color: white;
		font-size: 0.9em;
		font-weight: 700;
		padding: 0.65em 1.5em;
		border-radius: 12px;
		text-decoration: none;
		box-shadow: 0 4px 20px rgba(168,85,247,0.3);
		transition: transform 0.15s, box-shadow 0.15s;
	}

	.hero-cta:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 28px rgba(168,85,247,0.45);
		color: white;
	}

	/* ── Leaderboard section ── */
	.lb-section {
		margin-bottom: 1.2em;
	}

	/* ── Content grid ── */
	.content-grid {
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 1.5em;
		align-items: start;
	}

	/* ── Section heading ── */
	.section-heading {
		display: flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 1em;
		padding-bottom: 0.6em;
		border-bottom: 1px solid rgba(255,255,255,0.07);
	}

	.sh-icon { font-size: 1.1em; }

	.sh-title {
		font-size: 1em;
		font-weight: 700;
		color: #e2e8f0;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	/* ── Post grid ── */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.9em;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.post-card a {
		display: flex;
		flex-direction: column;
		background: rgba(255,255,255,0.03);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 12px;
		overflow: hidden;
		text-decoration: none;
		height: 100%;
		transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
	}

	.post-card a:hover {
		transform: translateY(-3px);
		border-color: rgba(168,85,247,0.3);
		box-shadow: 0 8px 24px rgba(168,85,247,0.12);
	}

	.post-thumb {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
		background: #0f172a;
	}

	.post-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		opacity: 0.85;
		transition: transform 0.3s, opacity 0.3s;
	}

	.post-card a:hover .post-thumb img {
		transform: scale(1.05);
		opacity: 1;
	}

	.post-placeholder {
		width: 100%; height: 100%;
		display: flex; flex-direction: column;
		align-items: center; justify-content: center;
		gap: 0.3em;
	}

	.ph-icon { font-size: 2em; opacity: 0.9; }
	.ph-cat { font-size: 0.7em; color: rgba(255,255,255,0.7); font-weight: 700; }

	.cat-tag {
		position: absolute;
		top: 0.4em; left: 0.4em;
		color: white;
		padding: 0.12em 0.45em;
		border-radius: 5px;
		font-size: 0.65em;
		font-weight: 700;
		backdrop-filter: blur(4px);
	}

	.post-body { padding: 0.65em 0.75em; flex: 1; }

	.post-title {
		margin: 0 0 0.3em;
		font-size: 0.82em;
		font-weight: 700;
		color: #e2e8f0;
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-card a:hover .post-title { color: #c084fc; }

	.post-date {
		margin: 0;
		font-size: 0.7em;
		color: #64748b;
	}

	/* ── Sidebar ── */
	.tools-sidebar {
		position: sticky;
		top: 100px;
		display: flex;
		flex-direction: column;
		gap: 1em;
	}

	.tab-bar {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.3em;
		background: rgba(255,255,255,0.04);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 10px;
		padding: 0.3em;
	}

	.tab-btn {
		background: transparent;
		border: none;
		color: #64748b;
		font-size: 0.72em;
		font-weight: 600;
		padding: 0.45em 0.3em;
		border-radius: 7px;
		cursor: pointer;
		transition: all 0.15s;
		white-space: nowrap;
	}

	.tab-btn.active {
		background: rgba(168,85,247,0.2);
		color: #c084fc;
	}

	.tab-btn:hover:not(.active) { color: #94a3b8; background: rgba(255,255,255,0.04); }

	.tab-content { display: none; }
	.tab-content.active { display: block; }

	.sidebar-extra { /* MultiCityWeather + ProphecyPoll */ }

	/* ── Responsive ── */
	@media (max-width: 1000px) {
		.content-grid { grid-template-columns: 1fr; }
		.tools-sidebar { position: static; }
		.posts-grid { grid-template-columns: repeat(3, 1fr); }
	}

	@media (max-width: 700px) {
		.posts-grid { grid-template-columns: repeat(2, 1fr); gap: 0.6em; }
		.hero-section { padding: 1.5em 1em; }
		.hide-mobile { display: none; }
	}

	@media (max-width: 480px) {
		.posts-grid { grid-template-columns: repeat(2, 1fr); }
	}
</style>
