---
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
---

<style is:global>
html body { background: #0f172a; color: #e2e8f0; }

.buy-wrap { max-width: 780px; margin: 0 auto; padding: 2.5rem 1.5rem; }
.buy-header { text-align: center; margin-bottom: 2rem; }
.buy-header h1 { font-size: 1.5rem; color: #f1f5f9; margin-bottom: .4rem; }
.buy-header p { color: #94a3b8; font-size: .88rem; }

.chat-area {
  background: #1e293b; border: 1px solid #334155; border-radius: 20px;
  padding: 1.25rem; min-height: 280px; max-height: 420px;
  overflow-y: auto; display: flex; flex-direction: column; gap: .75rem;
  margin-bottom: 1rem;
}
.msg { display: flex; gap: .65rem; align-items: flex-start; }
.msg.user { flex-direction: row-reverse; }
.msg-avatar {
  width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 1rem;
  background: rgba(168,85,247,.15);
}
.msg.user .msg-avatar { background: rgba(99,102,241,.15); }
.msg-bubble {
  background: #0f172a; border: 1px solid #334155; border-radius: 14px;
  padding: .65rem 1rem; font-size: .85rem; color: #e2e8f0;
  max-width: 82%; line-height: 1.6;
}
.msg.user .msg-bubble {
  background: rgba(168,85,247,.12); border-color: rgba(168,85,247,.3);
}

.chat-input-row { display: flex; gap: .65rem; margin-bottom: 1.5rem; }
.chat-input {
  flex: 1; background: #1e293b; border: 1px solid #334155; border-radius: 12px;
  padding: .65rem 1rem; color: #e2e8f0; font-size: .88rem; font-family: inherit;
  resize: none;
}
.chat-input:focus { outline: none; border-color: #a855f7; }
.btn-ask {
  padding: .65rem 1.2rem; border-radius: 12px; font-size: .88rem;
  background: linear-gradient(135deg, #a855f7, #7c3aed); border: none;
  color: #fff; cursor: pointer; font-weight: 600; transition: opacity .15s;
  white-space: nowrap;
}
.btn-ask:disabled { opacity: .5; cursor: not-allowed; }

.example-queries { margin-bottom: 1.5rem; }
.example-label { font-size: .75rem; color: #64748b; margin-bottom: .5rem; }
.chips { display: flex; flex-wrap: wrap; gap: .5rem; }
.chip {
  font-size: .78rem; padding: .3rem .8rem; border-radius: 100px;
  border: 1px solid #334155; background: #1e293b; color: #94a3b8;
  cursor: pointer; transition: all .15s;
}
.chip:hover { border-color: #a855f7; color: #a855f7; background: rgba(168,85,247,.08); }

.results-section { margin-top: 1rem; }
.results-title { font-size: .78rem; color: #64748b; margin-bottom: .75rem; text-transform: uppercase; letter-spacing: .05em; }
.results-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1rem;
}
.item-card {
  background: #1e293b; border: 1px solid #334155; border-radius: 16px;
  overflow: hidden; transition: border-color .15s, transform .15s;
}
.item-card:hover { border-color: #a855f7; transform: translateY(-2px); }
.item-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; background: #0f172a; }
.item-img-placeholder {
  width: 100%; aspect-ratio: 4/3; background: #0f172a;
  display: flex; align-items: center; justify-content: center;
  font-size: 2.5rem; color: #334155;
}
.item-body { padding: .9rem; }
.item-title { font-size: .85rem; font-weight: 700; color: #f1f5f9; margin-bottom: .35rem; line-height: 1.4; }
.item-meta { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: .5rem; }
.tag { font-size: .7rem; padding: .12rem .45rem; border-radius: 100px; font-weight: 600; }
.tag-cat { background: rgba(99,102,241,.15); color: #a5b4fc; }
.tag-cond-like_new { background: rgba(34,197,94,.12); color: #86efac; }
.tag-cond-good { background: rgba(251,191,36,.1); color: #fcd34d; }
.tag-cond-fair { background: rgba(148,163,184,.1); color: #94a3b8; }
.item-price { font-size: .95rem; font-weight: 800; color: #a855f7; }
.item-price-free { color: #34d399; }
.item-price-trade { color: #60a5fa; }
.item-footer { padding: .65rem .9rem .9rem; display: flex; justify-content: space-between; align-items: center; }
.item-city { font-size: .72rem; color: #64748b; }
.btn-inquire {
  font-size: .72rem; padding: .28rem .75rem; border-radius: 8px;
  background: rgba(168,85,247,.12); border: 1px solid rgba(168,85,247,.3);
  color: #a855f7; cursor: pointer; transition: background .15s;
}
.btn-inquire:hover { background: rgba(168,85,247,.25); }

.all-items-link { text-align: center; margin-top: 1.5rem; }
.all-items-link a { color: #a855f7; font-size: .85rem; text-decoration: none; }
.all-items-link a:hover { color: #c084fc; }

/* Modal */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,.6);
  display: flex; align-items: center; justify-content: center;
  z-index: 999; padding: 1rem;
}
.modal-overlay.hidden { display: none; }
.modal {
  background: #1e293b; border: 1px solid #334155; border-radius: 20px;
  padding: 1.5rem; max-width: 480px; width: 100%;
}
.modal h3 { color: #f1f5f9; margin-bottom: 1rem; font-size: 1rem; }
.modal input, .modal textarea {
  width: 100%; background: #0f172a; border: 1px solid #334155;
  border-radius: 10px; padding: .65rem .9rem; color: #e2e8f0; font-size: .85rem;
  margin-bottom: .75rem; box-sizing: border-box; font-family: inherit;
}
.modal input:focus, .modal textarea:focus { outline: none; border-color: #a855f7; }
.modal textarea { min-height: 80px; resize: vertical; }
.modal-actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: .5rem; }
.btn-cancel {
  padding: .55rem 1.2rem; border-radius: 10px; background: transparent;
  border: 1px solid #334155; color: #94a3b8; cursor: pointer; font-size: .85rem;
}
.btn-send {
  padding: .55rem 1.2rem; border-radius: 10px;
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  border: none; color: #fff; cursor: pointer; font-size: .85rem; font-weight: 600;
}
.modal-msg { font-size: .8rem; color: #64748b; margin-top: .5rem; }
.modal-msg.success { color: #34d399; }
.modal-msg.error { color: #f87171; }

@media (max-width: 600px) {
  .buy-wrap { padding: 1.5rem 1rem; }
  .results-grid { grid-template-columns: 1fr 1fr; gap: .75rem; }
}
</style>

<html lang="zh-TW">
<head>
  <BaseHead title="AI 幫我找 — 兩隻熊路邊攤" description="告訴小熊你想要什麼，AI 幫你從攤位上找最適合的商品。" />
</head>
<body>
  <Header />
  <div class="buy-wrap">
    <div class="buy-header">
      <h1>🤖 AI 幫你找好物</h1>
      <p>告訴小熊你想要什麼，牠幫你從攤位上找</p>
    </div>

    <div class="example-queries">
      <div class="example-label">常見搜尋</div>
      <div class="chips">
        <span class="chip" data-q="我想找便宜的藍牙耳機">藍牙耳機</span>
        <span class="chip" data-q="有沒有二手的筆電">筆電</span>
        <span class="chip" data-q="我在找打掃用的吸塵器">吸塵器</span>
        <span class="chip" data-q="有沒有免費的書">免費的書</span>
        <span class="chip" data-q="台北有沒有傢俱可以換物">傢俱換物</span>
        <span class="chip" data-q="找一件品牌衣服">品牌衣服</span>
      </div>
    </div>

    <div class="chat-area" id="chat-area">
      <div class="msg">
        <div class="msg-avatar">🐻</div>
        <div class="msg-bubble">嘿！我是小熊攤主 🛍️ 你想找什麼好物？直接告訴我，我幫你在攤位上找找看～</div>
      </div>
    </div>
    <div class="chat-input-row">
      <input class="chat-input" id="chat-input" type="text" placeholder="例如：我想找二手的 Switch，預算 2000 元以內" />
      <button class="btn-ask" id="btn-ask">🔍 找找看</button>
    </div>

    <div class="results-section" id="results-section" style="display:none">
      <div class="results-title" id="results-title">找到的商品</div>
      <div class="results-grid" id="results-grid"></div>
      <div class="all-items-link">
        <a href="/market">→ 逛逛全部攤位</a>
      </div>
    </div>
  </div>

  <!-- Inquire modal -->
  <div class="modal-overlay hidden" id="inquire-modal">
    <div class="modal">
      <h3 id="modal-item-title">聯絡賣家</h3>
      <input type="text" id="modal-buyer-name" placeholder="你的名字" />
      <input type="email" id="modal-buyer-email" placeholder="你的 Email（賣家會回覆你）" />
      <textarea id="modal-message" placeholder="想問賣家什麼？"></textarea>
      <div class="modal-actions">
        <button class="btn-cancel" id="modal-cancel">取消</button>
        <button class="btn-send" id="modal-send">送出詢問</button>
      </div>
      <p class="modal-msg" id="modal-msg"></p>
    </div>
  </div>

  <Footer />
</body>
</html>

<script>
  const COND_LABEL = { like_new: '近全新', good: '良好', fair: '普通' }
  const COND_CLS = { like_new: 'tag-cond-like_new', good: 'tag-cond-good', fair: 'tag-cond-fair' }

  let currentItemId = ''
  const chatArea = document.getElementById('chat-area')
  const chatInput = document.getElementById('chat-input')
  const btnAsk = document.getElementById('btn-ask')

  function addBubble(role, text) {
    const div = document.createElement('div')
    div.className = `msg${role === 'user' ? ' user' : ''}`
    div.innerHTML = `
      <div class="msg-avatar">${role === 'user' ? '👤' : '🐻'}</div>
      <div class="msg-bubble">${text.replace(/\n/g, '<br>')}</div>
    `
    chatArea.appendChild(div)
    chatArea.scrollTop = chatArea.scrollHeight
  }

  function renderResults(items) {
    const section = document.getElementById('results-section')
    const grid = document.getElementById('results-grid')
    const title = document.getElementById('results-title')

    if (!items.length) {
      section.style.display = 'none'
      return
    }

    title.textContent = `找到 ${items.length} 件商品`
    section.style.display = 'block'

    grid.innerHTML = items.map(item => {
      const img = item.image_urls?.[0]
        ? `<img class="item-img" src="${item.image_urls[0]}" alt="${item.title}" loading="lazy"/>`
        : `<div class="item-img-placeholder">📦</div>`
      const priceHtml = item.deal_type === 'free'
        ? '<span class="item-price item-price-free">免費</span>'
        : item.deal_type === 'trade'
        ? '<span class="item-price item-price-trade">換物</span>'
        : `<span class="item-price">NT$ ${Number(item.price || 0).toLocaleString()}</span>`
      const condCls = COND_CLS[item.condition] || 'tag-cond-fair'
      const condLabel = COND_LABEL[item.condition] || item.condition
      return `
        <div class="item-card">
          ${img}
          <div class="item-body">
            <div class="item-title">${item.title}</div>
            <div class="item-meta">
              <span class="tag tag-cat">${item.category}</span>
              <span class="tag ${condCls}">${condLabel}</span>
            </div>
            ${priceHtml}
          </div>
          <div class="item-footer">
            <span class="item-city">${item.location_city || ''}</span>
            <button class="btn-inquire" data-id="${item.id}" data-title="${item.title}">聯絡賣家</button>
          </div>
        </div>`
    }).join('')

    grid.querySelectorAll('.btn-inquire').forEach(btn => {
      btn.addEventListener('click', () => {
        const b = btn
        openModal(b.dataset.id, b.dataset.title)
      })
    })
  }

  async function ask() {
    const msg = chatInput.value.trim()
    if (!msg || btnAsk.disabled) return

    addBubble('user', msg)
    chatInput.value = ''
    btnAsk.disabled = true
    btnAsk.textContent = '找中...'

    const loading = document.createElement('div')
    loading.className = 'msg'
    loading.id = 'loading-bubble'
    loading.innerHTML = `<div class="msg-avatar">🐻</div><div class="msg-bubble" style="color:#64748b">找找看...</div>`
    chatArea.appendChild(loading)
    chatArea.scrollTop = chatArea.scrollHeight

    try {
      const res = await fetch('/api/market/chat-buy', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg }),
      })
      const data = await res.json()

      document.getElementById('loading-bubble')?.remove()
      addBubble('assistant', data.reply || '我幫你找了找～')

      if (data.items?.length) {
        renderResults(data.items)
      } else {
        document.getElementById('results-section').style.display = 'none'
      }
    } catch {
      document.getElementById('loading-bubble')?.remove()
      addBubble('assistant', '抱歉，暫時連不上，請稍後再試。')
    }

    btnAsk.disabled = false
    btnAsk.textContent = '🔍 找找看'
  }

  chatInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') ask() })
  btnAsk.addEventListener('click', ask)

  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chatInput.value = chip.dataset.q
      ask()
    })
  })

  function openModal(itemId, title) {
    currentItemId = itemId
    document.getElementById('modal-item-title').textContent = `聯絡賣家：${title}`
    document.getElementById('modal-msg').textContent = ''
    document.getElementById('modal-msg').className = 'modal-msg'
    document.getElementById('inquire-modal').classList.remove('hidden')
  }

  document.getElementById('modal-cancel').addEventListener('click', () => {
    document.getElementById('inquire-modal').classList.add('hidden')
  })
  document.getElementById('inquire-modal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) document.getElementById('inquire-modal').classList.add('hidden')
  })

  document.getElementById('modal-send').addEventListener('click', async () => {
    const name = document.getElementById('modal-buyer-name').value.trim()
    const email = document.getElementById('modal-buyer-email').value.trim()
    const message = document.getElementById('modal-message').value.trim()
    const msgEl = document.getElementById('modal-msg')
    if (!name || !email || !message) {
      msgEl.textContent = '請填寫所有欄位'
      msgEl.className = 'modal-msg error'
      return
    }
    const btn = document.getElementById('modal-send')
    btn.disabled = true
    btn.textContent = '送出中...'
    try {
      const res = await fetch('/api/market/inquire', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ item_id: currentItemId, buyer_name: name, buyer_email: email, message }),
      })
      const data = await res.json()
      if (data.success) {
        msgEl.textContent = '✓ 已送出！賣家會用 Email 聯絡你。'
        msgEl.className = 'modal-msg success'
        setTimeout(() => document.getElementById('inquire-modal').classList.add('hidden'), 2000)
      } else {
        msgEl.textContent = data.error || '送出失敗'
        msgEl.className = 'modal-msg error'
      }
    } catch {
      msgEl.textContent = '網路錯誤，請稍後再試'
      msgEl.className = 'modal-msg error'
    }
    btn.disabled = false
    btn.textContent = '送出詢問'
  })
</script>
