---
export const prerender = false
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getSession } from '../../utils/session'
import { supabaseAdmin } from '../../lib/supabase'

const token = Astro.cookies.get('sb_session')?.value || ''
const user = await getSession(token)
if (!user) return Astro.redirect('/api/auth/google')

const { data: items } = await supabaseAdmin
  .from('market_items')
  .select('*')
  .eq('seller_email', user.email)
  .neq('status', 'removed')
  .order('created_at', { ascending: false })
---

<style is:global>
html body { background: #0f172a; color: #e2e8f0; }

.my-wrap { max-width: 780px; margin: 0 auto; padding: 2.5rem 1.5rem; }
.my-header { margin-bottom: 2rem; }
.my-header h1 { font-size: 1.4rem; color: #f1f5f9; margin-bottom: .3rem; }
.my-header p { color: #64748b; font-size: .85rem; margin: 0; }

.my-actions { display: flex; gap: .75rem; margin-bottom: 1.75rem; }
.btn-new {
  display: inline-block; padding: .6rem 1.2rem; border-radius: 12px;
  background: linear-gradient(135deg, #a855f7, #7c3aed); color: #fff;
  font-size: .85rem; font-weight: 700; text-decoration: none; border: none; cursor: pointer;
}
.btn-new:hover { opacity: .85; color: #fff; }

.items-list { display: flex; flex-direction: column; gap: 1rem; }

.item-row {
  background: #1e293b; border: 1px solid #334155; border-radius: 16px;
  display: flex; gap: 1rem; align-items: center; padding: 1rem;
}
.item-thumb {
  width: 80px; height: 80px; border-radius: 10px; object-fit: cover;
  background: #0f172a; flex-shrink: 0;
}
.item-thumb-placeholder {
  width: 80px; height: 80px; border-radius: 10px; background: #0f172a;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; color: #334155; flex-shrink: 0;
}
.item-info { flex: 1; min-width: 0; }
.item-title { font-size: .9rem; font-weight: 700; color: #f1f5f9; margin-bottom: .3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.item-meta { font-size: .78rem; color: #64748b; }
.item-price { font-size: .88rem; font-weight: 700; color: #a855f7; margin-top: .2rem; }
.item-price-free { color: #34d399; }
.item-price-trade { color: #60a5fa; }

.tag-status-active { display: inline-block; padding: .15rem .5rem; border-radius: 100px; font-size: .7rem; font-weight: 600; background: rgba(34,197,94,.12); color: #86efac; }
.tag-status-sold { background: rgba(148,163,184,.1); color: #64748b; }

.item-actions { display: flex; flex-direction: column; gap: .5rem; flex-shrink: 0; }
.btn-remove {
  padding: .4rem .9rem; border-radius: 8px; border: 1px solid rgba(248,113,113,.3);
  background: rgba(248,113,113,.08); color: #f87171; font-size: .78rem; cursor: pointer;
  transition: background .15s; white-space: nowrap;
}
.btn-remove:hover { background: rgba(248,113,113,.2); }
.btn-mark-sold {
  padding: .4rem .9rem; border-radius: 8px; border: 1px solid #334155;
  background: transparent; color: #94a3b8; font-size: .78rem; cursor: pointer;
  transition: background .15s; white-space: nowrap;
}
.btn-mark-sold:hover { background: rgba(255,255,255,.05); }

.empty-state { text-align: center; padding: 4rem 1rem; color: #64748b; }
.empty-state .emoji { font-size: 3rem; display: block; margin-bottom: 1rem; }

.confirm-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,.6);
  display: flex; align-items: center; justify-content: center; z-index: 999; padding: 1rem;
}
.confirm-overlay.hidden { display: none; }
.confirm-box {
  background: #1e293b; border: 1px solid #334155; border-radius: 20px;
  padding: 1.75rem; max-width: 360px; width: 100%; text-align: center;
}
.confirm-box h3 { color: #f1f5f9; margin-bottom: .5rem; font-size: 1rem; }
.confirm-box p { color: #94a3b8; font-size: .85rem; margin-bottom: 1.25rem; }
.confirm-actions { display: flex; gap: .75rem; justify-content: center; }
.btn-cancel-sm {
  padding: .55rem 1.2rem; border-radius: 10px; background: transparent;
  border: 1px solid #334155; color: #94a3b8; cursor: pointer; font-size: .85rem;
}
.btn-confirm-remove {
  padding: .55rem 1.2rem; border-radius: 10px;
  background: #ef4444; border: none; color: #fff; cursor: pointer; font-size: .85rem; font-weight: 600;
}

@media (max-width: 500px) {
  .item-row { flex-wrap: wrap; }
  .item-actions { flex-direction: row; }
}
</style>

<html lang="zh-TW">
<head>
  <BaseHead title="我的上架商品 — 兩隻熊路邊攤" description="管理你在兩隻熊路邊攤上架的商品" />
</head>
<body>
  <Header />
  <div class="my-wrap">
    <div class="my-header">
      <h1>📦 我的上架商品</h1>
      <p>{user.name} · 共 {items?.length || 0} 件</p>
    </div>

    <div class="my-actions">
      <a href="/market/sell" class="btn-new">+ 再上架一件</a>
      <a href="/market" style="color:#94a3b8;font-size:.85rem;display:flex;align-items:center;text-decoration:none;">← 回到市集</a>
    </div>

    {items && items.length > 0 ? (
      <div class="items-list" id="items-list">
        {items.map(item => {
          const thumb = item.image_urls?.[0]
          const priceLabel = item.deal_type === 'free' ? '免費'
            : item.deal_type === 'trade' ? '換物'
            : `NT$ ${Number(item.price || 0).toLocaleString()}`
          const priceClass = item.deal_type === 'free' ? 'item-price-free'
            : item.deal_type === 'trade' ? 'item-price-trade' : ''
          const statusLabel = item.status === 'sold' ? '已售出' : '上架中'
          const statusClass = item.status === 'sold' ? 'tag-status-sold' : 'tag-status-active'
          return (
            <div class="item-row" id={`row-${item.id}`}>
              {thumb
                ? <img class="item-thumb" src={thumb} alt={item.title} />
                : <div class="item-thumb-placeholder">📦</div>
              }
              <div class="item-info">
                <div class="item-title">{item.title}</div>
                <div class="item-meta">{item.category} · {item.location_city || '未填地區'} · <span class={statusClass}>{statusLabel}</span></div>
                <div class={`item-price ${priceClass}`}>{priceLabel}</div>
              </div>
              <div class="item-actions">
                {item.status !== 'sold' && (
                  <button class="btn-mark-sold" data-id={item.id}>標記已售出</button>
                )}
                <button class="btn-remove" data-id={item.id} data-title={item.title}>下架刪除</button>
              </div>
            </div>
          )
        })}
      </div>
    ) : (
      <div class="empty-state">
        <span class="emoji">🧺</span>
        <p>你還沒有上架過商品</p>
        <a href="/market/sell" class="btn-new">去上架第一件</a>
      </div>
    )}
  </div>

  <!-- Confirm dialog -->
  <div class="confirm-overlay hidden" id="confirm-overlay">
    <div class="confirm-box">
      <h3>確定要下架嗎？</h3>
      <p id="confirm-title">這個動作無法復原，商品將從市集移除。</p>
      <div class="confirm-actions">
        <button class="btn-cancel-sm" id="confirm-cancel">取消</button>
        <button class="btn-confirm-remove" id="confirm-ok">確定下架</button>
      </div>
    </div>
  </div>

  <Footer />
</body>
</html>

<script>
  let pendingId = ''

  document.querySelectorAll('.btn-remove').forEach(btn => {
    btn.addEventListener('click', () => {
      const b = btn as HTMLElement
      pendingId = b.dataset.id!
      const title = b.dataset.title || '此商品'
      ;(document.getElementById('confirm-title') as HTMLElement).textContent =
        `「${title}」將從市集移除，確定嗎？`
      document.getElementById('confirm-overlay')!.classList.remove('hidden')
    })
  })

  document.getElementById('confirm-cancel')!.addEventListener('click', () => {
    document.getElementById('confirm-overlay')!.classList.add('hidden')
    pendingId = ''
  })

  document.getElementById('confirm-ok')!.addEventListener('click', async () => {
    if (!pendingId) return
    const btn = document.getElementById('confirm-ok') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = '處理中...'
    try {
      const res = await fetch('/api/market/remove', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ item_id: pendingId }),
      })
      const data = await res.json()
      if (data.success) {
        document.getElementById(`row-${pendingId}`)?.remove()
        document.getElementById('confirm-overlay')!.classList.add('hidden')
      }
    } catch {}
    btn.disabled = false
    btn.textContent = '確定下架'
    pendingId = ''
  })

  document.querySelectorAll('.btn-mark-sold').forEach(btn => {
    btn.addEventListener('click', async () => {
      const b = btn as HTMLElement
      const id = b.dataset.id!
      try {
        await fetch('/api/market/remove', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ item_id: id, action: 'sold' }),
        })
        const row = document.getElementById(`row-${id}`)
        const statusEl = row?.querySelector('.tag-status-active')
        if (statusEl) {
          statusEl.textContent = '已售出'
          statusEl.className = 'tag-status-sold'
        }
        b.remove()
      } catch {}
    })
  })
</script>
