---
export const prerender = false
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
---

<style is:global>
html body { background: #0f172a; color: #e2e8f0; }

.my-wrap { max-width: 780px; margin: 0 auto; padding: 2.5rem 1.5rem; }
.my-header { margin-bottom: 2rem; }
.my-header h1 { font-size: 1.4rem; color: #f1f5f9; margin-bottom: .3rem; }
.my-header p { color: #64748b; font-size: .85rem; margin: 0; }

.lookup-box {
  background: #1e293b; border: 1px solid #334155; border-radius: 16px;
  padding: 1.5rem; margin-bottom: 2rem;
}
.lookup-box p { color: #94a3b8; font-size: .85rem; margin: 0 0 1rem; }
.lookup-row { display: flex; gap: .65rem; }
.lookup-input {
  flex: 1; background: #0f172a; border: 1px solid #334155; border-radius: 10px;
  padding: .65rem 1rem; color: #e2e8f0; font-size: .9rem; font-family: inherit;
}
.lookup-input:focus { outline: none; border-color: #a855f7; }
.btn-lookup {
  padding: .65rem 1.4rem; border-radius: 10px;
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  border: none; color: #fff; font-size: .9rem; font-weight: 600; cursor: pointer;
  white-space: nowrap;
}

.my-actions { display: flex; gap: .75rem; margin-bottom: 1.75rem; }
.btn-new {
  display: inline-block; padding: .6rem 1.2rem; border-radius: 12px;
  background: linear-gradient(135deg, #a855f7, #7c3aed); color: #fff;
  font-size: .85rem; font-weight: 700; text-decoration: none;
}
.btn-new:hover { opacity: .85; color: #fff; }

.items-list { display: flex; flex-direction: column; gap: 1rem; }
.item-row {
  background: #1e293b; border: 1px solid #334155; border-radius: 16px;
  display: flex; gap: 1rem; align-items: center; padding: 1rem;
}
.item-thumb { width: 80px; height: 80px; border-radius: 10px; object-fit: cover; background: #0f172a; flex-shrink: 0; }
.item-thumb-placeholder { width: 80px; height: 80px; border-radius: 10px; background: #0f172a; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #334155; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-title { font-size: .9rem; font-weight: 700; color: #f1f5f9; margin-bottom: .3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.item-meta { font-size: .78rem; color: #64748b; }
.item-price { font-size: .88rem; font-weight: 700; color: #a855f7; margin-top: .2rem; }
.item-price-free { color: #34d399; }
.item-price-trade { color: #60a5fa; }
.tag-status-active { display: inline-block; padding: .15rem .5rem; border-radius: 100px; font-size: .7rem; font-weight: 600; background: rgba(34,197,94,.12); color: #86efac; }
.tag-status-sold { background: rgba(148,163,184,.1); color: #64748b; }
.item-actions { display: flex; flex-direction: column; gap: .5rem; flex-shrink: 0; }
.btn-remove { padding: .4rem .9rem; border-radius: 8px; border: 1px solid rgba(248,113,113,.3); background: rgba(248,113,113,.08); color: #f87171; font-size: .78rem; cursor: pointer; transition: background .15s; white-space: nowrap; }
.btn-remove:hover { background: rgba(248,113,113,.2); }
.btn-mark-sold { padding: .4rem .9rem; border-radius: 8px; border: 1px solid #334155; background: transparent; color: #94a3b8; font-size: .78rem; cursor: pointer; white-space: nowrap; }
.btn-mark-sold:hover { background: rgba(255,255,255,.05); }
.btn-edit { padding: .4rem .9rem; border-radius: 8px; border: 1px solid rgba(168,85,247,.3); background: rgba(168,85,247,.08); color: #a855f7; font-size: .78rem; cursor: pointer; white-space: nowrap; }
.btn-edit:hover { background: rgba(168,85,247,.2); }

/* Edit modal */
.edit-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.7); display: flex; align-items: flex-start; justify-content: center; z-index: 1000; padding: 1rem; overflow-y: auto; }
.edit-overlay.hidden { display: none; }
.edit-box { background: #1e293b; border: 1px solid #334155; border-radius: 20px; padding: 1.5rem; max-width: 500px; width: 100%; margin: auto; }
.edit-box h3 { color: #f1f5f9; font-size: 1rem; margin-bottom: 1.25rem; }
.edit-field { margin-bottom: 1rem; }
.edit-label { display: block; font-size: .78rem; color: #64748b; margin-bottom: .3rem; }
.edit-input, .edit-textarea, .edit-select {
  width: 100%; background: #0f172a; border: 1px solid #334155; border-radius: 8px;
  padding: .55rem .9rem; color: #e2e8f0; font-size: .85rem; font-family: inherit; box-sizing: border-box;
}
.edit-input:focus, .edit-textarea:focus, .edit-select:focus { outline: none; border-color: #a855f7; }
.edit-textarea { resize: vertical; min-height: 80px; line-height: 1.6; }
.edit-pin-row { border-top: 1px solid #334155; padding-top: 1rem; margin-top: .5rem; }
.edit-actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 1.25rem; }
.btn-edit-save { padding: .55rem 1.4rem; border-radius: 10px; background: linear-gradient(135deg,#a855f7,#7c3aed); border: none; color: #fff; font-size: .88rem; font-weight: 700; cursor: pointer; }
.edit-err { color: #f87171; font-size: .78rem; margin-top: .5rem; display: none; }

.empty-state { text-align: center; padding: 3rem 1rem; color: #64748b; }
.status-msg { color: #64748b; font-size: .85rem; margin-top: .75rem; }
.status-msg.error { color: #f87171; }

.section-title { font-size: .78rem; color: #64748b; text-transform: uppercase; letter-spacing: .05em; margin: 2rem 0 1rem; }
.inq-list { display: flex; flex-direction: column; gap: .75rem; }
.inq-card {
  background: #1e293b; border: 1px solid #334155; border-radius: 14px; padding: 1rem;
}
.inq-item-name { font-size: .72rem; color: #a855f7; margin-bottom: .4rem; }
.inq-buyer { font-size: .82rem; font-weight: 700; color: #f1f5f9; margin-bottom: .25rem; }
.inq-email { font-size: .75rem; color: #64748b; margin-bottom: .5rem; }
.inq-msg { font-size: .85rem; color: #cbd5e1; line-height: 1.65; white-space: pre-wrap; }
.inq-date { font-size: .72rem; color: #475569; margin-top: .5rem; }
.inq-empty { color: #64748b; font-size: .85rem; padding: 1rem 0; }

.confirm-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); display: flex; align-items: center; justify-content: center; z-index: 999; padding: 1rem; }
.confirm-overlay.hidden { display: none; }
.confirm-box { background: #1e293b; border: 1px solid #334155; border-radius: 20px; padding: 1.75rem; max-width: 360px; width: 100%; text-align: center; }
.confirm-box h3 { color: #f1f5f9; margin-bottom: .5rem; font-size: 1rem; }
.confirm-box p { color: #94a3b8; font-size: .85rem; margin-bottom: 1.25rem; }
.confirm-actions { display: flex; gap: .75rem; justify-content: center; }
.btn-cancel-sm { padding: .55rem 1.2rem; border-radius: 10px; background: transparent; border: 1px solid #334155; color: #94a3b8; cursor: pointer; font-size: .85rem; }
.btn-confirm-remove { padding: .55rem 1.2rem; border-radius: 10px; background: #ef4444; border: none; color: #fff; cursor: pointer; font-size: .85rem; font-weight: 600; }

@media (max-width: 500px) {
  .item-row { flex-wrap: wrap; }
  .item-actions { flex-direction: row; }
  .lookup-row { flex-direction: column; }
}
</style>

<html lang="zh-TW">
<head>
  <BaseHead title="我的上架商品 — 兩隻熊路邊攤" description="管理你在兩隻熊路邊攤上架的商品" />
</head>
<body>
  <Header />
  <div class="my-wrap">
    <div class="my-header">
      <h1>📦 我的上架商品</h1>
      <p>輸入上架時留的聯絡方式，查看你的商品</p>
    </div>

    <div class="lookup-box">
      <p>上架時填的 LINE ID 或電話號碼</p>
      <div class="lookup-row">
        <input class="lookup-input" id="lookup-input" type="text" placeholder="LINE ID 或 09xxxxxxxx" autocomplete="off" />
        <button class="btn-lookup" id="btn-lookup">查詢</button>
      </div>
      <div class="status-msg" id="lookup-status"></div>
    </div>

    <div class="my-actions">
      <a href="/market/sell" class="btn-new">+ 再上架一件</a>
      <a href="/market" style="color:#94a3b8;font-size:.85rem;display:flex;align-items:center;text-decoration:none;">← 回到市集</a>
    </div>

    <div id="items-container"></div>
    <div id="inquiries-container"></div>
  </div>

  <!-- Edit modal -->
  <div class="edit-overlay hidden" id="edit-overlay">
    <div class="edit-box">
      <h3>✏️ 編輯商品</h3>
      <div class="edit-field">
        <label class="edit-label">商品名稱</label>
        <input class="edit-input" id="ef-title" type="text" />
      </div>
      <div class="edit-field" style="display:flex;gap:.75rem;">
        <div style="flex:1">
          <label class="edit-label">交易方式</label>
          <select class="edit-select" id="ef-deal-type">
            <option value="sell">出售</option>
            <option value="trade">換物</option>
            <option value="free">免費</option>
          </select>
        </div>
        <div style="flex:1" id="ef-price-wrap">
          <label class="edit-label">售價（NT$）</label>
          <input class="edit-input" id="ef-price" type="number" min="0" />
        </div>
      </div>
      <div class="edit-field" style="display:flex;gap:.75rem;">
        <div style="flex:1">
          <label class="edit-label">商品狀況</label>
          <select class="edit-select" id="ef-condition">
            <option value="like_new">近全新</option>
            <option value="good">良好</option>
            <option value="fair">普通</option>
          </select>
        </div>
        <div style="flex:1">
          <label class="edit-label">縣市</label>
          <input class="edit-input" id="ef-city" type="text" />
        </div>
      </div>
      <div class="edit-field">
        <label class="edit-label">瑕疵說明</label>
        <input class="edit-input" id="ef-condition-notes" type="text" placeholder="無則留空" />
      </div>
      <div class="edit-field">
        <label class="edit-label">面交地點</label>
        <input class="edit-input" id="ef-location-note" type="text" placeholder="例：桃園車站附近" />
      </div>
      <div class="edit-field">
        <label class="edit-label">故事文案</label>
        <textarea class="edit-textarea" id="ef-story" rows="4"></textarea>
      </div>
      <div class="edit-field">
        <label class="edit-label">詳細資訊</label>
        <textarea class="edit-textarea" id="ef-plain" rows="4"></textarea>
      </div>
      <div class="edit-field">
        <label class="edit-label">聯絡方式</label>
        <div style="display:flex;gap:.5rem;">
          <select class="edit-select" id="ef-contact-type" style="width:100px;flex-shrink:0;">
            <option value="line">LINE</option>
            <option value="phone">電話</option>
            <option value="form">站內</option>
          </select>
          <input class="edit-input" id="ef-contact-val" type="text" placeholder="LINE ID 或電話" />
        </div>
      </div>
      <div class="edit-pin-row">
        <label class="edit-label">輸入刪除密碼確認身份</label>
        <input class="edit-input" id="ef-pin" type="number" placeholder="4 位數密碼" maxlength="4" />
        <p class="edit-err" id="ef-err"></p>
      </div>
      <div class="edit-actions">
        <button class="btn-cancel-sm" id="edit-cancel">取消</button>
        <button class="btn-edit-save" id="edit-save">儲存</button>
      </div>
    </div>
  </div>

  <div class="confirm-overlay hidden" id="confirm-overlay">
    <div class="confirm-box">
      <h3 id="confirm-heading">確定要下架嗎？</h3>
      <p id="confirm-title">商品將從市集移除。</p>
      <input type="number" id="confirm-pin" placeholder="輸入上架時設的 4 位數密碼" maxlength="4"
        style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:8px;padding:.55rem .9rem;color:#e2e8f0;font-size:.88rem;box-sizing:border-box;margin-bottom:.5rem;font-family:inherit;" />
      <p id="confirm-pin-error" style="color:#f87171;font-size:.78rem;margin:0 0 .75rem;display:none;"></p>
      <div class="confirm-actions">
        <button class="btn-cancel-sm" id="confirm-cancel">取消</button>
        <button class="btn-confirm-remove" id="confirm-ok">確定下架</button>
      </div>
    </div>
  </div>

  <Footer />
</body>
</html>

<script>
  let pendingId = ''
  let pendingAction = 'remove'
  let allMyItems: any[] = []
  let editingId = ''

  const lookupInput = document.getElementById('lookup-input') as HTMLInputElement
  const lookupStatus = document.getElementById('lookup-status')!
  const itemsContainer = document.getElementById('items-container')!

  document.getElementById('btn-lookup')!.addEventListener('click', doLookup)
  lookupInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') doLookup() })

  async function doLookup() {
    const contact = lookupInput.value.trim()
    if (!contact) { lookupStatus.textContent = '請輸入 LINE ID 或電話'; return }

    lookupStatus.textContent = '查詢中...'
    lookupStatus.className = 'status-msg'
    itemsContainer.innerHTML = ''

    try {
      const res = await fetch(`/api/market/my-items?contact=${encodeURIComponent(contact)}`)
      const data = await res.json()
      if (data.error) throw new Error(data.error)

      const items = data.items || []
      allMyItems = items
      lookupStatus.textContent = items.length ? `找到 ${items.length} 件商品` : '查無商品'
      loadInquiries(contact)

      if (!items.length) {
        itemsContainer.innerHTML = `<div class="empty-state"><p>查無商品，請確認 LINE ID 或電話是否輸入正確</p></div>`
        return
      }

      itemsContainer.innerHTML = `<div class="items-list" id="items-list">${items.map((item: any) => {
        const thumb = item.image_urls?.[0]
        const priceLabel = item.deal_type === 'free' ? '免費' : item.deal_type === 'trade' ? '換物' : `NT$ ${Number(item.price || 0).toLocaleString()}`
        const priceClass = item.deal_type === 'free' ? 'item-price-free' : item.deal_type === 'trade' ? 'item-price-trade' : ''
        const statusLabel = item.status === 'sold' ? '已售出' : '上架中'
        const statusClass = item.status === 'sold' ? 'tag-status-sold' : 'tag-status-active'
        return `
          <div class="item-row" id="row-${item.id}">
            ${thumb ? `<img class="item-thumb" src="${thumb}" alt="${item.title}" />` : `<div class="item-thumb-placeholder">📦</div>`}
            <div class="item-info">
              <div class="item-title">${item.title}</div>
              <div class="item-meta">${item.category} · ${item.location_city || '未填地區'} · <span class="${statusClass}">${statusLabel}</span></div>
              <div class="item-price ${priceClass}">${priceLabel}</div>
            </div>
            <div class="item-actions">
              <button class="btn-edit" data-id="${item.id}">編輯</button>
              ${item.status !== 'sold' ? `<button class="btn-mark-sold" data-id="${item.id}" data-title="${item.title}">標記已售出</button>` : ''}
              <button class="btn-remove" data-id="${item.id}" data-title="${item.title}">下架刪除</button>
            </div>
          </div>`
      }).join('')}</div>`

      bindActions()
    } catch (e: any) {
      lookupStatus.textContent = '查詢失敗：' + e.message
      lookupStatus.className = 'status-msg error'
    }
  }

  async function loadInquiries(contact: string) {
    const container = document.getElementById('inquiries-container')!
    container.innerHTML = ''
    try {
      const res = await fetch(`/api/market/my-inquiries?contact=${encodeURIComponent(contact)}`)
      const data = await res.json()
      const inquiries = data.inquiries || []

      container.innerHTML = `<p class="section-title">買家留言（${inquiries.length} 則）</p>`

      if (!inquiries.length) {
        container.innerHTML += `<p class="inq-empty">目前還沒有買家留言</p>`
        return
      }

      container.innerHTML += `<div class="inq-list">${inquiries.map((inq: any) => {
        const date = new Date(inq.created_at).toLocaleString('zh-TW', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' })
        return `
          <div class="inq-card">
            <div class="inq-item-name">關於：${inq.item_title}</div>
            <div class="inq-buyer">${inq.buyer_name}</div>
            <div class="inq-email"><a href="mailto:${inq.buyer_email}" style="color:#64748b;">${inq.buyer_email}</a></div>
            <div class="inq-msg">${inq.message}</div>
            <div class="inq-date">${date}</div>
          </div>`
      }).join('')}</div>`
    } catch {
      // silently fail — inquiries are optional
    }
  }

  function openConfirm(id: string, action: 'remove' | 'sold', title: string) {
    pendingId = id
    pendingAction = action
    ;(document.getElementById('confirm-heading') as HTMLElement).textContent =
      action === 'remove' ? '確定要下架嗎？' : '確定標記為已售出嗎？'
    ;(document.getElementById('confirm-title') as HTMLElement).textContent = title
    ;(document.getElementById('confirm-ok') as HTMLButtonElement).textContent =
      action === 'remove' ? '確定下架' : '確定售出'
    ;(document.getElementById('confirm-pin') as HTMLInputElement).value = ''
    ;(document.getElementById('confirm-pin-error') as HTMLElement).style.display = 'none'
    document.getElementById('confirm-overlay')!.classList.remove('hidden')
    ;(document.getElementById('confirm-pin') as HTMLInputElement).focus()
  }

  function bindActions() {
    document.querySelectorAll('.btn-edit').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id!
        const item = allMyItems.find(i => i.id === id)
        if (!item) return
        openEdit(item)
      })
    })

    document.querySelectorAll('.btn-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const b = btn as HTMLElement
        openConfirm(b.dataset.id!, 'remove', `「${b.dataset.title}」將從市集移除，確定嗎？`)
      })
    })

    document.querySelectorAll('.btn-mark-sold').forEach(btn => {
      btn.addEventListener('click', () => {
        const b = btn as HTMLElement
        openConfirm(b.dataset.id!, 'sold', `「${b.dataset.title}」將標記為已售出。`)
      })
    })
  }

  function openEdit(item: any) {
    editingId = item.id
    ;(document.getElementById('ef-title') as HTMLInputElement).value = item.title || ''
    ;(document.getElementById('ef-deal-type') as HTMLSelectElement).value = item.deal_type || 'sell'
    ;(document.getElementById('ef-price') as HTMLInputElement).value = item.price || ''
    ;(document.getElementById('ef-price-wrap') as HTMLElement).style.display = item.deal_type === 'sell' ? '' : 'none'
    ;(document.getElementById('ef-condition') as HTMLSelectElement).value = item.condition || 'good'
    ;(document.getElementById('ef-city') as HTMLInputElement).value = item.location_city || ''
    ;(document.getElementById('ef-condition-notes') as HTMLInputElement).value = item.condition_notes || ''
    ;(document.getElementById('ef-location-note') as HTMLInputElement).value = item.location_note || ''
    ;(document.getElementById('ef-story') as HTMLTextAreaElement).value = item.description_story || ''
    ;(document.getElementById('ef-plain') as HTMLTextAreaElement).value = item.description_plain || ''
    ;(document.getElementById('ef-contact-type') as HTMLSelectElement).value = item.contact_type || 'form'
    const contactVal = item.contact_line_id || item.contact_phone || ''
    ;(document.getElementById('ef-contact-val') as HTMLInputElement).value = contactVal
    ;(document.getElementById('ef-pin') as HTMLInputElement).value = ''
    ;(document.getElementById('ef-err') as HTMLElement).style.display = 'none'
    document.getElementById('edit-overlay')!.classList.remove('hidden')
  }

  document.getElementById('ef-deal-type')!.addEventListener('change', () => {
    const type = (document.getElementById('ef-deal-type') as HTMLSelectElement).value
    ;(document.getElementById('ef-price-wrap') as HTMLElement).style.display = type === 'sell' ? '' : 'none'
  })

  document.getElementById('edit-cancel')!.addEventListener('click', () => {
    document.getElementById('edit-overlay')!.classList.add('hidden')
  })
  document.getElementById('edit-overlay')!.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) document.getElementById('edit-overlay')!.classList.add('hidden')
  })

  document.getElementById('edit-save')!.addEventListener('click', async () => {
    const pin = (document.getElementById('ef-pin') as HTMLInputElement).value.trim()
    const errEl = document.getElementById('ef-err') as HTMLElement
    const dealType = (document.getElementById('ef-deal-type') as HTMLSelectElement).value
    const contactType = (document.getElementById('ef-contact-type') as HTMLSelectElement).value
    const contactVal = (document.getElementById('ef-contact-val') as HTMLInputElement).value.trim()
    const btn = document.getElementById('edit-save') as HTMLButtonElement

    errEl.style.display = 'none'
    btn.disabled = true; btn.textContent = '儲存中...'

    const payload: any = {
      item_id: editingId,
      pin,
      title:            (document.getElementById('ef-title') as HTMLInputElement).value.trim(),
      deal_type:        dealType,
      price:            dealType === 'sell' ? Number((document.getElementById('ef-price') as HTMLInputElement).value) || null : null,
      condition:        (document.getElementById('ef-condition') as HTMLSelectElement).value,
      location_city:    (document.getElementById('ef-city') as HTMLInputElement).value.trim(),
      condition_notes:  (document.getElementById('ef-condition-notes') as HTMLInputElement).value.trim() || null,
      location_note:    (document.getElementById('ef-location-note') as HTMLInputElement).value.trim() || null,
      description_story: (document.getElementById('ef-story') as HTMLTextAreaElement).value.trim(),
      description_plain: (document.getElementById('ef-plain') as HTMLTextAreaElement).value.trim(),
      contact_type:     contactType,
      contact_line_id:  contactType === 'line' ? contactVal : null,
      contact_phone:    contactType === 'phone' ? contactVal : null,
    }

    const res = await fetch('/api/market/edit-item', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })
    const data = await res.json()

    if (data.success) {
      // Update local cache
      const idx = allMyItems.findIndex(i => i.id === editingId)
      if (idx !== -1) Object.assign(allMyItems[idx], payload)
      document.getElementById('edit-overlay')!.classList.add('hidden')
      // Refresh row title if changed
      const row = document.getElementById(`row-${editingId}`)
      if (row) {
        const titleEl = row.querySelector('.item-title')
        if (titleEl) titleEl.textContent = payload.title
      }
    } else {
      errEl.textContent = data.error || '儲存失敗'
      errEl.style.display = 'block'
    }
    btn.disabled = false; btn.textContent = '儲存'
  })

  document.getElementById('confirm-cancel')!.addEventListener('click', () => {
    document.getElementById('confirm-overlay')!.classList.add('hidden')
    pendingId = ''
  })

  document.getElementById('confirm-ok')!.addEventListener('click', async () => {
    if (!pendingId) return
    const pin = (document.getElementById('confirm-pin') as HTMLInputElement).value.trim()
    const errEl = document.getElementById('confirm-pin-error') as HTMLElement
    if (!pin || !/^\d{4}$/.test(pin)) {
      errEl.textContent = '請輸入上架時設的 4 位數密碼'
      errEl.style.display = 'block'
      return
    }
    errEl.style.display = 'none'

    const btn = document.getElementById('confirm-ok') as HTMLButtonElement
    btn.disabled = true; btn.textContent = '處理中...'

    const res = await fetch('/api/market/remove', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_id: pendingId, action: pendingAction, pin }),
    })
    const data = await res.json()

    if (data.success) {
      if (pendingAction === 'remove') {
        document.getElementById(`row-${pendingId}`)?.remove()
      } else {
        const row = document.getElementById(`row-${pendingId}`)
        const statusEl = row?.querySelector('.tag-status-active')
        if (statusEl) { statusEl.textContent = '已售出'; statusEl.className = 'tag-status-sold' }
        row?.querySelector('.btn-mark-sold')?.remove()
      }
      document.getElementById('confirm-overlay')!.classList.add('hidden')
      pendingId = ''
    } else {
      errEl.textContent = data.error || '操作失敗，請再試一次'
      errEl.style.display = 'block'
    }

    btn.disabled = false
    btn.textContent = pendingAction === 'remove' ? '確定下架' : '確定售出'
  })
</script>
