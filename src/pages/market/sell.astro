---
export const prerender = false
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getSession } from '../../utils/session'

const token = Astro.cookies.get('sb_session')?.value || ''
const user = await getSession(token)
if (!user) return Astro.redirect('/api/auth/google')

const uName = user.name
const uEmail = user.email
---

<style is:global>
html body { background: #0f172a; color: #e2e8f0; }

.sell-wrap { max-width: 680px; margin: 0 auto; padding: 2.5rem 1.5rem; }
.sell-header { text-align: center; margin-bottom: 2rem; }
.sell-header h1 { font-size: 1.5rem; color: #f1f5f9; margin-bottom: .4rem; }
.sell-header p { color: #94a3b8; font-size: .88rem; }

/* Steps */
.step { display: none; }
.step.active { display: block; }

/* Transparent overlay — direct tap on iOS, no JS/label indirection needed */
.file-over {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0;
  cursor: pointer;
  z-index: 1;
}

/* Photo slots */
.photo-slot {
  border: 2px dashed #334155; border-radius: 14px;
  aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: border-color .2s; background: #1e293b;
  position: relative; overflow: hidden; text-align: center;
}
.photo-slot:hover { border-color: #a855f7; }
.photo-slot.has-photo { border-style: solid; border-color: #334155; }
.photo-slot img {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  border-radius: 12px; z-index: 2;
}
.slot-label { color: #64748b; font-size: .75rem; line-height: 1.5; pointer-events: none; z-index: 1; }
.slot-label small { color: #475569; font-size: .65rem; }
.slot-remove {
  position: absolute; top: 4px; right: 4px; z-index: 3;
  width: 20px; height: 20px; border-radius: 50%; background: rgba(0,0,0,.6);
  border: none; color: #fff; font-size: .7rem; cursor: pointer;
  display: flex; align-items: center; justify-content: center; line-height: 1;
}

/* Identify result */
.identify-card {
  background: #1e293b; border: 1px solid #334155; border-radius: 16px;
  padding: 1.25rem; margin-bottom: 1.5rem;
}
.identify-card h3 { color: #a855f7; font-size: .85rem; margin-bottom: .75rem; text-transform: uppercase; letter-spacing: .05em; }
.identify-row { display: flex; justify-content: space-between; align-items: center; padding: .4rem 0; border-bottom: 1px solid #1e293b; }
.identify-row:last-child { border-bottom: none; }
.identify-label { color: #64748b; font-size: .82rem; }
.identify-val { color: #e2e8f0; font-size: .88rem; font-weight: 600; }
.confidence-high { color: #34d399; }
.confidence-medium { color: #fcd34d; }
.confidence-low { color: #f87171; }

/* Chat */
.chat-box {
  background: #1e293b; border: 1px solid #334155; border-radius: 20px;
  padding: 1.25rem; min-height: 360px; max-height: 480px;
  overflow-y: auto; display: flex; flex-direction: column; gap: .75rem;
  margin-bottom: 1rem;
}
.msg { display: flex; gap: .65rem; align-items: flex-start; }
.msg.user { flex-direction: row-reverse; }
.msg-avatar {
  width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 1rem;
  background: rgba(168,85,247,.15);
}
.msg.user .msg-avatar { background: rgba(99,102,241,.15); }
.msg-bubble {
  background: #0f172a; border: 1px solid #334155; border-radius: 14px;
  padding: .65rem 1rem; font-size: .85rem; color: #e2e8f0;
  max-width: 82%; line-height: 1.6;
}
.msg.user .msg-bubble {
  background: rgba(168,85,247,.12); border-color: rgba(168,85,247,.3);
}

.chat-input-row { display: flex; gap: .65rem; }
.chat-input {
  flex: 1; background: #1e293b; border: 1px solid #334155; border-radius: 12px;
  padding: .65rem 1rem; color: #e2e8f0; font-size: .88rem; font-family: inherit;
  resize: none; min-height: 44px; max-height: 120px;
}
.chat-input:focus { outline: none; border-color: #a855f7; }
.btn-send-msg {
  padding: .65rem 1.1rem; border-radius: 12px; font-size: .88rem;
  background: linear-gradient(135deg, #a855f7, #7c3aed); border: none;
  color: #fff; cursor: pointer; font-weight: 600; transition: opacity .15s;
}
.btn-send-msg:disabled { opacity: .5; cursor: not-allowed; }

/* Finalize */
.final-preview {
  background: #1e293b; border: 1px solid #334155; border-radius: 16px;
  padding: 1.25rem; margin-bottom: 1.5rem;
}
.final-preview h3 { color: #a855f7; font-size: .85rem; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: .05em; }
.final-desc-story { color: #cbd5e1; font-size: .85rem; line-height: 1.7; white-space: pre-wrap; margin-bottom: 1rem; padding: 1rem; background: #0f172a; border-radius: 10px; }
.final-desc-plain { color: #94a3b8; font-size: .8rem; line-height: 1.7; white-space: pre-wrap; }
.final-img { max-height: 200px; border-radius: 12px; margin-bottom: 1rem; }

.btn-primary {
  width: 100%; padding: .8rem 1.5rem; border-radius: 14px; font-size: .95rem;
  background: linear-gradient(135deg, #a855f7, #7c3aed); border: none;
  color: #fff; cursor: pointer; font-weight: 700; transition: opacity .15s;
}
.btn-primary:disabled { opacity: .5; cursor: not-allowed; }
.btn-secondary {
  width: 100%; padding: .75rem 1.5rem; border-radius: 14px; font-size: .9rem;
  background: transparent; border: 1.5px solid #334155; color: #94a3b8;
  cursor: pointer; margin-top: .75rem; transition: border-color .15s;
}
.btn-secondary:hover { border-color: #a855f7; color: #a855f7; }

.step-indicator { display: flex; gap: .5rem; justify-content: center; margin-bottom: 1.5rem; }
.step-dot { width: 8px; height: 8px; border-radius: 50%; background: #334155; transition: background .2s; }
.step-dot.done { background: #7c3aed; }
.step-dot.current { background: #a855f7; }

.status-msg { text-align: center; padding: 1rem; color: #94a3b8; font-size: .85rem; }
.status-msg.error { color: #f87171; }

.success-box { text-align: center; padding: 3rem 1.5rem; }
.success-box .emoji { font-size: 4rem; display: block; margin-bottom: 1rem; }
.success-box h2 { color: #f1f5f9; margin-bottom: .5rem; }
.success-box p { color: #94a3b8; font-size: .88rem; }

@media (max-width: 600px) {
  .sell-wrap { padding: 1.5rem 1rem; }
}
</style>

<html lang="zh-TW">
<head>
  <BaseHead title="上架商品 — 兩隻熊路邊攤" description="讓 AI 幫你輕鬆上架二手商品" />
</head>
<body>
  <Header />
  <div class="sell-wrap">
    <div class="sell-header">
      <h1>📦 上架你的好物</h1>
      <p>拍一張照，AI 小熊幫你搞定所有細節</p>
    </div>

    <div class="step-indicator">
      <div class="step-dot current" id="dot-0"></div>
      <div class="step-dot" id="dot-1"></div>
      <div class="step-dot" id="dot-2"></div>
      <div class="step-dot" id="dot-3"></div>
    </div>

    <!-- Step 0: Upload -->
    <div class="step active" id="step-0">
      <p style="color:#94a3b8;font-size:.82rem;margin:0 0 .75rem;">第一張用來 AI 辨識，建議：正面、背面、尺寸標籤</p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;">
        <div class="photo-slot" id="slot-0">
          <input type="file" id="file-input-0" accept="image/*" class="file-over" />
          <span class="slot-label">第一張<br><small>正面（必填）</small></span>
        </div>
        <div class="photo-slot" id="slot-1">
          <input type="file" id="file-input-1" accept="image/*" class="file-over" />
          <span class="slot-label">第二張<br><small>背面（選填）</small></span>
        </div>
        <div class="photo-slot" id="slot-2">
          <input type="file" id="file-input-2" accept="image/*" class="file-over" />
          <span class="slot-label">第三張<br><small>尺寸標籤（選填）</small></span>
        </div>
      </div>
      <button class="btn-primary" id="btn-identify" style="margin-top:1.25rem;display:none">🔍 讓 AI 辨識第一張照片</button>
      <div class="status-msg" id="status-0"></div>
    </div>

    <!-- Step 1: Identify result + confirm -->
    <div class="step" id="step-1">
      <div class="identify-card" id="identify-result"></div>
      <button class="btn-primary" id="btn-start-chat">✓ 確認，開始聊聊細節</button>
      <button class="btn-secondary" id="btn-reupload">重新上傳照片</button>
    </div>

    <!-- Step 2: Chat -->
    <div class="step" id="step-2">
      <div class="chat-box" id="chat-box"></div>
      <div class="chat-input-row">
        <textarea class="chat-input" id="chat-input" placeholder="輸入回覆..." rows="1"></textarea>
        <button class="btn-send-msg" id="btn-chat-send">送出</button>
      </div>
      <div class="status-msg" id="status-2"></div>
    </div>

    <!-- Step 3: Preview + finalize -->
    <div class="step" id="step-3">
      <div class="final-preview" id="final-preview"></div>
      <button class="btn-primary" id="btn-finalize">🎉 確認上架！</button>
      <button class="btn-secondary" id="btn-back-chat">← 返回修改</button>
      <div class="status-msg" id="status-3"></div>
    </div>

    <!-- Step 4: Success -->
    <div class="step" id="step-4">
      <div class="success-box">
        <span class="emoji">🎉</span>
        <h2>上架成功！</h2>
        <p>你的商品已出現在路邊攤，等待有緣人～</p>
        <a href="/market" class="btn-primary" style="display:inline-block;margin-top:1.5rem;text-decoration:none">回到市集</a>
        <a href="/market/my" class="btn-secondary" style="display:inline-block;margin-top:.75rem;text-decoration:none">管理我的商品</a>
        <a href="/market/sell" class="btn-secondary" style="display:inline-block;margin-top:.75rem;text-decoration:none">再上架一件</a>
      </div>
    </div>
  </div>
  <Footer />
</body>
</html>

<script define:vars={{ uName, uEmail }}>
  let currentStep = 0
  let imageBase64s = []   // array of base64 strings, up to 3
  let identified = {}
  let chatHistory = []
  let sellerSession = {}
  let previewSrcs = []    // array of data URLs for preview

  function setStep(n) {
    document.querySelectorAll('.step').forEach((el, i) => el.classList.toggle('active', i === n))
    document.querySelectorAll('.step-dot').forEach((dot, i) => {
      dot.classList.toggle('current', i === n)
      dot.classList.toggle('done', i < n)
    })
    currentStep = n
  }

  function setStatus(step, msg, isError = false) {
    const el = document.getElementById(`status-${step}`)
    if (!el) return
    el.textContent = msg
    el.className = `status-msg${isError ? ' error' : ''}`
  }

  const btnIdentify = document.getElementById('btn-identify')

  // 3 independent photo slots
  for (let i = 0; i < 3; i++) {
    const slot = document.getElementById(`slot-${i}`)
    const input = document.getElementById(`file-input-${i}`)

    input.addEventListener('change', () => {
      const file = input.files[0]
      if (!file) return
      const reader = new FileReader()
      reader.onload = (e) => {
        const dataUrl = e.target.result
        previewSrcs[i] = dataUrl
        imageBase64s[i] = dataUrl.split(',')[1]

        // remove old img if any
        slot.querySelector('img')?.remove()
        slot.querySelector('.slot-remove')?.remove()

        const img = document.createElement('img')
        img.src = dataUrl
        slot.appendChild(img)
        slot.classList.add('has-photo')

        const removeBtn = document.createElement('button')
        removeBtn.className = 'slot-remove'
        removeBtn.textContent = '✕'
        removeBtn.addEventListener('click', (ev) => {
          ev.stopPropagation()
          ev.preventDefault()
          img.remove()
          removeBtn.remove()
          slot.classList.remove('has-photo')
          previewSrcs[i] = undefined
          imageBase64s[i] = undefined
          input.value = ''
          if (!imageBase64s[0]) btnIdentify.style.display = 'none'
        })
        slot.appendChild(removeBtn)

        if (imageBase64s[0]) btnIdentify.style.display = 'block'
      }
      reader.readAsDataURL(file)
    })
  }

  btnIdentify.addEventListener('click', async () => {
    const firstInput = document.getElementById('file-input-0') as HTMLInputElement
    if (!imageBase64s[0] || !firstInput.files?.[0]) return
    btnIdentify.disabled = true
    btnIdentify.textContent = '🔍 AI 辨識中...'
    setStatus(0, '')
    try {
      const formData = new FormData()
      formData.append('action', 'identify_image')
      formData.append('image', firstInput.files[0])  // use first image for AI
      const res = await fetch('/api/market/chat-sell', { method: 'POST', body: formData })
      if (!res.ok) throw new Error('HTTP ' + res.status)
      const data = await res.json()
      if (data.error) throw new Error(data.error)

      identified = data.identified
      sellerSession = { identified }

      const conf = identified.confidence || 'low'
      const confCls = conf === 'high' ? 'confidence-high' : conf === 'medium' ? 'confidence-medium' : 'confidence-low'
      const confLabel = conf === 'high' ? '高' : conf === 'medium' ? '中' : '低'
      const previewImgs = previewSrcs.map(src =>
        `<img src="${src}" style="max-height:120px;border-radius:8px;border:1px solid #334155;" />`
      ).join('')
      document.getElementById('identify-result').innerHTML = `
        <h3>AI 辨識結果</h3>
        <div style="display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap;">${previewImgs}</div>
        <div class="identify-row"><span class="identify-label">商品名稱</span><span class="identify-val">${identified.name || '—'}</span></div>
        <div class="identify-row"><span class="identify-label">分類</span><span class="identify-val">${identified.category || '—'}</span></div>
        <div class="identify-row"><span class="identify-label">市場新品價格</span><span class="identify-val">NT$ ${Number(identified.estimatedMarketPrice || 0).toLocaleString()}</span></div>
        <div class="identify-row"><span class="identify-label">辨識信心</span><span class="identify-val ${confCls}">${confLabel}</span></div>
      `
      setStep(1)
    } catch (e) {
      setStatus(0, '辨識失敗：' + e.message, true)
    }
    btnIdentify.disabled = false
    btnIdentify.textContent = '🔍 讓 AI 辨識第一張照片'
  })

  document.getElementById('btn-reupload').addEventListener('click', () => {
    for (let i = 0; i < 3; i++) {
      const slot = document.getElementById(`slot-${i}`)
      slot.querySelector('img')?.remove()
      slot.querySelector('.slot-remove')?.remove()
      slot.classList.remove('has-photo')
      const inp = document.getElementById(`file-input-${i}`) as HTMLInputElement
      inp.value = ''
    }
    btnIdentify.style.display = 'none'
    imageBase64s = []
    previewSrcs = []
    identified = {}
    setStep(0)
  })

  document.getElementById('btn-start-chat').addEventListener('click', () => {
    chatHistory = []
    sellerSession = { identified }
    const chatBox = document.getElementById('chat-box')
    chatBox.innerHTML = ''
    addBubble('assistant', `你好 ${uName}！我是小熊 🐻 我來幫你把這件「${identified.name || '商品'}」上架。\n\n先問你，這個東西你用了幾年了？`)
    setStep(2)
  })

  function addBubble(role, text) {
    const chatBox = document.getElementById('chat-box')
    const div = document.createElement('div')
    div.className = `msg${role === 'user' ? ' user' : ''}`
    div.innerHTML = `
      <div class="msg-avatar">${role === 'user' ? '👤' : '🐻'}</div>
      <div class="msg-bubble">${text.replace(/\n/g, '<br>')}</div>
    `
    chatBox.appendChild(div)
    chatBox.scrollTop = chatBox.scrollHeight
    if (role === 'assistant') {
      chatHistory.push({ role: 'assistant', content: text })
    }
  }

  const chatInput = document.getElementById('chat-input')
  const btnChatSend = document.getElementById('btn-chat-send')

  chatInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChat() }
  })
  btnChatSend.addEventListener('click', sendChat)

  async function sendChat() {
    const msg = chatInput.value.trim()
    if (!msg || btnChatSend.disabled) return

    addBubble('user', msg)
    chatHistory.push({ role: 'user', content: msg })
    chatInput.value = ''
    btnChatSend.disabled = true
    setStatus(2, '小熊思考中...')

    try {
      const formData = new FormData()
      formData.append('action', 'chat')
      formData.append('message', msg)
      formData.append('history', JSON.stringify(chatHistory.slice(-12)))
      formData.append('session', JSON.stringify(sellerSession))

      const res = await fetch('/api/market/chat-sell', { method: 'POST', body: formData })
      const data = await res.json()
      if (data.error) throw new Error(data.error)

      addBubble('assistant', data.reply)
      setStatus(2, '')

      if (data.isComplete) {
        setStatus(2, '資料收集完畢！正在生成商品文案...')
        await generatePreview()
      }
    } catch (e) {
      setStatus(2, '暫時連不上，請再試一次', true)
    }
    btnChatSend.disabled = false
  }

  async function generatePreview() {
    const formData = new FormData()
    formData.append('action', 'chat')
    formData.append('message', '請確認所有資訊，幫我生成上架預覽')
    formData.append('history', JSON.stringify(chatHistory))
    formData.append('session', JSON.stringify(sellerSession))

    // Parse session from chat context
    extractSessionFromHistory()

    const preview = document.getElementById('final-preview')
    const previewImgHtml = previewSrcs.map(src =>
      `<img src="${src}" style="max-height:140px;border-radius:10px;border:1px solid #334155;" />`
    ).join('')
    preview.innerHTML = `
      <h3>上架預覽</h3>
      ${previewSrcs.length ? `<div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;">${previewImgHtml}</div>` : ''}
      <div class="identify-row"><span class="identify-label">商品</span><span class="identify-val">${identified.name || '商品'}</span></div>
      <div class="identify-row"><span class="identify-label">分類</span><span class="identify-val">${identified.category || '其他'}</span></div>
      <p style="color:#64748b;font-size:.8rem;margin:.75rem 0 .4rem">文案由 AI 生成，上架後可在市集查看。</p>
    `
    setStep(3)
    setStatus(2, '')
  }

  function extractSessionFromHistory() {
    const lastFew = chatHistory.slice(-20).map(h => h.content).join('\n')
    const yearMatch = lastFew.match(/(\d+)\s*年/)
    if (yearMatch) sellerSession.yearsUsed = parseInt(yearMatch[1])

    if (/近全新|幾乎沒用|全新/.test(lastFew)) sellerSession.condition = 'like_new'
    else if (/良好|正常|沒什麼/.test(lastFew)) sellerSession.condition = 'good'
    else sellerSession.condition = 'fair'

    const priceMatch = lastFew.match(/(\d{2,6})\s*元|NT?\$?\s*(\d{2,6})/)
    if (priceMatch) sellerSession.price = parseInt(priceMatch[1] || priceMatch[2])

    if (/免費|送|給你/.test(lastFew)) { sellerSession.dealType = 'free'; sellerSession.price = undefined }
    else if (/換物|換換看|交換/.test(lastFew)) sellerSession.dealType = 'trade'
    else sellerSession.dealType = 'sell'

    const cityMatch = lastFew.match(/(台北|新北|桃園|台中|台南|高雄|基隆|新竹|苗栗|彰化|南投|雲林|嘉義|屏東|宜蘭|花蓮|台東|澎湖|金門|連江)/)
    if (cityMatch) sellerSession.locationCity = cityMatch[1]

    if (/LINE/.test(lastFew)) {
      sellerSession.contactType = 'line'
      const lineMatch = lastFew.match(/LINE[:\s]+(\S+)/)
      if (lineMatch) sellerSession.contactLineId = lineMatch[1]
    } else if (/\d{9,10}/.test(lastFew)) {
      sellerSession.contactType = 'phone'
      const phoneMatch = lastFew.match(/(\d{9,10})/)
      if (phoneMatch) sellerSession.contactPhone = phoneMatch[1]
    } else {
      sellerSession.contactType = 'form'
    }
  }

  document.getElementById('btn-back-chat').addEventListener('click', () => setStep(2))

  document.getElementById('btn-finalize').addEventListener('click', async () => {
    const btn = document.getElementById('btn-finalize')
    btn.disabled = true
    btn.textContent = '上架中...'
    setStatus(3, '')

    extractSessionFromHistory()

    try {
      const formData = new FormData()
      formData.append('action', 'finalize')
      formData.append('session', JSON.stringify(sellerSession))
      formData.append('imageBase64s', JSON.stringify(imageBase64s.filter(Boolean)))

      const res = await fetch('/api/market/chat-sell', { method: 'POST', body: formData })
      const data = await res.json()
      if (data.error) throw new Error(data.error)

      setStep(4)
    } catch (e) {
      setStatus(3, '上架失敗：' + e.message, true)
      btn.disabled = false
      btn.textContent = '🎉 確認上架！'
    }
  })
</script>
