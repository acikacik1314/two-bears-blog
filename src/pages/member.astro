function renderProphetPanel() {
  const panel = document.getElementById('prophet-panel')
  if (!panel) return
  const p = PROPHETS[currentProphet]
  const data = load()
  const myProphVotes = data.prophetVotes || {}
  const hitRate = p.total ? Math.round(p.verified / p.total * 100) : 0
  const hrColor = hitRate >= 70 ? '#86efac' : hitRate >= 50 ? '#fde68a' : '#fca5a5'

  let html = `<div class="prophet-profile">
    <div class="pp-avatar">${p.avatar}</div>
    <div class="pp-info">
      <div class="pp-name">${p.name} <span class="pp-origin">${p.origin}</span></div>
      <div class="pp-desc">${p.desc}</div>
      <div class="pp-stats">
        <div class="pp-stat"><span class="pp-stat-v" style="color:${hrColor}">${hitRate}%</span><span class="pp-stat-l">已驗證命中率</span></div>
        <div class="pp-stat"><span class="pp-stat-v">${p.verified}</span><span class="pp-stat-l">已驗證預言</span></div>
        <div class="pp-stat"><span class="pp-stat-v">${p.total}</span><span class="pp-stat-l">預言總數</span></div>
      </div>
    </div>
  </div>
  <div class="pred-list">`

  for (const pred of p.predictions) {
    const st = STATUS_INFO[pred.status]
    const cv = prophetVotes[pred.id] || { hit:0, miss:0, pend:0 }
    const cvTotal = cv.hit + cv.miss + cv.pend
    const myV = myProphVotes[pred.id]
    const catClr = CAT_COLORS[pred.cat] || '#64748b'
    const cvBar = cvTotal > 0 ? `<div class="cv-bar">
      <div class="cv-hit"  style="width:${Math.round(cv.hit/cvTotal*100)}%"></div>
      <div class="cv-miss" style="width:${Math.round(cv.miss/cvTotal*100)}%"></div>
      <div class="cv-pend" style="width:${100-Math.round(cv.hit/cvTotal*100)-Math.round(cv.miss/cvTotal*100)}%"></div>
    </div><div class="cv-counts">社群：👍${cv.hit} 👎${cv.miss} ⏳${cv.pend}</div>` : '<div class="cv-counts no-votes">尚無社群投票</div>'
    html += `<div class="pred-card">
      <div class="pred-head">
        <span class="pred-cat" style="background:${catClr}">${pred.cat}</span>
        <span class="${st.cls} pred-status">${st.label}</span>
        <span class="pred-year">${pred.year}</span>
      </div>
      <div class="pred-text">${escHtml(pred.text)}</div>
      ${cvBar}
      <div class="pred-vote-row">
        <span class="pred-vote-label">你的評分：</span>
        <button class="pv-btn hit${myV==='hit'?' pv-voted':''}" data-pid="${pred.id}" data-pv="hit" onclick="castProphetVote(this)">👍 命中</button>
        <button class="pv-btn miss${myV==='miss'?' pv-voted':''}" data-pid="${pred.id}" data-pv="miss" onclick="castProphetVote(this)">👎 未命中</button>
        <button class="pv-btn pend${myV==='pend'?' pv-voted':''}" data-pid="${pred.id}" data-pv="pend" onclick="castProphetVote(this)">⏳ 待觀察</button>
      </div>
    </div>`
  }
  html += '</div>'
  panel.innerHTML = html
}

window.castProphetVote = async function(btn) {
  const pid = btn.dataset.pid
  const pv  = btn.dataset.pv
  let data = load()
  if (!data.prophetVotes) data.prophetVotes = {}
  const prev = data.prophetVotes[pid]
  if (prev === pv) return
  data.prophetVotes[pid] = pv
  // Award points for first-time vote on this prediction
  if (!prev) { data.points += 5; data.todayVoted = true }
  save(data)
  // Update UI optimistically
  const card = btn.closest('.pred-card')
  if (card) { card.querySelectorAll('.pv-btn').forEach(b => b.classList.remove('pv-voted')); btn.classList.add('pv-voted') }
  updateTopbar(data)
  // POST to API
  try {
    const r = await fetch('/api/prophet-vote', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ predictionId: pid, vote: pv }) })
    if (r.ok) { prophetVotes[pid] = await r.json(); renderProphetPanel() }
  } catch {}
  if (!prev) showToast('✅ 投票成功 +5 pts')
}

