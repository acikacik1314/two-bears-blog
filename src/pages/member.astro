---
export const prerender = false

import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { getSession } from '../utils/session'
import { getCollection } from 'astro:content'

const token = Astro.cookies.get('sb_session')?.value
const user = token ? await getSession(token).catch(() => null) : null

const uName = user?.name ?? ''
const uEmail = user?.email ?? ''
const uPic  = user?.picture ?? ''
const hasAI = !!(import.meta.env.GROQ_API_KEY || process.env.GROQ_API_KEY || import.meta.env.GROQ_API_KEYS || process.env.GROQ_API_KEYS)

let recentPosts: { id: string; title: string; date: string; href: string }[] = []
if (user) {
  try {
    const all = (await getCollection('blog')).filter(p => !p.data.draft)
    recentPosts = all
      .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
      .slice(0, 8)
      .map(p => ({
        id: p.id,
        title: String(p.data.title),
        date: new Date(p.data.pubDate).toLocaleDateString('zh-TW'),
        href: `/blog/${p.id}/`,
      }))
  } catch {}
}
