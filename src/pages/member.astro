let currentPollIndex = 0
let pollData: any[] = []

async function loadPoll() {
  const wrap = document.getElementById('poll-wrap')
  if (!wrap) return
  try {
    const r = await fetch('/api/poll')
    pollData = await r.json()
    if (!pollData.length) { wrap.innerHTML = '<div class="mc-empty">本週民調載入中</div>'; return }
    renderPoll()
  } catch { wrap.innerHTML = '<div class="mc-empty">民調暫時無法載入</div>' }
}

function renderPoll() {
  const wrap = document.getElementById('poll-wrap')
  if (!wrap || !pollData.length) return
  const data = load()
  const poll = pollData[currentPollIndex] || pollData[0]
  const myVoted = (data.pollVotes || {})[poll.id]
  const totalVotes = (poll.votes || []).reduce((a: number, b: number) => a + b, 0)
  const paginationHtml = pollData.length > 1 ? `<div class="poll-pagination">
    ${pollData.map((p,i) => `<button class="pp-dot${i===currentPollIndex?' active':''}" onclick="switchPoll(${i})">${i+1}</button>`).join('')}
  </div>` : ''
  let optionsHtml = ''
  for (let i = 0; i < poll.options.length; i++) {
    const cnt = poll.votes?.[i] || 0
    const pct = totalVotes > 0 ? Math.round(cnt / totalVotes * 100) : 0
    const voted = myVoted === i
    optionsHtml += `<div class="poll-option ${voted?'voted':''}" onclick="${myVoted==null?`votePoll('${poll.id}',${i})`:''}">
      <div class="po-label">${poll.options[i]}</div>
      <div class="po-bar-wrap">
        <div class="po-bar" style="width:${myVoted!=null?pct:0}%"></div>
      </div>
      <div class="po-pct">${myVoted!=null?pct+'%':''}</div>
    </div>`
  }
  wrap.innerHTML = `<div class="poll-q">${escHtml(poll.question)}</div>${optionsHtml}
    <div class="poll-footer">${totalVotes} 票・${myVoted==null?'點選投票 <span class="todo-pts">+3 pts</span>':'已投票'}</div>
    ${paginationHtml}`
}

window.votePoll = async function(pollId, optionIndex) {
  let data = load()
  if (!data.pollVotes) data.pollVotes = {}
  if (data.pollVotes[pollId] != null) return
  data.pollVotes[pollId] = optionIndex
  data.points += 3
  save(data)
  updateTopbar(data)
  // POST
  try {
    const r = await fetch('/api/poll', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ option: optionIndex }) })
    if (r.ok) { const updated = await r.json(); const p = pollData.find(p => p.id === pollId); if (p && updated.votes) p.votes = updated.votes }
  } catch {}
  renderPoll()
  showToast('🗳️ 投票成功 +3 pts')
}

window.switchPoll = function(idx) {
  currentPollIndex = idx
  renderPoll()
}

// ── MARKET SNAPSHOT ─────────────────────────────────────────────
async function loadMarketSnapshot() {
  try {
    const [mktRes, fngRes, fxRes] = await Promise.allSettled([
      fetch('/api/market'),
      fetch('https://api.alternative.me/fng/?limit=1', { signal: AbortSignal.timeout(5000) }),
      fetch('https://open.er-api.com/v6/latest/USD', { signal: AbortSignal.timeout(5000) }),
    ])
    const set = (id, val, cls) => { const el = document.getElementById(id); if (el) { el.textContent = val; if (cls) el.className = `mkt-val ${cls}`; } }
    const fmt = (n, dec) => n == null ? '—' : n.toLocaleString('en-US', { maximumFractionDigits: dec ?? (n >= 100 ? 0 : 4) })
    const chg = (p) => p == null ? '' : ` ${p >= 0 ? '▲' : '▼'}${Math.abs(p).toFixed(1)}%`
    if (mktRes.status === 'fulfilled' && mktRes.value.ok) {
      const d = await mktRes.value.json()
      const qs = {}; for (const q of (d.quotes ?? [])) qs[q.symbol] = q
      const btc = d.crypto?.bitcoin; const xrp = d.crypto?.ripple
      if (btc) set('mkt-btc', `$${fmt(btc.usd)}${chg(btc.usd_24h_change)}`, btc.usd_24h_change >= 0 ? 'up' : 'dn')
      if (xrp) set('mkt-xrp', `$${fmt(xrp.usd, 4)}${chg(xrp.usd_24h_change)}`, xrp.usd_24h_change >= 0 ? 'up' : 'dn')
      if (qs['GC=F']) set('mkt-gold', `$${fmt(qs['GC=F'].price)}${chg(qs['GC=F'].change)}`, (qs['GC=F'].change ?? 0) >= 0 ? 'up' : 'dn')
      if (qs['^VIX']) { const v = qs['^VIX'].price; set('mkt-vix', fmt(v,1), v >= 30 ? 'dn' : v >= 20 ? 'warn' : 'up') }
    }
    if (fngRes.status === 'fulfilled' && fngRes.value.ok) {
      const j = await fngRes.value.json(); const val = parseInt(j?.data?.[0]?.value)
      const label = val >= 75 ? '極貪婪' : val >= 55 ? '貪婪' : val >= 45 ? '中立' : val >= 25 ? '恐懼' : '極恐懼'
      set('mkt-fng', `${val} ${label}`, val >= 55 ? 'dn' : val <= 35 ? 'up' : 'warn')
    }
    if (fxRes.status === 'fulfilled' && fxRes.value.ok) {
      const j = await fxRes.value.json(); const twd = j?.rates?.TWD
      if (twd) set('mkt-twd', twd.toFixed(2), null)
    }
  } catch {}
}

