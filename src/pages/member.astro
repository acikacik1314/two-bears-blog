  padding: .8em 1.2em; display: flex; align-items: center; gap: 1em;
  color: #e2e8f0; font-size: .88em; box-shadow: 0 8px 32px rgba(0,0,0,.5);
}
.mc-bonus-toast button { background: none; border: none; color: #64748b; cursor: pointer; font-size: 1em; }

/* ── TOPBAR ──────────────────────────────── */
.mc-topbar {
  display: grid; grid-template-columns: 1fr auto auto; gap: 1.5em; align-items: center;
  background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
  border-radius: 16px; padding: 1.2em 1.5em; margin: 1.5em 0 1em;
}
.mc-user-info { display: flex; align-items: center; gap: 1em; }
.mc-avatar { width: 52px; height: 52px; border-radius: 50%; border: 2px solid rgba(168,85,247,.4); }
.mc-username { font-size: 1em; font-weight: 700; color: #e2e8f0; }
.mc-bear-title { font-size: .78em; background: rgba(168,85,247,.2); color: #c084fc; padding: .15em .6em; border-radius: 20px; margin-left: .4em; }
.mc-email { font-size: .75em; color: #64748b; margin-top: .15em; }
.mc-level-block { min-width: 200px; }
.mc-lv-row { display: flex; align-items: center; gap: .5em; margin-bottom: .4em; }
.mc-lv-badge { background: linear-gradient(135deg,#7e22ce,#6b21a8); color: white; font-size: .7em; font-weight: 800; padding: .2em .7em; border-radius: 20px; }
.mc-lv-name { font-size: .88em; font-weight: 700; color: #e2e8f0; }
.mc-pts { margin-left: auto; font-size: .78em; color: #a855f7; font-weight: 700; }
.mc-lv-bar { height: 6px; background: rgba(255,255,255,.1); border-radius: 3px; overflow: hidden; margin-bottom: .3em; }
.mc-lv-fill { height: 100%; background: linear-gradient(90deg,#7e22ce,#a855f7); border-radius: 3px; transition: width .4s; }
.mc-lv-next { font-size: .68em; color: #64748b; }
.mc-streak-block { text-align: center; min-width: 100px; }
.mc-streak-num { font-size: 2em; font-weight: 900; color: #f97316; line-height: 1; }
.mc-streak-label { font-size: .68em; color: #64748b; margin-bottom: .3em; }
.mc-badges-row { display: flex; gap: .3em; flex-wrap: wrap; justify-content: center; }
.badge-chip { font-size: .65em; background: rgba(234,179,8,.15); color: #fbbf24; border: 1px solid rgba(234,179,8,.3); padding: .2em .5em; border-radius: 20px; cursor: default; }

/* ── TABS ────────────────────────────────── */
.mc-tabs { display: flex; gap: .3em; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: .35em; margin-bottom: 1.2em; }
.mc-tab { flex: 1; background: transparent; border: none; color: #94a3b8; font-size: .78em; font-weight: 600; padding: .55em .3em; border-radius: 8px; cursor: pointer; transition: all .15s; white-space: nowrap; }
.mc-tab.active { background: rgba(168,85,247,.2); color: #c084fc; }
.mc-tab:hover:not(.active) { color: #e2e8f0; background: rgba(255,255,255,.04); }
.mc-panel { display: none; }
.mc-panel.active { display: block; }

/* ── CARDS ───────────────────────────────── */
.mc-card {
  background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08);
  border-radius: 14px; padding: 1.2em; margin-bottom: 1em;
}
.mc-card.wide { grid-column: 1/-1; }
.mc-card.tall { height: fit-content; }
.mc-card-head { display: flex; align-items: center; gap: .5em; margin-bottom: 1em; padding-bottom: .6em; border-bottom: 1px solid rgba(255,255,255,.06); }
.mc-card-head h3 { font-size: .88em; font-weight: 700; color: #e2e8f0; margin: 0; }
.member-tag { font-size: .65em; background: rgba(168,85,247,.2); color: #c084fc; padding: .15em .6em; border-radius: 20px; margin-left: auto; }
.mc-loading { color: #64748b; font-size: .85em; padding: 1em; text-align: center; }
.mc-empty { color: #475569; font-size: .82em; padding: .8em; text-align: center; border: 1px dashed rgba(255,255,255,.1); border-radius: 8px; }

/* ── DASHBOARD ────────────────────────────── */
.dash-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1em; }
.dash-stats-row { grid-column: 1/-1; display: grid; grid-template-columns: repeat(4,1fr); gap: .8em; }
.dash-stat { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07); border-radius: 10px; padding: 1em; text-align: center; }
.ds-val { font-size: 1.4em; font-weight: 800; color: #a855f7; }
.ds-label { font-size: .7em; color: #64748b; margin-top: .2em; }
/* Advanced survival */
.adv-score-row { display: flex; align-items: center; gap: 1.5em; margin-bottom: 1em; }
.adv-big-score { font-size: 3em; font-weight: 900; line-height: 1; }
.adv-score-label { font-size: .85em; font-weight: 700; color: #e2e8f0; }
.adv-cats { display: flex; flex-direction: column; gap: .5em; }
.adv-cat { display: grid; grid-template-columns: 100px 1fr 40px; align-items: center; gap: .8em; }
.adv-cat-name { font-size: .78em; color: #94a3b8; }
.adv-cat-bar { height: 8px; background: rgba(255,255,255,.08); border-radius: 4px; overflow: hidden; }
.adv-cat-fill { height: 100%; border-radius: 4px; transition: width .4s; }
.adv-cat-score { font-size: .78em; font-weight: 700; text-align: right; }
/* Leaderboard */
.lb-list { display: flex; flex-direction: column; gap: .4em; }
.lb-row { display: flex; align-items: center; gap: .6em; padding: .4em; border-radius: 8px; background: rgba(255,255,255,.02); }
.lb-rank { font-size: .9em; width: 24px; text-align: center; }
.lb-name { flex: 1; font-size: .82em; color: #e2e8f0; }
.lb-cnt { font-size: .75em; color: #94a3b8; }
/* Tasks */
.todo-list { display: flex; flex-direction: column; gap: .5em; }
.todo-item { display: flex; align-items: center; gap: .6em; font-size: .83em; color: #94a3b8; }
.todo-icon { font-size: 1em; }
.todo-pts { font-size: .7em; background: rgba(168,85,247,.2); color: #c084fc; padding: .1em .4em; border-radius: 20px; margin-left: .3em; }
.todo-total { margin-top: .8em; padding-top: .6em; border-top: 1px solid rgba(255,255,255,.06); font-size: .78em; color: #94a3b8; text-align: right; }
.todo-total strong { color: #a855f7; }

/* ── PROPHECY LAB ─────────────────────────── */
.proph-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 1em; }
.proph-form { display: flex; flex-direction: column; gap: .6em; }
.proph-form textarea { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #e2e8f0; padding: .8em; font-size: .85em; resize: vertical; font-family: inherit; }
.proph-form textarea:focus { outline: none; border-color: rgba(168,85,247,.5); }
.proph-row { display: grid; grid-template-columns: 1fr 1fr; gap: .5em; }
.proph-form select, .proph-form input[type=month] {
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
  border-radius: 8px; color: #e2e8f0; padding: .6em .8em; font-size: .82em;
}
.proph-submit-btn { background: linear-gradient(135deg,#7e22ce,#6b21a8); color: white; border: none; border-radius: 8px; padding: .7em; font-size: .85em; font-weight: 700; cursor: pointer; transition: transform .15s; }
.proph-submit-btn:hover { transform: translateY(-1px); }
.btn-pts { font-size: .72em; background: rgba(255,255,255,.15); padding: .1em .4em; border-radius: 10px; margin-left: .3em; }
.proph-msg { font-size: .78em; padding: .3em; border-radius: 6px; }
.proph-msg.success { color: #86efac; background: rgba(34,197,94,.1); }
.proph-msg.error   { color: #fca5a5; background: rgba(239,68,68,.1); }
/* Community prophecy cards */
.proph-card { border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: .9em; margin-bottom: .7em; background: rgba(255,255,255,.02); }
.proph-card-head { display: flex; align-items: center; gap: .4em; margin-bottom: .5em; flex-wrap: wrap; }
.proph-cat-tag { font-size: .65em; font-weight: 700; color: white; padding: .15em .5em; border-radius: 20px; }
.proph-dl { font-size: .65em; color: #94a3b8; }
.proph-mine { font-size: .65em; background: rgba(59,130,246,.2); color: #93c5fd; padding: .15em .5em; border-radius: 20px; }
.proph-author { margin-left: auto; font-size: .7em; color: #64748b; }
.proph-card-text { font-size: .82em; color: #cbd5e1; line-height: 1.6; margin-bottom: .7em; }
.proph-card-foot { display: flex; align-items: center; gap: .5em; flex-wrap: wrap; }
.proph-vote-row { display: flex; gap: .3em; }
.vote-btn { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 20px; padding: .25em .7em; font-size: .7em; cursor: pointer; color: #94a3b8; transition: all .15s; }
.vote-btn.voted { border-color: rgba(168,85,247,.5); background: rgba(168,85,247,.2); color: #c084fc; font-weight: 700; }
.vote-btn.hit.voted   { border-color: rgba(34,197,94,.5);  background: rgba(34,197,94,.15);  color: #86efac; }
.vote-btn.miss.voted  { border-color: rgba(239,68,68,.5);  background: rgba(239,68,68,.15);  color: #fca5a5; }
.vote-btn.pend.voted  { border-color: rgba(234,179,8,.5);  background: rgba(234,179,8,.15);  color: #fde68a; }
.bet-open-btn { margin-left: auto; background: rgba(251,191,36,.1); border: 1px solid rgba(251,191,36,.2); color: #fbbf24; border-radius: 20px; padding: .25em .8em; font-size: .7em; cursor: pointer; transition: all .15s; }
.bet-open-btn:hover { background: rgba(251,191,36,.2); }
/* My records */
.my-proph-row { display: flex; align-items: center; gap: .5em; padding: .4em; border-radius: 8px; font-size: .78em; border-bottom: 1px solid rgba(255,255,255,.05); }
.my-proph-cat { font-size: .65em; background: rgba(168,85,247,.2); color: #c084fc; padding: .1em .4em; border-radius: 20px; white-space: nowrap; }
.my-proph-txt { flex: 1; color: #94a3b8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.my-proph-date { color: #475569; white-space: nowrap; }
.bet-row { padding: .5em; border-radius: 8px; margin-bottom: .4em; font-size: .8em; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.06); }
.bet-row.won  { border-color: rgba(34,197,94,.3); background: rgba(34,197,94,.05); }
.bet-row.lost { border-color: rgba(239,68,68,.3); background: rgba(239,68,68,.05); }
.bet-proph { color: #94a3b8; margin-bottom: .2em; }
.bet-meta { color: #64748b; font-size: .88em; }

/* ── TOOLS ───────────────────────────────── */
.tools-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1em; }
/* Calc */
.calc-tabs { display: flex; gap: .3em; margin-bottom: 1em; }
.calc-tab { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #94a3b8; border-radius: 8px; padding: .4em 1.2em; font-size: .82em; font-weight: 600; cursor: pointer; transition: all .15s; }
.calc-tab.active { background: rgba(168,85,247,.2); color: #c084fc; border-color: rgba(168,85,247,.4); }
.calc-form { display: flex; flex-direction: column; gap: .7em; margin-bottom: 1em; }
.calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: .6em; }
.calc-field { display: flex; flex-direction: column; gap: .3em; }
.calc-field label { font-size: .75em; color: #94a3b8; }
.calc-field input { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #e2e8f0; padding: .6em .8em; font-size: .85em; }
.calc-btn { background: linear-gradient(135deg,#1e40af,#1d4ed8); color: white; border: none; border-radius: 8px; padding: .65em; font-size: .85em; font-weight: 700; cursor: pointer; }
.calc-cost { font-size: .8em; color: #94a3b8; margin-bottom: .6em; }
.calc-table { width: 100%; border-collapse: collapse; font-size: .8em; }
.calc-table th { color: #64748b; font-size: .8em; text-align: left; padding: .3em .5em; border-bottom: 1px solid rgba(255,255,255,.08); }
.calc-table td { padding: .35em .5em; border-bottom: 1px solid rgba(255,255,255,.04); color: #94a3b8; }
.calc-table tr.pos td:last-child, .calc-table tr.pos td:nth-child(3) { color: #86efac; }
.calc-table tr.neg td:last-child, .calc-table tr.neg td:nth-child(3) { color: #fca5a5; }
/* Checklist */
.checklist-cats { display: flex; flex-direction: column; gap: .6em; }
.cl-cat { background: rgba(255,255,255,.02); border-radius: 8px; padding: .7em; }
.cl-cat-title { font-size: .78em; font-weight: 700; color: #e2e8f0; margin-bottom: .5em; }
.cl-item { display: flex; align-items: center; gap: .5em; font-size: .78em; color: #94a3b8; margin-bottom: .3em; cursor: pointer; }
.cl-item input[type=checkbox] { accent-color: #a855f7; }
/* Geopolitical */
.geo-grid { display: flex; flex-direction: column; gap: .6em; }
.geo-item { display: grid; grid-template-columns: 120px 1fr 36px; align-items: center; gap: .6em; }
.geo-name { font-size: .78em; color: #94a3b8; }
.geo-bar { height: 8px; border-radius: 4px; transition: width .5s; }
.geo-bar.red    { background: #ef4444; }
.geo-bar.orange { background: #f97316; }
.geo-bar.yellow { background: #eab308; }
.geo-val { font-size: .75em; font-weight: 700; color: #94a3b8; text-align: right; }
.geo-note { font-size: .68em; color: #475569; margin-top: .8em; }

/* ── COMMUNITY ────────────────────────────── */
.comm-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1em; }
/* Forum */
.forum-cats { display: flex; gap: .3em; margin-bottom: .8em; flex-wrap: wrap; }
.forum-cat-btn { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #94a3b8; border-radius: 20px; padding: .3em .9em; font-size: .75em; font-weight: 600; cursor: pointer; transition: all .15s; }
.forum-cat-btn.active { background: rgba(168,85,247,.2); color: #c084fc; border-color: rgba(168,85,247,.4); }
.forum-form { display: flex; flex-direction: column; gap: .5em; margin-bottom: .8em; }
.forum-form textarea { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #e2e8f0; padding: .7em; font-size: .82em; resize: none; font-family: inherit; }
.forum-post-btn { background: rgba(168,85,247,.2); border: 1px solid rgba(168,85,247,.3); color: #c084fc; border-radius: 8px; padding: .5em; font-size: .82em; font-weight: 700; cursor: pointer; }
.forum-posts { max-height: 400px; overflow-y: auto; }
.forum-post { border-bottom: 1px solid rgba(255,255,255,.05); padding: .6em 0; }
.fp-head { display: flex; align-items: center; gap: .5em; margin-bottom: .3em; }
.fp-author { font-size: .75em; color: #a855f7; font-weight: 700; }
.fp-time { font-size: .68em; color: #475569; margin-left: auto; }
.fp-text { font-size: .8em; color: #cbd5e1; line-height: 1.5; }
/* Wish wall */
.wish-date { font-size: .8em; color: #64748b; margin-bottom: .5em; }
.wish-today-display { min-height: 2.5em; background: rgba(255,255,255,.03); border: 1px dashed rgba(255,255,255,.1); border-radius: 8px; padding: .7em; font-size: .85em; color: #fde68a; margin-bottom: .8em; line-height: 1.5; font-style: italic; }
.wish-today-display.has-wish { border-style: solid; border-color: rgba(234,179,8,.25); background: rgba(234,179,8,.05); }
.wish-form { display: flex; gap: .5em; margin-bottom: .8em; }
.wish-form input { flex: 1; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #e2e8f0; padding: .6em .8em; font-size: .82em; }
.wish-btn { background: rgba(234,179,8,.2); border: 1px solid rgba(234,179,8,.3); color: #fbbf24; border-radius: 8px; padding: .5em .9em; font-size: .82em; font-weight: 700; cursor: pointer; white-space: nowrap; }
.wish-history-title { font-size: .75em; color: #475569; margin-bottom: .4em; }
.wish-row { display: flex; gap: .5em; padding: .3em 0; border-bottom: 1px solid rgba(255,255,255,.04); font-size: .78em; }
.wish-d { color: #475569; white-space: nowrap; }
.wish-t { color: #94a3b8; font-style: italic; }
/* Tribe stats */
.tribe-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: .8em; margin-bottom: .8em; }
.ts-item { text-align: center; background: rgba(255,255,255,.03); border-radius: 10px; padding: .8em; }
.ts-icon { font-size: 1.3em; margin-bottom: .3em; }
.ts-val { font-size: 1.1em; font-weight: 800; color: #a855f7; }
.ts-label { font-size: .7em; color: #64748b; margin-top: .2em; }
.tribe-note { font-size: .68em; color: #475569; text-align: center; }

/* ── AI ASSISTANT ─────────────────────────── */
.ai-setup { max-width: 500px; margin: 3em auto; text-align: center; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 2em; }
.ai-setup-icon { font-size: 3em; margin-bottom: .5em; }
.ai-setup h3 { color: #e2e8f0; margin: 0 0 .5em; }
.ai-setup p { color: #94a3b8; font-size: .88em; }
.ai-setup ol { text-align: left; color: #94a3b8; font-size: .85em; padding-left: 1.5em; margin: 1em 0; line-height: 2; }
.ai-setup a { color: #a855f7; }
.ai-setup code { background: rgba(255,255,255,.1); padding: .1em .4em; border-radius: 4px; font-size: .9em; }
.ai-wrap { display: flex; flex-direction: column; gap: 1em; }
.ai-header { display: flex; align-items: center; gap: 1em; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 1em 1.2em; }
.ai-icon { font-size: 2em; }
.ai-header h3 { color: #e2e8f0; margin: 0 0 .2em; font-size: .95em; }
.ai-desc { font-size: .78em; color: #64748b; margin: 0; }
.ai-quick-btns { display: flex; gap: .5em; flex-wrap: wrap; }
.ai-quick { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #94a3b8; border-radius: 20px; padding: .4em .9em; font-size: .78em; cursor: pointer; transition: all .15s; }
.ai-quick:hover { background: rgba(168,85,247,.15); color: #c084fc; border-color: rgba(168,85,247,.3); }
.ai-messages { background: rgba(255,255,255,.02); border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1em; min-height: 200px; max-height: 400px; overflow-y: auto; display: flex; flex-direction: column; gap: .8em; }
.ai-msg.user { align-self: flex-end; }
.ai-msg.ai   { align-self: flex-start; }
.ai-msg.user .ai-bubble { background: rgba(168,85,247,.2); color: #e2e8f0; border-radius: 12px 12px 2px 12px; padding: .7em 1em; font-size: .85em; max-width: 80%; }
.ai-msg.ai   .ai-bubble { background: rgba(255,255,255,.06); color: #cbd5e1; border-radius: 12px 12px 12px 2px; padding: .7em 1em; font-size: .85em; max-width: 90%; white-space: pre-wrap; line-height: 1.7; }
.ai-input-row { display: flex; gap: .5em; }
.ai-input-row input { flex: 1; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 10px; color: #e2e8f0; padding: .7em 1em; font-size: .88em; }
.ai-input-row input:focus { outline: none; border-color: rgba(168,85,247,.5); }
.ai-send-btn { background: linear-gradient(135deg,#7e22ce,#6b21a8); color: white; border: none; border-radius: 10px; padding: .7em 1.5em; font-size: .88em; font-weight: 700; cursor: pointer; }

/* ── MARKET SNAPSHOT ──────────────────────── */
.mkt-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: .6em; }
.mkt-item { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.06); border-radius: 10px; padding: .7em .8em; }
.mkt-name { font-size: .7em; color: #64748b; margin-bottom: .2em; }
.mkt-val { font-size: .9em; font-weight: 700; color: #94a3b8; }
.mkt-val.up   { color: #86efac; }
.mkt-val.dn   { color: #fca5a5; }
.mkt-val.warn { color: #fde68a; }

/* ── VOTE STATS BAR ───────────────────────── */
.vote-stats-bar { margin-bottom: 1em; padding: .7em; background: rgba(255,255,255,.03); border-radius: 8px; }
.vsb-label { font-size: .7em; color: #64748b; margin-bottom: .4em; }
.vsb-track { display: flex; height: 20px; border-radius: 10px; overflow: hidden; }
.vsb-hit  { background: rgba(34,197,94,.4);  display: flex; align-items: center; justify-content: center; font-size: .62em; color: white; min-width: 2em; }
.vsb-miss { background: rgba(239,68,68,.4);  display: flex; align-items: center; justify-content: center; font-size: .62em; color: white; min-width: 2em; }
.vsb-pend { background: rgba(234,179,8,.35); display: flex; align-items: center; justify-content: center; font-size: .62em; color: white; min-width: 2em; }
