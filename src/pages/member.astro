          <div class="vsb-miss" style="width:${mPct}%" title="未命中 ${missCnt}">👎 ${mPct}%</div>
          <div class="vsb-pend" style="width:${pPct}%" title="待觀察 ${pendCnt}">⏳ ${pPct}%</div>
        </div>
      </div>`
    }
    let html = statsHtml
    for (const p of list.slice(0,20)) {
      const myVote = data.votes?.[p.id]
      const catClrs = { '地緣政治':'#ef4444','加密貨幣':'#a855f7','自然災害':'#f97316','台灣':'#3b82f6','靈性預言':'#8b5cf6','其他':'#64748b' }
      const clr = catClrs[p.category] ?? '#64748b'
      const dl = p.deadline ? `<span class="proph-dl">截止 ${p.deadline}</span>` : ''
      const isMe = p.email === uEmail
      const daysAgo = Math.floor((Date.now() - p.submittedAt) / 86400000)
      const timeStr = daysAgo === 0 ? '今天' : daysAgo === 1 ? '昨天' : `${daysAgo}天前`
      html += `<div class="proph-card" data-id="${p.id}">
        <div class="proph-card-head">
          <span class="proph-cat-tag" style="background:${clr}">${p.category}</span>
          ${dl}
          ${isMe ? '<span class="proph-mine">我的</span>' : ''}
          <span class="proph-time">${timeStr}</span>
          <span class="proph-author">${p.author}</span>
        </div>
        <div class="proph-card-text">${escHtml(p.content)}</div>
        <div class="proph-card-foot">
          <div class="proph-vote-row">
            <button class="vote-btn hit${myVote==='hit'?' voted':''}" data-id="${p.id}" data-v="hit" onclick="castVote(this)">👍 命中</button>
            <button class="vote-btn miss${myVote==='miss'?' voted':''}" data-id="${p.id}" data-v="miss" onclick="castVote(this)">👎 未命中</button>
            <button class="vote-btn pend${myVote==='pend'?' voted':''}" data-id="${p.id}" data-v="pend" onclick="castVote(this)">⏳ 待觀察</button>
          </div>
          <button class="bet-open-btn" data-id="${p.id}" data-txt="${escHtml(p.content.slice(0,40))}" onclick="openBet(this)">🎲 下注</button>
        </div>
      </div>`
    }
    wrap.innerHTML = html
  } catch {
    wrap.innerHTML = '<div class="mc-empty">載入失敗，請稍後再試</div>'
  }
}

function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }

function castVote(btn) {
  const id = btn.dataset.id
  const v  = btn.dataset.v
  let data = load()
  const already = data.votes?.[id]
  if (already === v) return
  if (!data.votes) data.votes = {}
  data.votes[id] = v
  let bonus = 0
  if (!data.todayVoted) { data.points += 5; data.todayVoted = true; bonus = 5 }
  save(data)
  // Update UI
  const card = btn.closest('.proph-card')
  if (card) {
    card.querySelectorAll('.vote-btn').forEach(b => b.classList.remove('voted'))
    btn.classList.add('voted')
  }
  updateTopbar(data)
  if (bonus) showToast(`✅ 投票成功！+${bonus} 積分`)
}

// Virtual bet modal
function openBet(btn) {
  const id  = btn.dataset.id
  const txt = btn.dataset.txt
  const data = load()
  const existing = (data.bets||[]).find(b => b.id === id)
  if (existing) { showToast('你已對此預言下注'); return }
  const side = prompt(`下注「${txt}…」\n\n1 = 命中  2 = 未命中\n輸入1或2：`)
  if (!side) return
  const sideName = side === '1' ? 'hit' : side === '2' ? 'miss' : null
  if (!sideName) return
  const amtStr = prompt(`下注多少積分？（現有 ${data.points} pts，最多投入 ${Math.floor(data.points*0.5)||10}）`)
  const amt = parseInt(amtStr)
  if (!amt || amt <= 0) return
  if (amt > data.points) { showToast('積分不足！'); return }
  data.points -= amt
  if (!data.bets) data.bets = []
