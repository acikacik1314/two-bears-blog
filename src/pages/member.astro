// ── POSITION CALCULATOR ──────────────────────────────────────────
const ASSETS = {
  xrp:  { targets: [3, 5, 10, 27, 100, 589], unit: 'XRP', label: '數量（XRP）', dec: 4 },
  gold: { targets: [2800, 3000, 3500, 4000, 5000, 10000], unit: '盎司', label: '數量（盎司）', dec: 2 },
  btc:  { targets: [80000, 100000, 150000, 200000, 500000, 1000000], unit: 'BTC', label: '數量（BTC）', dec: 8 },
}
let currentAsset = 'xrp'

document.querySelectorAll('.calc-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.calc-tab').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    currentAsset = btn.dataset.asset
    document.getElementById('calc-qty-label').textContent = ASSETS[currentAsset].label
    document.getElementById('calc-result').innerHTML = ''
  })
})

window.calcPnL = function() {
  const entry = parseFloat(document.getElementById('calc-entry').value)
  const qty   = parseFloat(document.getElementById('calc-qty').value)
  if (!entry || !qty) return
  const a = ASSETS[currentAsset]
  const cost = entry * qty
  const rows = a.targets.map(t => {
    const val  = t * qty
    const pnl  = val - cost
    const pct  = ((t - entry) / entry * 100)
    const cls  = pnl >= 0 ? 'pos' : 'neg'
    return `<tr class="${cls}">
      <td>$${t.toLocaleString()}</td>
      <td>$${val.toLocaleString('en-US',{maximumFractionDigits:0})}</td>
      <td>${pnl>=0?'+':''}$${pnl.toLocaleString('en-US',{maximumFractionDigits:0})}</td>
      <td>${pct>=0?'+':''}${pct.toFixed(1)}%</td>
    </tr>`
  }).join('')
  document.getElementById('calc-result').innerHTML = `
    <div class="calc-cost">成本：$${cost.toLocaleString('en-US',{maximumFractionDigits:2})}</div>
    <table class="calc-table"><thead><tr><th>目標價</th><th>總值</th><th>損益</th><th>漲跌</th></tr></thead><tbody>${rows}</tbody></table>`
}

