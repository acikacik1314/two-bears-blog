<script define:vars={{ uName, uEmail, hasAI }}>

// ── DATA STORE ──────────────────────────────────────────────────
const DATA_KEY = 'tb_v3_data'
const DFLT = {
  points: 0, streak: 0, lastLogin: null, totalLogins: 0, badges: [], wishes: [],
}
function load() {
  try { const r = localStorage.getItem(DATA_KEY); return r ? { ...DFLT, ...JSON.parse(r) } : { ...DFLT } }
  catch { return { ...DFLT } }
}
function save(d) {
  try { localStorage.setItem(DATA_KEY, JSON.stringify(d)) } catch {}
}

// ── LEVELS ──────────────────────────────────────────────────────
const LEVELS = [
  { lv:1,  name:'旅人',       min:0 },
  { lv:3,  name:'觀察者',     min:200 },
  { lv:7,  name:'末日研究員', min:600 },
  { lv:12, name:'警戒者',     min:1200 },
  { lv:18, name:'預言師',     min:2000 },
  { lv:25, name:'先知',       min:3500 },
  { lv:33, name:'末日哲人',   min:6000 },
  { lv:40, name:'守望者',     min:10000 },
  { lv:48, name:'時空偵探',   min:16000 },
  { lv:50, name:'時間旅者',   min:25000 },
]
function getLevel(pts) {
  let idx = 0
  for (let i = 0; i < LEVELS.length; i++) { if (pts >= LEVELS[i].min) idx = i; else break; }
  const cur = LEVELS[idx]
  const nxt = LEVELS[idx + 1]
  const pct = nxt ? Math.min(100, ((pts - cur.min) / (nxt.min - cur.min)) * 100) : 100
  return { ...cur, next: nxt, pct }
}
function bearTitle(badges) {
  if (badges.includes('century')) return '🐻‍❄️ 神棍大師'
  if (badges.includes('month'))   return '🐻 金熊'
  if (badges.includes('week'))    return '🐻 銀熊'
  return '🐻 青熊'
}
const BADGE_INFO = {
  week:    { icon:'🌟', name:'週連勝',   desc:'連續登入7天' },
  month:   { icon:'🥈', name:'月度使徒', desc:'連續登入30天' },
  century: { icon:'👑', name:'百日鐵粉', desc:'連續登入100天' },
}

// ── DAILY LOGIN ─────────────────────────────────────────────────
function checkLogin(data) {
  const today = new Date().toISOString().slice(0,10)
  const yest  = new Date(Date.now()-86400000).toISOString().slice(0,10)
  if (data.lastLogin === today) return { data, bonus: 0 }
  const streak = data.lastLogin === yest ? data.streak + 1 : 1
  let bonus = 10
  const newBadges = [...(data.badges||[])]
  if (streak >= 7   && !newBadges.includes('week'))    { newBadges.push('week');    bonus += 50  }
  if (streak >= 30  && !newBadges.includes('month'))   { newBadges.push('month');   bonus += 200 }
  if (streak >= 100 && !newBadges.includes('century')) { newBadges.push('century'); bonus += 1000 }
  const nd = { ...data, points: data.points + bonus, streak, lastLogin: today, totalLogins: (data.totalLogins||0)+1, badges: newBadges }
  return { data: nd, bonus }
}

// ── HELPERS ──────────────────────────────────────────────────────
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }
function set(id, v) { const el = document.getElementById(id); if (el) el.textContent = v }

// ── UPDATE BUNKER PASS UI ────────────────────────────────────────
function updateTopbar(data) {
  const lv = getLevel(data.points)
  set('lv-badge', `Lv ${lv.lv}`)
  set('lv-name', lv.name)
  set('pts-display', `${data.points.toLocaleString()} pts`)
  const fill = document.getElementById('lv-fill')
  if (fill) fill.style.width = `${lv.pct}%`
  set('lv-next', lv.next ? `下一級：${lv.next.min.toLocaleString()} pts (${lv.next.name})` : '🎉 已達最高等級！')
  set('streak-num', data.streak)
  set('bear-title', bearTitle(data.badges))
  // Badges row in pass card
  const br = document.getElementById('badges-row')
  if (br) {
    br.innerHTML = ''
    for (const b of (data.badges||[])) {
      if (BADGE_INFO[b]) {
        const sp = document.createElement('span')
        sp.className = 'badge-chip'
        sp.title = BADGE_INFO[b].desc
        sp.textContent = `${BADGE_INFO[b].icon} ${BADGE_INFO[b].name}`
        br.appendChild(sp)
      }
    }
  }
  // Pass tab stats
  set('ps-points', data.points.toLocaleString())
  set('ps-streak', `${data.streak}天`)
  set('ps-logins', data.totalLogins || 1)
  set('cur-lv-tag', `Lv ${lv.lv} ${lv.name}`)
  renderLevelMap(data.points)
  renderBadgeShowcase(data.badges)
  updateDailyTab(data)
}

function renderLevelMap(pts) {
  const map = document.getElementById('level-map')
  if (!map) return
  const curLv = getLevel(pts)
  map.innerHTML = LEVELS.map(lvl => {
    const done = pts >= lvl.min
    const isCur = lvl.lv === curLv.lv
    return `<div class="lm-item${done?' done':''}${isCur?' current':''}">
      <div class="lm-lv">Lv ${lvl.lv}</div>
      <div class="lm-name">${lvl.name}</div>
      <div class="lm-pts">${lvl.min.toLocaleString()}</div>
    </div>`
  }).join('')
}

function renderBadgeShowcase(badges) {
  const wrap = document.getElementById('badge-showcase')
  if (!wrap) return
  const earned = (badges||[]).filter(b => BADGE_INFO[b])
  if (!earned.length) {
    wrap.innerHTML = '<div class="mc-empty">繼續登入累積連勝，解鎖專屬徽章！</div>'
    return
  }
  wrap.innerHTML = earned.map(b => {
    const info = BADGE_INFO[b]
    return `<div class="badge-full">
      <div class="bf-icon">${info.icon}</div>
      <div class="bf-name">${info.name}</div>
      <div class="bf-desc">${info.desc}</div>
    </div>`
  }).join('')
}

function updateDailyTab(data) {
  const today = new Date().toISOString().slice(0,10)
  set('todo-login-icon', data.lastLogin === today ? '✅' : '⬜')
  set('todo-wish-icon', (data.wishes||[]).some(w=>w.date===today) ? '✅' : '⬜')
  set('streak-big-num', data.streak)
  set('streak-total', data.totalLogins || 1)
  updateBadgeProgress('week', data.streak, 7, data.badges)
  updateBadgeProgress('month', data.streak, 30, data.badges)
  updateBadgeProgress('century', data.streak, 100, data.badges)
}

function updateBadgeProgress(key, streak, target, badges) {
  const bar = document.getElementById(`bpi-${key}-bar`)
  const status = document.getElementById(`bpi-${key}-status`)
  const earned = (badges||[]).includes(key)
  const pct = earned ? 100 : Math.min(100, Math.round(streak / target * 100))
  if (bar) { bar.style.width = `${pct}%`; bar.style.background = earned ? '#86efac' : '#a855f7' }
  if (status) status.textContent = earned ? '✅ 已獲得' : `${streak}/${target}`
}

// ── WISH WALL ────────────────────────────────────────────────────
function initWish(data) {
  const today = new Date().toISOString().slice(0,10)
  const el = document.getElementById('wish-date')
  if (el) el.textContent = today.replace(/-/g,'/')
  const todayWish = (data.wishes||[]).find(w => w.date === today)
  const disp = document.getElementById('wish-today')
  if (disp) {
    if (todayWish) { disp.textContent = `🕯️ "${todayWish.text}"`; disp.classList.add('has-wish') }
    else { disp.textContent = ''; disp.classList.remove('has-wish') }
  }
  const hist = document.getElementById('wish-history')
  if (hist) {
    const past = (data.wishes||[]).filter(w=>w.date!==today).slice(0,5)
    hist.innerHTML = past.map(w=>`<div class="wish-row"><span class="wish-d">${w.date}</span><span class="wish-t">"${escHtml(w.text)}"</span></div>`).join('') || '<div class="mc-empty">尚無願望紀錄</div>'
  }
}
document.getElementById('wish-form')?.addEventListener('submit', e => {
  e.preventDefault()
  const text = (document.getElementById('wish-input') as HTMLInputElement).value.trim()
  if (!text) return
  const today = new Date().toISOString().slice(0,10)
  let data = load()
  if (!data.wishes) data.wishes = []
  if (data.wishes.some((w: any) => w.date === today)) { showToast('今天已許過願望了 🕯️'); return }
  data.wishes.unshift({ date: today, text })
  data.wishes = data.wishes.slice(0,30)
  data.points += 3
  save(data)
  ;(document.getElementById('wish-input') as HTMLInputElement).value = ''
  updateTopbar(data)
  initWish(data)
  showToast('🕯️ 願望已發送 +3 pts')
})

// ── AI ASSISTANT ─────────────────────────────────────────────────
const AI_QUOTA_KEY = 'tb_ai_quota'
function getAIQuota() {
  const today = new Date().toISOString().slice(0,10)
  try {
    const raw = localStorage.getItem(AI_QUOTA_KEY)
    if (!raw) return 5
    const d = JSON.parse(raw)
    if (d.date !== today) return 5
    return Math.max(0, 5 - (d.used || 0))
  } catch { return 5 }
}
function useAIQuota() {
  const today = new Date().toISOString().slice(0,10)
  try {
    const raw = localStorage.getItem(AI_QUOTA_KEY)
    const d = raw ? JSON.parse(raw) : { date: today, used: 0 }
    if (d.date !== today) { localStorage.setItem(AI_QUOTA_KEY, JSON.stringify({ date: today, used: 1 })); return 4 }
    d.used = (d.used || 0) + 1
    localStorage.setItem(AI_QUOTA_KEY, JSON.stringify(d))
    return Math.max(0, 5 - d.used)
  } catch { return 5 }
}
function updateQuotaDisplay() {
  const el = document.getElementById('ai-quota')
  if (el) el.textContent = String(getAIQuota())
}

if (hasAI) {
  const aiForm = document.getElementById('ai-form')
  const aiInput = document.getElementById('ai-input') as HTMLInputElement

  aiForm?.addEventListener('submit', async e => {
    e.preventDefault()
    const q = aiInput.value.trim()
    if (!q) return
    if (getAIQuota() <= 0) { showToast('今日 AI 使用額度已達上限（5次/天）'); return }
    aiInput.value = ''
    appendAIMsg('user', q)
    const loadEl = appendAIMsg('ai', '⏳ 分析中…')
    const remaining = useAIQuota()
    updateQuotaDisplay()
    try {
      const r = await fetch('/api/ai-prophecy', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ question: q }) })
      const d = await r.json()
      if (loadEl) loadEl.querySelector('.ai-bubble')!.textContent = d.answer || '無法獲得回應'
    } catch {
      if (loadEl) loadEl.querySelector('.ai-bubble')!.textContent = '連線失敗，請稍後再試'
    }
    if (remaining === 0) showToast('今日 AI 額度已用完，明日再來 🤖')
  })
}
window.aiQuick = function(btn: HTMLElement) {
  const inp = document.getElementById('ai-input') as HTMLInputElement
  if (inp) { inp.value = btn.textContent || ''; document.getElementById('ai-form')?.dispatchEvent(new Event('submit')) }
}
function appendAIMsg(role: string, text: string) {
  const msgs = document.getElementById('ai-messages')
  if (!msgs) return null
  const div = document.createElement('div')
  div.className = `ai-msg ${role}`
  div.innerHTML = `<div class="ai-bubble">${escHtml(text)}</div>`
  msgs.appendChild(div)
  msgs.scrollTop = msgs.scrollHeight
  return div
}

// ── TOAST ─────────────────────────────────────────────────────────
function showToast(msg: string) {
  const t = document.getElementById('bonus-toast')
  const m = document.getElementById('bonus-msg')
  if (!t||!m) return
  m.textContent = msg
  t.style.display = 'flex'
  setTimeout(() => { t.style.display = 'none' }, 4000)
}

// ── TAB SWITCHING ─────────────────────────────────────────────────
document.querySelectorAll('.mc-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.mc-tab').forEach(b=>b.classList.remove('active'))
    document.querySelectorAll('.mc-panel').forEach(p=>p.classList.remove('active'))
    btn.classList.add('active')
    document.getElementById(`tab-${(btn as HTMLElement).dataset.tab}`)?.classList.add('active')
  })
})

// ── TERMINAL ANIMATION (GUEST) ───────────────────────────────────
;(function initTerminal() {
  const tb = document.getElementById('term-body')
  if (!tb) return
  const lines = [
    '> CONNECTING TO BUNKER_OS…',
    '> SCANNING IDENTITY CREDENTIALS…',
    '> [ERROR] BUNKER PASS NOT FOUND',
    '> CLEARANCE LEVEL: ████████ DENIED',
    '> REASON: 未建立避難所通行證',
    '> ─────────────────────────────',
    '> ACTION REQUIRED: 建立你的通行證以進入',
    '> INITIATING REGISTRATION PROTOCOL…█',
  ]
  let lineIdx = 0, charIdx = 0, text = ''
  function tick() {
    if (lineIdx >= lines.length) return
    const line = lines[lineIdx]
    if (charIdx < line.length) {
      text += line[charIdx++]
      tb.innerHTML = text.replace(/\n/g,'<br/>') + '<span class="term-cursor">█</span>'
    } else {
      text += '\n'; lineIdx++; charIdx = 0
      setTimeout(tick, 250)
      return
    }
    setTimeout(tick, charIdx < 3 ? 60 : 18)
  }
  setTimeout(tick, 600)
})()

// ── DATA EXPORT ───────────────────────────────────────────────────
window.exportData = function() {
  const data = load()
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' })
  const a = document.createElement('a')
  a.href = URL.createObjectURL(blob)
  a.download = `twobears-data-${new Date().toISOString().slice(0,10)}.json`
  a.click()
}

// ── INIT ──────────────────────────────────────────────────────────
;(function init() {
  let data = load()
  const { data: nd, bonus } = checkLogin(data)
  if (bonus) {
    data = nd
    save(data)
    let msg = `🎉 今日登入 +${bonus} pts！`
    if (nd.streak >= 100 && bonus > 100) msg += '  👑 達成百日鐵粉！'
    else if (nd.streak >= 30 && bonus > 30) msg += '  🥈 達成月度使徒！'
    else if (nd.streak >= 7 && bonus > 10) msg += `  🌟 連續 ${nd.streak} 天！`
    showToast(msg)
  }
  updateTopbar(data)
  initWish(data)
  updateQuotaDisplay()
})()
</script>

