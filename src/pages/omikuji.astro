---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '命運籤 ｜ 兩隻熊異象觀測站';
const description = '賽博神社御神籤，連接宇宙頻率，抽取今日命運。';
---

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
  <style is:global>
    .omi-page {
      background: #020a14;
      min-height: 100vh;
      color: #e2e8f0;
      font-family: 'Noto Sans TC', sans-serif;
    }

    /* Grid background */
    .omi-grid-bg {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,245,255,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,245,255,.04) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      animation: omiGridMove 5s linear infinite;
    }
    .omi-grid-vignette {
      position: fixed;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(ellipse 80% 80% at 50% 40%, transparent 25%, #020a14 100%);
    }

    /* Keyframes */
    @keyframes omiGridMove {
      0%   { background-position: 0 0; }
      100% { background-position: 60px 60px; }
    }
    @keyframes omiShake {
      0%,100% { transform: translateX(0) rotate(0deg); }
      10%      { transform: translateX(-10px) rotate(-4deg); }
      20%      { transform: translateX(10px)  rotate(4deg); }
      30%      { transform: translateX(-12px) rotate(-3deg); }
      40%      { transform: translateX(12px)  rotate(3deg); }
      50%      { transform: translateX(-7px)  rotate(-2deg); }
      60%      { transform: translateX(7px)   rotate(2deg); }
      70%      { transform: translateX(-4px)  rotate(-1deg); }
      80%      { transform: translateX(4px)   rotate(1deg); }
    }
    @keyframes omiFloat {
      0%,100% { transform: translateY(0px); }
      50%      { transform: translateY(-14px); }
    }
    @keyframes omiReveal {
      0%   { opacity: 0; transform: scale(0.5) rotateY(90deg); }
      65%  { transform: scale(1.04) rotateY(-4deg); }
      100% { opacity: 1; transform: scale(1) rotateY(0deg); }
    }
    @keyframes omiScan {
      0%   { top: -2px; }
      100% { top: 100%; }
    }
    @keyframes omiGlow {
      0%,100% { opacity: 0.6; }
      50%      { opacity: 1; }
    }

    .omi-shake  { animation: omiShake 0.45s ease-in-out infinite; }
    .omi-float  { animation: omiFloat 3s ease-in-out infinite; }
    .omi-reveal { animation: omiReveal 0.75s cubic-bezier(0.34,1.56,0.64,1) forwards; }
    .omi-glow   { animation: omiGlow 2s ease-in-out infinite; }

    /* Layout */
    .omi-wrap {
      position: relative;
      z-index: 10;
      max-width: 560px;
      margin: 0 auto;
      padding: 3rem 1.25rem 4rem;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Header */
    .omi-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .omi-eyebrow {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: .75rem;
      font-size: .7rem;
      letter-spacing: .3em;
      text-transform: uppercase;
      color: #00f5ff;
      margin-bottom: .75rem;
    }
    .omi-eyebrow::before,
    .omi-eyebrow::after {
      content: '';
      display: inline-block;
      width: 2.5rem;
      height: 1px;
      background: rgba(0,245,255,.4);
    }
    .omi-title {
      font-size: 3rem;
      font-weight: 900;
      letter-spacing: .15em;
      margin: 0 0 .4rem;
      background: linear-gradient(135deg, #fff 0%, #00f5ff 50%, #a78bfa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .omi-subtitle {
      font-size: .7rem;
      letter-spacing: .25em;
      color: #475569;
    }

    /* Main area */
    .omi-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
    }

    /* Torii */
    .omi-torii {
      font-size: 4rem;
      opacity: .35;
      filter: drop-shadow(0 0 12px rgba(251,146,60,.6));
    }

    /* Bear */
    .omi-bear-img {
      width: 11rem;
      height: 11rem;
      object-fit: contain;
    }
    .omi-bear-idle   { filter: drop-shadow(0 0 16px rgba(0,245,255,.35)); }
    .omi-bear-result { filter: drop-shadow(0 0 12px var(--fortune-glow)); }

    /* Idle text */
    .omi-idle-desc   { text-align: center; color: #94a3b8; font-size: .875rem; }
    .omi-idle-hint   { text-align: center; color: rgba(0,245,255,.6); font-size: .7rem; letter-spacing: .2em; margin-top: .25rem; }

    /* Draw button */
    .omi-btn-draw {
      position: relative;
      padding: 1rem 3rem;
      border-radius: .75rem;
      font-weight: 900;
      font-size: 1.05rem;
      letter-spacing: .15em;
      cursor: pointer;
      transition: transform .25s, box-shadow .25s;
      border: 1.5px solid rgba(0,245,255,.4);
      background: linear-gradient(135deg, rgba(0,245,255,.08), rgba(167,139,250,.08));
      box-shadow: 0 0 24px rgba(0,245,255,.15), inset 0 0 20px rgba(0,245,255,.04);
      color: #e2e8f0;
    }
    .omi-btn-draw:hover  { transform: scale(1.04); box-shadow: 0 0 32px rgba(0,245,255,.28); }
    .omi-btn-draw:active { transform: scale(.96); }
    .omi-btn-draw span {
      background: linear-gradient(135deg, #00f5ff, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .omi-idle-note { color: #334155; font-size: .7rem; }

    /* Shaking progress */
    .omi-shake-label { color: #94a3b8; font-size: .8rem; letter-spacing: .25em; }
    .omi-progress-track {
      width: 12rem;
      height: 5px;
      border-radius: 9999px;
      background: #1e293b;
      overflow: hidden;
    }
    .omi-progress-fill {
      height: 100%;
      border-radius: 9999px;
      background: linear-gradient(90deg, #00f5ff, #a78bfa);
      box-shadow: 0 0 8px #00f5ff;
      transition: width .15s;
    }
    .omi-dots {
      display: flex;
      gap: .5rem;
    }
    .omi-dot {
      width: 6px;
      height: 6px;
      border-radius: 9999px;
      background: rgba(0,245,255,.15);
      transition: background .15s, box-shadow .15s;
    }
    .omi-dot.on {
      background: #00f5ff;
      box-shadow: 0 0 6px #00f5ff;
    }
    .omi-scan-label { color: rgba(0,245,255,.45); font-size: .65rem; letter-spacing: .3em; }

    /* Fortune Slip */
    .omi-slip {
      width: 100%;
      border-radius: 1rem;
      overflow: hidden;
      position: relative;
      border: 1px solid var(--fortune-border);
      box-shadow: 0 0 40px var(--fortune-glow), 0 0 0 1px var(--fortune-border);
    }
    .omi-slip-scan {
      position: absolute;
      left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--fortune-color), transparent);
      animation: omiScan 3s linear infinite;
      opacity: .4;
      pointer-events: none;
    }
    .omi-slip-bar {
      padding: .6rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: .7rem;
      letter-spacing: .25em;
      text-transform: uppercase;
      background: var(--fortune-bar-bg);
      border-bottom: 1px solid var(--fortune-border);
    }
    .omi-slip-bar-label { color: var(--fortune-color); }
    .omi-slip-bar-date  { color: #475569; letter-spacing: .05em; }

    .omi-slip-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }

    /* Fortune top row */
    .omi-top-row { display: flex; align-items: center; gap: 1rem; }
    .omi-badge {
      flex-shrink: 0;
      width: 5rem; height: 5rem;
      border-radius: .75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--fortune-badge-bg);
      border: 2px solid var(--fortune-border);
      box-shadow: 0 0 16px var(--fortune-glow);
    }
    .omi-badge-type {
      font-size: 1.75rem;
      font-weight: 900;
      color: var(--fortune-color);
    }
    .omi-badge-rank { font-size: .65rem; color: #475569; text-align: center; margin-top: .25rem; }

    .omi-tagline-wrap { flex: 1; min-width: 0; }
    .omi-tagline {
      font-size: .65rem;
      letter-spacing: .2em;
      color: var(--fortune-color);
      margin-bottom: .5rem;
    }
    .omi-poem {
      font-size: .8rem;
      color: #cbd5e1;
      line-height: 1.6;
      font-style: italic;
      padding-left: .75rem;
      border-left: 2px solid var(--fortune-border);
    }

    .omi-bear-cell { flex-shrink: 0; text-align: center; }
    .omi-bear-cell-img { width: 5rem; height: 5rem; object-fit: contain; }
    .omi-bear-cell-label { font-size: .6rem; color: #475569; margin-top: .2rem; }

    /* Predictions grid */
    .omi-pred-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
    .omi-pred-card {
      border-radius: .6rem;
      padding: .75rem;
      background: rgba(255,255,255,.025);
      border: 1px solid rgba(255,255,255,.07);
    }
    .omi-pred-label {
      font-size: .65rem;
      font-weight: 700;
      color: var(--fortune-color);
      margin-bottom: .4rem;
    }
    .omi-pred-text { font-size: .7rem; color: #64748b; line-height: 1.6; }

    /* Lucky stats */
    .omi-lucky-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: .5rem; }
    .omi-lucky-card {
      text-align: center;
      border-radius: .5rem;
      padding: .5rem .25rem;
      background: var(--fortune-lucky-bg);
      border: 1px solid var(--fortune-lucky-border);
    }
    .omi-lucky-label { font-size: .6rem; color: #475569; margin-bottom: .2rem; }
    .omi-lucky-val   { font-size: .8rem; font-weight: 700; color: var(--fortune-color); }

    /* Advice */
    .omi-advice {
      border-radius: .6rem;
      padding: .75rem 1rem;
      font-size: .8rem;
      line-height: 1.65;
      color: #94a3b8;
      background: var(--fortune-advice-bg);
      border: 1px solid var(--fortune-advice-border);
    }

    /* Action buttons */
    .omi-actions { display: flex; gap: .75rem; width: 100%; }
    .omi-btn-share {
      flex: 1;
      padding: .875rem;
      border-radius: .75rem;
      font-weight: 900;
      font-size: .875rem;
      letter-spacing: .1em;
      cursor: pointer;
      border: none;
      transition: opacity .2s, transform .15s;
      background: linear-gradient(135deg, #00f5ff, #a78bfa);
      color: #020a14;
      box-shadow: 0 0 20px rgba(0,245,255,.25);
    }
    .omi-btn-share:hover  { opacity: .9; }
    .omi-btn-share:active { transform: scale(.96); }
    .omi-btn-reset {
      padding: .875rem 1.5rem;
      border-radius: .75rem;
      font-weight: 700;
      font-size: .875rem;
      letter-spacing: .05em;
      cursor: pointer;
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.1);
      color: #64748b;
      transition: border-color .2s, transform .15s;
    }
    .omi-btn-reset:hover  { border-color: rgba(0,245,255,.35); }
    .omi-btn-reset:active { transform: scale(.96); }

    /* History */
    .omi-history {
      width: 100%;
      max-width: 560px;
      margin: 2.5rem auto 0;
      padding: 0 1.25rem;
    }
    .omi-history-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
      cursor: pointer;
      user-select: none;
    }
    .omi-history-title {
      font-size: .7rem;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: #475569;
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .omi-history-title::before {
      content: '';
      display: inline-block;
      width: 1.5rem;
      height: 1px;
      background: #334155;
    }
    .omi-history-toggle {
      font-size: .65rem;
      color: #334155;
      transition: color .2s;
    }
    .omi-history-header:hover .omi-history-toggle { color: #64748b; }
    .omi-history-list {
      display: flex;
      flex-direction: column;
      gap: .5rem;
    }
    .omi-history-item {
      display: flex;
      align-items: center;
      gap: .75rem;
      padding: .6rem .875rem;
      border-radius: .6rem;
      background: rgba(255,255,255,.02);
      border: 1px solid rgba(255,255,255,.05);
      transition: border-color .2s;
    }
    .omi-history-item:hover { border-color: rgba(255,255,255,.1); }
    .omi-history-badge {
      font-size: .9rem;
      font-weight: 900;
      min-width: 2rem;
      text-align: center;
    }
    .omi-history-info { flex: 1; min-width: 0; }
    .omi-history-poem {
      font-size: .7rem;
      color: #475569;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .omi-history-date { font-size: .6rem; color: #334155; margin-top: .15rem; }
    .omi-history-empty { text-align: center; color: #334155; font-size: .75rem; padding: 1.5rem 0; }
    .omi-history-clear {
      font-size: .6rem;
      color: #334155;
      background: none;
      border: none;
      cursor: pointer;
      padding: .2rem .5rem;
      border-radius: .3rem;
      transition: color .2s;
    }
    .omi-history-clear:hover { color: #ef4444; }

    /* Footer */
    .omi-footer { text-align: center; padding-top: 2rem; font-size: .65rem; color: #1e293b; }

    @media (max-width: 400px) {
      .omi-pred-grid { grid-template-columns: 1fr; }
      .omi-top-row { flex-wrap: wrap; }
    }
  </style>
</head>

<body class="omi-page">
  <div class="omi-grid-bg"></div>
  <div class="omi-grid-vignette"></div>

  <Header />

  <div class="omi-wrap">
    <!-- Header -->
    <header class="omi-header">
      <div class="omi-eyebrow">兩隻熊異象觀測站</div>
      <h1 class="omi-title">命運籤</h1>
      <p class="omi-subtitle">CYBER ORACLE · 数字御神籤</p>
    </header>

    <!-- Dynamic area -->
    <main class="omi-main" id="omi-main">

      <!-- IDLE -->
      <div id="state-idle">
        <div class="omi-torii" style="text-align:center">⛩</div>
        <div style="text-align:center">
          <div class="omi-float">
            <img src="/omikuji-idle.png" alt="守護熊" class="omi-bear-img omi-bear-idle" />
          </div>
        </div>
        <div>
          <p class="omi-idle-desc">歡迎來到賽博神社</p>
          <p class="omi-idle-hint">搖動裝置或點擊按鈕，抽取今日命運</p>
        </div>
        <button class="omi-btn-draw" id="btn-draw">
          <span>🎋 抽取命運</span>
        </button>
        <p class="omi-idle-note">每日一籤，問卜宇宙頻率</p>
      </div>

      <!-- SHAKING (hidden initially) -->
      <div id="state-shaking" style="display:none; flex-direction:column; align-items:center; gap:1.5rem; width:100%">
        <p class="omi-shake-label" id="shake-label" style="animation: pulse 1s infinite">正在連接宇宙頻率...</p>
        <div class="omi-shake" style="text-align:center">
          <img src="/omikuji-idle.png" alt="抽籤中" class="omi-bear-img omi-bear-idle" />
        </div>
        <div class="omi-progress-track">
          <div class="omi-progress-fill" id="omi-progress" style="width:0%"></div>
        </div>
        <div class="omi-dots" id="omi-dots">
          <div class="omi-dot" data-i="0"></div>
          <div class="omi-dot" data-i="1"></div>
          <div class="omi-dot" data-i="2"></div>
          <div class="omi-dot" data-i="3"></div>
          <div class="omi-dot" data-i="4"></div>
          <div class="omi-dot" data-i="5"></div>
          <div class="omi-dot" data-i="6"></div>
          <div class="omi-dot" data-i="7"></div>
          <div class="omi-dot" data-i="8"></div>
          <div class="omi-dot" data-i="9"></div>
        </div>
        <p class="omi-scan-label">SCANNING · SIGNAL · LOCK</p>
      </div>

      <!-- RESULT (hidden initially) -->
      <div id="state-result" style="display:none; flex-direction:column; gap:1rem; width:100%">
        <div class="omi-slip omi-reveal" id="omi-slip">
          <div class="omi-slip-scan"></div>
          <div class="omi-slip-bar">
            <span class="omi-slip-bar-label">ORACLE · RESULT</span>
            <span class="omi-slip-bar-date" id="slip-date"></span>
          </div>
          <div class="omi-slip-body">
            <!-- Top row: badge + tagline + bear -->
            <div class="omi-top-row">
              <div>
                <div class="omi-badge omi-glow" id="slip-badge">
                  <span class="omi-badge-type" id="slip-type"></span>
                </div>
                <div class="omi-badge-rank" id="slip-rank"></div>
              </div>
              <div class="omi-tagline-wrap">
                <div class="omi-tagline" id="slip-tagline"></div>
                <div class="omi-poem" id="slip-poem"></div>
              </div>
              <div class="omi-bear-cell">
                <img id="slip-bear-img" src="" alt="" class="omi-bear-cell-img omi-bear-result" />
                <div class="omi-bear-cell-label" id="slip-bear-label"></div>
              </div>
            </div>

            <!-- Predictions -->
            <div class="omi-pred-grid">
              <div class="omi-pred-card">
                <div class="omi-pred-label">📊 總體運勢</div>
                <div class="omi-pred-text" id="pred-overall"></div>
              </div>
              <div class="omi-pred-card">
                <div class="omi-pred-label">💰 財運</div>
                <div class="omi-pred-text" id="pred-wealth"></div>
              </div>
              <div class="omi-pred-card">
                <div class="omi-pred-label">💫 感情運</div>
                <div class="omi-pred-text" id="pred-love"></div>
              </div>
              <div class="omi-pred-card">
                <div class="omi-pred-label">⚡ 行動指令</div>
                <div class="omi-pred-text" id="pred-action"></div>
              </div>
            </div>

            <!-- Lucky stats -->
            <div class="omi-lucky-row">
              <div class="omi-lucky-card">
                <div class="omi-lucky-label">幸運數字</div>
                <div class="omi-lucky-val" id="lucky-num"></div>
              </div>
              <div class="omi-lucky-card">
                <div class="omi-lucky-label">幸運方位</div>
                <div class="omi-lucky-val" id="lucky-dir"></div>
              </div>
              <div class="omi-lucky-card">
                <div class="omi-lucky-label">幸運色</div>
                <div class="omi-lucky-val" id="lucky-color"></div>
              </div>
            </div>

            <!-- Advice -->
            <div class="omi-advice" id="slip-advice"></div>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="omi-actions">
          <button class="omi-btn-share" id="btn-share">分享命運 →</button>
          <button class="omi-btn-reset" id="btn-reset">再抽一次</button>
        </div>
      </div>

    </main>

    <footer class="omi-footer">兩隻熊異象觀測站 · 命運籤僅供娛樂，不構成任何建議</footer>
  </div>

  <!-- History (outside omi-wrap to use full relative z-index) -->
  <div class="omi-history" id="omi-history-section">
    <div class="omi-history-header" id="history-toggle-btn">
      <div class="omi-history-title">籤詩紀錄</div>
      <div style="display:flex;align-items:center;gap:.75rem">
        <button class="omi-history-clear" id="history-clear-btn">清除</button>
        <span class="omi-history-toggle" id="history-arrow">▼</span>
      </div>
    </div>
    <div id="history-list-wrap">
      <div class="omi-history-list" id="omi-history-list"></div>
    </div>
  </div>

  <Footer />
</body>
</html>

<script>
const FORTUNES = [
  {
    type: '大吉', rank: 1, rankLabel: '最高吉兆',
    color: '#f59e0b', glow: 'rgba(245,158,11,0.45)', badgeBg: 'rgba(245,158,11,0.15)',
    border: 'rgba(245,158,11,0.45)', barBg: 'rgba(245,158,11,0.1)',
    luckyBg: 'rgba(245,158,11,0.08)', luckyBorder: 'rgba(245,158,11,0.22)',
    adviceBg: 'rgba(245,158,11,0.06)', adviceBorder: 'rgba(245,158,11,0.18)',
    gradient: 'linear-gradient(135deg, rgba(245,158,11,0.08) 0%, rgba(0,245,255,0.04) 100%)',
    bearImage: '/omikuji-daiki.png', bearLabel: 'Great!',
    tagline: '異象確認 · 時機已至',
    poem: '量子漣漪匯聚核心，觀測者的眼睛已然睜開。',
    overall: '宇宙訊號強烈共振，今日的你站在命運的節點上。大膽行動，天時地利皆在你掌中，不容錯過。',
