  if (wrap) wrap.style.display = historyOpen ? 'block' : 'none';
  if (arrow) arrow.textContent = historyOpen ? '▼' : '▶';
});

document.getElementById('history-clear-btn')?.addEventListener('click', (e) => {
  e.stopPropagation();
  if (confirm('確定清除所有訊號紀錄？')) {
    localStorage.removeItem(HISTORY_KEY);
    renderHistory();
    renderStreak();
  }
});

// Device shake
let lastX = 0, lastY = 0, lastZ = 0;
window.addEventListener('devicemotion', (e) => {
  const acc = e.accelerationIncludingGravity;
  if (!acc) return;
  const x = acc.x || 0, y = acc.y || 0, z = acc.z || 0;
  const delta = Math.abs(x - lastX) + Math.abs(y - lastY) + Math.abs(z - lastZ);
  lastX = x; lastY = y; lastZ = z;
  const now = Date.now();
  if (delta > 15 && now - lastShakeTime > 1200) {
    lastShakeTime = now;
    const stateIdle = document.getElementById('state-idle');
    if (stateIdle && stateIdle.style.display !== 'none') triggerDraw();
  }
});

// ── Init ──────────────────────────────────────────────────────────────────────
fetchAndShowTickers();
renderHistory();
renderStreak();
</script>
