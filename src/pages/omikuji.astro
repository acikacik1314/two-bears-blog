---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '每日訊號 ｜ 兩隻熊未來人觀測站';
const description = '未來人訊號卡：結合真實市場異象，為你解讀今日時間線。';
---

<style is:global>
  .omi-page {
    background: #020a14;
    min-height: 100vh;
    color: #e2e8f0;
    font-family: 'Noto Sans TC', sans-serif;
  }

  .omi-grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,245,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,245,255,.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    animation: omiGridMove 5s linear infinite;
  }
  .omi-grid-vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 80% 80% at 50% 40%, transparent 25%, #020a14 100%);
  }

  @keyframes omiGridMove {
    0%   { background-position: 0 0; }
    100% { background-position: 60px 60px; }
  }
  @keyframes omiShake {
    0%,100% { transform: translateX(0) rotate(0deg); }
    10%     { transform: translateX(-10px) rotate(-4deg); }
    20%     { transform: translateX(10px) rotate(4deg); }
    30%     { transform: translateX(-12px) rotate(-3deg); }
    40%     { transform: translateX(12px) rotate(3deg); }
    50%     { transform: translateX(-7px) rotate(-2deg); }
    60%     { transform: translateX(7px) rotate(2deg); }
    70%     { transform: translateX(-4px) rotate(-1deg); }
    80%     { transform: translateX(4px) rotate(1deg); }
  }
  @keyframes omiFloat {
    0%,100% { transform: translateY(0px); }
    50%     { transform: translateY(-14px); }
  }
  @keyframes omiReveal {
    0%   { opacity: 0; transform: scale(0.5) rotateY(90deg); }
    65%  { transform: scale(1.04) rotateY(-4deg); }
    100% { opacity: 1; transform: scale(1) rotateY(0deg); }
  }
  @keyframes omiScan {
    0%   { top: -2px; }
    100% { top: 100%; }
  }
  @keyframes omiGlow {
    0%,100% { opacity: 0.6; }
    50%     { opacity: 1; }
  }
  @keyframes omiFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .omi-shake  { animation: omiShake 0.45s ease-in-out infinite; }
  .omi-float  { animation: omiFloat 3s ease-in-out infinite; }
  .omi-reveal { animation: omiReveal 0.75s cubic-bezier(0.34,1.56,0.64,1) forwards; }
  .omi-glow   { animation: omiGlow 2s ease-in-out infinite; }

  .omi-wrap {
    position: relative;
    z-index: 10;
    max-width: 560px;
    margin: 0 auto;
    padding: 3rem 1.25rem 4rem;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Warning block ── */
  .omi-warning {
    margin-bottom: 1.75rem;
    border-radius: .75rem;
    border: 1px solid rgba(239,68,68,.2);
    background: rgba(239,68,68,.04);
    padding: .875rem 1rem;
    animation: omiFadeIn .6s ease both;
  }
  .omi-warning-title {
    font-size: .65rem;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: rgba(239,68,68,.7);
    margin-bottom: .6rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .omi-warning-title::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: rgba(239,68,68,.3);
  }
  .omi-warning-grid {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem .75rem;
  }
  .omi-ticker-chip {
    font-size: .7rem;
    color: #64748b;
    display: flex;
    align-items: center;
    gap: .3rem;
  }
  .omi-ticker-chip .val { color: #94a3b8; }
  .omi-ticker-chip .up  { color: #34d399; }
  .omi-ticker-chip .dn  { color: #f87171; }
  .omi-warning-loading { font-size: .7rem; color: #334155; }

  /* ── Streak badge ── */
  .omi-streak {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    margin-bottom: 1.25rem;
    animation: omiFadeIn .7s .1s ease both;
    opacity: 0;
  }
  .omi-streak-badge {
    font-size: .65rem;
    letter-spacing: .15em;
    color: #475569;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 9999px;
    padding: .2rem .75rem;
    display: flex;
    align-items: center;
    gap: .4rem;
  }
  .omi-streak-badge.active {
    border-color: rgba(251,191,36,.35);
    color: #fbbf24;
    background: rgba(251,191,36,.05);
  }
  .omi-streak-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #1e293b;
    display: inline-block;
  }
  .omi-streak-dot.lit { background: #fbbf24; box-shadow: 0 0 4px #fbbf24; }
  .omi-streak-unlock {
    font-size: .65rem;
    color: rgba(251,191,36,.7);
    letter-spacing: .1em;
  }

  /* ── Header ── */
  .omi-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .omi-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    font-size: .7rem;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: #00f5ff;
    margin-bottom: .75rem;
  }
  .omi-eyebrow::before,
  .omi-eyebrow::after {
    content: '';
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background: rgba(0,245,255,.4);
  }
  .omi-title {
    font-size: 2.75rem;
    font-weight: 900;
    letter-spacing: .1em;
    margin: 0 0 .4rem;
    background: linear-gradient(135deg, #fff 0%, #00f5ff 50%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .omi-subtitle {
    font-size: .7rem;
    letter-spacing: .25em;
    color: #475569;
  }

  /* ── Main area ── */
  .omi-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .omi-torii {
    font-size: 4rem;
    opacity: .35;
    filter: drop-shadow(0 0 12px rgba(251,146,60,.6));
  }

  .omi-bear-img {
    width: 11rem;
    height: 11rem;
    object-fit: contain;
  }
  .omi-bear-idle   { filter: drop-shadow(0 0 16px rgba(0,245,255,.35)); }
  .omi-bear-result { filter: drop-shadow(0 0 12px var(--fortune-glow)); }

  .omi-idle-desc { text-align: center; color: #94a3b8; font-size: .875rem; }
  .omi-idle-hint { text-align: center; color: rgba(0,245,255,.6); font-size: .7rem; letter-spacing: .2em; margin-top: .25rem; }

  .omi-btn-draw {
    position: relative;
    padding: 1rem 3rem;
    border-radius: .75rem;
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: .15em;
    cursor: pointer;
    transition: transform .25s, box-shadow .25s;
    border: 1.5px solid rgba(0,245,255,.4);
    background: linear-gradient(135deg, rgba(0,245,255,.08), rgba(167,139,250,.08));
    box-shadow: 0 0 24px rgba(0,245,255,.15), inset 0 0 20px rgba(0,245,255,.04);
    color: #e2e8f0;
  }
  .omi-btn-draw:hover  { transform: scale(1.04); box-shadow: 0 0 32px rgba(0,245,255,.28); }
  .omi-btn-draw:active { transform: scale(.96); }
  .omi-btn-draw span {
    background: linear-gradient(135deg, #00f5ff, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .omi-btn-draw:disabled {
    opacity: .5;
    cursor: not-allowed;
    transform: none;
  }

  .omi-idle-note { color: #334155; font-size: .7rem; }

  /* ── Shaking state ── */
  .omi-shake-label { color: #94a3b8; font-size: .8rem; letter-spacing: .25em; }
  .omi-progress-track {
    width: 12rem;
    height: 5px;
    border-radius: 9999px;
    background: #1e293b;
    overflow: hidden;
  }
  .omi-progress-fill {
    height: 100%;
    border-radius: 9999px;
    background: linear-gradient(90deg, #00f5ff, #a78bfa);
    box-shadow: 0 0 8px #00f5ff;
    transition: width .15s;
  }
  .omi-dots { display: flex; gap: .5rem; }
  .omi-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: rgba(0,245,255,.15);
    transition: background .15s, box-shadow .15s;
  }
  .omi-dot.on { background: #00f5ff; box-shadow: 0 0 6px #00f5ff; }
  .omi-scan-label { color: rgba(0,245,255,.45); font-size: .65rem; letter-spacing: .3em; }

  /* ── Fortune Slip ── */
  .omi-slip {
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    position: relative;
    border: 1px solid var(--fortune-border);
    box-shadow: 0 0 40px var(--fortune-glow), 0 0 0 1px var(--fortune-border);
  }
  .omi-slip-scan {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--fortune-color), transparent);
    animation: omiScan 3s linear infinite;
    opacity: .4;
    pointer-events: none;
  }
  .omi-slip-bar {
    padding: .6rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: .7rem;
    letter-spacing: .25em;
    text-transform: uppercase;
    background: var(--fortune-bar-bg);
    border-bottom: 1px solid var(--fortune-border);
  }
  .omi-slip-bar-label { color: var(--fortune-color); }
  .omi-slip-bar-date  { color: #475569; letter-spacing: .05em; }

  .omi-slip-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }

  .omi-top-row { display: flex; align-items: center; gap: 1rem; }
  .omi-badge {
    flex-shrink: 0;
    width: 5rem; height: 5rem;
    border-radius: .75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--fortune-badge-bg);
    border: 2px solid var(--fortune-border);
    box-shadow: 0 0 16px var(--fortune-glow);
  }
  .omi-badge-type  { font-size: 1.5rem; font-weight: 900; color: var(--fortune-color); }
  .omi-badge-rank  { font-size: .6rem; color: #475569; text-align: center; margin-top: .2rem; }

  .omi-tagline-wrap { flex: 1; min-width: 0; }
  .omi-tagline {
    font-size: .65rem;
    letter-spacing: .2em;
    color: var(--fortune-color);
    margin-bottom: .5rem;
  }
  .omi-poem {
    font-size: .8rem;
    color: #cbd5e1;
    line-height: 1.6;
    font-style: italic;
    padding-left: .75rem;
    border-left: 2px solid var(--fortune-border);
  }

  .omi-bear-cell { flex-shrink: 0; text-align: center; }
  .omi-bear-cell-img { width: 5rem; height: 5rem; object-fit: contain; }
  .omi-bear-cell-label { font-size: .6rem; color: #475569; margin-top: .2rem; }

  /* AI content area */
  .omi-ai-content {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .omi-ai-section {
    border-radius: .6rem;
    padding: .75rem 1rem;
    background: rgba(255,255,255,.02);
    border: 1px solid rgba(255,255,255,.06);
  }
  .omi-ai-label {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--fortune-color);
    opacity: .8;
    margin-bottom: .4rem;
  }
  .omi-ai-text {
    font-size: .78rem;
    color: #94a3b8;
    line-height: 1.65;
  }

  /* Pred grid */
  .omi-pred-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
  .omi-pred-card {
    border-radius: .6rem;
    padding: .75rem;
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
  }
  .omi-pred-label {
    font-size: .65rem;
    font-weight: 700;
    color: var(--fortune-color);
    margin-bottom: .4rem;
  }
  .omi-pred-text { font-size: .72rem; color: #64748b; line-height: 1.6; }

  /* Lucky stats */
  .omi-lucky-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: .5rem; }
  .omi-lucky-card {
    text-align: center;
    border-radius: .5rem;
    padding: .5rem .25rem;
    background: var(--fortune-lucky-bg);
    border: 1px solid var(--fortune-lucky-border);
  }
  .omi-lucky-label { font-size: .6rem; color: #475569; margin-bottom: .2rem; }
  .omi-lucky-val   { font-size: .8rem; font-weight: 700; color: var(--fortune-color); }

  /* Advice */
  .omi-advice {
    border-radius: .6rem;
    padding: .75rem 1rem;
    font-size: .8rem;
    line-height: 1.65;
    color: #94a3b8;
    background: var(--fortune-advice-bg);
    border: 1px solid var(--fortune-advice-border);
  }

  /* Action buttons */
  .omi-actions { display: flex; gap: .75rem; width: 100%; }
  .omi-btn-share {
    flex: 1;
    padding: .875rem;
    border-radius: .75rem;
    font-weight: 900;
    font-size: .875rem;
    letter-spacing: .1em;
    cursor: pointer;
    border: none;
    transition: opacity .2s, transform .15s;
    background: linear-gradient(135deg, #00f5ff, #a78bfa);
    color: #020a14;
    box-shadow: 0 0 20px rgba(0,245,255,.25);
  }
  .omi-btn-share:hover  { opacity: .9; }
  .omi-btn-share:active { transform: scale(.96); }
  .omi-btn-reset {
    padding: .875rem 1.5rem;
    border-radius: .75rem;
    font-weight: 700;
    font-size: .875rem;
    cursor: pointer;
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.1);
    color: #64748b;
    transition: border-color .2s, transform .15s;
  }
  .omi-btn-reset:hover  { border-color: rgba(0,245,255,.35); }
  .omi-btn-reset:active { transform: scale(.96); }

  /* CTA block */
  .omi-cta-block {
    width: 100%;
    margin-top: .5rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }
  .omi-cta-label {
    font-size: .6rem;
    letter-spacing: .2em;
    color: #334155;
    text-align: center;
    text-transform: uppercase;
  }
  .omi-cta-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .6rem;
  }
  .omi-cta-btn {
    display: block;
    padding: .75rem .5rem;
    border-radius: .6rem;
    text-align: center;
    text-decoration: none;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .05em;
    border: 1px solid transparent;
    transition: background .2s, border-color .2s;
    color: #94a3b8;
    background: rgba(255,255,255,.02);
    border-color: rgba(255,255,255,.07);
  }
  .omi-cta-btn:hover {
    background: rgba(255,255,255,.05);
    border-color: rgba(255,255,255,.13);
    color: #cbd5e1;
  }
  .omi-cta-btn .cta-icon { display: block; font-size: 1.25rem; margin-bottom: .25rem; }
  .omi-cta-btn .cta-sub  { font-size: .6rem; color: #475569; margin-top: .15rem; display: block; }

  /* History */
  .omi-history {
    width: 100%;
    max-width: 560px;
    margin: 2.5rem auto 0;
    padding: 0 1.25rem;
  }
  .omi-history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    cursor: pointer;
    user-select: none;
  }
  .omi-history-title {
    font-size: .7rem;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: #475569;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .omi-history-title::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: #334155;
  }
  .omi-history-toggle { font-size: .65rem; color: #334155; transition: color .2s; }
  .omi-history-header:hover .omi-history-toggle { color: #64748b; }
  .omi-history-list { display: flex; flex-direction: column; gap: .5rem; }
  .omi-history-item {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem .875rem;
    border-radius: .6rem;
    background: rgba(255,255,255,.02);
    border: 1px solid rgba(255,255,255,.05);
    transition: border-color .2s;
  }
  .omi-history-item:hover { border-color: rgba(255,255,255,.1); }
  .omi-history-badge { font-size: .9rem; font-weight: 900; min-width: 2.5rem; text-align: center; }
  .omi-history-info { flex: 1; min-width: 0; }
  .omi-history-poem {
    font-size: .7rem;
    color: #475569;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .omi-history-date { font-size: .6rem; color: #334155; margin-top: .15rem; }
  .omi-history-empty { text-align: center; color: #334155; font-size: .75rem; padding: 1.5rem 0; }
  .omi-history-clear {
    font-size: .6rem;
    color: #334155;
    background: none;
    border: none;
    cursor: pointer;
    padding: .2rem .5rem;
    border-radius: .3rem;
    transition: color .2s;
  }
  .omi-history-clear:hover { color: #ef4444; }

  .omi-footer { text-align: center; padding-top: 2rem; font-size: .65rem; color: #1e293b; }

  @media (max-width: 640px) {
    .omi-pred-grid { grid-template-columns: 1fr; }
    .omi-top-row   { flex-wrap: wrap; }
    .omi-cta-row   { grid-template-columns: 1fr; }
    .omi-idle-desc { font-size: 1rem; }
    .omi-shake-label { font-size: .9rem; }
    .omi-idle-hint { font-size: .8rem; }
    .omi-badge-type { font-size: 1.6rem; }
    .omi-badge-rank { font-size: .75rem; }
    .omi-idle-note  { font-size: .8rem; }
    .omi-footer     { font-size: .75rem; }
    .omi-slip-body  { padding: 1rem; }
  }
  @media (max-width: 400px) {
    .omi-pred-grid { grid-template-columns: 1fr; }
    .omi-top-row   { flex-wrap: wrap; }
    .omi-cta-row   { grid-template-columns: 1fr; }
  }
</style>

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
</head>

<body class="omi-page">
  <div class="omi-grid-bg"></div>
  <div class="omi-grid-vignette"></div>

  <Header />

  <div class="omi-wrap">
    <!-- Daily market warning block -->
    <div class="omi-warning" id="omi-warning">
      <div class="omi-warning-title">未來人今日警示</div>
      <div class="omi-warning-grid" id="warning-grid">
        <span class="omi-warning-loading">掃描市場訊號中…</span>
      </div>
    </div>

    <!-- Streak badge -->
    <div class="omi-streak" id="omi-streak">
      <div class="omi-streak-badge" id="streak-badge">
        <span id="streak-dots"></span>
        <span id="streak-text">連續抽籤紀錄</span>
      </div>
      <span class="omi-streak-unlock" id="streak-unlock" style="display:none">🔓 七日訊號解鎖！</span>
    </div>

    <!-- Page header -->
    <header class="omi-header">
      <div class="omi-eyebrow">兩隻熊未來人觀測站</div>
      <h1 class="omi-title">每日訊號</h1>
      <p class="omi-subtitle">FUTURE SIGNAL · 時間線直讀</p>
    </header>

    <!-- Dynamic area -->
    <main class="omi-main" id="omi-main">

      <!-- IDLE -->
      <div id="state-idle">
        <div class="omi-torii" style="text-align:center">⛩</div>
        <div style="text-align:center">
          <div class="omi-float">
            <img src="/omikuji-idle.png" alt="守護熊" class="omi-bear-img omi-bear-idle" />
          </div>
        </div>
        <div>
          <p class="omi-idle-desc">未來人正在這條時間線的另一端等你</p>
          <p class="omi-idle-hint">搖動裝置或點擊按鈕，抽取今日訊號</p>
        </div>
        <button class="omi-btn-draw" id="btn-draw">
          <span>📡 接收今日訊號</span>
        </button>
        <p class="omi-idle-note">每日一籤 · 結合真實市場異象</p>
      </div>

      <!-- SHAKING -->
      <div id="state-shaking" style="display:none; flex-direction:column; align-items:center; gap:1.5rem; width:100%">
        <p class="omi-shake-label" id="shake-label">掃描今日市場異象…</p>
        <div class="omi-shake" style="text-align:center">
          <img src="/omikuji-idle.png" alt="抽籤中" class="omi-bear-img omi-bear-idle" />
        </div>
        <div class="omi-progress-track">
          <div class="omi-progress-fill" id="omi-progress" style="width:0%"></div>
        </div>
        <div class="omi-dots" id="omi-dots">
          <div class="omi-dot" data-i="0"></div>
