function drawFortune() {
  const weights = [15, 35, 35, 15];
  let r = Math.random() * 100;
  for (let i = 0; i < weights.length; i++) {
    r -= weights[i];
    if (r <= 0) return FORTUNES[i];
  }
  return FORTUNES[1];
}

// ── History ──────────────────────────────────────────────────────────────────
const HISTORY_KEY = 'tb_omikuji_history';
const HISTORY_MAX = 50;

function loadHistory() {
  try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); }
  catch { return []; }
}

function saveToHistory(f) {
  const history = loadHistory();
  history.unshift({
    type: f.type,
    color: f.color,
    poem: f.poem,
    tagline: f.tagline,
    date: new Date().toLocaleString('zh-TW', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' }),
  });
  localStorage.setItem(HISTORY_KEY, JSON.stringify(history.slice(0, HISTORY_MAX)));
  renderHistory();
}

function renderHistory() {
  const list = document.getElementById('omi-history-list');
  if (!list) return;
  const history = loadHistory();
  if (history.length === 0) {
    list.innerHTML = '<div class="omi-history-empty">尚無紀錄，快去抽第一籤！</div>';
    return;
  }
  list.innerHTML = history.map(h => `
    <div class="omi-history-item">
      <div class="omi-history-badge" style="color:${h.color}">${h.type}</div>
      <div class="omi-history-info">
        <div class="omi-history-poem">${h.tagline} · 「${h.poem}」</div>
        <div class="omi-history-date">${h.date}</div>
      </div>
    </div>
  `).join('');
}

// ── State refs ──────────────────────────────────────────────────────────────
let currentFortune = null;
let isDrawing = false;
let lastShakeTime = 0;

function showState(name) {
  ['idle', 'shaking', 'result'].forEach(s => {
    const el = document.getElementById('state-' + s);
    if (el) el.style.display = (s === name) ? 'flex' : 'none';
  });
}

function applyFortuneVars(f) {
  const slip = document.getElementById('omi-slip');
  if (!slip) return;
  slip.style.setProperty('--fortune-color', f.color);
  slip.style.setProperty('--fortune-glow', f.glow);
  slip.style.setProperty('--fortune-border', f.border);
  slip.style.setProperty('--fortune-badge-bg', f.badgeBg);
  slip.style.setProperty('--fortune-bar-bg', f.barBg);
  slip.style.setProperty('--fortune-lucky-bg', f.luckyBg);
  slip.style.setProperty('--fortune-lucky-border', f.luckyBorder);
  slip.style.setProperty('--fortune-advice-bg', f.adviceBg);
  slip.style.setProperty('--fortune-advice-border', f.adviceBorder);
  slip.style.background = f.gradient;
}

function populateResult(f) {
  document.getElementById('slip-date').textContent = new Date().toLocaleDateString('zh-TW');
  document.getElementById('slip-type').textContent = f.type;
  document.getElementById('slip-rank').textContent = f.rankLabel;
  document.getElementById('slip-tagline').textContent = f.tagline;
  document.getElementById('slip-poem').textContent = '「' + f.poem + '」';
  document.getElementById('slip-bear-img').src = f.bearImage;
  document.getElementById('slip-bear-img').alt = f.type;
  document.getElementById('slip-bear-img').style.setProperty('--fortune-glow', f.glow);
  document.getElementById('slip-bear-label').textContent = f.bearLabel;
  document.getElementById('pred-overall').textContent = f.overall;
  document.getElementById('pred-wealth').textContent = f.wealth;
  document.getElementById('pred-love').textContent = f.love;
  document.getElementById('pred-action').textContent = f.action;
  document.getElementById('lucky-num').textContent = f.luckyNum;
  document.getElementById('lucky-dir').textContent = f.luckyDir;
  document.getElementById('lucky-color').textContent = f.luckyColor;
  document.getElementById('slip-advice').textContent = f.advice;
  applyFortuneVars(f);
}

function triggerDraw() {
  if (isDrawing) return;
  isDrawing = true;
  showState('shaking');

  const progressBar = document.getElementById('omi-progress');
  const dots = document.querySelectorAll('.omi-dot');
  let count = 0;
  const total = 10;

  const interval = setInterval(() => {
    count++;
    const pct = Math.round((count / total) * 100);
    if (progressBar) progressBar.style.width = pct + '%';
    dots.forEach((d, i) => {
      if (i < count) d.classList.add('on');
    });

    if (count >= total) {
      clearInterval(interval);
      const f = drawFortune();
      currentFortune = f;
      populateResult(f);
      saveToHistory(f);

      // Reset slip animation
      const slip = document.getElementById('omi-slip');
      if (slip) {
        slip.classList.remove('omi-reveal');
        void slip.offsetWidth; // reflow
        slip.classList.add('omi-reveal');
      }

      showState('result');
      isDrawing = false;
    }
  }, 120);
}

function resetDraw() {
  currentFortune = null;
  isDrawing = false;
  // Reset dots
  document.querySelectorAll('.omi-dot').forEach(d => d.classList.remove('on'));
  const pb = document.getElementById('omi-progress');
  if (pb) pb.style.width = '0%';
  showState('idle');
}

// Event listeners
document.getElementById('btn-draw')?.addEventListener('click', triggerDraw);
document.getElementById('btn-reset')?.addEventListener('click', resetDraw);
document.getElementById('btn-share')?.addEventListener('click', () => {
  if (!currentFortune) return;
  const text = `【兩隻熊命運籤】今日抽到「${currentFortune.type}」\n${currentFortune.tagline}\n「${currentFortune.poem}」\n\n🐻 twobears.vercel.app/omikuji`;
  if (navigator.share) {
    navigator.share({ title: '兩隻熊命運籤', text });
  } else {
    navigator.clipboard.writeText(text).then(() => alert('已複製到剪貼板！'));
  }
});

// History toggle & clear
let historyOpen = true;
document.getElementById('history-toggle-btn')?.addEventListener('click', () => {
  historyOpen = !historyOpen;
  const wrap = document.getElementById('history-list-wrap');
  const arrow = document.getElementById('history-arrow');
  if (wrap) wrap.style.display = historyOpen ? 'block' : 'none';
  if (arrow) arrow.textContent = historyOpen ? '▼' : '▶';
});
document.getElementById('history-clear-btn')?.addEventListener('click', (e) => {
  e.stopPropagation();
  if (confirm('確定清除所有籤詩紀錄？')) {
    localStorage.removeItem(HISTORY_KEY);
    renderHistory();
  }
});

// Init history on load
renderHistory();

// Device shake
let lastX = 0, lastY = 0, lastZ = 0;
window.addEventListener('devicemotion', (e) => {
  const acc = e.accelerationIncludingGravity;
  if (!acc) return;
  const x = acc.x || 0, y = acc.y || 0, z = acc.z || 0;
  const delta = Math.abs(x - lastX) + Math.abs(y - lastY) + Math.abs(z - lastZ);
  lastX = x; lastY = y; lastZ = z;
  const now = Date.now();
  if (delta > 15 && now - lastShakeTime > 1200) {
    lastShakeTime = now;
    const stateIdle = document.getElementById('state-idle');
    if (stateIdle && stateIdle.style.display !== 'none') triggerDraw();
  }
});
</script>
