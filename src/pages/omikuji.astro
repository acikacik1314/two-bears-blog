// ── History ──────────────────────────────────────────────────────────────────
const HISTORY_KEY = 'tb_omikuji_v2';
const HISTORY_MAX = 50;

interface HistoryItem {
  type: string;
  color: string;
  tagline: string;
  date: string;
  isoDate: string;
}

function loadHistory(): HistoryItem[] {
  try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); }
  catch { return []; }
}

function saveToHistory(item: HistoryItem) {
  const history = loadHistory();
  history.unshift(item);
  localStorage.setItem(HISTORY_KEY, JSON.stringify(history.slice(0, HISTORY_MAX)));
  renderHistory();
}

function renderHistory() {
  const list = document.getElementById('omi-history-list');
  if (!list) return;
  const history = loadHistory();
  if (!history.length) {
    list.innerHTML = '<div class="omi-history-empty">尚無紀錄，快去接收第一個訊號！</div>';
    return;
  }
  list.innerHTML = history.map(h => `
    <div class="omi-history-item">
      <div class="omi-history-badge" style="color:${h.color}">${h.type}</div>
      <div class="omi-history-info">
        <div class="omi-history-poem">「${h.tagline}」</div>
        <div class="omi-history-date">${h.date}</div>
      </div>
    </div>
  `).join('');
}

// ── Streak calculation ────────────────────────────────────────────────────────
function getStreak(): number {
  const history = loadHistory();
  if (!history.length) return 0;
  const today = new Date().toISOString().slice(0, 10);
  let streak = 0;
  let d = new Date(Date.now() - 86400000);
  while (streak < 30) {
    const ds = d.toISOString().slice(0, 10);
    if (!history.find(h => h.isoDate === ds)) break;
    streak++;
    d = new Date(d.getTime() - 86400000);
  }
  const drewToday = history.some(h => h.isoDate === today);
  return drewToday ? streak + 1 : streak + 1;
}

function renderStreak() {
  const streak = getStreak();
  const el = document.getElementById('omi-streak');
  const badge = document.getElementById('streak-badge');
  const dotsEl = document.getElementById('streak-dots');
  const textEl = document.getElementById('streak-text');
  const unlock = document.getElementById('streak-unlock');
  if (!el || !badge || !dotsEl || !textEl || !unlock) return;

  el.style.opacity = '1';
  const dots = Array.from({ length: 7 }, (_, i) =>
    `<span class="omi-streak-dot ${i < streak ? 'lit' : ''}"></span>`
  ).join(' ');
  dotsEl.innerHTML = dots;

  if (streak >= 7) {
    badge.classList.add('active');
    textEl.textContent = `連續 ${streak} 天`;
    unlock.style.display = 'inline';
  } else if (streak > 1) {
    badge.classList.add('active');
    textEl.textContent = `連續 ${streak} 天 · 集滿 7 天解鎖特殊訊號`;
    unlock.style.display = 'none';
  } else {
    textEl.textContent = streak === 1 ? '已抽今日訊號 · 明天繼續' : '開始連續觀測，集滿 7 天解鎖特殊訊號';
    unlock.style.display = 'none';
  }
}

// ── Tickers ───────────────────────────────────────────────────────────────────
let cachedTickers: Record<string, any> = {};

async function fetchAndShowTickers() {
  try {
    const r = await fetch('/api/market');
    if (!r.ok) throw new Error('no data');
    const d = await r.json();
    const t: Record<string, any> = {};
    for (const q of (d.quotes || [])) {
      if (q.symbol === '^VIX')  t.vix = q;
      if (q.symbol === 'GC=F')  t.gold = q;
      if (q.symbol === '^TWII') t.twii = q;
      if (q.symbol === '^GSPC') t.spx = q;
    }
    if (d.crypto?.bitcoin) t.btc = { price: d.crypto.bitcoin.usd, change: d.crypto.bitcoin.usd_24h_change };
    cachedTickers = t;
    renderWarning(t);
  } catch {
    const grid = document.getElementById('warning-grid');
    if (grid) grid.innerHTML = '<span class="omi-warning-loading" style="color:#475569">市場數據暫時無法取得</span>';
  }
}

function fmt(price: number, decimals = 0): string {
  return price.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
}

function chgSpan(pct: number | null): string {
  if (pct == null) return '';
  const cls = pct >= 0 ? 'up' : 'dn';
  return ` <span class="${cls}">${pct >= 0 ? '+' : ''}${pct.toFixed(1)}%</span>`;
}

function vixSentiment(vix: number): string {
  if (vix >= 30) return '🔴 極度恐慌';
  if (vix >= 25) return '🟠 市場恐慌';
  if (vix >= 20) return '🟡 輕度警戒';
  if (vix >= 15) return '🟢 相對穩定';
  return '🔵 過度樂觀';
}

function renderWarning(t: Record<string, any>) {
  const grid = document.getElementById('warning-grid');
  if (!grid) return;
  const chips: string[] = [];
  if (t.vix) chips.push(
    `<span class="omi-ticker-chip">VIX <span class="val">${fmt(t.vix.price, 1)}</span> ${vixSentiment(t.vix.price)}</span>`
  );
  if (t.gold) chips.push(
    `<span class="omi-ticker-chip">黃金 <span class="val">$${fmt(t.gold.price)}</span>${chgSpan(t.gold.change)}</span>`
  );
  if (t.twii) chips.push(
    `<span class="omi-ticker-chip">台股 <span class="val">${fmt(t.twii.price)}</span>${chgSpan(t.twii.change)}</span>`
  );
  if (t.btc) chips.push(
    `<span class="omi-ticker-chip">BTC <span class="val">$${fmt(t.btc.price)}</span>${chgSpan(t.btc.change)}</span>`
  );
  grid.innerHTML = chips.join('') || '<span class="omi-warning-loading" style="color:#475569">數據載入中…</span>';
}

// ── State machine ─────────────────────────────────────────────────────────────
let currentResult: any = null;
let isDrawing = false;
let lastShakeTime = 0;

function showState(name: string) {
  ['idle', 'shaking', 'result'].forEach(s => {
    const el = document.getElementById('state-' + s);
    if (el) el.style.display = (s === name) ? 'flex' : 'none';
  });
}

function applyFortuneVars(type: string) {
  const s = FORTUNE_STYLES[type] ?? FORTUNE_STYLES['中吉'];
  const slip = document.getElementById('omi-slip');
  if (!slip) return;
  slip.style.setProperty('--fortune-color', s.color);
  slip.style.setProperty('--fortune-glow', s.glow);
  slip.style.setProperty('--fortune-border', s.border);
  slip.style.setProperty('--fortune-badge-bg', s.badgeBg);
  slip.style.setProperty('--fortune-bar-bg', s.barBg);
  slip.style.setProperty('--fortune-lucky-bg', s.luckyBg);
  slip.style.setProperty('--fortune-lucky-border', s.luckyBorder);
  slip.style.setProperty('--fortune-advice-bg', s.adviceBg);
  slip.style.setProperty('--fortune-advice-border', s.adviceBorder);
  (slip as HTMLElement).style.background = s.gradient;
}

function populateResult(res: any) {
  const s = FORTUNE_STYLES[res.type] ?? FORTUNE_STYLES['中吉'];
  document.getElementById('slip-date')!.textContent = new Date().toLocaleDateString('zh-TW');
  document.getElementById('slip-type')!.textContent = res.type;
  document.getElementById('slip-rank')!.textContent = res.rankLabel;
  document.getElementById('slip-tagline')!.textContent = '時間線訊號 · ' + new Date().toLocaleDateString('zh-TW');
  document.getElementById('slip-poem')!.textContent = '「' + (res.ai?.tagline || '') + '」';
  const bearImg = document.getElementById('slip-bear-img') as HTMLImageElement;
  bearImg.src = s.bearImage;
  bearImg.alt = res.type;
  bearImg.style.setProperty('--fortune-glow', s.glow);
  document.getElementById('slip-bear-label')!.textContent = s.bearLabel;
  document.getElementById('pred-overall')!.textContent = res.ai?.overall || '';
  document.getElementById('pred-wealth')!.textContent = res.ai?.wealth || '';
  document.getElementById('pred-love')!.textContent = res.ai?.love || '';
  document.getElementById('pred-action')!.textContent = res.ai?.action || '';
  document.getElementById('lucky-num')!.textContent = String(res.ai?.luckyNum ?? '');
  document.getElementById('lucky-dir')!.textContent = res.ai?.luckyDir || '';
  document.getElementById('lucky-color')!.textContent = res.ai?.luckyColor || '';
  document.getElementById('slip-advice')!.textContent = '🐻 ' + (res.ai?.advice || '');
  applyFortuneVars(res.type);
}

// Build ticker payload for API
function buildTickerPayload() {
  const t = cachedTickers;
  return {
    vix:        t.vix?.price,
    gold:       t.gold?.price,
    goldChange: t.gold?.change,
    twii:       t.twii?.price,
    twiiChange: t.twii?.change,
    spx:        t.spx?.price,
    spxChange:  t.spx?.change,
    btc:        t.btc?.price,
    btcChange:  t.btc?.change,
  };
}

// Check if 7-day unlock applies for THIS draw
function checkIs7Day(): boolean {
  const history = loadHistory();
  const today = new Date().toISOString().slice(0, 10);
  if (history.some(h => h.isoDate === today)) return false;
  let count = 0;
  let d = new Date(Date.now() - 86400000);
  while (count < 6) {
    const ds = d.toISOString().slice(0, 10);
    if (!history.find(h => h.isoDate === ds)) break;
    count++;
    d = new Date(d.getTime() - 86400000);
  }
  return count >= 6;
}

const SHAKE_LABELS = [
  '掃描今日市場異象…',
  '讀取時間線座標…',
  '比對多維度訊號…',
  '未來人正在解讀…',
  '鎖定今日頻率…',
];

async function triggerDraw() {
  if (isDrawing) return;
  isDrawing = true;
  showState('shaking');

  const progressBar = document.getElementById('omi-progress')!;
  const dots = document.querySelectorAll('.omi-dot');
  const shakeLabel = document.getElementById('shake-label')!;
  const scanLabel = document.getElementById('scan-sublabel')!;
  let count = 0;
  const total = 10;

  // Animate dots during API call
  const animInterval = setInterval(() => {
    if (count < total) {
      count++;
      const pct = Math.round((count / total) * 100);
      progressBar.style.width = pct + '%';
      dots.forEach((d, i) => { if (i < count) d.classList.add('on'); });
      shakeLabel.textContent = SHAKE_LABELS[Math.floor(count / 2)] || SHAKE_LABELS[4];
    }
  }, 180);

  try {
    const history = loadHistory();
    const is7Day = checkIs7Day();

    const res = await fetch('/api/omikuji-draw', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tickers: buildTickerPayload(),
        history: history.slice(0, 5).map(h => ({ type: h.type, isoDate: h.isoDate, tagline: h.tagline })),
        is7Day,
      }),
    });

    clearInterval(animInterval);
    // Fill progress to 100%
    count = total;
    progressBar.style.width = '100%';
    dots.forEach(d => d.classList.add('on'));
    scanLabel.textContent = 'SIGNAL · LOCKED ✓';

    if (!res.ok) throw new Error('api error');
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'draw failed');

    currentResult = data;
    populateResult(data);

    // Save to history
    const today = new Date().toISOString().slice(0, 10);
    const displayDate = new Date().toLocaleString('zh-TW', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    const s = FORTUNE_STYLES[data.type] ?? FORTUNE_STYLES['中吉'];
    saveToHistory({
      type: data.type,
      color: s.color,
      tagline: data.ai?.tagline || '',
      date: displayDate,
      isoDate: today,
    });

    await new Promise(r => setTimeout(r, 300));

    const slip = document.getElementById('omi-slip')!;
    slip.classList.remove('omi-reveal');
    void slip.offsetWidth;
    slip.classList.add('omi-reveal');
    showState('result');
    renderStreak();

  } catch (err) {
    clearInterval(animInterval);
    shakeLabel.textContent = '⚠️ 訊號中斷，請稍後再試';
    await new Promise(r => setTimeout(r, 1500));
    resetDraw();
  } finally {
    isDrawing = false;
  }
}

function resetDraw() {
  currentResult = null;
  isDrawing = false;
  document.querySelectorAll('.omi-dot').forEach(d => d.classList.remove('on'));
  const pb = document.getElementById('omi-progress');
  if (pb) pb.style.width = '0%';
  const shakeLabel = document.getElementById('shake-label');
  if (shakeLabel) shakeLabel.textContent = '掃描今日市場異象…';
  const scanLabel = document.getElementById('scan-sublabel');
  if (scanLabel) scanLabel.textContent = 'FUTURE · SIGNAL · LOCK';
  showState('idle');
}

// ── Event listeners ───────────────────────────────────────────────────────────
document.getElementById('btn-draw')?.addEventListener('click', triggerDraw);
document.getElementById('btn-reset')?.addEventListener('click', resetDraw);

document.getElementById('btn-share')?.addEventListener('click', () => {
  if (!currentResult) return;
  const tagline = currentResult.ai?.tagline || '';
  const text = `【兩隻熊 未來人訊號卡】今日抽到「${currentResult.type}」\n「${tagline}」\n\n結合真實市場異象的時間線訊號\n🐻 twobears.vercel.app/omikuji`;
  if (navigator.share) {
    navigator.share({ title: '未來人每日訊號', text });
  } else {
    navigator.clipboard.writeText(text).then(() => alert('已複製到剪貼板！'));
  }
});

let historyOpen = true;
