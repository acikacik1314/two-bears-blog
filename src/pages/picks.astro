---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-TW">
<head>
  <BaseHead title="🐻 兩隻熊幫你選 — 選擇困難症終結者" description="告訴兩隻熊你想買什麼，AI 幫你分析最適合的產品。沒有業配，純粹站在你那邊。" />
<style is:global>
.hero{background:var(--bear,#3d2b1f);color:var(--paper,#f7f4ef);padding:3rem 1.5rem 2.5rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'🐻';position:absolute;left:-20px;bottom:-20px;font-size:130px;opacity:.05;pointer-events:none;transform:scaleX(-1)}
.hero::after{content:'🐻';position:absolute;right:-10px;bottom:-20px;font-size:120px;opacity:.05;pointer-events:none}
.hero-tag{font-size:11px;letter-spacing:.3em;color:rgba(212,170,32,.7);text-transform:uppercase;margin-bottom:1rem}
.hero h1{font-family:'Noto Serif TC',serif;font-weight:400;font-size:clamp(1.6rem,4vw,2.2rem);line-height:1.4;margin-bottom:.75rem}
.hero h1 em{font-style:normal;color:#d4aa20}
.hero-sub{font-size:13px;color:rgba(247,244,239,.6);max-width:420px;margin:0 auto}

.main{max-width:720px;margin:0 auto;padding:2rem 1.5rem}

.first-visit-tip{background:rgba(184,150,12,.08);border:.5px solid rgba(184,150,12,.3);border-radius:6px;padding:.75rem 1rem;margin-bottom:1.5rem;font-size:12px;color:var(--ink2,#4a4540);line-height:1.6}
.first-visit-tip strong{color:#b8960c}

.examples{margin-bottom:1.5rem}
.examples-label{font-size:11px;color:var(--ink3,#8a827a);margin-bottom:8px;letter-spacing:.1em}
.example-chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{font-size:11px;padding:5px 12px;border-radius:100px;border:.5px solid var(--paper3,#e4dfd6);background:var(--paper,#f7f4ef);color:var(--ink2,#4a4540);cursor:pointer;transition:all .15s;line-height:1.5}
.chip:hover{background:var(--bear,#3d2b1f);color:var(--paper,#f7f4ef);border-color:var(--bear,#3d2b1f)}
.chip:active{transform:scale(.97)}

.input-card{background:var(--paper,#f7f4ef);border:.5px solid var(--paper3,#e4dfd6);border-radius:6px;overflow:hidden;margin-bottom:1.5rem;box-shadow:0 1px 8px rgba(26,24,22,.08);transition:box-shadow .2s}
.input-card:focus-within{box-shadow:0 2px 16px rgba(26,24,22,.12)}
.input-card textarea{width:100%;border:none;padding:1.25rem;font-family:'Noto Sans TC',serif;font-size:14px;line-height:1.7;background:transparent;color:var(--ink,#1a1816);resize:none;min-height:100px}
.input-card textarea:focus{outline:none}
.input-card textarea::placeholder{color:var(--ink3,#8a827a)}
.input-footer{padding:.75rem 1.25rem;border-top:.5px solid var(--paper3,#e4dfd6);background:var(--paper2,#ede9e2);display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap}
.char-count{font-size:11px;color:var(--ink3,#8a827a);flex-shrink:0}
.send-btn{padding:9px 20px;background:var(--bear,#3d2b1f);color:var(--paper,#f7f4ef);border:none;border-radius:6px;font-size:13px;font-family:'Noto Sans TC',sans-serif;font-weight:500;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px}
.send-btn:hover:not(:disabled){background:#b8960c;color:var(--bear,#3d2b1f);transform:translateY(-1px)}
.send-btn:disabled{opacity:.45;cursor:not-allowed}

#resultSection{display:none;margin-bottom:1.5rem}
.result-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;gap:8px;flex-wrap:wrap}
.result-title{font-family:'Noto Serif TC',serif;font-size:14px;color:var(--ink3,#8a827a);letter-spacing:.1em}
.share-row{display:flex;gap:6px}
.share-btn{font-size:11px;padding:5px 12px;border-radius:100px;border:.5px solid var(--paper3,#e4dfd6);background:var(--paper,#f7f4ef);color:var(--ink2,#4a4540);cursor:pointer;font-family:'Noto Sans TC',sans-serif;transition:all .15s;display:flex;align-items:center;gap:4px}
.share-btn:hover{border-color:#b8960c;color:#b8960c}
.share-btn.line{background:#00b300;color:#fff;border-color:#00b300}
.share-btn.line:hover{background:#009900;border-color:#009900}
.share-btn.copied{background:#2a5a3a;color:#fff;border-color:#2a5a3a}

.result-card{background:var(--paper,#f7f4ef);border:.5px solid var(--paper3,#e4dfd6);border-radius:6px;overflow:hidden;box-shadow:0 1px 8px rgba(26,24,22,.08)}
.result-body{padding:1.5rem;font-size:14px;line-height:1.85;color:var(--ink2,#4a4540)}
.result-body:empty{display:none}
.result-body h2{font-family:'Noto Serif TC',serif;color:var(--ink,#1a1816);margin:1.25rem 0 .5rem;font-weight:600;font-size:16px;border-bottom:.5px solid var(--paper3,#e4dfd6);padding-bottom:.5rem}
.result-body h2:first-child{margin-top:0}
.result-body h3{font-family:'Noto Serif TC',serif;color:var(--bear,#3d2b1f);font-size:14px;font-weight:600;margin:.75rem 0 .25rem}
.result-body strong{color:var(--ink,#1a1816);font-weight:500}
.result-body hr{border:none;border-top:.5px solid var(--paper3,#e4dfd6);margin:1rem 0}
.result-body p{margin-bottom:.5rem}
.result-body ul{padding-left:1.25rem;margin:.25rem 0}
.result-body li{margin-bottom:.25rem}

.bear-verdict{background:var(--bear,#3d2b1f);color:var(--paper,#f7f4ef);padding:1rem 1.5rem;display:flex;gap:10px;align-items:flex-start}
.bear-icon{font-size:24px;flex-shrink:0;margin-top:2px}
.verdict-text{font-size:13px;line-height:1.7;color:rgba(247,244,239,.85);font-style:italic}
.verdict-text strong{color:#d4aa20;font-style:normal}

.followup-section{margin-top:1rem}
.followup-label{font-size:12px;color:var(--ink3,#8a827a);margin-bottom:6px;display:flex;align-items:center;gap:5px}
.followup-label::before{content:'💬'}
.followup-row{display:flex;gap:8px}
.followup-input{flex:1;font-size:13px;padding:9px 12px;border:.5px solid var(--paper3,#e4dfd6);border-radius:6px;background:var(--paper,#f7f4ef);color:var(--ink,#1a1816);font-family:'Noto Sans TC',sans-serif;transition:border-color .2s}
.followup-input:focus{outline:none;border-color:#b8960c}
.followup-input::placeholder{color:var(--ink3,#8a827a)}
.followup-btn{padding:9px 16px;background:var(--bear,#3d2b1f);color:var(--paper,#f7f4ef);border:none;border-radius:6px;font-size:12px;font-family:'Noto Sans TC',sans-serif;cursor:pointer;transition:all .15s;white-space:nowrap}
.followup-btn:hover{background:#b8960c;color:var(--bear,#3d2b1f)}
.followup-btn:disabled{opacity:.4;cursor:not-allowed}
.followup-chips{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px}
.followup-chip{font-size:11px;padding:4px 10px;border-radius:100px;border:.5px solid var(--paper3,#e4dfd6);background:var(--paper,#f7f4ef);color:var(--ink2,#4a4540);cursor:pointer;transition:all .15s}
.followup-chip:hover{background:var(--paper2,#ede9e2)}

.loading{text-align:center;padding:2.5rem 1rem;color:var(--ink3,#8a827a)}
.loading-dots span{display:inline-block;width:6px;height:6px;border-radius:50%;background:#b8960c;margin:0 2px;animation:bounce 1.2s infinite}
.loading-dots span:nth-child(2){animation-delay:.2s}
.loading-dots span:nth-child(3){animation-delay:.4s}
@keyframes bounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-6px)}}

.disclaimer{font-size:11px;color:var(--ink3,#8a827a);text-align:center;padding:1.5rem 0;line-height:1.8}

.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--ink,#1a1816);color:var(--paper,#f7f4ef);font-size:13px;padding:10px 20px;border-radius:100px;opacity:0;transition:all .3s;pointer-events:none;z-index:999;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ===== 去哪買區塊 ===== */
.buy-links-section{margin-top:1rem;background:var(--paper,#f7f4ef);border:.5px solid var(--paper3,#e4dfd6);border-radius:6px;overflow:hidden}
.buy-links-header{background:var(--bear,#3d2b1f);color:var(--paper,#f7f4ef);padding:.6rem 1rem;font-size:13px;font-weight:600;display:flex;align-items:center;gap:6px}
.price-loading{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:400;opacity:.7;margin-left:4px}
.price-loading-dot{width:4px;height:4px;border-radius:50%;background:currentColor;animation:pricePulse 1.2s ease-in-out infinite}
.price-loading-dot:nth-child(2){animation-delay:.2s}
.price-loading-dot:nth-child(3){animation-delay:.4s}
@keyframes pricePulse{0%,80%,100%{opacity:.25;transform:scale(.8)}40%{opacity:1;transform:scale(1)}}
.buy-product-row{padding:.7rem 1rem;border-bottom:.5px solid var(--paper3,#e4dfd6)}
.buy-product-row:last-child{border-bottom:none}
.buy-product-name{font-size:12px;font-weight:600;color:var(--ink,#1a1816);margin-bottom:.45rem}
.buy-btn-row{display:flex;flex-wrap:wrap;gap:.35rem}
.buy-platform-btn{display:flex;flex-direction:column;align-items:center;gap:1px;font-size:11px;padding:5px 10px;border-radius:12px;border:1.5px solid var(--pc,#999);background:transparent;color:var(--pc,#999);cursor:pointer;font-family:'Noto Sans TC',sans-serif;transition:all .15s;white-space:nowrap;font-weight:500;text-decoration:none}
.buy-platform-btn:hover{background:var(--pc,#999);color:#fff;transform:translateY(-1px)}
.btn-price{font-size:9px;font-weight:600;opacity:.75;letter-spacing:.01em}
@media(max-width:600px){.buy-btn-row{gap:.3rem}.buy-platform-btn{font-size:10px;padding:3px 8px}}

.history-section{margin-top:2rem;border-top:.5px solid var(--paper3,#e4dfd6);padding-top:1.5rem}
.history-label{font-size:11px;color:var(--ink3,#8a827a);margin-bottom:.75rem;letter-spacing:.1em}
.history-list{display:flex;flex-direction:column;gap:6px}
.history-item{font-size:12px;padding:8px 12px;border:.5px solid var(--paper3,#e4dfd6);border-radius:6px;background:var(--paper,#f7f4ef);cursor:pointer;color:var(--ink2,#4a4540);transition:all .15s;display:flex;justify-content:space-between;align-items:center;gap:8px}
.history-item:hover{background:var(--paper2,#ede9e2)}
.history-q{flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.history-time{font-size:10px;color:var(--ink3,#8a827a);flex-shrink:0}

@media(max-width:600px){
  .hero{padding:2.5rem 1rem 2rem}
  .main{padding:1.5rem 1rem}
  .result-header{flex-direction:column;align-items:flex-start}
  .followup-row{flex-direction:column}
  .followup-btn{width:100%}
  .input-footer{flex-direction:column;align-items:stretch}
  .send-btn{justify-content:center;width:100%}
  .char-count{text-align:right}
  html{font-size:22px}
  .hero-sub{font-size:20px}
  .input-card textarea{font-size:20px}
  .result-title{font-size:20px}
  .result-body{font-size:22px}
  .result-body h2{font-size:24px}
  .result-body h3{font-size:22px}
  .verdict-text{font-size:20px}
  .history-item{font-size:20px}
  .history-label{font-size:18px}
  .chip{font-size:18px}
  .send-btn{font-size:20px}
  .followup-input{font-size:20px}
  .followup-label{font-size:18px}
  .first-visit-tip{font-size:18px}
}
</style>
</head>
<body>
  <Header />

  <div class="hero">
    <div class="hero-tag">兩隻熊幫你選 · BEAR PICKS</div>
    <h1>選擇困難？<em>讓熊幫你決定</em>。</h1>
    <p class="hero-sub">告訴我們你想買什麼、預算多少、用途是什麼，兩隻熊幫你找到最適合的選擇——沒有業配，純粹站在你那邊。</p>
  </div>

  <div class="main">

    <div class="first-visit-tip">
      👋 在下面輸入你的需求，<strong>越詳細越好</strong>——預算、使用情境、特殊需求都寫上來，熊才能給你最準的推薦。
    </div>

    <div class="examples">
      <div class="examples-label">💡 不知道怎麼問？試試這些</div>
      <div class="example-chips">
        <span class="chip" onclick="setExample(this)">空氣清淨機，25坪，家裡有小孩，預算一萬</span>
        <span class="chip" onclick="setExample(this)">藍牙耳機，通勤用，降噪，預算三千以內</span>
        <span class="chip" onclick="setExample(this)">電風扇，套房用，靜音，預算一千五</span>
        <span class="chip" onclick="setExample(this)">保溫杯，上班族帶咖啡用，預算六百</span>
        <span class="chip" onclick="setExample(this)">掃地機器人，有地毯，養貓，預算八千</span>
        <span class="chip" onclick="setExample(this)">筆電，大學生，輕薄，預算三萬</span>
        <span class="chip" onclick="setExample(this)">電動牙刷，全家共用，預算兩千以內</span>
        <span class="chip" onclick="setExample(this)">咖啡機，每天喝兩杯，懶人版，預算五千</span>
      </div>
    </div>

    <div class="input-card">
      <textarea id="userInput"
        placeholder="告訴我你想買什麼、使用情境、預算、有什麼特別需求...&#10;&#10;例如：「我想買一台空氣清淨機，家裡約25坪，有一個兩歲小孩，希望安靜不吵，預算一萬以內，台灣買得到的品牌」"
        oninput="updateCount()"></textarea>
      <div class="input-footer">
        <span class="char-count" id="charCount">0 字</span>
        <button class="send-btn" id="sendBtn" onclick="askBear()">
          🐻 兩隻熊幫我選 →
        </button>
      </div>
    </div>

    <div id="resultSection">
      <div class="result-header">
        <div class="result-title">🐻 兩隻熊的分析報告</div>
        <div class="share-row">
          <button class="share-btn" id="copyBtn" onclick="copyResult()">📋 複製結果</button>
          <button class="share-btn line" onclick="shareToLine()">LINE 分享</button>
        </div>
      </div>
      <div class="result-card">
        <div class="result-body" id="resultBody"></div>
        <div class="bear-verdict" id="bearVerdict" style="display:none">
          <div class="bear-icon">🐻</div>
          <div class="verdict-text" id="verdictText"></div>
        </div>
      </div>

      <!-- 去哪買區塊 -->
      <div class="buy-links-section" id="buyLinksSection" style="display:none">
        <div class="buy-links-header">🛒 去哪買？點平台按鈕直接搜尋<span id="priceLoadingIndicator" style="display:none" class="price-loading">抓價格中<span class="price-loading-dot"></span><span class="price-loading-dot"></span><span class="price-loading-dot"></span></span></div>
      </div>

      <div class="followup-section" id="followupSection" style="display:none">
        <div class="followup-label"> 還有問題？繼續追問熊</div>
        <div class="followup-chips">
          <span class="followup-chip" onclick="setFollowup(this)">那 A 跟 B 比起來哪個好？</span>
          <span class="followup-chip" onclick="setFollowup(this)">有更便宜的選項嗎？</span>
          <span class="followup-chip" onclick="setFollowup(this)">這個品牌售後服務如何？</span>
          <span class="followup-chip" onclick="setFollowup(this)">在哪裡買比較便宜？</span>
          <span class="followup-chip" onclick="setFollowup(this)">最近有特價活動嗎？</span>
        </div>
        <div class="followup-row">
          <input type="text" class="followup-input" id="followupInput"
            placeholder="例如：最推薦的那個跟 Dyson 比起來呢？"
            onkeydown="if(event.key==='Enter')askFollowup()">
          <button class="followup-btn" id="followupBtn" onclick="askFollowup()">繼續問 →</button>
        </div>
      </div>
    </div>

    <div class="history-section" id="historySection" style="display:none">
      <div class="history-label">📜 你問過的問題</div>
      <div class="history-list" id="historyList"></div>
    </div>

    <div class="disclaimer">
      🐻 兩隻熊幫你選 · 純粹站在你那邊，沒有業配<br>
      AI 建議僅供參考，購買前建議自行確認最新價格與規格
    </div>

  </div>

  <div class="toast" id="toast"></div>

  <Footer />

<script is:inline>
const API_URL = '/api/bear-picks'
let conversationHistory = []
let lastRawText = ''
let queryHistory = []

// ===== 平台設定 =====
const BUY_PLATFORMS = [
  { name: 'momo',   icon: '🛍️', color: '#e94560', match: /momo/i,
    home: 'https://www1.gamepark.com.tw/3Ii4v', ichannels: true,
    search: k => `https://www.momoshop.com.tw/search/searchShop.jsp?keyword=${k}` },
  { name: '蝦皮',   icon: '🛒', color: '#f07113', match: /蝦皮|shopee/i,
    aff: 'https://tlcafftrax.com/track/clicks/5282/c627c2b7900723d7fb9cab248d2596412379128f78e8e4fc0576f6476a0449a8c23ae5a5112d',
    search: k => `https://shopee.tw/mall/search?keyword=${k}` },
  { name: '酷澎',   icon: '⚡', color: '#1db8c2', match: /酷澎|coupang/i,
    home: 'https://whitehippo.net/3RDil', ichannels: true,
    search: k => `https://www.tw.coupang.com/search?q=${k}` },
  { name: 'Yahoo',  icon: '💜', color: '#7b00d4', match: /yahoo|雅虎/i,
    aff: 'https://afftck.com/track/clicks/3416/c627c2bc9b0521dff088ec23d62e994c21695b9633e0e5f00666a44125095ff88635aca3163d8e',
    search: k => `https://tw.buy.yahoo.com/search/product?p=${k}` },
  { name: '樂天',   icon: '🌸', color: '#bf0000', match: /樂天|rakuten/i,
    aff: 'https://affclkr.com/track/clicks/9379/c627c2b8900224ddfe9cab248d2596412379128f78e4e5f30e76f6476a0449a8c23ae5a5112d',
    search: k => `https://www.rakuten.com.tw/search/${k}/` },
  { name: '家樂福', icon: '🏪', color: '#004fa3', match: /家樂福|carrefour/i,
    search: k => `https://online.carrefour.com.tw/zh/search?q=${k}` },
  { name: '小三美日',icon:'💄', color: '#1a7f37', match: /小三|s3/i,
    aff: 'https://abzcoupon.com/track/clicks/4281/c627c2bc9b0521dffc8cec23d62e994c21695b9633e0e2f60f61a44125095ff88635aca3163d8e',
    search: k => `https://www.s3.com.tw/Search?q=${k}` },
  { name: 'PChome', icon: '📦', color: '#005bab', match: /pchome/i,
    search: k => `https://24h.pchome.com.tw/search/?q=${k}` },
]

let _priceLoadingCount = 0
function setPriceLoading(delta) {
  _priceLoadingCount = Math.max(0, _priceLoadingCount + delta)
  const el = document.getElementById('priceLoadingIndicator')
  if (el) el.style.display = _priceLoadingCount > 0 ? 'inline-flex' : 'none'
}

async function fetchProductPrices(product, priceEls) {
  setPriceLoading(+1)
  try {
    const res = await fetch('/api/compare', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ keyword: product })
    })
    if (!res.ok) return
    const data = await res.json()
    if (!Array.isArray(data.results)) return
    for (const r of data.results) {
      for (const p of BUY_PLATFORMS) {
        if (p.match && p.match.test(r.platform) && priceEls[p.name]) {
          priceEls[p.name].textContent = 'NT$' + r.price.toLocaleString()
          break
        }
      }
    }
  } catch { /* silently fail */ }
  finally { setPriceLoading(-1) }
}

// 從 AI 回應標題中抽出推薦產品名稱
function extractProducts(text) {
  const patterns = [
    /##\s+🏆[^：:]*[：:]\s*(.+)/,
    /##\s+💰[^：:]*[：:]\s*(.+)/,
    /##\s+⬆[^：:]*[：:]\s*(.+)/,
  ]
  return patterns
    .map(pat => { const m = text.match(pat); return m ? m[1].replace(/\*+/g,'').trim() : null })
    .filter(n => n && n.length > 1 && n.length < 60)
    .filter((v, i, a) => a.indexOf(v) === i) // 去重
}

function renderBuyLinks(products) {
  const section = document.getElementById('buyLinksSection')
  if (!products.length) { section.style.display = 'none'; return }
  // 保留 header，清空舊的產品行
  const header = section.querySelector('.buy-links-header')
  section.innerHTML = ''
  section.appendChild(header)
  section.style.display = 'block'

  for (const product of products) {
    const row = document.createElement('div')
    row.className = 'buy-product-row'
    const nameEl = document.createElement('div')
    nameEl.className = 'buy-product-name'
    nameEl.textContent = '📦 ' + product
    row.appendChild(nameEl)
    const btnRow = document.createElement('div')
    btnRow.className = 'buy-btn-row'
    const kw = encodeURIComponent(product)
    const priceEls = {}
    for (const p of BUY_PLATFORMS) {
      const btn = document.createElement('a')
      btn.className = 'buy-platform-btn'
      btn.style.setProperty('--pc', p.color)
      btn.title = p.name + ' 搜尋「' + product + '」'
      btn.href = p.ichannels
        ? (p.home || p.aff)
        : (p.aff ? p.aff + '?t=' + encodeURIComponent(encodeURIComponent(p.search(kw))) : p.search(kw))
      btn.target = '_blank'
      btn.rel = 'sponsored nofollow noopener'
      const labelEl = document.createElement('span')
      labelEl.textContent = p.icon + ' ' + p.name
      const priceEl = document.createElement('span')
      priceEl.className = 'btn-price'
      priceEl.textContent = '⋯'
      btn.appendChild(labelEl)
      btn.appendChild(priceEl)
      priceEls[p.name] = priceEl
      btnRow.appendChild(btn)
    }
    row.appendChild(btnRow)
    section.appendChild(row)
    fetchProductPrices(product, priceEls)
  }
}

window.addEventListener('load', () => {
  const hist = localStorage.getItem('bear_history')
  if (hist) {
    try { queryHistory = JSON.parse(hist) } catch(e) { queryHistory = [] }
    renderHistory()
  }
  document.getElementById('userInput').addEventListener('keydown', e => {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) askBear()
  })
})

function updateCount() {
  document.getElementById('charCount').textContent = document.getElementById('userInput').value.length + ' 字'
}

function setExample(el) {
  document.getElementById('userInput').value = el.textContent
  updateCount()
  document.getElementById('userInput').focus()
}

function setFollowup(el) {
  document.getElementById('followupInput').value = el.textContent
  document.getElementById('followupInput').focus()
}

async function askBear() {
  const question = document.getElementById('userInput').value.trim()
  if (!question) { showToast('請輸入你想買什麼！'); return }
  conversationHistory = [{ role: 'user', parts: [{ text: question }] }]
  setLoadingState(true, 'main')
  await fetchAndRender()
  setLoadingState(false, 'main')
  addToHistory(question)
}

async function askFollowup() {
  const q = document.getElementById('followupInput').value.trim()
  if (!q) { showToast('請輸入追問內容'); return }
  conversationHistory.push({ role: 'user', parts: [{ text: q }] })
  setLoadingState(true, 'followup')
  await fetchAndRender()
  setLoadingState(false, 'followup')
  document.getElementById('followupInput').value = ''
}

async function fetchAndRender() {
  const resultSection = document.getElementById('resultSection')
  const resultBody = document.getElementById('resultBody')
  const bearVerdict = document.getElementById('bearVerdict')
  const verdictText = document.getElementById('verdictText')

  resultSection.style.display = 'block'
  resultBody.innerHTML = `<div class="loading">
    <div class="loading-dots"><span></span><span></span><span></span></div>
    <p style="margin-top:12px;font-size:13px">兩隻熊正在幫你分析市場...</p>
  </div>`
  bearVerdict.style.display = 'none'
  document.getElementById('followupSection').style.display = 'none'
  resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' })

  try {
    const res = await fetch(API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: conversationHistory, temperature: 0.7, max_tokens: 4096 })
    })
    const data = await res.json()

    if (data.text) {
      const text = data.text
      lastRawText = text
      conversationHistory.push({ role: 'model', parts: [{ text }] })

      const verdictMatch = text.match(/🐻\s*兩隻熊的話[：:]\s*([\s\S]+)$/)
      let mainText = text
      let verdict = ''
      if (verdictMatch) {
        verdict = verdictMatch[1].trim()
        mainText = text.replace(/---[\s\S]*$/, '').trim()
      }

      resultBody.innerHTML = formatText(mainText)

      if (verdict) {
        verdictText.innerHTML = inlineFormat(verdict)
        bearVerdict.style.display = 'flex'
      }
      // 抽取產品名稱並渲染購買連結
      renderBuyLinks(extractProducts(mainText))
      document.getElementById('followupSection').style.display = 'block'
    } else if (data.error) {
      resultBody.innerHTML = `<p style="color:#8b2020">⚠ ${data.error}</p>`
    }
  } catch (err) {
    resultBody.innerHTML = `<p style="color:#8b2020">⚠ 連線失敗，請稍後再試。</p>`
  }
}

function setLoadingState(loading, type) {
  if (type === 'main') {
    const btn = document.getElementById('sendBtn')
    btn.disabled = loading
    btn.innerHTML = loading ? '🐻 熊在思考中...' : '🐻 再問一次 →'
  } else {
    const btn = document.getElementById('followupBtn')
    btn.disabled = loading
    btn.textContent = loading ? '思考中...' : '繼續問 →'
  }
}

function formatText(text) {
  const lines = text.split('\n')
  let html = ''
  for (const line of lines) {
    if (/^## /.test(line)) {
      html += `<h2>${inlineFormat(line.replace(/^## /, ''))}</h2>`
    } else if (/^### /.test(line)) {
      html += `<h3>${inlineFormat(line.replace(/^### /, ''))}</h3>`
    } else if (/^---$/.test(line)) {
      html += '<hr>'
    } else if (/^[-*] /.test(line)) {
      html += `<ul><li>${inlineFormat(line.replace(/^[-*] /, ''))}</li></ul>`
    } else if (line.trim() === '') {
      html += '<br>'
    } else {
      html += `<p>${inlineFormat(line)}</p>`
    }
  }
  return html.replace(/<\/ul><ul>/g, '')
}

function inlineFormat(text) {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
}

function copyResult() {
  if (!lastRawText) return
  const question = conversationHistory[0]?.parts[0]?.text || ''
  const shareText = `🐻 兩隻熊幫你選\n\n問題：${question}\n\n${lastRawText}\n\n— 兩隻熊幫你選 · 沒有業配，純粹站在你那邊`
  navigator.clipboard.writeText(shareText).then(() => {
    const btn = document.getElementById('copyBtn')
    btn.classList.add('copied')
    btn.textContent = '✅ 已複製！'
    showToast('結果已複製到剪貼簿')
    setTimeout(() => { btn.classList.remove('copied'); btn.textContent = '📋 複製結果' }, 2500)
  }).catch(() => showToast('請手動複製內容'))
}

function shareToLine() {
  if (!lastRawText) return
  const question = conversationHistory[0]?.parts[0]?.text || ''
  const excerpt = lastRawText.substring(0, 300) + '...'
  const text = encodeURIComponent(`🐻 兩隻熊幫你選\n\n問題：${question}\n\n${excerpt}`)
  window.open(`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(location.href)}&text=${text}`, '_blank')
}

function addToHistory(question) {
  const now = new Date()
  const timeStr = `${now.getMonth()+1}/${now.getDate()} ${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')}`
  queryHistory.unshift({ q: question, t: timeStr })
  if (queryHistory.length > 10) queryHistory = queryHistory.slice(0, 10)
  localStorage.setItem('bear_history', JSON.stringify(queryHistory))
  renderHistory()
}

function renderHistory() {
  if (queryHistory.length === 0) return
  const section = document.getElementById('historySection')
  const list = document.getElementById('historyList')
  section.style.display = 'block'
  list.innerHTML = queryHistory.map(item => `
    <div class="history-item" onclick="reask(this)" data-q="${item.q.replace(/"/g, '&quot;')}">
      <span class="history-q">${item.q}</span>
      <span class="history-time">${item.t}</span>
    </div>
  `).join('')
}

function reask(el) {
  const q = el.getAttribute('data-q')
  document.getElementById('userInput').value = q
  updateCount()
  window.scrollTo({ top: 0, behavior: 'smooth' })
  document.getElementById('userInput').focus()
}

function showToast(msg) {
  const toast = document.getElementById('toast')
  toast.textContent = msg
  toast.classList.add('show')
  setTimeout(() => toast.classList.remove('show'), 2800)
}
</script>
</body>
</html>
