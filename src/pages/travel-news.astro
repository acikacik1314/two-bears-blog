loadCategory('japan-tax', 'panel-travel');

// ─────────────────────────────
// AI Advisor Quiz
// ─────────────────────────────
let currentStep = 1;
const TOTAL_STEPS = 5;

function updateProgress(step: number) {
  const pct = Math.round((step / TOTAL_STEPS) * 100);
  const fill  = document.getElementById('progress-fill')!;
  const label = document.getElementById('progress-label')!;
  fill.style.width  = pct + '%';
  label.textContent = `第 ${step} 步，共 ${TOTAL_STEPS} 步`;
}

(window as any).nextStep = function(step: number) {
  if (step === 1) {
    const age = parseInt((document.getElementById('q-age') as HTMLInputElement).value);
    if (!age || age < 18 || age > 80) { alert('請輸入 18-80 之間的年齡'); return; }
  }
  if (step === 2 && !document.querySelector<HTMLInputElement>('input[name="budget"]:checked')) {
    alert('請選擇預算類型'); return;
  }
  if (step === 3 && !document.querySelector<HTMLInputElement>('input[name="duration"]:checked')) {
    alert('請選擇計劃時長'); return;
  }
  if (step === 4) {
    const checked = document.querySelectorAll<HTMLInputElement>('input[name="purpose"]:checked');
    if (!checked.length) { alert('請至少選擇一個目的'); return; }
  }
  document.getElementById(`step-${step}`)!.classList.remove('active');
  currentStep = step + 1;
  document.getElementById(`step-${currentStep}`)!.classList.add('active');
  updateProgress(currentStep);
};

(window as any).prevStep = function(step: number) {
  document.getElementById(`step-${step}`)!.classList.remove('active');
  currentStep = step - 1;
  document.getElementById(`step-${currentStep}`)!.classList.add('active');
  updateProgress(currentStep);
};

(window as any).submitQuiz = async function() {
  const age      = parseInt((document.getElementById('q-age') as HTMLInputElement).value);
  const budget   = (document.querySelector<HTMLInputElement>('input[name="budget"]:checked')?.value ?? '') as 'low'|'medium'|'high';
  const duration = (document.querySelector<HTMLInputElement>('input[name="duration"]:checked')?.value ?? '') as 'short'|'medium'|'long';
  const purpose  = [...document.querySelectorAll<HTMLInputElement>('input[name="purpose"]:checked')].map(e => e.value);
  const countries = [...document.querySelectorAll<HTMLInputElement>('input[name="countries"]:checked')].map(e => e.value);
  const has_skill = (document.getElementById('q-skill') as HTMLInputElement).value.trim();
  const work_ok   = (document.getElementById('q-work-ok') as HTMLInputElement).checked;
  const study_ok  = (document.getElementById('q-study-ok') as HTMLInputElement).checked;

  // hide steps & progress
  document.getElementById(`step-${currentStep}`)!.classList.remove('active');
  document.getElementById('quiz-progress')!.style.display = 'none';

  const loadingEl = document.getElementById('advisor-loading')!;
  const errorEl   = document.getElementById('advisor-error')!;
  const resultEl  = document.getElementById('advisor-result')!;
  loadingEl.classList.add('show');
  errorEl.hidden = true;
  resultEl.classList.remove('show');

  try {
    const res  = await fetch('/api/travel-advisor', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ age, budget, duration, purpose, preferred_countries: countries, work_ok, study_ok, has_skill }),
    });
    const data = await res.json();
    loadingEl.classList.remove('show');
    if (!res.ok || data.error) {
      errorEl.hidden = false;
      errorEl.textContent = '⚠️ ' + (data.error ?? '發生錯誤，請稍後再試');
      return;
    }
    renderAdvisorResult(data);
  } catch {
    loadingEl.classList.remove('show');
    errorEl.hidden = false;
    errorEl.textContent = '⚠️ 網路錯誤，請稍後再試';
  }
};

function diffBadge(d?: string): string {
  if (!d) return '';
  const cls = d === '容易' ? 'badge-easy' : d === '中等' ? 'badge-medium' : 'badge-hard';
  return `<span class="badge ${cls}">${d}</span>`;
}

function renderAdvisorResult(data: any) {
  const bm = data.best_match ?? {};
  document.getElementById('advisor-best')!.innerHTML = `
    <div class="best-card">
      <p class="best-label">🏆 最佳推薦方案</p>
      <p class="best-type">${bm.type ?? ''}</p>
      <p class="best-country">📍 ${bm.country ?? ''}</p>
      <p class="best-reason">${bm.reason ?? ''}</p>
      <div class="best-meta">
        ${bm.estimated_cost ? `<span class="badge badge-deadline">💰 ${bm.estimated_cost}</span>` : ''}
        ${diffBadge(bm.difficulty)}
      </div>
    </div>`;

  const alts = data.alternatives ?? [];
  document.getElementById('advisor-alts')!.innerHTML = alts.length ? `
    <p class="alts-title">📌 其他推薦方案</p>
    <div class="alt-cards">
      ${alts.map((a: any) => `
        <div class="alt-card">
          <div class="alt-top">
            <span class="alt-type">${a.type ?? ''}</span>
            <span class="alt-country">· ${a.country ?? ''}</span>
            ${diffBadge(a.difficulty)}
            ${a.estimated_cost ? `<span class="badge badge-deadline">💰 ${a.estimated_cost}</span>` : ''}
          </div>
          <p class="alt-reason">${a.reason ?? ''}</p>
        </div>`).join('')}
    </div>` : '';

  const steps = data.action_steps ?? [];
  document.getElementById('advisor-steps')!.innerHTML = steps.length ? `
    <div class="steps-box">
      <p class="steps-title">📋 行動步驟</p>
      <ul class="steps-list">${steps.map((s: string) => `<li>${s}</li>`).join('')}</ul>
    </div>` : '';

  const warns = data.warnings ?? [];
  document.getElementById('advisor-warns')!.innerHTML = warns.length ? `
    <div class="warns-box">
      <p class="warns-title">⚠️ 注意事項</p>
      <ul class="warns-list">${warns.map((w: string) => `<li>${w}</li>`).join('')}</ul>
    </div>` : '';

  document.getElementById('advisor-result')!.classList.add('show');
}

// ─────────────────────────────
// Rent Quiz
// ─────────────────────────────
let rqStep = 1;
const RQ_TOTAL = 4;

function rqUpdateProgress(step: number) {
  const pct = Math.round((step / RQ_TOTAL) * 100);
  (document.getElementById('rq-progress-fill') as HTMLElement).style.width = pct + '%';
  (document.getElementById('rq-progress-label') as HTMLElement).textContent = `第 ${step} 步，共 ${RQ_TOTAL} 步`;
}

(window as any).updateSlider = function(val: string) {
  const n = parseInt(val);
  const pct = ((n - 5000) / (80000 - 5000)) * 100;
  const slider = document.getElementById('rq-budget') as HTMLInputElement;
  slider.style.background = `linear-gradient(to right, #38bdf8 0%, #38bdf8 ${pct}%, #1e3a5f ${pct}%)`;
  (document.getElementById('rq-budget-display') as HTMLElement).textContent =
    `NT$${Number(val).toLocaleString()} / 月`;
};

(window as any).rqNextStep = function(step: number) {
  if (step === 2 && !document.querySelector<HTMLInputElement>('input[name="rq-duration"]:checked')) {
    alert('請選擇租賃時長'); return;
  }
  if (step === 3) {
    const checked = document.querySelectorAll<HTMLInputElement>('input[name="rq-countries"]:checked');
    if (!checked.length) { alert('請至少選擇一個國家'); return; }
  }
  document.getElementById(`rq-step-${step}`)!.classList.remove('active');
  rqStep = step + 1;
  document.getElementById(`rq-step-${rqStep}`)!.classList.add('active');
  rqUpdateProgress(rqStep);
};

(window as any).rqPrevStep = function(step: number) {
  document.getElementById(`rq-step-${step}`)!.classList.remove('active');
  rqStep = step - 1;
  document.getElementById(`rq-step-${rqStep}`)!.classList.add('active');
  rqUpdateProgress(rqStep);
};

(window as any).submitRentQuiz = async function() {
  const budget_twd = parseInt((document.getElementById('rq-budget') as HTMLInputElement).value);
  const duration   = document.querySelector<HTMLInputElement>('input[name="rq-duration"]:checked')?.value ?? '';
  const countries  = [...document.querySelectorAll<HTMLInputElement>('input[name="rq-countries"]:checked')].map(e => e.value);
  const must_have  = [...document.querySelectorAll<HTMLInputElement>('input[name="rq-must"]:checked')].map(e => e.value);

  document.getElementById(`rq-step-${rqStep}`)!.classList.remove('active');
  (document.getElementById('rq-progress') as HTMLElement).style.display = 'none';

  const loadingEl = document.getElementById('rq-loading')!;
  const errorEl   = document.getElementById('rq-error')!;
  const resultEl  = document.getElementById('rq-result')!;
  loadingEl.classList.add('show');
  errorEl.hidden   = true;
  resultEl.hidden  = true;

  try {
    const res  = await fetch('/api/rent-advisor', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ budget_twd, duration, preferred_countries: countries, city_preference: '大城市', must_have, travel_purpose: '旅遊或生活' }),
    });
    const data = await res.json();
    loadingEl.classList.remove('show');
    if (!res.ok || data.error) {
      errorEl.hidden = false;
      errorEl.textContent = '⚠️ ' + (data.error ?? '發生錯誤，請稍後再試');
      return;
    }
    renderRentResult(data);
  } catch {
    loadingEl.classList.remove('show');
    errorEl.hidden = false;
    errorEl.textContent = '⚠️ 網路錯誤，請稍後再試';
  }
};

function renderRentResult(data: any) {
  const bm = data.best_match ?? {};
  document.getElementById('rq-best')!.innerHTML = `
    <div class="rent-best-card">
      <p class="rent-best-label">🏆 最推薦選項</p>
      <p class="rent-best-location">${bm.country ?? ''} · ${bm.city ?? ''}</p>
      <p class="rent-best-area">📍 ${bm.area ?? ''}</p>
      <p class="rent-best-price">${bm.estimated_rent ?? ''}</p>
      <p class="rent-best-reason">${bm.reason ?? ''}</p>
    </div>`;

  const comps = data.comparisons ?? [];
  document.getElementById('rq-comparisons')!.innerHTML = comps.length ? `
    <p class="rent-comp-title">📊 其他國家比較</p>
    <div class="rent-comp-cards">
      ${comps.map((c: any) => {
        const diffCls = c.foreigner_difficulty === '容易' ? 'badge-easy' : c.foreigner_difficulty === '困難' ? 'badge-hard' : 'badge-medium';
        return `<div class="rent-comp-card">
          <p class="rcc-location">${c.country ?? ''} · ${c.city ?? ''}</p>
          <p class="rcc-area">📍 ${c.area ?? ''}</p>
          <p class="rcc-price">${c.estimated_rent ?? ''}</p>
          <p class="rcc-verdict">${c.verdict ?? ''}</p>
          <span class="badge ${diffCls}">外國人 ${c.foreigner_difficulty ?? ''}</span>
        </div>`;
      }).join('')}
    </div>` : '';

  const tips = data.budget_tips ?? [];
  document.getElementById('rq-tips')!.innerHTML = tips.length ? `
    <div class="tn-tips" style="margin-bottom:.75rem">
      <div class="tn-tips-title">💰 省錢技巧</div>
      <ul class="tips-list">${tips.map((t: string) => `<li>${t}</li>`).join('')}</ul>
    </div>` : '';

  const warns = data.warnings ?? [];
  document.getElementById('rq-warns')!.innerHTML = warns.length ? `
    <div class="warns-box">
      <p class="warns-title">⚠️ 注意事項</p>
      <ul class="warns-list">${warns.map((w: string) => `<li>${w}</li>`).join('')}</ul>
    </div>` : '';

  (document.getElementById('rq-result') as HTMLElement).hidden = false;
}

(window as any).resetRentQuiz = function() {
  rqStep = 1;
  document.querySelectorAll('.rq-step').forEach(s => s.classList.remove('active'));
  document.getElementById('rq-step-1')!.classList.add('active');
  (document.getElementById('rq-progress') as HTMLElement).style.display = '';
  rqUpdateProgress(1);
  (document.getElementById('rq-budget') as HTMLInputElement).value = '20000';
  (window as any).updateSlider('20000');
  document.querySelectorAll<HTMLInputElement>('input[name="rq-duration"]').forEach(e => e.checked = false);
  document.querySelectorAll<HTMLInputElement>('input[name="rq-countries"]').forEach(e => e.checked = e.value === '日本' || e.value === '泰國' || e.value === '韓國');
  document.querySelectorAll<HTMLInputElement>('input[name="rq-must"]').forEach(e => e.checked = false);
  (document.getElementById('rq-loading') as HTMLElement).classList.remove('show');
  (document.getElementById('rq-error') as HTMLElement).hidden = true;
  (document.getElementById('rq-result') as HTMLElement).hidden = true;
};

(window as any).resetQuiz = function() {
  currentStep = 1;
  document.querySelectorAll('.quiz-step').forEach(s => s.classList.remove('active'));
  document.getElementById('step-1')!.classList.add('active');
  document.getElementById('quiz-progress')!.style.display = '';
  updateProgress(1);
  // reset form
  (document.getElementById('q-age') as HTMLInputElement).value = '';
  document.querySelectorAll<HTMLInputElement>('input[name="budget"]').forEach(e => e.checked = false);
  document.querySelectorAll<HTMLInputElement>('input[name="duration"]').forEach(e => e.checked = false);
  document.querySelectorAll<HTMLInputElement>('input[name="purpose"]').forEach(e => e.checked = false);
  document.querySelectorAll<HTMLInputElement>('input[name="countries"]').forEach(e => e.checked = false);
  (document.getElementById('q-skill') as HTMLInputElement).value = '';
  (document.getElementById('q-work-ok') as HTMLInputElement).checked = true;
  (document.getElementById('q-study-ok') as HTMLInputElement).checked = true;

  document.getElementById('advisor-loading')!.classList.remove('show');
  document.getElementById('advisor-result')!.classList.remove('show');
  document.getElementById('advisor-error')!.hidden = true;
};
</script>
