---
export const prerender = false;
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<style is:global>
html body { background: #0f172a; color: #e2e8f0; }
</style>

<!doctype html>
<html lang="zh-TW">
<head>
  <BaseHead
    title="旅遊移民最新報｜旅遊、移民、打工、留學"
    description="兩隻熊追蹤日本退稅、泰韓歐洲免簽、移民方案、打工度假、留學資訊，AI 問卷幫你找最適合的海外生活方式。"
  />
</head>
<body>
  <Header />
  <main class="tn-page">

    <header class="tn-hero">
      <p class="tn-eyebrow">兩隻熊 × AI 即時情報</p>
      <h1>✈️ 旅遊移民最新報</h1>
      <p class="tn-sub">出發前必看，AI 幫你追蹤最新政策 · 移民方案 · 海外生活資訊 🐻</p>
    </header>

    <!-- 主分區 tabs -->
    <div class="section-tabs" role="tablist" aria-label="資訊分類">
      <button class="section-btn active" data-section="travel"     role="tab" aria-selected="true">✈️ 旅遊資訊</button>
      <button class="section-btn"        data-section="immigration" role="tab" aria-selected="false">🏠 移民資訊</button>
      <button class="section-btn"        data-section="lifestyle"   role="tab" aria-selected="false">📚 海外生活</button>
      <button class="section-btn"        data-section="rent"        role="tab" aria-selected="false">🏠 海外居住</button>
      <button class="section-btn"        data-section="advisor"     role="tab" aria-selected="false">🤖 AI 顧問</button>
    </div>

    <!-- Section 1: 旅遊資訊 -->
    <div id="section-travel" class="section-panel active">
      <div class="sub-tabs" role="tablist">
        <button class="tab-btn active" data-cat="japan-tax"     role="tab">🇯🇵 日本退稅</button>
        <button class="tab-btn"        data-cat="japan-news"    role="tab">🇯🇵 日本旅遊</button>
        <button class="tab-btn"        data-cat="thailand-visa" role="tab">🇹🇭 泰國免簽</button>
        <button class="tab-btn"        data-cat="thailand-news" role="tab">🇹🇭 泰國旅遊</button>
        <button class="tab-btn"        data-cat="korea-news"    role="tab">🇰🇷 韓國旅遊</button>
        <button class="tab-btn"        data-cat="europe-news"   role="tab">🇪🇺 歐洲旅遊</button>
      </div>
      <div id="panel-travel" class="news-panel">
        <div class="tn-loading"><div class="spinner"></div><p>AI 正在搜尋最新資訊，請稍候…</p></div>
        <div class="tn-error" hidden></div>
        <div class="tn-content" hidden>
          <div class="tn-summary"></div>
          <div class="tn-items"></div>
          <div class="tn-tips"></div>
          <p class="tn-disclaimer">⚠️ 資料由 AI 即時搜尋整理，可能有時間差，建議出發前再次確認官方資訊。</p>
        </div>
      </div>
    </div>

    <!-- Section 2: 移民資訊 -->
    <div id="section-immigration" class="section-panel" hidden>
      <div class="sub-tabs" role="tablist">
        <button class="tab-btn active" data-cat="immigration-easy"    role="tab">🌟 最容易移民</button>
        <button class="tab-btn"        data-cat="immigration-country" role="tab">🗺️ 各國方案</button>
      </div>
      <div id="panel-immigration" class="news-panel">
        <div class="tn-loading"><div class="spinner"></div><p>AI 正在搜尋最新資訊，請稍候…</p></div>
        <div class="tn-error" hidden></div>
        <div class="tn-content" hidden>
          <div class="tn-summary"></div>
          <div class="tn-items imm-items"></div>
          <div class="tn-tips"></div>
          <p class="tn-disclaimer">⚠️ 移民資訊僅供參考，申請前請諮詢專業移民顧問或查閱官方網站。</p>
        </div>
      </div>
    </div>

    <!-- Section 3: 海外生活 -->
    <div id="section-lifestyle" class="section-panel" hidden>
      <div class="sub-tabs" role="tablist">
        <button class="tab-btn active" data-cat="working-holiday" role="tab">🎒 打工度假</button>
        <button class="tab-btn"        data-cat="study-abroad"    role="tab">🎓 留學資訊</button>
        <button class="tab-btn"        data-cat="study-holiday"   role="tab">💻 數位遊牧</button>
      </div>
      <div id="panel-lifestyle" class="news-panel">
        <div class="tn-loading"><div class="spinner"></div><p>AI 正在搜尋最新資訊，請稍候…</p></div>
        <div class="tn-error" hidden></div>
        <div class="tn-content" hidden>
          <div class="tn-summary"></div>
          <div class="tn-items life-items"></div>
          <div class="tn-tips"></div>
          <p class="tn-disclaimer">⚠️ 資料由 AI 即時搜尋整理，申請前請再次確認官方最新規定。</p>
        </div>
      </div>
    </div>

    <!-- Section 5: 海外租屋 -->
    <div id="section-rent" class="section-panel" hidden>
      <div class="sub-tabs" role="tablist">
        <button class="tab-btn active" data-cat="japan-rent-short"    role="tab">🇯🇵 日本短期租屋</button>
        <button class="tab-btn"        data-cat="japan-rent-long"     role="tab">🇯🇵 日本長期租屋</button>
        <button class="tab-btn"        data-cat="thailand-rent-short" role="tab">🇹🇭 泰國短期租屋</button>
        <button class="tab-btn"        data-cat="thailand-rent-long"  role="tab">🇹🇭 泰國長期租屋</button>
        <button class="tab-btn"        data-cat="korea-rent-short"    role="tab">🇰🇷 韓國短期租屋</button>
        <button class="tab-btn"        data-cat="korea-rent-long"     role="tab">🇰🇷 韓國長期租屋</button>
        <button class="tab-btn tab-danger" data-cat="japan-scam"       role="tab">🇯🇵 日本購屋騙局</button>
        <button class="tab-btn tab-danger" data-cat="thailand-scam"    role="tab">🇹🇭 泰國購屋騙局</button>
        <button class="tab-btn tab-danger" data-cat="korea-scam"       role="tab">🇰🇷 韓國購屋騙局</button>
      </div>
      <div id="panel-rent" class="news-panel">
        <div class="tn-loading"><div class="spinner"></div><p>AI 正在搜尋最新資訊，請稍候…</p></div>
        <div class="tn-error" hidden></div>
        <div class="tn-content" hidden>
          <div class="tn-summary"></div>
          <div class="tn-items rent-items"></div>
          <div class="tn-tips"></div>
          <p class="tn-disclaimer">⚠️ 資料由 AI 即時搜尋整理，租屋前請在 Zigbang、Dabang 等平台確認實際行情。</p>
        </div>
      </div>

      <!-- 🧮 預算租屋問卷 -->
      <div class="rent-quiz-box">
        <div class="rent-quiz-intro">
          <p class="rent-quiz-title">🧮 我的預算能租到什麼？</p>
          <p class="rent-quiz-sub">4 個問題，AI 即時比較各國租屋行情</p>
        </div>

        <div class="quiz-progress" id="rq-progress">
          <div class="progress-bar"><div class="progress-fill" id="rq-progress-fill" style="width:25%"></div></div>
          <p class="progress-label" id="rq-progress-label">第 1 步，共 4 步</p>
        </div>

        <!-- RQ Step 1: 預算滑桿 -->
        <div class="rq-step active" id="rq-step-1">
          <p class="step-q">每月租屋預算？</p>
          <div class="slider-wrap">
            <input type="range" id="rq-budget" class="budget-slider"
              min="5000" max="80000" step="5000" value="20000"
              oninput="updateSlider(this.value)" />
            <div class="slider-value-row">
              <span class="slider-min">NT$5,000</span>
              <span class="slider-current" id="rq-budget-display">NT$20,000 / 月</span>
              <span class="slider-max">NT$80,000</span>
            </div>
          </div>
          <button class="quiz-next-btn" onclick="rqNextStep(1)">下一步 →</button>
        </div>

        <!-- RQ Step 2: 時長 -->
        <div class="rq-step" id="rq-step-2">
          <p class="step-q">預計租多久？</p>
          <div class="option-cards">
            <label class="opt-card">
              <input type="radio" name="rq-duration" value="1個月以內">
              <span class="opt-title">超短期</span>
              <span class="opt-desc">1 個月以內<br>需找短租平台</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="rq-duration" value="1-3個月">
              <span class="opt-title">短期</span>
              <span class="opt-desc">1-3 個月<br>月租或轉租</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="rq-duration" value="3-6個月">
              <span class="opt-title">中期</span>
              <span class="opt-desc">3-6 個月<br>正規月租</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="rq-duration" value="6個月以上">
              <span class="opt-title">長期</span>
              <span class="opt-desc">6 個月以上<br>可考慮全稅</span>
            </label>
          </div>
          <button class="quiz-back-btn" onclick="rqPrevStep(2)">← 上一步</button>
          <button class="quiz-next-btn" onclick="rqNextStep(2)">下一步 →</button>
        </div>

        <!-- RQ Step 3: 國家 -->
        <div class="rq-step" id="rq-step-3">
          <p class="step-q">想去哪些國家？（可多選）</p>
          <div class="checkbox-grid">
            <label class="check-item"><input type="checkbox" name="rq-countries" value="日本" checked> 🇯🇵 日本</label>
            <label class="check-item"><input type="checkbox" name="rq-countries" value="泰國" checked> 🇹🇭 泰國</label>
            <label class="check-item"><input type="checkbox" name="rq-countries" value="韓國" checked> 🇰🇷 韓國</label>
          </div>
          <button class="quiz-back-btn" onclick="rqPrevStep(3)">← 上一步</button>
          <button class="quiz-next-btn" onclick="rqNextStep(3)">下一步 →</button>
        </div>

        <!-- RQ Step 4: 必備條件 -->
        <div class="rq-step" id="rq-step-4">
          <p class="step-q">必備條件？（可多選）</p>
          <div class="checkbox-grid">
            <label class="check-item"><input type="checkbox" name="rq-must" value="附家具"> 🛋️ 附家具</label>
            <label class="check-item"><input type="checkbox" name="rq-must" value="近捷運"> 🚇 近捷運</label>
            <label class="check-item"><input type="checkbox" name="rq-must" value="含網路"> 📶 含網路</label>
            <label class="check-item"><input type="checkbox" name="rq-must" value="含水電"> 💡 含水電</label>
            <label class="check-item"><input type="checkbox" name="rq-must" value="獨立衛浴"> 🚿 獨立衛浴</label>
            <label class="check-item"><input type="checkbox" name="rq-must" value="外國人友善"> 🌏 外國人友善</label>
            <label class="check-item"><input type="checkbox" name="rq-must" value="允許短租"> 📅 允許短租</label>
          </div>
          <button class="quiz-back-btn" onclick="rqPrevStep(4)">← 上一步</button>
          <button class="quiz-submit-btn" id="rq-submit" onclick="submitRentQuiz()">🔍 AI 幫我比較行情</button>
        </div>

        <!-- 載入中 -->
        <div class="advisor-loading" id="rq-loading">
          <div class="spinner"></div>
          <p>AI 正在搜尋各城市最新租屋行情，請稍候…</p>
        </div>

        <!-- 錯誤 -->
        <div class="advisor-error" id="rq-error" hidden></div>

        <!-- 結果 -->
        <div class="rent-result" id="rq-result" hidden>
          <div id="rq-best"></div>
          <div id="rq-comparisons"></div>
          <div id="rq-tips"></div>
          <div id="rq-warns"></div>
          <p class="tn-disclaimer" style="margin-top:1rem">
            💡 租金行情為 AI 即時分析，實際價格以 Zigbang、Airbnb、591 等平台為準。
          </p>
          <button class="quiz-reset-btn" onclick="resetRentQuiz()">🔄 重新查詢</button>
        </div>
      </div>
    </div>

    <!-- Section 4: AI 顧問 -->
    <div id="section-advisor" class="section-panel" hidden>
      <div class="advisor-box">
        <div class="advisor-intro">
          <p class="advisor-intro-title">🤖 AI 海外生活顧問</p>
          <p class="advisor-intro-sub">回答 5 個問題，AI 幫你找最適合的海外生活方案</p>
        </div>

        <!-- 進度條 -->
        <div class="quiz-progress" id="quiz-progress">
          <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:20%"></div></div>
          <p class="progress-label" id="progress-label">第 1 步，共 5 步</p>
        </div>

        <!-- Step 1: 年齡 -->
        <div class="quiz-step active" id="step-1">
          <p class="step-q">你今年幾歲？</p>
          <div class="age-input-wrap">
            <input type="number" id="q-age" class="age-input" min="18" max="80" placeholder="例如 28" />
            <span class="age-unit">歲</span>
          </div>
          <p class="age-hint">打工度假通常限 30 歲以下，其他方案不受年齡限制</p>
          <button class="quiz-next-btn" onclick="nextStep(1)">下一步 →</button>
        </div>

        <!-- Step 2: 預算 -->
        <div class="quiz-step" id="step-2">
          <p class="step-q">你的海外生活預算？</p>
          <div class="option-cards">
            <label class="opt-card">
              <input type="radio" name="budget" value="low">
              <span class="opt-title">省錢型</span>
              <span class="opt-desc">每月 3 萬台幣以下<br>打工補貼為主</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="budget" value="medium">
              <span class="opt-title">舒適型</span>
              <span class="opt-desc">每月 3-8 萬台幣<br>遠端工作或留學</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="budget" value="high">
              <span class="opt-title">充裕型</span>
              <span class="opt-desc">每月 8 萬台幣以上<br>移民或精品留學</span>
            </label>
          </div>
          <button class="quiz-back-btn" onclick="prevStep(2)">← 上一步</button>
          <button class="quiz-next-btn" onclick="nextStep(2)">下一步 →</button>
        </div>

        <!-- Step 3: 時長 -->
        <div class="quiz-step" id="step-3">
          <p class="step-q">計劃在海外待多久？</p>
          <div class="option-cards">
            <label class="opt-card">
              <input type="radio" name="duration" value="short">
              <span class="opt-title">短期</span>
              <span class="opt-desc">1-6 個月<br>體驗為主</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="duration" value="medium">
              <span class="opt-title">中期</span>
              <span class="opt-desc">6-18 個月<br>深度生活</span>
            </label>
            <label class="opt-card">
              <input type="radio" name="duration" value="long">
              <span class="opt-title">長期</span>
              <span class="opt-desc">18 個月以上<br>落地生根</span>
            </label>
          </div>
          <button class="quiz-back-btn" onclick="prevStep(3)">← 上一步</button>
          <button class="quiz-next-btn" onclick="nextStep(3)">下一步 →</button>
        </div>

        <!-- Step 4: 目的 -->
        <div class="quiz-step" id="step-4">
          <p class="step-q">主要目的是？（可多選）</p>
          <div class="checkbox-grid">
            <label class="check-item"><input type="checkbox" name="purpose" value="旅遊體驗"> 🌏 旅遊體驗</label>
            <label class="check-item"><input type="checkbox" name="purpose" value="打工賺錢"> 💰 打工賺錢</label>
            <label class="check-item"><input type="checkbox" name="purpose" value="語言學習"> 📖 語言學習</label>
            <label class="check-item"><input type="checkbox" name="purpose" value="學歷文憑"> 🎓 學歷文憑</label>
            <label class="check-item"><input type="checkbox" name="purpose" value="遠端工作"> 💻 遠端工作</label>
            <label class="check-item"><input type="checkbox" name="purpose" value="永久移民"> 🏠 永久移民</label>
          </div>
          <button class="quiz-back-btn" onclick="prevStep(4)">← 上一步</button>
          <button class="quiz-next-btn" onclick="nextStep(4)">下一步 →</button>
        </div>

        <!-- Step 5: 國家與技能 -->
        <div class="quiz-step" id="step-5">
          <p class="step-q">還有一些細節…</p>

          <p class="sub-label">偏好哪些國家？（可多選）</p>
          <div class="checkbox-grid">
            <label class="check-item"><input type="checkbox" name="countries" value="日本"> 🇯🇵 日本</label>
            <label class="check-item"><input type="checkbox" name="countries" value="澳洲"> 🇦🇺 澳洲</label>
            <label class="check-item"><input type="checkbox" name="countries" value="加拿大"> 🇨🇦 加拿大</label>
            <label class="check-item"><input type="checkbox" name="countries" value="英國"> 🇬🇧 英國</label>
            <label class="check-item"><input type="checkbox" name="countries" value="歐洲"> 🇪🇺 歐洲</label>
            <label class="check-item"><input type="checkbox" name="countries" value="東南亞"> 🌴 東南亞</label>
            <label class="check-item"><input type="checkbox" name="countries" value="韓國"> 🇰🇷 韓國</label>
            <label class="check-item"><input type="checkbox" name="countries" value="紐西蘭"> 🇳🇿 紐西蘭</label>
          </div>

          <p class="sub-label" style="margin-top:1.2rem">有什麼專業技能？（選填）</p>
          <input type="text" id="q-skill" class="skill-input" placeholder="例如：軟體工程師、廚師、設計師…" maxlength="60" />

          <div class="toggle-row">
            <label class="toggle-label">
              <input type="checkbox" id="q-work-ok" checked>
              <span>願意打工</span>
            </label>
            <label class="toggle-label">
              <input type="checkbox" id="q-study-ok" checked>
              <span>願意留學</span>
            </label>
          </div>

          <button class="quiz-back-btn" onclick="prevStep(5)">← 上一步</button>
          <button class="quiz-submit-btn" id="quiz-submit" onclick="submitQuiz()">🤖 AI 幫我找方案</button>
        </div>

        <!-- 載入中 -->
        <div class="advisor-loading" id="advisor-loading">
          <div class="spinner"></div>
          <p>AI 正在分析你的條件並搜尋最新方案，請稍候…</p>
        </div>

        <!-- 錯誤 -->
        <div class="advisor-error" id="advisor-error" hidden></div>

        <!-- 結果 -->
        <div class="advisor-result" id="advisor-result">
          <div id="advisor-best"></div>
          <div id="advisor-alts"></div>
          <div id="advisor-steps"></div>
          <div id="advisor-warns"></div>
          <button class="quiz-reset-btn" onclick="resetQuiz()">🔄 重新測驗</button>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</body>
</html>

<style>
.tn-page {
  max-width: 900px;
  margin: 0 auto;
  padding: 2rem 1rem 5rem;
}

/* ── hero ── */
.tn-hero { text-align: center; padding: 3rem 1rem 2rem; }
.tn-eyebrow {
  font-size: .82rem; letter-spacing: .08em;
  color: #38bdf8; text-transform: uppercase; margin: 0 0 .6rem;
}
.tn-hero h1 {
  font-size: clamp(1.8rem, 5vw, 2.6rem);
  font-weight: 800; color: #f1f5f9; margin: 0 0 .6rem;
}
.tn-sub { color: #94a3b8; font-size: 1rem; margin: 0; }

/* ── section tabs ── */
.section-tabs {
  display: flex; gap: .4rem; flex-wrap: wrap;
  margin-bottom: 1.75rem;
  border-bottom: 2px solid #1e293b; padding-bottom: 0;
}
.section-btn {
  padding: .65rem 1.25rem;
  border: none; border-bottom: 3px solid transparent;
  background: transparent; color: #64748b;
  font-size: .95rem; font-weight: 700; cursor: pointer;
  margin-bottom: -2px; border-radius: 6px 6px 0 0;
  transition: color .2s, border-color .2s, background .2s;
  white-space: nowrap;
}
.section-btn:hover { color: #cbd5e1; background: rgba(255,255,255,.04); }
.section-btn.active { color: #38bdf8; border-bottom-color: #38bdf8; background: rgba(56,189,248,.06); }

/* ── section panels ── */
.section-panel { min-height: 300px; }

/* ── sub tabs ── */
.sub-tabs {
  display: flex; gap: .35rem; flex-wrap: wrap;
  margin-bottom: 1.5rem;
}
.tab-btn {
  padding: .45rem .9rem;
  border: 1px solid #334155; border-radius: 20px;
  background: transparent; color: #64748b;
  font-size: .82rem; font-weight: 600; cursor: pointer;
  transition: all .2s; white-space: nowrap;
}
.tab-btn:hover { color: #cbd5e1; border-color: #475569; background: rgba(255,255,255,.04); }
