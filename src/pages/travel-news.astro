}
.rcc-location { font-size: .88rem; font-weight: 700; color: #e2e8f0; margin-bottom: .2rem; }
.rcc-area     { font-size: .75rem; color: #475569; margin-bottom: .4rem; }
.rcc-price    { font-size: .85rem; font-weight: 700; color: #a3e635; margin-bottom: .35rem; }
.rcc-verdict  { font-size: .78rem; color: #64748b; line-height: 1.4; margin-bottom: .35rem; }
