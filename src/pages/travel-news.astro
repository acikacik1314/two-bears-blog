<script>
// ─────────────────────────────
// Types
// ─────────────────────────────
type TravelCategory =
  | 'japan-tax' | 'japan-news'
  | 'thailand-visa' | 'thailand-news'
  | 'korea-news' | 'europe-news'
  | 'immigration-easy' | 'immigration-country'
  | 'working-holiday' | 'study-abroad' | 'study-holiday'
  | 'japan-rent-short' | 'japan-rent-long'
  | 'thailand-rent-short' | 'thailand-rent-long'
  | 'korea-rent-short' | 'korea-rent-long'
  | 'japan-scam' | 'thailand-scam' | 'korea-scam';

type SectionId = 'travel' | 'immigration' | 'lifestyle' | 'rent' | 'advisor';

interface NewsItem {
  title: string;
  content: string;
  effective_date?: string;
  country?: string;
  difficulty?: '容易' | '中等' | '困難';
  age_limit?: string;
  deadline?: string;
  unique_system?: string;
  red_flags?: string[];
  how_to_avoid?: string;
  real_cases?: string;
  legal_risk?: '高' | '中' | '低';
  source?: string;
}

interface NewsData {
  summary?: string;
  updated_at?: string;
  items?: NewsItem[];
  tips?: string[];
}

// ─────────────────────────────
// Shared cache & state
// ─────────────────────────────
const cache = new Map<TravelCategory, NewsData>();

const sectionPanelOf: Record<SectionId, string> = {
  travel: 'panel-travel',
  immigration: 'panel-immigration',
  lifestyle: 'panel-lifestyle',
  rent: 'panel-rent',
  advisor: '',
};

const sectionDefaultCat: Record<SectionId, TravelCategory | null> = {
  travel: 'japan-tax',
  immigration: 'immigration-easy',
  lifestyle: 'working-holiday',
  rent: 'japan-rent-short',
  advisor: null,
};

// ─────────────────────────────
// Section switching
// ─────────────────────────────
const sectionBtns = document.querySelectorAll<HTMLButtonElement>('.section-btn');
const sectionPanels = document.querySelectorAll<HTMLElement>('.section-panel');

sectionBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    const sid = btn.dataset.section as SectionId;
    sectionBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');

    sectionPanels.forEach(p => p.hidden = true);
    const panel = document.getElementById(`section-${sid}`);
    if (panel) panel.hidden = false;

    // auto-load first tab if not yet loaded
    const defaultCat = sectionDefaultCat[sid];
    if (defaultCat && !cache.has(defaultCat)) {
      const panelId = sectionPanelOf[sid];
      loadCategory(defaultCat, panelId);
    }
  });
});

// ─────────────────────────────
// Sub-tab switching
// ─────────────────────────────
function attachSubTabs(sectionEl: HTMLElement, panelId: string) {
  const btns = sectionEl.querySelectorAll<HTMLButtonElement>('.tab-btn');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const cat = btn.dataset.cat as TravelCategory;
      loadCategory(cat, panelId);
    });
  });
}

(['travel', 'immigration', 'lifestyle', 'rent'] as SectionId[]).forEach(sid => {
  const sectionEl = document.getElementById(`section-${sid}`)!;
  const panelId = sectionPanelOf[sid];
  attachSubTabs(sectionEl, panelId);
});

// ─────────────────────────────
// Panel helpers
// ─────────────────────────────
function getPanel(panelId: string) {
  const p = document.getElementById(panelId)!;
  return {
    loading: p.querySelector<HTMLElement>('.tn-loading')!,
    error:   p.querySelector<HTMLElement>('.tn-error')!,
    content: p.querySelector<HTMLElement>('.tn-content')!,
  };
}

function showLoading(panelId: string) {
  const { loading, error, content } = getPanel(panelId);
  loading.hidden = false; error.hidden = true; content.hidden = true;
}
function showError(panelId: string, msg: string) {
  const { loading, error, content } = getPanel(panelId);
  loading.hidden = true; error.hidden = false; content.hidden = true;
  error.textContent = '⚠️ ' + msg;
}
function showContent(panelId: string) {
  const { loading, error, content } = getPanel(panelId);
  loading.hidden = true; error.hidden = true; content.hidden = false;
}

// ─────────────────────────────
// Rendering
// ─────────────────────────────
const IMMIG_CATS = new Set(['immigration-easy', 'immigration-country']);
const LIFE_CATS  = new Set(['working-holiday', 'study-abroad', 'study-holiday']);
const RENT_CATS  = new Set(['japan-rent-short', 'japan-rent-long', 'thailand-rent-short', 'thailand-rent-long', 'korea-rent-short', 'korea-rent-long']);
const SCAM_CATS  = new Set(['japan-scam', 'thailand-scam', 'korea-scam']);

function difficultyClass(d?: string) {
  if (d === '容易') return 'badge-easy';
  if (d === '中等') return 'badge-medium';
  if (d === '困難') return 'badge-hard';
  return '';
}

function legalRiskClass(r?: string) {
  if (r === '高') return 'badge-risk-high';
  if (r === '中') return 'badge-risk-mid';
  if (r === '低') return 'badge-risk-low';
  return '';
}

function renderNewsItem(item: NewsItem, cat: TravelCategory): string {
  const isImmig = IMMIG_CATS.has(cat);
  const isLife  = LIFE_CATS.has(cat);
  const isRent  = RENT_CATS.has(cat);
  const isScam  = SCAM_CATS.has(cat);

  // Scam cards have their own layout
  if (isScam) {
    const riskCls = legalRiskClass(item.legal_risk);
    const riskBadge = riskCls
      ? `<span class="badge ${riskCls}">⚖️ 風險：${item.legal_risk}</span>` : '';
    const casesBadge = item.real_cases
      ? `<span class="badge badge-deadline">📰 真實案例</span>` : '';
    const flagsHtml = (item.red_flags?.length)
      ? `<ul class="red-flags-list">${item.red_flags.map(f => `<li>${f}</li>`).join('')}</ul>` : '';
    const avoidHtml = item.how_to_avoid ? `
      <div class="how-to-avoid-box">
        <p class="how-to-avoid-label">✅ 如何避免</p>
        <p class="how-to-avoid-text">${item.how_to_avoid}</p>
      </div>` : '';
    const casesHtml = item.real_cases ? `
      <div class="real-cases-box">
        <p class="real-cases-label">📰 真實案例</p>
        <p class="real-cases-text">${item.real_cases}</p>
      </div>` : '';

    return `<div class="news-card" style="border-color:rgba(239,68,68,.25)">
      <div class="news-card-top">
        <span class="news-title">${item.title ?? ''}</span>
        <div style="display:flex;gap:.3rem;flex-wrap:wrap">${riskBadge}${casesBadge}</div>
      </div>
      <p class="news-content">${item.content ?? ''}</p>
      ${flagsHtml}
      ${avoidHtml}
      ${casesHtml}
      ${item.source ? `<p class="news-source">${item.source}</p>` : ''}
    </div>`;
  }

  const badges: string[] = [];
  if (item.country) badges.push(`<span class="badge badge-country">${item.country}</span>`);
  if (item.difficulty && difficultyClass(item.difficulty)) {
    badges.push(`<span class="badge ${difficultyClass(item.difficulty)}">${item.difficulty}</span>`);
  }
  if (item.age_limit) badges.push(`<span class="badge badge-age">🎂 ${item.age_limit}</span>`);
  if (item.deadline)  badges.push(`<span class="badge badge-deadline">⏰ ${item.deadline}</span>`);

  const badgeRow = badges.length ? `<div class="badge-row">${badges.join('')}</div>` : '';
  const dateTag  = (!isImmig && !isLife && !isRent && item.effective_date)
    ? `<span class="news-date">${item.effective_date}</span>` : '';
  const uniqueBox = (isRent && item.unique_system) ? `
    <div class="unique-system-box">
      <p class="unique-system-label">📋 制度說明</p>
      <p class="unique-system-text">${item.unique_system}</p>
    </div>` : '';

  return `<div class="news-card">
    <div class="news-card-top">
      <span class="news-title">${item.title ?? ''}</span>
      ${dateTag}
    </div>
    ${badgeRow}
    <p class="news-content">${item.content ?? ''}</p>
    ${uniqueBox}
    ${item.source ? `<p class="news-source">${item.source}</p>` : ''}
  </div>`;
}

function renderContent(panelId: string, data: NewsData, cat: TravelCategory) {
  const p = document.getElementById(panelId)!;

  const summaryEl = p.querySelector('.tn-summary')!;
  summaryEl.innerHTML = `
    <p class="tn-summary-label">📋 重點摘要</p>
    <p class="tn-summary-text">${data.summary ?? ''}</p>
    <p class="tn-updated">AI 搜尋日期：${data.updated_at ?? ''}</p>`;

  const itemsEl = p.querySelector('.tn-items')!;
  itemsEl.innerHTML = (data.items ?? []).map(item => renderNewsItem(item, cat)).join('');

  const tipsEl = p.querySelector('.tn-tips')!;
  const tips = data.tips ?? [];
  tipsEl.innerHTML = tips.length ? `
    <div class="tn-tips-title">🧳 台灣人實用提醒</div>
    <ul class="tips-list">${tips.map(t => `<li>${t}</li>`).join('')}</ul>` : '';

  showContent(panelId);
}

// ─────────────────────────────
// Fetch
// ─────────────────────────────
async function loadCategory(cat: TravelCategory, panelId: string) {
  if (cache.has(cat)) {
    renderContent(panelId, cache.get(cat)!, cat);
    return;
  }
  showLoading(panelId);
  try {
    const res  = await fetch('/api/travel-news', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ category: cat }),
    });
    const data = await res.json();
    if (!res.ok || data.error) { showError(panelId, data.error ?? '發生錯誤，請稍後再試'); return; }
    cache.set(cat, data);
    renderContent(panelId, data, cat);
  } catch {
    showError(panelId, '網路錯誤，請稍後再試');
  }
}

// ─────────────────────────────
