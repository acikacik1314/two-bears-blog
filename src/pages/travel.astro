<script is:inline>
// ── 設定 ──────────────────────────────────────────
const TRACKING_BASE = 'https://abzcoupon.com/track/clicks/3408/c627c2ba900929dcfc9cab248d2596412379128f78eee2f40f76f6476a0449a8c23ae5a5112d';
const CID = '1933603';

const INTENT_PARAMS = {
  all: {
    extra: '',
    sort: 'popularity',
    label: '綜合排序',
    detail: '顯示所有房型'
  },
  luxury: {
    extra: '&hotelStarRating=5&hotelReviewScore=9&roomAmenities=31&hotelFacility=91&groupedBedTypes=1,5',
    sort: 'price_desc',
    label: '✨ 5星・評分9+・特大床・Spa・含網路',
    detail: '按價格高→低排序'
  },
  escape: {
    extra: '&hotelReviewScore=9&roomAmenities=31&hotelFacility=91',
    sort: 'rating_desc',
    label: '🌿 評分9+・Spa・含網路',
    detail: '按評分高→低排序'
  },
  base: {
    extra: '&hotelReviewScore=8&roomAmenities=31,42',
    sort: 'price_asc',
    label: '🏡 評分8+・附廚房・含網路',
    detail: '按價格低→高排序'
  },
};

let currentIntent = 'all';

// ── 日期預設 ─────────────────────────────────────
function offsetDate(days) {
  const d = new Date();
  d.setDate(d.getDate() + days);
  return d.toISOString().split('T')[0];
}
document.getElementById('checkIn').value  = offsetDate(30);
document.getElementById('checkOut').value = offsetDate(33);

// ── Agoda 跳轉（帶意圖篩選參數）────────────────────
function goAgoda(cityId) {
  const checkIn  = document.getElementById('checkIn').value  || offsetDate(30);
  const checkOut = document.getElementById('checkOut').value || offsetDate(33);
  const adults   = document.getElementById('adults').value;
  const rooms    = document.getElementById('rooms').value;
  const params   = INTENT_PARAMS[currentIntent] || INTENT_PARAMS.all;

  const agodaUrl =
    'https://www.agoda.com/zh-tw/search' +
    '?city='     + cityId +
    '&checkIn='  + checkIn +
    '&checkOut=' + checkOut +
    '&rooms='    + rooms +
    '&adults='   + adults +
    '&locale=zh-tw&currency=TWD' +
    '&sort='     + params.sort +
    params.extra +
    '&cid='      + CID +
    '&productType=-1';

  const finalUrl = TRACKING_BASE + '?t=' + encodeURIComponent(encodeURIComponent(agodaUrl));

  if (typeof gtag !== 'undefined') {
    gtag('event', 'agoda_click', {
      city_id: cityId,
      intent:  currentIntent,
      check_in: checkIn
    });
  }

  window.open(finalUrl, '_blank', 'noopener');
}

// ── Booking.com 跳轉（帶意圖篩選參數）──────────────
const BOOKING_NFLT = {
  luxury: 'class%3D5%3Breview_score%3D90%3Bhotelfacility%3D433%3Broomfacility%3D5',
  escape: 'review_score%3D90%3Bhotelfacility%3D433',
  base:   'review_score%3D80%3Broomfacility%3D999',
  all:    'review_score%3D80'
};

function goBooking(ss) {
  const checkIn  = document.getElementById('checkIn').value  || offsetDate(30);
  const checkOut = document.getElementById('checkOut').value || offsetDate(33);
  const adults   = document.getElementById('adults').value;
  const rooms    = document.getElementById('rooms').value;
  const nflt     = BOOKING_NFLT[currentIntent] || BOOKING_NFLT.all;

  const url =
    'https://www.booking.com/searchresults.zh-tw.html' +
    '?ss='           + encodeURIComponent(ss) +
    '&aid=304142' +
    '&checkin='      + checkIn +
    '&checkout='     + checkOut +
    '&group_adults=' + adults +
    '&no_rooms='     + rooms +
    '&nflt='         + nflt;

  window.open(url, '_blank', 'noopener');
}

// ── 更新 badge 說明 ───────────────────────────────
function updateBadge(intent) {
  const badge  = document.getElementById('intentBadge');
  const text   = document.getElementById('badgeText');
  const detail = document.getElementById('badgeDetail');
  const params = INTENT_PARAMS[intent];

  if (intent === 'all') {
    badge.classList.add('hidden');
  } else {
    badge.classList.remove('hidden');
    text.textContent   = params.label;
    detail.textContent = '· ' + params.detail;
  }
}

// ── 城市卡片篩選 ─────────────────────────────────
function filterCards(tag, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.city-card').forEach(card => {
    const tags = card.dataset.tags || '';
    card.classList.toggle('hidden', tag !== 'all' && !tags.includes(tag));
  });
}

// ── 意圖按鈕 ─────────────────────────────────────
function setIntent(intent, btn) {
  currentIntent = intent;
  document.querySelectorAll('.intent-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  updateBadge(intent);

  const filterMap = { all:'all', luxury:'luxury', escape:'escape', base:'base' };
  const filterBtn = document.querySelector('[data-filter="' + (filterMap[intent] || 'all') + '"]');
  if (filterBtn) filterCards(filterMap[intent] || 'all', filterBtn);
}

// ── 韌性條動畫 ───────────────────────────────────
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return;
    entry.target.querySelectorAll('.r-fill').forEach(bar => {
      const w = bar.style.width;
      bar.style.width = '0%';
      requestAnimationFrame(() => setTimeout(() => { bar.style.width = w; }, 80));
    });
    observer.unobserve(entry.target);
  });
}, { threshold: 0.2 });

document.querySelectorAll('.city-card').forEach(c => observer.observe(c));
</script>
</body>
