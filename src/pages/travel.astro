---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="zh-TW">
<head>
  <BaseHead
    title="如果世界越來越亂，你還想去哪裡？｜兩隻熊人生清單"
    description="兩隻熊精選人生清單旅遊目的地，台灣人視角深度避雷分析，附 Agoda 聯盟最低價連結"
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600&family=Noto+Sans+TC:wght@300;400;500&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
  <style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1816;--ink2:#4a4540;--ink3:#8a827a;
  --paper:#f7f4ef;--paper2:#ede9e2;--paper3:#e4dfd6;
  --gold:#b8960c;--gold2:#d4aa20;--red:#8b2020;--green:#2a5a3a;
  --radius:3px;--shadow:0 1px 8px rgba(26,24,22,0.08);
}
body{background:var(--paper);color:var(--ink);font-family:'Noto Sans TC',sans-serif;font-weight:300;line-height:1.7}

/* HERO */
.hero{background:var(--ink);color:var(--paper);padding:5rem 2rem 4rem;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 40% at 20% 50%,rgba(184,150,12,.12) 0%,transparent 70%),radial-gradient(ellipse 40% 60% at 80% 30%,rgba(139,32,32,.10) 0%,transparent 70%);pointer-events:none}
.hero-eyebrow{font-family:'Cinzel',serif;font-size:11px;letter-spacing:.25em;color:var(--gold2);margin-bottom:1.5rem;text-transform:uppercase}
.hero h1{font-family:'Noto Serif TC',serif;font-weight:300;font-size:clamp(1.8rem,5vw,3rem);line-height:1.4;max-width:700px;margin:0 auto 1.25rem;letter-spacing:.02em}
.hero h1 em{font-style:normal;color:var(--gold2)}
.hero-sub{font-size:14px;color:rgba(247,244,239,.6);max-width:480px;margin:0 auto 1.5rem;line-height:1.8}
.hero-bears{font-size:28px;letter-spacing:.1em;margin-bottom:.75rem}
.hero-nav{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:1.5rem}
.hero-nav a{font-size:12px;padding:6px 16px;border-radius:100px;border:.5px solid rgba(247,244,239,.25);color:rgba(247,244,239,.7);text-decoration:none;transition:all .2s}
.hero-nav a:hover{border-color:var(--gold2);color:var(--gold2)}

/* SEARCH (sticky) */
.search-wrap{background:var(--ink);padding:0 2rem 1.25rem;position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(247,244,239,.06)}
.search-inner{max-width:900px;margin:0 auto;display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.search-inner label{font-size:11px;color:rgba(247,244,239,.4);white-space:nowrap}
.search-inner input,.search-inner select{font-size:13px;padding:7px 12px;border:.5px solid rgba(247,244,239,.15);border-radius:var(--radius);background:rgba(247,244,239,.06);color:var(--paper);font-family:'Noto Sans TC',sans-serif;font-weight:300}
.search-inner input[type="date"]{width:145px;color-scheme:dark}
.search-inner input:focus,.search-inner select:focus{outline:none;border-color:var(--gold2)}
.search-inner select option{background:var(--ink)}

/* FILTER */
.filter-wrap{background:var(--paper2);border-bottom:1px solid var(--paper3);padding:.85rem 2rem}
.filter-inner{max-width:900px;margin:0 auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
.filter-label{font-size:11px;color:var(--ink3);letter-spacing:.1em;margin-right:4px}
.filter-btn{font-size:11px;padding:5px 12px;border-radius:100px;border:.5px solid var(--paper3);background:var(--paper);color:var(--ink3);cursor:pointer;font-family:'Noto Sans TC',sans-serif;font-weight:300;transition:all .15s}
.filter-btn:hover{border-color:var(--gold);color:var(--gold)}
.filter-btn.active{background:var(--ink);border-color:var(--ink);color:var(--paper)}

/* MAIN */
.main{max-width:900px;margin:0 auto;padding:2rem}

/* INTENT ROW */
.intent-row{display:flex;gap:10px;margin-bottom:2rem;flex-wrap:wrap}
.intent-btn{flex:1;min-width:150px;padding:12px 14px;border:.5px solid var(--paper3);border-radius:var(--radius);background:var(--paper);cursor:pointer;text-align:left;font-family:'Noto Sans TC',sans-serif;transition:all .2s;box-shadow:var(--shadow)}
.intent-btn:hover{border-color:var(--gold);transform:translateY(-1px)}
.intent-btn.active{border-color:var(--gold);background:#fffbee}
.intent-icon{font-size:18px;margin-bottom:4px}
.intent-title{font-size:12px;font-weight:500;color:var(--ink);margin-bottom:1px}
.intent-desc{font-size:10px;color:var(--ink3);line-height:1.5}

/* INTENT BADGE */
.intent-badge{
  background:var(--ink);color:var(--paper);
  border-radius:var(--radius);padding:.75rem 1rem;
  margin-bottom:1.5rem;font-size:12px;
  display:flex;align-items:center;gap:10px;flex-wrap:wrap
}
.intent-badge strong{color:var(--gold2)}
.intent-badge span{color:rgba(247,244,239,.6);font-size:11px}
.intent-badge.hidden{display:none}

/* SECTION TITLE */
.section-title{font-family:'Noto Serif TC',serif;font-size:12px;font-weight:400;color:var(--ink3);letter-spacing:.15em;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:.5px solid var(--paper3)}

/* CITY GRID */
.city-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;margin-bottom:2rem}
.city-card{background:var(--paper);border:.5px solid var(--paper3);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);transition:all .2s}
.city-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(26,24,22,.12);border-color:var(--gold)}
.city-card.hidden{display:none}

.card-header{padding:1.25rem 1.25rem 1rem;border-bottom:.5px solid var(--paper3);position:relative}
.card-flag{font-size:20px;margin-bottom:5px}
.card-city{font-family:'Noto Serif TC',serif;font-size:17px;font-weight:400;color:var(--ink);margin-bottom:2px}
.card-region{font-size:11px;color:var(--ink3)}
.card-score{position:absolute;top:1.25rem;right:1.25rem;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;border:1.5px solid currentColor}
.score-high{color:var(--green);background:rgba(42,90,58,.08)}
.score-mid{color:var(--gold);background:rgba(184,150,12,.08)}
.score-low{color:var(--red);background:rgba(139,32,32,.08)}

.card-body{padding:1rem 1.25rem}
.card-intent-tag{display:inline-flex;align-items:center;gap:4px;font-size:10px;padding:3px 8px;border-radius:100px;margin-bottom:10px}
.tag-luxury{background:rgba(184,150,12,.12);color:#7a6008}
.tag-escape{background:rgba(42,90,58,.12);color:#1a4028}
.tag-base{background:rgba(60,80,140,.12);color:#253060}

.card-quote{font-family:'Noto Serif TC',serif;font-size:12px;font-style:italic;color:var(--ink2);line-height:1.7;margin-bottom:12px;padding-left:10px;border-left:2px solid var(--paper3)}

.resilience{margin-bottom:12px}
.resilience-title{font-size:10px;color:var(--ink3);letter-spacing:.1em;margin-bottom:6px}
.resilience-bars{display:flex;flex-direction:column;gap:4px}
.r-bar{display:flex;align-items:center;gap:8px}
.r-label{font-size:10px;color:var(--ink3);width:52px;flex-shrink:0}
.r-track{flex:1;height:3px;background:var(--paper3);border-radius:2px;overflow:hidden}
.r-fill{height:100%;border-radius:2px;background:var(--gold);transition:width .8s ease}
.r-fill.high{background:var(--green)}
.r-fill.low{background:var(--red)}

.card-warning{font-size:11px;color:var(--red);background:rgba(139,32,32,.06);border-left:2px solid var(--red);padding:6px 10px;border-radius:0 var(--radius) var(--radius) 0;margin-bottom:10px;line-height:1.6}
.card-tip{font-size:11px;color:var(--green);background:rgba(42,90,58,.06);border-left:2px solid var(--green);padding:6px 10px;border-radius:0 var(--radius) var(--radius) 0;margin-bottom:10px;line-height:1.6}

/* CARD FOOTER */
.card-footer{padding:.85rem 1.25rem;border-top:.5px solid var(--paper3);background:var(--paper2);display:flex;gap:6px}
.book-btn{flex:1;padding:8px 10px;border-radius:var(--radius);border:.5px solid var(--paper3);background:var(--paper);color:var(--ink2);font-size:11px;font-family:'Noto Sans TC',sans-serif;cursor:pointer;text-decoration:none;text-align:center;display:flex;align-items:center;justify-content:center;gap:4px;transition:all .15s;font-weight:400}
.book-btn:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.book-btn.primary{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.book-btn.primary:hover{background:var(--gold);border-color:var(--gold);color:var(--ink)}

/* PROPHET STRIP */
.prophet-strip{background:var(--ink);color:var(--paper);border-radius:var(--radius);padding:1.5rem;margin-bottom:2rem;display:flex;gap:1.5rem;flex-wrap:wrap}
.prophet-card{flex:1;min-width:180px;border-left:2px solid rgba(184,150,12,.3);padding-left:1rem}
.prophet-name{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.15em;color:var(--gold2);margin-bottom:5px}
.prophet-quote{font-family:'Noto Serif TC',serif;font-size:12px;font-style:italic;color:rgba(247,244,239,.65);line-height:1.7}

.disclaimer{font-size:11px;color:var(--ink3);text-align:center;padding:1rem 0 2rem;line-height:1.8}

@media(max-width:600px){
  .search-inner{gap:6px}
  .intent-row{flex-direction:column}
  .prophet-strip{flex-direction:column}
  .city-grid{grid-template-columns:1fr}
  .search-inner input[type="date"]{width:130px}
}
  </style>
</head>
<body>
  <Header />

<div class="hero">
  <div class="hero-bears">🐻🐻</div>
  <div class="hero-eyebrow">兩隻熊的人生清單 · BUCKET LIST TRAVEL</div>
  <h1>如果世界越來越亂，<br>你<em>還想去哪裡</em>？</h1>
  <p class="hero-sub">預言家說的那些事也許不會發生，但有些地方、有些時刻，值得你現在就出發。</p>
  <div class="hero-nav">
    <a href="/">← 回首頁</a>
    <a href="/avoid">🚨 避雷地圖</a>
    <a href="/podcast">🎙 預言 Podcast</a>
    <a href="/blog">📖 最新文章</a>
  </div>
</div>

<div class="search-wrap">
  <div class="search-inner">
    <label>入住</label>
    <input type="date" id="checkIn">
    <label>退房</label>
    <input type="date" id="checkOut">
    <label>大人</label>
    <select id="adults">
      <option value="1">1人</option>
      <option value="2" selected>2人</option>
      <option value="3">3人</option>
      <option value="4">4人</option>
    </select>
    <label>房間</label>
    <select id="rooms">
      <option value="1" selected>1間</option>
      <option value="2">2間</option>
    </select>
  </div>
</div>

<div class="filter-wrap">
  <div class="filter-inner">
    <span class="filter-label">篩選</span>
    <button class="filter-btn active" data-filter="all" onclick="filterCards('all',this)">全部</button>
    <button class="filter-btn" data-filter="luxury" onclick="filterCards('luxury',this)">✨ 奢華</button>
    <button class="filter-btn" data-filter="escape" onclick="filterCards('escape',this)">🌿 避世</button>
    <button class="filter-btn" data-filter="base" onclick="filterCards('base',this)">🏡 長住</button>
    <button class="filter-btn" data-filter="japan" onclick="filterCards('japan',this)">🇯🇵 日本</button>
    <button class="filter-btn" data-filter="sea" onclick="filterCards('sea',this)">🌏 東南亞</button>
    <button class="filter-btn" data-filter="taiwan" onclick="filterCards('taiwan',this)">🇹🇼 台灣</button>
    <button class="filter-btn" data-filter="korea" onclick="filterCards('korea',this)">🇰🇷 韓國</button>
  </div>
</div>

<div class="main">

  <div class="prophet-strip">
    <div class="prophet-card">
      <div class="prophet-name">BRANDON BIGGS</div>
      <div class="prophet-quote">「財富將轉移。在最後的日子裡，那些準備好的人將擁有充足的資源。」</div>
    </div>
    <div class="prophet-card">
      <div class="prophet-name">松原照子</div>
      <div class="prophet-quote">「千年古都的地脈能量，在未來的震盪中相對穩定。去那些有歷史的地方感受一下吧。」</div>
    </div>
    <div class="prophet-card">
      <div class="prophet-name">JOE McMONEAGLE</div>
      <div class="prophet-quote">「在混亂之前，先找到讓你的心回到平靜的地方。清空大腦，你會發現世界其實很平靜。」</div>
    </div>
  </div>

  <div class="intent-row">
    <button class="intent-btn active" data-intent="all" onclick="setIntent('all',this)">
      <div class="intent-icon">🌍</div>
      <div class="intent-title">全部顯示</div>
      <div class="intent-desc">讓我自己決定</div>
    </button>
    <button class="intent-btn" data-intent="luxury" onclick="setIntent('luxury',this)">
      <div class="intent-icon">🥂</div>
      <div class="intent-title">最後一次奢華</div>
      <div class="intent-desc">4星以上・高景觀・頂級體驗</div>
    </button>
    <button class="intent-btn" data-intent="escape" onclick="setIntent('escape',this)">
      <div class="intent-icon">🌿</div>
      <div class="intent-title">與世隔絕</div>
      <div class="intent-desc">溫泉・秘境・最高評分優先</div>
    </button>
    <button class="intent-btn" data-intent="base" onclick="setIntent('base',this)">
      <div class="intent-icon">🏡</div>
      <div class="intent-title">長期落腳考察</div>
      <div class="intent-desc">附廚房・長住・最低價優先</div>
    </button>
  </div>

  <!-- 目前篩選條件說明 -->
  <div class="intent-badge hidden" id="intentBadge">
    <span>🎯 目前搜尋條件：</span>
    <strong id="badgeText"></strong>
    <span id="badgeDetail"></span>
  </div>

  <div class="section-title">🐻 兩隻熊人生清單 · 精選目的地</div>

  <div class="city-grid" id="cityGrid">

    <!-- 京都 -->
    <div class="city-card" data-tags="japan escape">
      <div class="card-header">
        <div class="card-flag">🇯🇵</div>
        <div class="card-city">京都 · 宇治</div>
        <div class="card-region">日本關西 · 千年古都</div>
        <div class="card-score score-high">87</div>
      </div>
      <div class="card-body">
        <div class="card-intent-tag tag-escape">🌿 與世隔絕</div>
        <div class="card-quote">松原照子暗示，千年古都的地脈在未來震盪中相對穩定。京都是台灣人心中最接近「結界」的地方。</div>
        <div class="resilience">
          <div class="resilience-title">韌性指數</div>
          <div class="resilience-bars">
            <div class="r-bar"><span class="r-label">🛡 寧靜度</span><div class="r-track"><div class="r-fill high" style="width:92%"></div></div></div>
            <div class="r-bar"><span class="r-label">🚇 交通</span><div class="r-track"><div class="r-fill high" style="width:85%"></div></div></div>
            <div class="r-bar"><span class="r-label">🏪 機能</span><div class="r-track"><div class="r-fill" style="width:70%"></div></div></div>
            <div class="r-bar"><span class="r-label">✈️ 撤離</span><div class="r-track"><div class="r-fill" style="width:75%"></div></div></div>
          </div>
        </div>
        <div class="card-warning">⚠️ 避雷：祇園四条商務旅館常見12㎡小房，行李箱無法攤平。嵐山往來需爬坡，帶行李箱請三思。</div>
        <div class="card-tip">✓ 推薦：宇治或嵐山區公寓型旅館，空間大、安靜，步行至車站為平路。</div>
      </div>
      <div class="card-footer">
        <a class="book-btn primary" href="#" onclick="goAgoda(1784); return false;">🔍 搜尋京都住宿</a>
        <a class="book-btn" href="#" onclick="goBooking('Kyoto'); return false;">Booking</a>
      </div>
    </div>

    <!-- 河口湖 -->
    <div class="city-card" data-tags="japan luxury">
      <div class="card-header">
        <div class="card-flag">🇯🇵</div>
        <div class="card-city">河口湖 · 富士山麓</div>
        <div class="card-region">日本關東 · 富士山第一排</div>
        <div class="card-score score-mid">72</div>
      </div>
      <div class="card-body">
        <div class="card-intent-tag tag-luxury">✨ 最後一次奢華</div>
        <div class="card-quote">比格斯和松原照子都提過富士山的未來變數。如果這是最平靜的一年，這輩子總要任性一次，在第一排看過富士山倒影。</div>
        <div class="resilience">
          <div class="resilience-title">韌性指數</div>
          <div class="resilience-bars">
            <div class="r-bar"><span class="r-label">🛡 寧靜度</span><div class="r-track"><div class="r-fill high" style="width:90%"></div></div></div>
            <div class="r-bar"><span class="r-label">🚇 交通</span><div class="r-track"><div class="r-fill" style="width:58%"></div></div></div>
            <div class="r-bar"><span class="r-label">🏪 機能</span><div class="r-track"><div class="r-fill" style="width:52%"></div></div></div>
            <div class="r-bar"><span class="r-label">✈️ 撤離</span><div class="r-track"><div class="r-fill" style="width:62%"></div></div></div>
          </div>
        </div>
        <div class="card-warning">⚠️ 避雷：河口湖交通靠巴士，班次有限，大行李要計算時間。冬季清晨氣溫極低。</div>
        <div class="card-tip">✓ 推薦：湖北岸一線湖景旅館，清晨富士山無雲機率冬春最高，私人風呂值得升等。</div>
      </div>
      <div class="card-footer">
        <a class="book-btn primary" href="#" onclick="goAgoda(5085); return false;">🔍 搜尋東京/富士住宿</a>
        <a class="book-btn" href="#" onclick="goBooking('Kawaguchiko'); return false;">Booking</a>
      </div>
    </div>

    <!-- 大阪 -->
    <div class="city-card" data-tags="japan luxury">
      <div class="card-header">
        <div class="card-flag">🇯🇵</div>
        <div class="card-city">大阪</div>
        <div class="card-region">日本關西 · 美食之都</div>
        <div class="card-score score-mid">68</div>
      </div>
      <div class="card-body">
        <div class="card-intent-tag tag-luxury">✨ 最後一次奢華</div>
        <div class="card-quote">世界再亂，大阪的章魚燒不會少。這是那種「讓人忘記末日」的城市，吃飽喝足，煩惱自然少一半。</div>
        <div class="resilience">
          <div class="resilience-title">韌性指數</div>
          <div class="resilience-bars">
            <div class="r-bar"><span class="r-label">🛡 寧靜度</span><div class="r-track"><div class="r-fill" style="width:55%"></div></div></div>
            <div class="r-bar"><span class="r-label">🚇 交通</span><div class="r-track"><div class="r-fill high" style="width:90%"></div></div></div>
            <div class="r-bar"><span class="r-label">🏪 機能</span><div class="r-track"><div class="r-fill high" style="width:95%"></div></div></div>
            <div class="r-bar"><span class="r-label">✈️ 撤離</span><div class="r-track"><div class="r-fill high" style="width:85%"></div></div></div>
          </div>
        </div>
        <div class="card-warning">⚠️ 避雷：新今宮NT$800旅館周邊夜間氛圍複雜。心齋橋設計旅館雙人房常只有11㎡。</div>
        <div class="card-tip">✓ 推薦：北堀江或南船場公寓型旅館，空間大、鄰近美食、治安好。</div>
      </div>
      <div class="card-footer">
        <a class="book-btn primary" href="#" onclick="goAgoda(9590); return false;">🔍 搜尋大阪住宿</a>
        <a class="book-btn" href="#" onclick="goBooking('Osaka'); return false;">Booking</a>
      </div>
    </div>

    <!-- 首爾 -->
    <div class="city-card" data-tags="korea luxury">
      <div class="card-header">
        <div class="card-flag">🇰🇷</div>
        <div class="card-city">首爾</div>
        <div class="card-region">韓國 · 時尚美食之都</div>
        <div class="card-score score-mid">70</div>
